{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-solution",
      "type": "shell",
      "command": "dotnet build .\\DZDDashboard.sln",
      "group": "build",
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "run-api",
      "type": "shell",
      "command": "dotnet run --project .\\DZDDashboard.Api\\DZDDashboard.Api.csproj",
      "isBackground": true,
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "run-client",
      "type": "shell",
      "command": "dotnet run --project .\\DZDDashboard.Client\\DZDDashboard.Client.csproj",
      "isBackground": true,
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}