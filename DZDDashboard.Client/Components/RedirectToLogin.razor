@inject NavigationManager Navigation

<div style="position:fixed;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--mud-palette-background,#fff);z-index:9999;gap:16px;">
    @if (_showAccessDenied)
    {
        <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Style="font-size:3rem;" />
        <MudText Typo="Typo.h6">Bu sayfa için yetkiniz bulunmuyor.</MudText>
    }
    else
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.body1" Style="color:var(--mud-palette-text-secondary);">Giriş ekranına yönlendiriliyorsunuz...</MudText>
    }
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private bool _showAccessDenied;
    private bool _navigated;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _navigated)
        {
            return;
        }

        var authState = await AuthenticationStateTask;
        var isAuthenticated = authState.User.Identity?.IsAuthenticated == true;

        if (isAuthenticated)
        {
            _showAccessDenied = true;
            StateHasChanged();
            return;
        }

        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var returnUrl = string.IsNullOrWhiteSpace(relativePath)
            ? "/"
            : $"/{relativePath}";

        _navigated = true;
        var signInUrl = $"/MicrosoftIdentity/Account/SignIn?returnUrl={Uri.EscapeDataString(returnUrl)}";
        Navigation.NavigateTo(signInUrl, forceLoad: true, replace: true);
    }
}

