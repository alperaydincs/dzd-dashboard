@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.JSInterop
@using DZDDashboard.Client.Theme
@using System.Security.Claims
@using DZDDashboard.Client.Services
@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.Utils
@using Microsoft.Identity.Web

@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IUserClientService UserService
@inject INotificationCenterService NotificationCenter
@inject IJSRuntime JS

@implements IDisposable

<MudThemeProvider Theme="_myTheme" />
<MudDialogProvider />
<MudPopoverProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@DzdIcons.Menu" Color="Color.Inherit" OnClick="@DrawerToggle" />
            </Authorized>
        </AuthorizeView>

        <MudText Typo="Typo.h5" Class="ml-3">@PageTitle</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="appbar-user-actions" Style="gap:10px;">
                    <div style="margin-right:8px;">
                        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="notifications-menu">
                            <ActivatorContent>
                                @if (_unreadNotifications > 0)
                                {
                                    <MudBadge Content="@_unreadNotifications" Color="Color.Error" Overlap="true">
                                        <MudIconButton Icon="@DzdIcons.Bell" Color="Color.Inherit" Size="Size.Small" Class="notifications-trigger" />
                                    </MudBadge>
                                }
                                else
                                {
                                    <MudIconButton Icon="@DzdIcons.Bell" Color="Color.Inherit" Size="Size.Small" Class="notifications-trigger" />
                                }
                            </ActivatorContent>
                            <ChildContent>
                                <MudStack Class="notifications-panel">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="notifications-header">
                                        <MudText Typo="Typo.subtitle2">Notifications</MudText>
                                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="MarkAllNotificationsAsRead">Mark all read</MudButton>
                                    </MudStack>
                                    <MudDivider />

                                    @if (_notifications.Count == 0)
                                    {
                                        <MudText Typo="Typo.caption" Class="pa-3">No notifications yet.</MudText>
                                    }
                                    else
                                    {
                                        @foreach (var notification in _notifications)
                                        {
                                            <MudListItem T="string" Class="notification-item" OnClick="@(() => MarkNotificationAsRead(notification.Id))">
                                                <MudStack Spacing="0" Class="notification-item-content">
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                                        <MudText Typo="Typo.subtitle2">@notification.Title</MudText>
                                                        @if (!notification.IsRead)
                                                        {
                                                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Text">New</MudChip>
                                                        }
                                                    </MudStack>
                                                    <MudText Typo="Typo.caption">@notification.Message</MudText>
                                                    <MudText Typo="Typo.caption" Class="notification-time">@AppFormatter.FormatElapsed(notification.CreatedAtUtc)</MudText>
                                                </MudStack>
                                            </MudListItem>
                                        }
                                    }
                                </MudStack>
                            </ChildContent>
                        </MudMenu>
                    </div>

                    <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="profile-menu">
                        <ActivatorContent>
                            <MudAvatar Color="Color.Primary" Style="cursor:pointer;">
                                @if (!string.IsNullOrEmpty(_avatarDataUrl))
                                {
                                    <MudImage Src="@_avatarDataUrl" Alt="User Avatar" />
                                }
                                else
                                {
                                    @_userInitials
                                }
                            </MudAvatar>
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem Href="/my-profile" Icon="@DzdIcons.User">My Profile</MudMenuItem>
                            <AuthorizeView Roles="@Roles.AdminOrHr" Context="authContext">
                                <Authorized>
                                    <MudMenuItem Href="/settings" Icon="@DzdIcons.Settings">Settings</MudMenuItem>
                                </Authorized>
                            </AuthorizeView>
                            <MudMenuItem OnClick="Logout" Icon="@DzdIcons.LogOut">Logout</MudMenuItem>
                        </ChildContent>
                    </MudMenu>
                </MudStack>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/MicrosoftIdentity/Account/SignIn" Color="Color.Inherit">Login</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <AuthorizeView>
        <Authorized>
            <MudDrawer @bind-Open="_drawerOpen" Elevation="0" Variant="DrawerVariant.Persistent" ClipMode="DrawerClipMode.Never" Class="custom-sidebar">
                <div class="sidebar-logo">
                    <img src="/images/dzd_logo.png" alt="Company Logo" class="sidebar-logo-image" />
                </div>
                <nav class="sidebar-nav">
                    <a href="/" class="nav-item @(IsActive(NavSection.Dashboard) ? "nav-item-active" : "")">
                        <MudIcon Icon="@DzdIcons.LayoutDashboard" Class="nav-icon" />
                        <span class="nav-label">Dashboard</span>
                    </a>

                    <div class="nav-item @(IsEmployeesMenuActive ? "nav-item-active" : "")" @onclick="ToggleEmployeesMenu">
                        <MudIcon Icon="@DzdIcons.Users" Class="nav-icon" />
                        <span class="nav-label">Employees</span>
                        <MudIcon Icon="@(_employeesMenuExpanded ? DzdIcons.ChevronUp : DzdIcons.ChevronDown)" Class="nav-expand-icon" />
                    </div>

                    @if (_employeesMenuExpanded)
                    {
                        <div class="submenu">
                            <a href="/employees" class="submenu-item @(IsActive(NavSection.Employees) ? "submenu-item-active" : "")">
                                <span class="submenu-indicator"></span>
                                <span class="submenu-label">Employees</span>
                            </a>
                            <a href="/departments" class="submenu-item @(IsActive(NavSection.Departments) ? "submenu-item-active" : "")">
                                <span class="submenu-indicator"></span>
                                <span class="submenu-label">Departments</span>
                            </a>
                            <a href="/positions" class="submenu-item @(IsActive(NavSection.Positions) ? "submenu-item-active" : "")">
                                <span class="submenu-indicator"></span>
                                <span class="submenu-label">Positions</span>
                            </a>
                        </div>
                    }

                    <a href="/attendance" class="nav-item @(IsActive(NavSection.Attendance) ? "nav-item-active" : "")">
                        <MudIcon Icon="@DzdIcons.Clock3" Class="nav-icon" />
                        <span class="nav-label">Attendance</span>
                    </a>

                    <a href="/leave-management" class="nav-item @(IsActive(NavSection.LeaveManagement) ? "nav-item-active" : "")">
                        <MudIcon Icon="@DzdIcons.CalendarCheck" Class="nav-icon" />
                        <span class="nav-label">Leave Management</span>
                    </a>

                    <a href="/training" class="nav-item @(IsActive(NavSection.Training) ? "nav-item-active" : "")">
                        <MudIcon Icon="@DzdIcons.GraduationCap" Class="nav-icon" />
                        <span class="nav-label">Training</span>
                    </a>

                    <a href="/performance" class="nav-item @(IsActive(NavSection.Performance) ? "nav-item-active" : "")">
                        <MudIcon Icon="@DzdIcons.TrendingUp" Class="nav-icon" />
                        <span class="nav-label">Performance</span>
                    </a>

                    <a href="/company" class="nav-item @(IsActive(NavSection.Company) ? "nav-item-active" : "")">
                        <MudIcon Icon="@DzdIcons.BriefcaseBusiness" Class="nav-icon" />
                        <span class="nav-label">Company</span>
                    </a>

                    <AuthorizeView Roles="@Roles.AdminOrHr" Context="navAuthCtx">
                        <a href="/settings" class="nav-item @(IsActive(NavSection.Settings) ? "nav-item-active" : "")">
                            <MudIcon Icon="@DzdIcons.Settings" Class="nav-icon" />
                            <span class="nav-label">Settings</span>
                        </a>
                    </AuthorizeView>
                </nav>
            </MudDrawer>
        </Authorized>
    </AuthorizeView>
    <MudMainContent Class="pt-16 px-4">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    // ── Nav section enum (replaces 10 individual booleans) ──────────────────
    private enum NavSection
    {
        None, Dashboard, Employees, Departments, Positions,
        Attendance, LeaveManagement, Training, Performance, Company, Settings, MyProfile
    }

    private static readonly Dictionary<NavSection, string> NavTitles = new()
    {
        [NavSection.None]           = "DZD Dashboard",
        [NavSection.Dashboard]      = "DZD Dashboard",
        [NavSection.Employees]      = "Employees",
        [NavSection.Departments]    = "Departments",
        [NavSection.Positions]      = "Positions",
        [NavSection.Attendance]     = "Attendance",
        [NavSection.LeaveManagement]= "Leave Management",
        [NavSection.Training]       = "Training",
        [NavSection.Performance]    = "Performance",
        [NavSection.Company]        = "Company",
        [NavSection.Settings]       = "Settings",
        [NavSection.MyProfile]      = "My Profile",
    };

    private static readonly HashSet<NavSection> EmployeesMenuSections =
        [NavSection.Employees, NavSection.Departments, NavSection.Positions];

    private NavSection _activeSection = NavSection.Dashboard;
    private bool _employeesMenuExpanded;

    private bool IsActive(NavSection section) => _activeSection == section;
    private bool IsEmployeesMenuActive => EmployeesMenuSections.Contains(_activeSection);
    private string PageTitle => NavTitles.GetValueOrDefault(_activeSection, "DZD Dashboard");

    private readonly MudTheme _myTheme = AppTheme.Default;
    private bool _drawerOpen = true;
    private string _avatarDataUrl = string.Empty;
    private string _userInitials = "?";
    private List<AppNotification> _notifications = [];
    private int _unreadNotifications;

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;
    private void ToggleEmployeesMenu() => _employeesMenuExpanded = !_employeesMenuExpanded;

    protected override async Task OnInitializedAsync()
    {
        SetActiveSection(Nav.Uri);
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        Nav.LocationChanged += OnLocationChanged;
        NotificationCenter.Changed += OnNotificationsChanged;
        LoadNotifications();
        await LoadAvatarAsync();
    }

    private async Task LoadAvatarAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            _userInitials = AppFormatter.GetInitials(user.Identity.Name);
            try
            {
                var avatarDto = await UserService.GetMyAvatarAsync();
                _avatarDataUrl = avatarDto != null && !string.IsNullOrEmpty(avatarDto.ContentBase64)
                    ? $"data:{avatarDto.ContentType ?? "image/png"};base64,{avatarDto.ContentBase64}"
                    : string.Empty;
            }
            catch
            {
                _avatarDataUrl = string.Empty;
            }
        }
        else
        {
            _avatarDataUrl = string.Empty;
            _userInitials  = "?";
        }

        await InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        SetActiveSection(e.Location);
        _ = InvokeAsync(StateHasChanged);
    }

    private Task Logout()
    {
        Nav.NavigateTo("/MicrosoftIdentity/Account/SignOut", forceLoad: true, replace: true);
        return Task.CompletedTask;
    }

    private void OnAuthenticationStateChanged(Task<AuthenticationState> task)
        => _ = HandleAuthStateChangedAsync(task);

    private async Task HandleAuthStateChangedAsync(Task<AuthenticationState> task)
    {
        try { await task; } catch { /* auth state tasks can fault on circuit teardown */ }
        await LoadAvatarAsync();
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        Nav.LocationChanged -= OnLocationChanged;
        NotificationCenter.Changed -= OnNotificationsChanged;
    }

    private void OnNotificationsChanged()
    {
        LoadNotifications();
        _ = InvokeAsync(StateHasChanged);
    }

    private void LoadNotifications()
    {
        _notifications       = NotificationCenter.GetAll().ToList();
        _unreadNotifications = NotificationCenter.UnreadCount;
    }

    private void MarkNotificationAsRead(int id) => NotificationCenter.MarkAsRead(id);
    private void MarkAllNotificationsAsRead()   => NotificationCenter.MarkAllAsRead();


    private void SetActiveSection(string location)
    {
        var path = Nav.ToBaseRelativePath(location);

        _activeSection = true switch
        {
            _ when string.IsNullOrEmpty(path)                                        => NavSection.Dashboard,
            _ when Seg(path, "employees") || Seg(path, "employee")                   => NavSection.Employees,
            _ when Seg(path, "departments")                                           => NavSection.Departments,
            _ when Seg(path, "positions")                                             => NavSection.Positions,
            _ when Seg(path, "attendance")                                            => NavSection.Attendance,
            _ when Seg(path, "leave-management")                                      => NavSection.LeaveManagement,
            _ when Seg(path, "training")                                              => NavSection.Training,
            _ when Seg(path, "performance")                                           => NavSection.Performance,
            _ when Seg(path, "company")                                               => NavSection.Company,
            _ when Seg(path, "settings")                                              => NavSection.Settings,
            _ when path.Equals("my-profile", StringComparison.OrdinalIgnoreCase)     => NavSection.MyProfile,
            _                                                                         => NavSection.None,
        };

        if (EmployeesMenuSections.Contains(_activeSection))
            _employeesMenuExpanded = true;
    }

    private static bool Seg(string path, string segment)
        => path.Equals(segment, StringComparison.OrdinalIgnoreCase)
        || path.StartsWith(segment + "/", StringComparison.OrdinalIgnoreCase);
}
