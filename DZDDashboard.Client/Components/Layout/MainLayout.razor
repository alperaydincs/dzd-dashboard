@inherits LayoutComponentBase
@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.Utils
@inject DZDDashboard.Client.Localization.AppLocalizer Loc
@inject IJSRuntime JS

<MudThemeProvider Theme="_myTheme" />
<MudDialogProvider />
<MudPopoverProvider />
<MudSnackbarProvider />

@if (!_ready)
{
    <div class="app-loading-overlay">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.body2" Class="mt-4" Style="color:var(--dzd-text-secondary);">@LoadingText</MudText>
    </div>
}
<MudLayout>
    <MudAppBar Elevation="1">
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.h5">@Loc[PageTitle]</MudText>
                <MudSpacer />
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="appbar-user-actions" Style="gap:10px;">
                    <MudButtonGroup Size="Size.Small" Variant="Variant.Outlined" Class="lang-switch">
                        <MudButton OnClick='@(() => SetCulture("en"))'>EN</MudButton>
                        <MudButton OnClick='@(() => SetCulture("tr"))'>TR</MudButton>
                    </MudButtonGroup>
                    <div style="margin-right:8px;">
                        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="notifications-menu">
                            <ActivatorContent Context="notificationsMenuContext">
                                <MudBadge Content="@_unreadNotifications" Color="Color.Error" Overlap="true" Visible="@(_unreadNotifications > 0)">
                                    <MudIconButton Icon="@DzdIcons.Bell" Color="Color.Inherit" Size="Size.Small" Class="notifications-trigger" OnClick="@notificationsMenuContext.ToggleAsync" />
                                </MudBadge>
                            </ActivatorContent>
                            <ChildContent>
                                <MudStack Class="notifications-panel">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="notifications-header">
                                        <MudText Typo="Typo.subtitle2">@Loc["appbar.notifications"]</MudText>
                                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="MarkAllNotificationsAsRead">@Loc["appbar.markAllRead"]</MudButton>
                                    </MudStack>
                                    <MudDivider />

                                    @if (_notifications.Count == 0)
                                    {
                                        <MudText Typo="Typo.caption" Class="pa-3">@Loc["appbar.noNotifications"]</MudText>
                                    }
                                    else
                                    {
                                        @foreach (var notification in _notifications)
                                        {
                                            <MudListItem T="string" Class="notification-item" OnClick="@(() => MarkNotificationAsRead(notification.Id))">
                                                <MudStack Spacing="0" Class="notification-item-content">
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                                        <MudText Typo="Typo.subtitle2">@notification.Title</MudText>
                                                        @if (!notification.IsRead)
                                                        {
                                                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Text">@Loc["appbar.new"]</MudChip>
                                                        }
                                                    </MudStack>
                                                    <MudText Typo="Typo.caption">@notification.Message</MudText>
                                                    <MudText Typo="Typo.caption" Class="notification-time">@AppFormatter.FormatElapsed(notification.CreatedAtUtc)</MudText>
                                                </MudStack>
                                            </MudListItem>
                                        }
                                    }
                                </MudStack>
                            </ChildContent>
                        </MudMenu>
                    </div>

                    <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="profile-menu">
                        <ActivatorContent Context="profileMenuContext">
                            <span class="profile-avatar-trigger" @onclick="@profileMenuContext.ToggleAsync">
                                <InitialsAvatar FullName="@_header.Name"
                                                ImageSrc="@_header.AvatarSrc"
                                                ColorIndex="@_header.ColorIndex"
                                                Size="40" Class="clickable" />
                                <span class="profile-avatar-caret">
                                    <MudIcon Icon="@DzdIcons.ChevronDown" Size="Size.Small" />
                                </span>
                            </span>
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem Href="/my-profile" Icon="@DzdIcons.User">@Loc["appbar.myProfile"]</MudMenuItem>
                            <AuthorizeView Roles="@Roles.AdminOrHr" Context="settingsAuthContext">
                                <Authorized Context="settingsAuthContext">
                                    <MudMenuItem Href="/settings" Icon="@DzdIcons.Settings">@Loc["appbar.settings"]</MudMenuItem>
                                </Authorized>
                            </AuthorizeView>
                            <MudMenuItem OnClick="Logout" Icon="@DzdIcons.LogOut">@Loc["appbar.logout"]</MudMenuItem>
                        </ChildContent>
                    </MudMenu>
                </MudStack>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/MicrosoftIdentity/Account/SignIn" Color="Color.Inherit">@Loc["appbar.login"]</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <AuthorizeView>
        <Authorized>
            <MudDrawer @bind-Open="_drawerOpen" Elevation="0" Variant="DrawerVariant.Mini" Width="240px" MiniWidth="104px" ClipMode="DrawerClipMode.Never" Class="custom-sidebar">
                <div class="sidebar-logo @(_drawerOpen ? "" : "sidebar-collapsed")" @onclick="DrawerToggle" title="Toggle menu">
                    <img src="@(_drawerOpen ? "/images/dzd_logo.svg" : "/images/dzd_logo_small.svg")" alt="Company Logo" class="sidebar-logo-image" />
                    <MudIcon Icon="@(_drawerOpen ? DzdIcons.ChevronLeft : DzdIcons.ChevronRight)" Class="sidebar-toggle-icon" />
                </div>
                <MudDivider Class="sidebar-divider" />
                <nav class="sidebar-nav @(_drawerOpen ? "" : "sidebar-collapsed")">
                    @foreach (var link in NavLinks)
                    {
                        <AuthorizeView Roles="@link.RequiredRoles" Context="navAuthContext">
                            <a href="@link.Href" class="nav-item @(IsActive(link.Section) ? "nav-item-active" : "")">
                                <MudIcon Icon="@link.Icon" Class="nav-icon" />
                                <span class="nav-label">@Loc[link.Label]</span>
                            </a>
                        </AuthorizeView>
                    }
                </nav>
                <AuthorizeView Roles="@SettingsNavLink.RequiredRoles" Context="settingsNavAuthContext">
                    <MudDivider Class="sidebar-divider" />
                </AuthorizeView>
                <div class="sidebar-footer-nav @(_drawerOpen ? "" : "sidebar-collapsed")">
                    <AuthorizeView Roles="@SettingsNavLink.RequiredRoles" Context="settingsNavAuthContext">
                        <a href="@SettingsNavLink.Href" class="nav-item @(IsActive(SettingsNavLink.Section) ? "nav-item-active" : "")">
                            <MudIcon Icon="@SettingsNavLink.Icon" Class="nav-icon" />
                            <span class="nav-label">@Loc[SettingsNavLink.Label]</span>
                        </a>
                    </AuthorizeView>
                </div>
            </MudDrawer>
        </Authorized>
    </AuthorizeView>
    <MudMainContent Class="pt-16 px-4">
        @Body
    </MudMainContent>
</MudLayout>
