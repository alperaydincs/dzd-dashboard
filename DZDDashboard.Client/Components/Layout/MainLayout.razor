@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.JSInterop
@using DZDDashboard.Common.DTOs.Users
@using DZDDashboard.Client.Theme
@using System.Security.Claims

@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory

@implements IDisposable


<MudThemeProvider Theme="_myTheme" />
<MudDialogProvider />
<MudPopoverProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="1">
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@DrawerToggle" />
            </Authorized>
        </AuthorizeView>

        <MudText Typo="Typo.h5" Class="ml-3">@_pageTitle</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                         AnchorOrigin="Origin.BottomRight"
                         TransformOrigin="Origin.TopRight">
                    <ActivatorContent>
                        <MudAvatar Color="Color.Primary" Style="cursor:pointer;">
                            @if (!string.IsNullOrEmpty(_avatarDataUrl))
                            {
                                <MudImage Src="@_avatarDataUrl" Alt="User Avatar" />
                            }
                            else
                            {
                                @_userInitials
                            }
                        </MudAvatar>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Href="/my-profile" Icon="@Icons.Material.Filled.Person">My Profile</MudMenuItem>
                        <AuthorizeView Roles="Admin,HR" Context="authContext">
                            <Authorized>
                                <MudMenuItem Href="/settings" Icon="@Icons.Material.Filled.Settings">Settings</MudMenuItem>
                            </Authorized>
                        </AuthorizeView>
                        <MudMenuItem OnClick="Logout" Icon="@Icons.Material.Filled.Logout">Logout</MudMenuItem>
                    </ChildContent>
                </MudMenu>

            </Authorized>
            <NotAuthorized>
                <MudButton Href="/MicrosoftIdentity/Account/SignIn" Color="Color.Inherit">Login</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <AuthorizeView>
        <Authorized>
            <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="DrawerVariant.Mini" ClipMode="DrawerClipMode.Always" Class="nav-drawer">
                <MudList T="string">
                    <MudListItem Href="/" Icon="@Icons.Material.Filled.Dashboard" Class="@(_isDashboardSelected ? "mud-selected-item" : "")">
                        Dashboard
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.People" OnClick="@ToggleSecondDrawer" Class="@(_isEmployeesSelected ? "mud-selected-item" : "")">
                        Employees
                    </MudListItem>
                </MudList>
            </MudDrawer>

            <MudDrawer @bind-Open="_secondDrawerOpen"
                       Class="second-drawer-offset nav-drawer"
                       Elevation="1"
                       Variant="DrawerVariant.Temporary"
                       ClipMode="DrawerClipMode.Always">
                <MudList T="string">
                    <MudListSubheader>Employee Management</MudListSubheader>
                    <MudListItem Href="/employees" Icon="@Icons.Material.Filled.List" Class="@(_isEmployeesSelected ? "mud-selected-item" : "")">
                        Employees
                    </MudListItem>
                    <MudListItem Href="/departments" Icon="@Icons.Material.Filled.Business" Class="@(_isDepartmentsSelected ? "mud-selected-item" : "")">
                        Departments
                    </MudListItem>
                    <MudListItem Href="/positions" Icon="@Icons.Material.Filled.Work" Class="@(_isPositionsSelected ? "mud-selected-item" : "")">
                        Positions
                    </MudListItem>
                </MudList>
            </MudDrawer>
        </Authorized>
    </AuthorizeView>
    <MudMainContent Class="pt-16 px-4">
        @Body
    </MudMainContent>
</MudLayout>


@code {

    private string _pageTitle = "DZD Dashboard";
    private readonly MudTheme _myTheme = AppTheme.Default;
    private bool _drawerOpen = true;
    private bool _secondDrawerOpen = false;
    private bool _isEmployeesSelected;
    private bool _isDashboardSelected;
    private bool _isDepartmentsSelected;
    private bool _isPositionsSelected;
    private string _avatarDataUrl = string.Empty;
    private string _userInitials = "?";

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
        if (!_drawerOpen) { _secondDrawerOpen = false; }
    }

    private void ToggleSecondDrawer()
    {
        _secondDrawerOpen = !_secondDrawerOpen;
        _drawerOpen = true;
    }

    protected override async Task OnInitializedAsync()
    {
        UpdatePageTitle(Nav.Uri);
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        Nav.LocationChanged += OnLocationChanged;
        await LoadAvatarAsync();
    }

    private async Task LoadAvatarAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated ?? false)
        {
            _userInitials = GetInitials(user.Identity.Name);

            try
            {
                var client = HttpClientFactory.CreateClient("Api");
                var avatarDto = await client.GetFromJsonAsync<UserAvatarDto>("api/users/my-avatar");

                if (avatarDto != null && !string.IsNullOrEmpty(avatarDto.ContentBase64))
                {
                    _avatarDataUrl = $"data:{avatarDto.ContentType ?? "image/png"};base64,{avatarDto.ContentBase64}";
                }
                else
                {
                    _avatarDataUrl = string.Empty;
                }
            }
            catch (Exception ex)
            {
                _avatarDataUrl = string.Empty;
                Console.WriteLine($"MainLayout: Avatar yüklenemedi: {ex.Message}");
            }
        }
        else
        {
            _avatarDataUrl = string.Empty;
            _userInitials = "?";
        }

        await InvokeAsync(StateHasChanged);
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";

        var parts = name.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length > 1)
        {
            return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
        }

        return name.Length > 0 ? $"{name[0]}".ToUpper() : "?";
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdatePageTitle(e.Location);
        if (_secondDrawerOpen) { _secondDrawerOpen = false; }
        InvokeAsync(StateHasChanged);
    }

    private Task Logout()
    {
        Nav.NavigateTo("/MicrosoftIdentity/Account/SignOut", forceLoad: true, replace: true);
        return Task.CompletedTask;
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        await task;
        await LoadAvatarAsync();
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }

    private void UpdatePageTitle(string location)
    {
        var relativePath = Nav.ToBaseRelativePath(location);
        
        _isEmployeesSelected = relativePath.StartsWith("employees", StringComparison.OrdinalIgnoreCase) || 
                               relativePath.StartsWith("employee", StringComparison.OrdinalIgnoreCase);
        _isDepartmentsSelected = relativePath.StartsWith("departments", StringComparison.OrdinalIgnoreCase);
        _isPositionsSelected = relativePath.StartsWith("positions", StringComparison.OrdinalIgnoreCase);
        _isDashboardSelected = string.IsNullOrEmpty(relativePath);

        if (_isEmployeesSelected)
        {
            _pageTitle = "Employees";
        }
        else if (_isDepartmentsSelected)
        {
            _pageTitle = "Departments";
        }
        else if (_isPositionsSelected)
        {
            _pageTitle = "Positions";
        }
        else if (relativePath.Equals("my-profile", StringComparison.OrdinalIgnoreCase))
        {
            _pageTitle = "My Profile";
        }
        else
        {
            _pageTitle = "DZD Dashboard";
        }
    }
}