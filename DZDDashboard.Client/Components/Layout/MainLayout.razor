@inherits LayoutComponentBase
@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.Utils

<MudThemeProvider Theme="_myTheme" />
<MudDialogProvider />
<MudPopoverProvider />
<MudSnackbarProvider />

@if (!_ready)
{
    <div class="app-loading-overlay">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.body2" Class="mt-4" Style="color:var(--dzd-text-secondary);">@LoadingText</MudText>
    </div>
}
<MudLayout>
    <MudAppBar Elevation="1">
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.h5">@PageTitle</MudText>
                <MudSpacer />
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="appbar-user-actions" Style="gap:10px;">
                    <div style="margin-right:8px;">
                        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="notifications-menu">
                            <ActivatorContent>
                                <MudBadge Content="@_unreadNotifications" Color="Color.Error" Overlap="true" Visible="@(_unreadNotifications > 0)">
                                    <MudIconButton Icon="@DzdIcons.Bell" Color="Color.Inherit" Size="Size.Small" Class="notifications-trigger" />
                                </MudBadge>
                            </ActivatorContent>
                            <ChildContent>
                                <MudStack Class="notifications-panel">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="notifications-header">
                                        <MudText Typo="Typo.subtitle2">Notifications</MudText>
                                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="MarkAllNotificationsAsRead">Mark all read</MudButton>
                                    </MudStack>
                                    <MudDivider />

                                    @if (_notifications.Count == 0)
                                    {
                                        <MudText Typo="Typo.caption" Class="pa-3">No notifications yet.</MudText>
                                    }
                                    else
                                    {
                                        @foreach (var notification in _notifications)
                                        {
                                            <MudListItem T="string" Class="notification-item" OnClick="@(() => MarkNotificationAsRead(notification.Id))">
                                                <MudStack Spacing="0" Class="notification-item-content">
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                                        <MudText Typo="Typo.subtitle2">@notification.Title</MudText>
                                                        @if (!notification.IsRead)
                                                        {
                                                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Text">New</MudChip>
                                                        }
                                                    </MudStack>
                                                    <MudText Typo="Typo.caption">@notification.Message</MudText>
                                                    <MudText Typo="Typo.caption" Class="notification-time">@AppFormatter.FormatElapsed(notification.CreatedAtUtc)</MudText>
                                                </MudStack>
                                            </MudListItem>
                                        }
                                    }
                                </MudStack>
                            </ChildContent>
                        </MudMenu>
                    </div>

                    <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="profile-menu">
                        <ActivatorContent>
                            <InitialsAvatar FullName="@_header.Name"
                                            ImageSrc="@_header.AvatarDataUrl"
                                            ColorIndex="@_header.ColorIndex"
                                            Size="40" Class="clickable" />
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem Href="/my-profile" Icon="@DzdIcons.User">My Profile</MudMenuItem>
                            <AuthorizeView Roles="@Roles.AdminOrHr" Context="settingsAuthContext">
                                <Authorized Context="settingsAuthContext">
                                    <MudMenuItem Href="/settings" Icon="@DzdIcons.Settings">Settings</MudMenuItem>
                                </Authorized>
                            </AuthorizeView>
                            <MudMenuItem OnClick="Logout" Icon="@DzdIcons.LogOut">Logout</MudMenuItem>
                        </ChildContent>
                    </MudMenu>
                </MudStack>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/MicrosoftIdentity/Account/SignIn" Color="Color.Inherit">Login</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <AuthorizeView>
        <Authorized>
            @if (!_onboardingMode)
            {
            <MudDrawer @bind-Open="_drawerOpen" Elevation="0" Variant="DrawerVariant.Mini" Width="240px" MiniWidth="104px" ClipMode="DrawerClipMode.Never" Class="custom-sidebar">
                <div class="sidebar-logo @(_drawerOpen ? "" : "sidebar-collapsed")" @onclick="DrawerToggle" title="Toggle menu">
                    <img src="@(_drawerOpen ? "/images/dzd_logo.svg" : "/images/dzd_logo_small.svg")" alt="Company Logo" class="sidebar-logo-image" />
                    <MudIcon Icon="@(_drawerOpen ? DzdIcons.ChevronLeft : DzdIcons.ChevronRight)" Class="sidebar-toggle-icon" />
                </div>
                <MudDivider Class="sidebar-divider" />
                <nav class="sidebar-nav @(_drawerOpen ? "" : "sidebar-collapsed")">
                    @foreach (var link in NavLinks)
                    {
                        <AuthorizeView Roles="@link.RequiredRoles" Context="navAuthContext">
                            <a href="@link.Href" class="nav-item @(IsActive(link.Section) ? "nav-item-active" : "")">
                                <MudIcon Icon="@link.Icon" Class="nav-icon" />
                                <span class="nav-label">@link.Label</span>
                            </a>
                        </AuthorizeView>
                    }
                </nav>
            </MudDrawer>
            }
        </Authorized>
    </AuthorizeView>
    <MudMainContent Class="pt-16 px-4">
        @Body
    </MudMainContent>
</MudLayout>
