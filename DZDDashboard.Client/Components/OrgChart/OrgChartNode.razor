@using DZDDashboard.Client.Components.OrgChart
@using DZDDashboard.Client.Services
@inject NavigationManager Nav
@inject EmployeeNavigationState EmployeeNavigationState

<li>
    <MudStack Spacing="0" AlignItems="AlignItems.Center" Class="node-container">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0" Class="node-row">
            <MudPaper Class="@GetNodeCardClass()" Elevation="0" @onclick="@(() => HandleNodeClick(Node.User, isUser: Node.User is not null))">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="node-card-content">
                    @if (Node.User != null)
                    {
                        <MudAvatar Color="GetAvatarColor(Node.User)" Size="Size.Large" Class="node-avatar dzd-avatar dzd-avatar-lg">
                            @if (Node.User.Avatar != null && !string.IsNullOrEmpty(Node.User.Avatar.ContentBase64))
                            {
                                <MudImage Src="@($"data:{Node.User.Avatar.ContentType};base64,{Node.User.Avatar.ContentBase64}")" />
                            }
                            else
                            {
                                @GetUserInitials(Node.User)
                            }
                        </MudAvatar>
                    }
                    else
                    {
                        <MudAvatar Color="Color.Default" Size="Size.Large" Class="node-avatar node-avatar-empty dzd-avatar dzd-avatar-lg">
                            <MudIcon Icon="@DzdIcons.UserRound" />
                        </MudAvatar>
                    }

                    <MudStack Spacing="0" AlignItems="AlignItems.Start" Class="node-texts">
                        <MudText Typo="Typo.subtitle2" Class="@GetPrimaryLabelClass()">@GetPrimaryLabel()</MudText>
                        <MudText Typo="Typo.caption" Class="node-position">@GetPositionName()</MudText>

                        @if (TryGetMetaChipText(out var metaText))
                        {
                            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Class="node-meta-chip">
                                @metaText
                            </MudChip>
                        }
                    </MudStack>
                </MudStack>
            </MudPaper>

            @if (IsEditMode)
            {
                <MudStack Spacing="1" Class="ms-2 node-actions">
                    <MudIconButton Icon="@DzdIcons.Plus" Size="Size.Small" Color="Color.Success"
                                   OnClick="@(() => OnAddChild.InvokeAsync(Node))" />
                    <MudIconButton Icon="@DzdIcons.Trash2" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => OnDeleteNode.InvokeAsync(Node))" />
                </MudStack>
            }
        </MudStack>

        @if (Node.Children.Any())
        {
            <MudIconButton Icon="@(Node.IsExpanded ? DzdIcons.ChevronUp : DzdIcons.ChevronDown)"
                           Size="Size.Small"
                           Color="Color.Primary"
                           OnClick="ToggleExpand"
                           Class="expand-btn" />
        }
    </MudStack>

    @if (Node.IsExpanded && Node.Children.Any())
    {
        <ul>
            @foreach (var child in Node.Children)
            {
                <OrgChartNode Node="child" 
                              IsEditMode="IsEditMode" 
                              IsSelectionMode="IsSelectionMode"
                              OnAddChild="OnAddChild"
                              OnEditNode="OnEditNode"
                              OnDeleteNode="OnDeleteNode"
                              OnNodeSelected="OnNodeSelected" />
            }
        </ul>
    }
</li>

@code {
    [Parameter, EditorRequired] public OrgChartNodeItem Node { get; set; } = default!;
    
    [Parameter] public bool IsEditMode { get; set; }
    [Parameter] public bool IsSelectionMode { get; set; }
    
    [Parameter] public EventCallback<OrgChartNodeItem> OnAddChild { get; set; }
    [Parameter] public EventCallback<OrgChartNodeItem> OnEditNode { get; set; }
    [Parameter] public EventCallback<OrgChartNodeItem> OnDeleteNode { get; set; }
    [Parameter] public EventCallback<OrgChartNodeItem> OnNodeSelected { get; set; }

    private void ToggleExpand()
    {
        Node.IsExpanded = !Node.IsExpanded;
    }

    private async Task HandleNodeClick(UserDto? user, bool isUser)
    {
        if (IsSelectionMode)
        {
             await OnNodeSelected.InvokeAsync(Node);
        }
        else if (IsEditMode)
        {
            await OnEditNode.InvokeAsync(Node);
        }
        else if (isUser && user != null)
        {
            EmployeeNavigationState.SelectedEmployeeId = user.Id;
            Nav.NavigateTo("/employee/card");
        }
    }

    private string GetPositionName()
    {
        if (Node?.Position == null) return "Unknown";
        return !string.IsNullOrWhiteSpace(Node.Position.Name) ? Node.Position.Name : $"Position {Node.Position.Id}";
    }

    private string GetNodeCardClass()
    {
        var baseClass = "node-card pa-3";

        if (Node.User is null)
        {
            baseClass += " node-card-empty";
        }

        if (IsSelectionMode) return baseClass + " cursor-pointer"; 
        if (IsEditMode) return baseClass + " cursor-pointer";
        if (Node.User != null) return baseClass + " cursor-pointer";
        return baseClass;
    }

    private string GetPrimaryLabel()
    {
        if (Node.User is null)
        {
            return "Empty";
        }

        var firstName = Node.User.FirstName?.Trim();
        var lastName = Node.User.LastName?.Trim();
        var fullName = string.Join(" ", new[] { firstName, lastName }.Where(v => !string.IsNullOrWhiteSpace(v)));

        if (!string.IsNullOrWhiteSpace(fullName))
        {
            return fullName;
        }

        return Node.User.Email ?? $"User {Node.User.Id}";
    }

    private string GetPrimaryLabelClass()
    {
        return Node.User is null ? "node-primary node-primary-empty" : "node-primary";
    }

    private static string GetUserInitials(UserDto user)
    {
        var first = string.IsNullOrWhiteSpace(user.FirstName) ? string.Empty : user.FirstName.Trim()[0].ToString();
        var last = string.IsNullOrWhiteSpace(user.LastName) ? string.Empty : user.LastName.Trim()[0].ToString();
        var initials = (first + last).ToUpperInvariant();

        return string.IsNullOrWhiteSpace(initials) ? "?" : initials;
    }

    private bool TryGetMetaChipText(out string chipText)
    {
        chipText = string.Empty;

        if (Node.User is null)
        {
            return false;
        }

        var jobName = Node.User.Job?.Name?.Trim();
        var departmentName = Node.User.Department?.Name?.Trim();

        if (string.IsNullOrWhiteSpace(jobName) && string.IsNullOrWhiteSpace(departmentName))
        {
            return false;
        }

        chipText = string.IsNullOrWhiteSpace(jobName)
            ? departmentName!
            : string.IsNullOrWhiteSpace(departmentName)
                ? jobName
                : $"{jobName} - {departmentName}";

        return true;
    }

    private static Color GetAvatarColor(UserDto u)
    {
        return (u.Id % 6) switch
        {
            0 => Color.Primary,
            1 => Color.Secondary,
            2 => Color.Info,
            3 => Color.Success,
            4 => Color.Warning,
            _ => Color.Tertiary
        };
    }
}



