@using DZDDashboard.Common.Utils

<div class="dzd-initials-avatar @Class" style="@StyleString" @attributes="Attributes">
    @if (!string.IsNullOrEmpty(ImageSrc))
    {
        <img src="@ImageSrc" alt="@FullName" class="dzd-initials-avatar__img" />
    }
    else
    {
        @AppFormatter.GetInitials(FullName)
    }
</div>

@code {
    [Parameter, EditorRequired] public string FullName { get; set; } = string.Empty;

    [Parameter] public int Size { get; set; } = 40;

    [Parameter] public string? ImageSrc { get; set; }

    [Parameter] public int? ColorIndex { get; set; }

    [Parameter] public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? Attributes { get; set; }

    private const double FontRatio = 0.4;

    private string StyleString
    {
        get
        {
            var fontSize = (int)Math.Round(Size * FontRatio);
            var background = string.IsNullOrEmpty(ImageSrc)
                ? (ColorIndex is int i && i >= 0 && i < Gradients.Length ? Gradients[i] : GradientFor(FullName))
                : "transparent";
            return $"width:{Size}px;height:{Size}px;font-size:{fontSize}px;background:{background};";
        }
    }

    public static readonly string[] Gradients =
    [
        "linear-gradient(135deg,#6366F1,#8B5CF6)",
        "linear-gradient(135deg,#0EA5E9,#2563EB)",
        "linear-gradient(135deg,#10B981,#059669)",
        "linear-gradient(135deg,#F59E0B,#F97316)",
        "linear-gradient(135deg,#EF4444,#EC4899)",
        "linear-gradient(135deg,#8B5CF6,#EC4899)",
        "linear-gradient(135deg,#14B8A6,#0EA5E9)",
        "linear-gradient(135deg,#F43F5E,#F59E0B)",
        "linear-gradient(135deg,#22C55E,#84CC16)",
        "linear-gradient(135deg,#3B82F6,#6366F1)"
    ];

    private static string GradientFor(string? name) => Gradients[StableIndex(name)];

    private static int StableIndex(string? name)
    {
        var key = (name ?? string.Empty).Trim().ToLowerInvariant();
        unchecked
        {
            uint hash = 2166136261;
            foreach (var c in key)
            {
                hash ^= c;
                hash *= 16777619;
            }
            return (int)(hash % (uint)Gradients.Length);
        }
    }
}
