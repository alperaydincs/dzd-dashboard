@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@using DZDDashboard.Common.Validation
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@DzdIcons.ClipboardCheck" Color="Color.Primary" Size="Size.Small" />
            <MudText Typo="Typo.h6">Adımı Tamamla: @Item.Title</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="3">
            @if (_isBenefit)
            {
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Sağlayıcı" @bind-Value="_dto.ProviderName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="Para Birimi" @bind-Value="_dto.Currency" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var c in Currencies.All)
                        {
                            <MudSelectItem Value="@c">@c</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                @if (Item.BenefitKind == ChecklistBenefitKinds.Bes)
                {
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Label="İşveren BES Tutarı (aylık)" @bind-Value="_dto.EmployerAmount" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Format="N2" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Label="Çalışan BES Tutarı (aylık)" @bind-Value="_dto.EmployeeAmount" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Format="N2" />
                    </MudItem>
                }
                else if (Item.BenefitKind == ChecklistBenefitKinds.Oss)
                {
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal?" Label="Çalışan için tutar (aylık)" @bind-Value="_dto.EmployeeAmount" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Format="N2" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.subtitle2">Bağımlılar (@_dto.Dependents.Count / @ValidationConstants.MaxBenefitDependents)</MudText>
                            <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@DzdIcons.Plus"
                                       OnClick="AddDependent" Disabled="@(_dto.Dependents.Count >= ValidationConstants.MaxBenefitDependents)">Bağımlı Ekle</MudButton>
                        </MudStack>
                    </MudItem>
                    @foreach (var dep in _dto.Dependents)
                    {
                        <MudItem xs="12" sm="4">
                            <MudSelect T="string" Label="Bağımlı Tipi" @bind-Value="dep.DependentType" Variant="Variant.Outlined" Margin="Margin.Dense">
                                @foreach (var t in DependentTypes.All)
                                {
                                    <MudSelectItem Value="@t">@t</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField T="string" Label="Ad (ops.)" @bind-Value="dep.DependentName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="10" sm="3">
                            <MudNumericField T="decimal" Label="Tutar" @bind-Value="dep.Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Format="N2" />
                        </MudItem>
                        <MudItem xs="2" sm="1" Class="d-flex align-center">
                            <MudIconButton Icon="@DzdIcons.Trash2" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveDependent(dep))" />
                        </MudItem>
                    }
                }
            }

            <MudItem xs="12">
                <MudTextField T="string" Label="Not (ops.)" @bind-Value="_dto.Note" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
            </MudItem>

            @if (_isBenefit)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
                        Tamamlandığında bu tutarlar çalışanın Payment ekranına otomatik yansır.
                    </MudAlert>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">Vazgeç</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="@_submitted">Tamamla</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public ChecklistItemDto Item { get; set; } = default!;

    private CompleteChecklistItemDto _dto = new();
    private bool _isBenefit;
    private bool _submitted;

    protected override void OnInitialized()
    {
        _isBenefit = Item.BenefitKind != ChecklistBenefitKinds.None;
        _dto = new CompleteChecklistItemDto
        {
            Note           = Item.Note,
            ProviderName   = Item.ProviderName,
            Currency       = string.IsNullOrWhiteSpace(Item.Currency) ? Currencies.Try : Item.Currency,
            EmployeeAmount = Item.EmployeeAmount,
            EmployerAmount = Item.EmployerAmount,
            Dependents     = [.. Item.Dependents.Select(d => new ChecklistItemDependentInputDto
            {
                Order = d.Order, DependentType = d.DependentType, DependentName = d.DependentName, Amount = d.Amount
            })]
        };
    }

    private void AddDependent()
        => _dto.Dependents.Add(new ChecklistItemDependentInputDto { DependentType = DependentTypes.Child, Order = _dto.Dependents.Count + 1 });

    private void RemoveDependent(ChecklistItemDependentInputDto dep) => _dto.Dependents.Remove(dep);

    private void Submit()
    {
        if (_submitted) return;

        if (Item.BenefitKind == ChecklistBenefitKinds.Bes && _dto.EmployeeAmount is null && _dto.EmployerAmount is null)
        {
            Snackbar.Add("BES için işveren ve/veya çalışan tutarı girilmelidir.", Severity.Warning);
            return;
        }
        if (Item.BenefitKind == ChecklistBenefitKinds.Oss && _dto.EmployeeAmount is null)
        {
            Snackbar.Add("ÖSS için çalışan tutarı girilmelidir.", Severity.Warning);
            return;
        }

        _submitted = true;
        MudDialog.Close(DialogResult.Ok(_dto));
    }

    private void Cancel() => MudDialog.Cancel();
}
