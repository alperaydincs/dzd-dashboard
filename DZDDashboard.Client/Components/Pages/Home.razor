@page "/"
@using DZDDashboard.Common.Constants
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject DZDDashboard.Client.Localization.AppLocalizer Loc

<PageTitle>Home</PageTitle>

<AuthorizeView>
    <Authorized>
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h4" GutterBottom="true">@string.Format(Loc["home.welcome"], context.User.Identity!.Name!)</MudText>
            <MudText Typo="Typo.body1">@Loc["home.description"]</MudText>

            @{
                var roles = context.User.Claims
                    .Where(c => c.Type == DzdClaimTypes.RoleClaimType)
                    .Select(c => c.Value)
                    .Distinct()
                    .OrderBy(r => r)
                    .ToList();
            }

            @if (roles.Any())
            {
                <MudText Typo="Typo.h6" Class="mt-4">@Loc["home.yourRoles"]</MudText>
                <MudList T="string">
                    @foreach (var role in roles)
                    {
                        <MudListItem Icon="@DzdIcons.Shield">@role</MudListItem>
                    }
                </MudList>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Class="mt-4">@Loc["home.noRoles"]</MudAlert>
            }
        </MudPaper>
    </Authorized>
</AuthorizeView>
