@page "/"
@using Microsoft.JSInterop
@using System.Net.Http.Json
@using DZDDashboard.Common.DTOs

@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar

<PageTitle>Home</PageTitle>

@if (!_authChecked)
{
    <MudProgressCircular Color="Color.Default" Indeterminate="true" />
}
else if (!(_user.Identity?.IsAuthenticated ?? false))
{
    <p>Redirecting to login...</p>
}
else
{
    <MudPaper Class="pa-4">
        <MudText Typo="Typo.h4" GutterBottom="true">Welcome, @_user.Identity!.Name!</MudText>
        <MudText Typo="Typo.body1">This is your dashboard. You can add more components and information here.</MudText>

        @if (_roles.Any())
        {
            <MudText Typo="Typo.h6" Class="mt-4">Your Roles:</MudText>
            <MudList T="string">
                @foreach (var role in _roles)
                {
                    <MudListItem Icon="@Icons.Material.Filled.Shield">
                        @role
                    </MudListItem>
                }
            </MudList>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">You do not have any assigned roles.</MudAlert>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="CheckApiClaims">Debug: Check API Claims</MudButton>

        @if (_apiDebugInfo != null)
        {
            <MudPaper Class="pa-4 mt-4" Elevation="2">
                <MudText Typo="Typo.h6">API Claims Debug:</MudText>
                <MudText>Authenticated: @_apiDebugInfo.Authenticated</MudText>
                <MudText>Identity Name: @_apiDebugInfo.IdentityName</MudText>
                <MudText>Roles Count: @_apiDebugInfo.RolesCount</MudText>
                @if (_apiDebugInfo.Roles.Any())
                {
                    <MudText Typo="Typo.subtitle2" Class="mt-2">Roles:</MudText>
                    <pre style="background: #f5f5f5; padding: 12px; border-radius: 4px;">@(string.Join("\n", _apiDebugInfo.Roles))</pre>
                }
                <MudText Typo="Typo.subtitle2" Class="mt-2">All Claims:</MudText>
                <pre style="background: #f5f5f5; padding: 12px; border-radius: 4px; overflow-x: auto; max-height: 300px; overflow-y: auto; font-size: 12px;">@(string.Join("\n", _apiDebugInfo.Claims.Select(c => $"{c.Type}: {c.Value}")))</pre>
            </MudPaper>
        }
    </MudPaper>
}

@code {
    private ClaimsPrincipal _user = new(new ClaimsIdentity());
    private bool _authChecked;
    private List<string> _roles = new();
    private DebugClaimsDto? _apiDebugInfo;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _user = authState.User;

        if (!(_user.Identity?.IsAuthenticated ?? false))
        {
            try
            {
                Nav.NavigateTo("/MicrosoftIdentity/Account/SignIn", forceLoad: true, replace: true);
            }
            catch (JSDisconnectedException)
            {
            }
        }
        else
        {
            _roles = _user.Claims
                .Where(c => c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role")
                .Select(c => c.Value)
                .Distinct()
                .OrderBy(r => r)
                .ToList();
        }
        _authChecked = true;
    }

    private async Task CheckApiClaims()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("Api");
            _apiDebugInfo = await client.GetFromJsonAsync<DebugClaimsDto>("api/users/debug-claims");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}
