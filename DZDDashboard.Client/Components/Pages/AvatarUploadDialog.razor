@using Microsoft.AspNetCore.Components.Forms
@using DZDDashboard.Client.Models
@using DZDDashboard.Common.Constants
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid Spacing="2" Justify="Justify.Center">

            <MudItem xs="12" Class="d-flex flex-column align-center">
                <MudText Typo="Typo.subtitle1" GutterBottom="true">
                    @(!string.IsNullOrEmpty(_previewImageDataUrl) ? "New Photo (Preview)" : "Current Photo")
                </MudText>

                <MudAvatar Color="Color.Primary" Rounded="true" Size="Size.Large" Style="width:180px; height:180px; font-size: 5rem;">
                    @if (!string.IsNullOrEmpty(_previewImageDataUrl))
                    {
                        <MudImage Src="@_previewImageDataUrl" Alt="New Avatar Preview" />
                    }
                    else if (!string.IsNullOrEmpty(CurrentAvatarUrl))
                    {
                        <MudImage Src="@CurrentAvatarUrl" Alt="Current Avatar" />
                    }
                    else
                    {
                        @UserInitials
                    }
                </MudAvatar>
            </MudItem>

            <MudItem xs="12">
                <MudFileUpload T="IBrowserFile" Accept=".jpg,.jpeg,.png" MaximumFileCount="1" OnFilesChanged="OnInputFileChanged">
                    <ActivatorContent>
                        <MudButton HtmlTag="label"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@DzdIcons.CloudUpload"
                                   Class="mt-4">
                            Select Photo (.png, .jpg)
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                @if (_selectedFile is not null)
                {
                    <MudText Typo="Typo.body2" Class="mt-2" Align="Align.Center">
                        Selected file: @_selectedFile.Name
                    </MudText>
                }
            </MudItem>

        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Save" Disabled="@(_selectedFile is null)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string CurrentAvatarUrl { get; set; } = string.Empty;
    [Parameter] public string UserInitials      { get; set; } = string.Empty;

    private IBrowserFile? _selectedFile;
    private string?       _previewImageDataUrl;
    private byte[]?       _fileBytes;

    private async Task OnInputFileChanged(InputFileChangeEventArgs e)
    {
        if (e.FileCount == 0) { Reset(); return; }

        var file = e.File;
        if (file is null) return;

        // Client-side MIME validation — mirrors server-side AvatarConstants
        if (!AvatarConstants.AllowedMimeTypes.Contains(file.ContentType, StringComparer.OrdinalIgnoreCase))
        {
            Snackbar.Add($"Unsupported file type. Allowed: {string.Join(", ", AvatarConstants.AllowedExtensions)}.", Severity.Warning);
            Reset(); return;
        }

        if (file.Size > AvatarConstants.MaxFileSizeBytes)
        {
            Snackbar.Add($"File size cannot exceed {AvatarConstants.MaxFileSizeBytes / 1024 / 1024} MB.", Severity.Warning);
            Reset(); return;
        }

        try
        {
            using var stream = file.OpenReadStream(AvatarConstants.MaxFileSizeBytes);
            using var ms     = new MemoryStream();
            await stream.CopyToAsync(ms);
            _fileBytes           = ms.ToArray();
            _previewImageDataUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(_fileBytes)}";
            _selectedFile        = file;
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to read the selected file. Please try a different file.", Severity.Error);
            Reset();
        }
    }

    private void Reset()
    {
        _selectedFile        = null;
        _previewImageDataUrl = null;
        _fileBytes           = null;
    }

    void Save()
    {
        if (_selectedFile is null || _fileBytes is null) return;
        MudDialog.Close(DialogResult.Ok(
            new AvatarUploadResult(_selectedFile.Name, _selectedFile.ContentType, _fileBytes)));
    }

    void Cancel() => MudDialog.Cancel();
}



