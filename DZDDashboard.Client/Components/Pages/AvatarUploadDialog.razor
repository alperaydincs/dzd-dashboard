@using Microsoft.AspNetCore.Components.Forms
@using DZDDashboard.Client.Models
@using DZDDashboard.Common.Constants
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid Spacing="2" Justify="Justify.Center">

            <MudItem xs="12" Class="d-flex flex-column align-center">
                <MudText Typo="Typo.subtitle1" GutterBottom="true">
                    @(!string.IsNullOrEmpty(_previewImageDataUrl) ? "New Photo (Preview)" : "Current Photo")
                </MudText>

                <InitialsAvatar FullName="@UserFullName"
                                ImageSrc="@(!string.IsNullOrEmpty(_previewImageDataUrl) ? _previewImageDataUrl : (string.IsNullOrEmpty(CurrentAvatarUrl) ? null : CurrentAvatarUrl))"
                                ColorIndex="@_selectedColorIndex"
                                Size="180" />
            </MudItem>

            @if (string.IsNullOrEmpty(_previewImageDataUrl) && string.IsNullOrEmpty(CurrentAvatarUrl))
            {
                <MudItem xs="12" Class="d-flex flex-column align-center">
                    <MudText Typo="Typo.body2" Class="mb-2" Style="color:var(--dzd-text-secondary);">Background color</MudText>
                    <div class="avatar-color-palette">
                        @for (var i = 0; i < InitialsAvatar.Gradients.Length; i++)
                        {
                            var index = i;
                            <button type="button"
                                    class="avatar-color-swatch @(_selectedColorIndex == index ? "selected" : "")"
                                    style="@($"background:{InitialsAvatar.Gradients[index]};")"
                                    @onclick="@(() => _selectedColorIndex = index)"
                                    aria-label="@($"Color {index + 1}")"></button>
                        }
                    </div>
                </MudItem>
            }

            <MudItem xs="12">
                <MudFileUpload T="IBrowserFile" Accept=".jpg,.jpeg,.png" MaximumFileCount="1" OnFilesChanged="OnInputFileChanged">
                    <ActivatorContent>
                        <MudButton HtmlTag="label"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@DzdIcons.CloudUpload"
                                   Class="mt-4">
                            Select Photo (.png, .jpg)
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                @if (_selectedFile is not null)
                {
                    <MudText Typo="Typo.body2" Class="mt-2" Align="Align.Center">
                        Selected file: @_selectedFile.Name
                    </MudText>
                }
            </MudItem>

        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Save" Disabled="@(_selectedFile is null && _selectedColorIndex == CurrentColorIndex)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string CurrentAvatarUrl { get; set; } = string.Empty;
    [Parameter] public string UserFullName       { get; set; } = string.Empty;
    [Parameter] public int?   CurrentColorIndex { get; set; }

    private IBrowserFile? _selectedFile;
    private string?       _previewImageDataUrl;
    private byte[]?       _fileBytes;
    private int?          _selectedColorIndex;

    protected override void OnParametersSet() => _selectedColorIndex = CurrentColorIndex;

    private async Task OnInputFileChanged(InputFileChangeEventArgs e)
    {
        if (e.FileCount == 0) { Reset(); return; }

        var file = e.File;
        if (file is null) return;

        if (!AvatarConstants.AllowedMimeTypes.Contains(file.ContentType, StringComparer.OrdinalIgnoreCase))
        {
            Snackbar.Add($"Unsupported file type. Allowed: {string.Join(", ", AvatarConstants.AllowedExtensions)}.", Severity.Warning);
            Reset(); return;
        }

        if (file.Size > AvatarConstants.MaxFileSizeBytes)
        {
            Snackbar.Add($"File size cannot exceed {AvatarConstants.MaxFileSizeBytes / 1024 / 1024} MB.", Severity.Warning);
            Reset(); return;
        }

        try
        {
            using var stream = file.OpenReadStream(AvatarConstants.MaxFileSizeBytes);
            using var ms     = new MemoryStream();
            await stream.CopyToAsync(ms);
            _fileBytes           = ms.ToArray();
            _previewImageDataUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(_fileBytes)}";
            _selectedFile        = file;
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to read the selected file. Please try a different file.", Severity.Error);
            Reset();
        }
    }

    private void Reset()
    {
        _selectedFile        = null;
        _previewImageDataUrl = null;
        _fileBytes           = null;
    }

    void Save()
    {
        var file = _selectedFile is not null && _fileBytes is not null
            ? new AvatarUploadResult(_selectedFile.Name, _selectedFile.ContentType, _fileBytes)
            : null;
        var colorChanged = _selectedColorIndex != CurrentColorIndex;

        if (file is null && !colorChanged) return;

        MudDialog.Close(DialogResult.Ok(new AvatarDialogResult(file, _selectedColorIndex, colorChanged)));
    }

    void Cancel() => MudDialog.Cancel();
}



