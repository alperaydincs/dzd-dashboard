@using Microsoft.AspNetCore.Components.Forms
@using DZDDashboard.Client.Models
@using DZDDashboard.Common.Constants
@inject ISnackbar Snackbar
@inject DZDDashboard.Client.Localization.AppLocalizer Loc

<MudDialog>
    <DialogContent>
        <MudGrid Spacing="2" Justify="Justify.Center">

            <MudItem xs="12" Class="d-flex flex-column align-center">
                <MudText Typo="Typo.subtitle1" GutterBottom="true">
                    @(!string.IsNullOrEmpty(_previewImageDataUrl) ? Loc["avatarDialog.newPhotoPreview"] : Loc["avatarDialog.currentPhoto"])
                </MudText>

                <InitialsAvatar FullName="@UserFullName"
                                ImageSrc="@(!string.IsNullOrEmpty(_previewImageDataUrl) ? _previewImageDataUrl : (string.IsNullOrEmpty(CurrentAvatarUrl) ? null : CurrentAvatarUrl))"
                                ColorIndex="@_selectedColorIndex"
                                Size="180" />
            </MudItem>

            @if (string.IsNullOrEmpty(_previewImageDataUrl) && string.IsNullOrEmpty(CurrentAvatarUrl))
            {
                <MudItem xs="12" Class="d-flex flex-column align-center">
                    <MudText Typo="Typo.body2" Class="mb-2" Style="color:var(--dzd-text-secondary);">@Loc["avatarDialog.backgroundColor"]</MudText>
                    <div class="avatar-color-palette">
                        @for (var i = 0; i < InitialsAvatar.Gradients.Length; i++)
                        {
                            var index = i;
                            <button type="button"
                                    class="avatar-color-swatch @(_selectedColorIndex == index ? "selected" : "")"
                                    style="@($"background:{InitialsAvatar.Gradients[index]};")"
                                    @onclick="@(() => _selectedColorIndex = index)"
                                    aria-label="@string.Format(Loc["avatarDialog.colorLabel"], index + 1)"></button>
                        }
                    </div>
                </MudItem>
            }

            <MudItem xs="12">
                <MudFileUpload T="IBrowserFile" Accept=".jpg,.jpeg,.png" MaximumFileCount="1" OnFilesChanged="OnInputFileChanged">
                    <CustomContent Context="fileUpload">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@DzdIcons.CloudUpload"
                                   Class="mt-4"
                                   OnClick="@fileUpload.OpenFilePickerAsync">
                            @Loc["avatarDialog.selectPhoto"]
                        </MudButton>
                    </CustomContent>
                </MudFileUpload>
                @if (_selectedFile is not null)
                {
                    <MudText Typo="Typo.body2" Class="mt-2" Align="Align.Center">
                        @string.Format(Loc["avatarDialog.selectedFile"], _selectedFile.Name)
                    </MudText>
                }
            </MudItem>

            @if (!string.IsNullOrEmpty(CurrentAvatarUrl) && _selectedFile is null)
            {
                <MudItem xs="12" Class="d-flex justify-center">
                    <MudButton Variant="Variant.Text"
                               Color="Color.Error"
                               StartIcon="@DzdIcons.Trash2"
                               OnClick="RemovePhoto">
                        @Loc["avatarDialog.removePhoto"]
                    </MudButton>
                </MudItem>
            }

        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@Loc["common.cancel"]</MudButton>
        <MudButton Color="Color.Primary" OnClick="Save" Disabled="@(_selectedFile is null && _selectedColorIndex == CurrentColorIndex)">@Loc["common.save"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string CurrentAvatarUrl { get; set; } = string.Empty;
    [Parameter] public string UserFullName       { get; set; } = string.Empty;
    [Parameter] public int?   CurrentColorIndex { get; set; }

    private IBrowserFile? _selectedFile;
    private string?       _previewImageDataUrl;
    private byte[]?       _fileBytes;
    private int?          _selectedColorIndex;

    protected override void OnParametersSet() => _selectedColorIndex = CurrentColorIndex;

    private async Task OnInputFileChanged(InputFileChangeEventArgs e)
    {
        if (e.FileCount == 0) { Reset(); return; }

        var file = e.File;
        if (file is null) return;

        if (!AvatarConstants.AllowedMimeTypes.Contains(file.ContentType, StringComparer.OrdinalIgnoreCase))
        {
            Snackbar.Add(string.Format(Loc["avatarDialog.unsupportedFileType"], string.Join(", ", AvatarConstants.AllowedExtensions)), Severity.Warning);
            Reset(); return;
        }

        if (file.Size > AvatarConstants.MaxFileSizeBytes)
        {
            Snackbar.Add(string.Format(Loc["avatarDialog.fileSizeExceeds"], AvatarConstants.MaxFileSizeBytes / 1024 / 1024), Severity.Warning);
            Reset(); return;
        }

        try
        {
            using var stream = file.OpenReadStream(AvatarConstants.MaxFileSizeBytes);
            using var ms     = new MemoryStream();
            await stream.CopyToAsync(ms);
            _fileBytes           = ms.ToArray();
            _previewImageDataUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(_fileBytes)}";
            _selectedFile        = file;
        }
        catch (Exception)
        {
            Snackbar.Add(Loc["avatarDialog.readFileFailed"], Severity.Error);
            Reset();
        }
    }

    private void Reset()
    {
        _selectedFile        = null;
        _previewImageDataUrl = null;
        _fileBytes           = null;
    }

    void Save()
    {
        var file = _selectedFile is not null && _fileBytes is not null
            ? new AvatarUploadResult(_selectedFile.Name, _selectedFile.ContentType, _fileBytes)
            : null;
        var colorChanged = _selectedColorIndex != CurrentColorIndex;

        if (file is null && !colorChanged) return;

        MudDialog.Close(DialogResult.Ok(new AvatarDialogResult(file, _selectedColorIndex, colorChanged)));
    }

    void RemovePhoto()
        => MudDialog.Close(DialogResult.Ok(new AvatarDialogResult(null, _selectedColorIndex, false, Removed: true)));

    void Cancel() => MudDialog.Cancel();
}



