@page "/settings/payrolllocations"
@using Microsoft.AspNetCore.Authorization
@using DZDDashboard.Client.Components.Pages.Admin.Dialogs
@using DZDDashboard.Client.Services
@using DZDDashboard.Common.DTOs
@attribute [Authorize(Roles = "Admin,HR")]

@inject IDialogService DialogServiceRef
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject OrganizationService OrgService

<div class="settings-detail-page">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
            <MudText Typo="Typo.h4">Payroll Locations</MudText>
            <MudButton StartIcon="@DzdIcons.ArrowLeft"
                       Color="Color.Primary"
                       Variant="Variant.Text"
                       @onclick="NavigateToSettings">
                Back to Settings
            </MudButton>
        </MudStack>

        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </MudStack>
        }
        else if (!_payrollLocations.Any())
        {
            <MudPaper Elevation="2" Class="pa-6 text-center">
                <MudIcon Icon="@DzdIcons.MapPin" Style="font-size: 3rem; color: var(--dzd-text-secondary);" />
                <MudText Typo="Typo.h6" Style="color: var(--dzd-text-tertiary)" Class="mt-3">No Payroll Locations Yet</MudText>
                <MudText Typo="Typo.body2" Style="color: var(--dzd-text-tertiary)" Class="mt-2">Create payroll locations to standardize where employees are registered for payroll processing.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="() => OpenPayrollLocationDialog()" Class="mt-4">
                    <MudIcon Icon="@DzdIcons.Plus" Class="mr-2" />
                    Create Payroll Location
                </MudButton>
            </MudPaper>
        }
        else
        {
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_searchTerm"
                              Placeholder="Search payroll locations..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@DzdIcons.Search"
                              Variant="Variant.Outlined"
                              Immediate="true" />

                <MudStack Spacing="2">
                    @foreach (var location in FilteredPayrollLocations)
                    {
                        <MudPaper Elevation="0" Class="payrolllocation-card pa-4">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@DzdIcons.MapPin" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle1" Class="location-name">@location.Name</MudText>
                                </MudStack>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIconButton Icon="@DzdIcons.Pencil"
                                                   Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="() => OpenPayrollLocationDialog(location)" />
                                    <MudIconButton Icon="@DzdIcons.Trash2"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="() => DeletePayrollLocation(location.Id)" />
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@DzdIcons.Plus"
                           OnClick="() => OpenPayrollLocationDialog()"
                           Style="width: auto; align-self: flex-end; margin-top: 12px;">
                    Add New Payroll Location
                </MudButton>
            </MudStack>
        }
    </MudContainer>
</div>

@code {
    private bool _loading = true;
    private List<PayrollLocationDto> _payrollLocations = new();
    private string _searchTerm = string.Empty;

    private void NavigateToSettings() => Nav.NavigateTo("/settings");

    private List<PayrollLocationDto> FilteredPayrollLocations
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_searchTerm))
                return _payrollLocations;

            return _payrollLocations
                .Where(p => p.Name?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _payrollLocations = await OrgService.GetPayrollLocationsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenPayrollLocationDialog(PayrollLocationDto? payrollLocation = null)
    {
        var parameters = new DialogParameters
        {
            ["PayrollLocation"] = payrollLocation ?? new PayrollLocationDto()
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialogTitle = payrollLocation is null || payrollLocation.Id == 0 ? "Add Payroll Location" : "Edit Payroll Location";
        var dialog = await DialogServiceRef.ShowAsync<PayrollLocationDialog>(dialogTitle, parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task DeletePayrollLocation(int id)
    {
        var result = await DialogServiceRef.ShowMessageBox("Delete Payroll Location",
            "Are you sure you want to delete this payroll location?",
            yesText: "Delete", cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await OrgService.DeletePayrollLocationAsync(id);
                await LoadData();
                Snackbar.Add("Payroll location deleted successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }

}
