@page "/settings/companies"
@using Microsoft.AspNetCore.Authorization
@using DZDDashboard.Common.DTOs.Organization
@using DZDDashboard.Client.Components.Pages.Admin.Dialogs
@using DZDDashboard.Client.Services
@attribute [Authorize(Roles = "Admin,HR")]

@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject OrganizationService OrgService
@inject IDialogService DialogServiceRef

<div class="settings-detail-page">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="settings-detail-header mb-6">
            <MudText Typo="Typo.h4" Class="settings-detail-title">Companies</MudText>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                       Color="Color.Primary"
                       Variant="Variant.Outlined"
                       @onclick="GoBack">
                Back to Settings
            </MudButton>
        </MudStack>

        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </MudStack>
        }
        else if (!_companies.Any())
        {
            <MudPaper Elevation="2" Class="pa-6 text-center">
                <MudIcon Icon="@Icons.Material.Filled.BusinessCenter" Style="font-size: 3rem; color: var(--dzd-text-secondary);" />
                <MudText Typo="Typo.h6" Class="mt-3" Style="color: var(--dzd-text-tertiary);">No Companies Yet</MudText>
                <MudText Typo="Typo.body2" Class="mt-2" Style="color: var(--dzd-text-tertiary);">Create your first company to get started building your organizational structure.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="() => OpenCompanyDialog()" Class="mt-4">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" />
                    Create Company
                </MudButton>
            </MudPaper>
        }
        else
        {
            <MudStack Spacing="3">
                <MudExpansionPanels MultiExpansion="true" Elevation="0">
                    @foreach (var company in _companies)
                    {
                        var departments = _departments.Where(d => d.CompanyId == company.Id).ToList();

                        <MudExpansionPanel Class="company-card">
                            <TitleContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle1">@company.Name</MudText>
                                </MudStack>
                            </TitleContent>

                            <ChildContent>
                                <MudStack Spacing="2">
                                    <MudStack Spacing="1">
                                        @if (!string.IsNullOrWhiteSpace(company.Description))
                                        {
                                            <MudText Typo="Typo.body2" Style="color: var(--dzd-text-tertiary);">@company.Description</MudText>
                                            <MudDivider Class="my-1" />
                                        }
                                        <MudText Typo="Typo.caption" Style="color: var(--dzd-text-tertiary);">Departments: @departments.Count</MudText>
                                    </MudStack>
                                    @if (departments.Any())
                                    {
                                        <MudList T="DepartmentDto" ReadOnly="true" Style="background: transparent;">
                                            @foreach (var dept in departments)
                                            {
                                                <MudListItem T="DepartmentDto" Class="department-item">
                                                    <MudText Typo="Typo.body2">@dept.Name</MudText>
                                                </MudListItem>
                                            }
                                        </MudList>
                                    }

                                    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1" Class="mt-2">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.Edit"
                                                   OnClick="() => OpenCompanyDialog(company)">
                                            Edit 
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Error"
                                                   StartIcon="@Icons.Material.Filled.Delete"
                                                   OnClick="() => DeleteCompany(company.Id)">
                                            Delete
                                        </MudButton>
                                    </MudStack>
                                </MudStack>
                            </ChildContent>
                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="() => OpenCompanyDialog()"
                           Style="width: auto; align-self: flex-end; margin-top: 12px;">
                    Add New Company
                </MudButton>
            </MudStack>
        }
    </MudContainer>
</div>

@code {
    private bool _loading = true;
    private List<CompanyDto> _companies = new();
    private List<DepartmentDto> _departments = new();
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }
    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _companies = await OrgService.GetCompaniesAsync();
            _departments = await OrgService.GetDepartmentsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

        private void GoBack() => Nav.NavigateTo("/settings");

    private async Task OpenCompanyDialog(CompanyDto? company = null)
    {
        var parameters = new DialogParameters { ["Company"] = company ?? new CompanyDto() };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialogTitle = company is null ? "Add Company" : "Edit Company";
        var dialog = await DialogServiceRef.ShowAsync<CompanyDialog>(dialogTitle, parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task DeleteCompany(int id)
    {
        var result = await DialogServiceRef.ShowMessageBox("Delete Company", 
            "Are you sure you want to delete this company? Associated departments will also be deleted.", 
            yesText: "Delete", cancelText: "Cancel");
        if (result == true)
        {
            try
            {
                await OrgService.DeleteCompanyAsync(id);
                await LoadData();
                Snackbar.Add("Company deleted successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }

}
