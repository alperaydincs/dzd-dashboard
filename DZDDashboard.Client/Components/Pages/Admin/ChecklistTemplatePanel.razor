@using DZDDashboard.Client.Services
@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@inject IChecklistTemplateClientService Templates
@inject ISnackbar Snackbar

<MudPaper Elevation="0" Class="pa-4">
    <MudText Typo="Typo.h6" Class="mb-1">İşe Alım / Çıkış Adımları</MudText>
    <MudText Typo="Typo.body2" Class="mb-4" Style="color:var(--dzd-text-secondary);">
        Hangi adımların istendiğini, zorunlu olup olmadığını ve belge gerektirip gerektirmediğini buradan ayarla.
    </MudText>

    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4" @bind-ActivePanelIndex="_tabIndex">
        <MudTabPanel Text="İşe Alım" />
        <MudTabPanel Text="İstifa" />
        <MudTabPanel Text="İşten Çıkarma" />
    </MudTabs>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudSimpleTable Dense="true" Hover="true" Class="mt-2">
            <thead>
                <tr>
                    <th>Sıra</th>
                    <th>Adım</th>
                    <th style="text-align:center;">Aktif</th>
                    <th style="text-align:center;">Zorunlu</th>
                    <th style="text-align:center;">Belge</th>
                    <th style="text-align:center;">Yan Hak</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in _items)
                {
                    <tr>
                        <td style="width:70px;">
                            <MudNumericField T="int" @bind-Value="t.Sequence" Variant="Variant.Text" Margin="Margin.Dense" HideSpinButtons="true" />
                        </td>
                        <td>
                            <MudTextField T="string" @bind-Value="t.Title" Variant="Variant.Text" Margin="Margin.Dense" />
                        </td>
                        <td style="text-align:center;"><MudSwitch T="bool" @bind-Value="t.IsEnabled" Color="Color.Primary" /></td>
                        <td style="text-align:center;"><MudSwitch T="bool" @bind-Value="t.IsRequired" Color="Color.Secondary" /></td>
                        <td style="text-align:center;"><MudSwitch T="bool" @bind-Value="t.RequiresDocument" Color="Color.Tertiary" /></td>
                        <td style="text-align:center;">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@(t.BenefitKind == ChecklistBenefitKinds.None ? Color.Default : Color.Info)">@BenefitLabel(t.BenefitKind)</MudChip>
                        </td>
                        <td style="white-space:nowrap; text-align:right;">
                            <MudIconButton Icon="@DzdIcons.Check" Color="Color.Success" Size="Size.Small" OnClick="@(() => SaveAsync(t))" />
                            <MudIconButton Icon="@DzdIcons.Trash2" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteAsync(t))" />
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>

        <MudPaper Elevation="0" Class="pa-3 mt-4" Style="border:1px dashed var(--mud-palette-lines-default);">
            <MudGrid Spacing="2" AlignItems="Center">
                <MudItem xs="12" sm="5">
                    <MudTextField T="string" Label="Yeni adım başlığı" @bind-Value="_newTitle" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="6" sm="2">
                    <MudSwitch T="bool" @bind-Value="_newRequired" Color="Color.Secondary" Label="Zorunlu" />
                </MudItem>
                <MudItem xs="6" sm="2">
                    <MudSwitch T="bool" @bind-Value="_newRequiresDocument" Color="Color.Tertiary" Label="Belge" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@DzdIcons.Plus" OnClick="AddAsync">Adım Ekle</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }
</MudPaper>

@code {
    private int _tabIndex;
    private bool _loading = true;
    private List<ChecklistStepTemplateDto> _items = [];

    private string _newTitle = string.Empty;
    private bool _newRequired = true;
    private bool _newRequiresDocument;

    private int _lastTab = -1;

    private string CurrentProcessType => _tabIndex switch
    {
        1 => TemplateProcessTypes.OffboardingResignation,
        2 => TemplateProcessTypes.OffboardingTermination,
        _ => TemplateProcessTypes.Onboarding
    };

    protected override async Task OnParametersSetAsync()
    {
        if (_tabIndex != _lastTab)
        {
            _lastTab = _tabIndex;
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _items = await Templates.GetAsync(CurrentProcessType) ?? [];
        _loading = false;
    }

    private async Task SaveAsync(ChecklistStepTemplateDto t)
    {
        var resp = await Templates.UpdateAsync(t.Id, t);
        if (!resp.IsSuccessStatusCode) { Snackbar.Add("Kaydedilemedi.", Severity.Error); return; }
        Snackbar.Add("Adım güncellendi.", Severity.Success);
    }

    private async Task DeleteAsync(ChecklistStepTemplateDto t)
    {
        var resp = await Templates.DeleteAsync(t.Id);
        if (!resp.IsSuccessStatusCode) { Snackbar.Add("Silinemedi.", Severity.Error); return; }
        _items.Remove(t);
    }

    private async Task AddAsync()
    {
        if (string.IsNullOrWhiteSpace(_newTitle)) { Snackbar.Add("Başlık zorunludur.", Severity.Warning); return; }
        var dto = new ChecklistStepTemplateDto
        {
            ProcessType      = CurrentProcessType,
            Title            = _newTitle.Trim(),
            Sequence         = (_items.Count == 0 ? 0 : _items.Max(i => i.Sequence)) + 1,
            IsRequired       = _newRequired,
            RequiresDocument = _newRequiresDocument,
            IsEnabled        = true,
            BenefitKind      = ChecklistBenefitKinds.None
        };
        var created = await Templates.CreateAsync(dto);
        if (created is null) { Snackbar.Add("Eklenemedi.", Severity.Error); return; }
        _items.Add(created);
        _newTitle = string.Empty;
        _newRequired = true;
        _newRequiresDocument = false;
        Snackbar.Add("Adım eklendi.", Severity.Success);
    }

    private static string BenefitLabel(string kind) => kind switch
    {
        ChecklistBenefitKinds.Bes => "BES",
        ChecklistBenefitKinds.Oss => "ÖSS",
        _                         => "—"
    };
}
