@using DZDDashboard.Common.DTOs
@using DZDDashboard.Client.Services
@using DZDDashboard.Client.Components.Shared
@using MudBlazor
@inherits CrudDialogBase
@inject IOrganizationClientService OrgService

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Company.Name" Label="Name" Required="true" Variant="Variant.Outlined" />
        <MudTextField @bind-Value="Company.Description" Label="Description" Lines="3" Class="mt-3" Variant="Variant.Outlined" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!IsFormValid || _saving)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public CompanyDto Company { get; set; } = new();

    private bool IsFormValid => !string.IsNullOrWhiteSpace(Company.Name);

    private async Task Submit() => await SaveAsync(
        Company.Id,
        () => OrgService.CreateCompanyAsync(Company),
        () => OrgService.UpdateCompanyAsync(Company),
        "company");
}
