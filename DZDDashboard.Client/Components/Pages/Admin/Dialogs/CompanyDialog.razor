@using DZDDashboard.Common.DTOs
@using DZDDashboard.Client.Services
@using DZDDashboard.Client.Components.Shared
@using MudBlazor
@inherits CrudDialogBase
@inject IOrganizationClientService OrgService

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Company.Name" Label="@Loc["dialogField.name"]" Required="true" Variant="Variant.Outlined" Immediate="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@Loc["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="@(!IsFormValid || _saving)">@Loc["common.save"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public CompanyDto Company { get; set; } = new();

    private bool IsFormValid => !string.IsNullOrWhiteSpace(Company.Name);

    private async Task Submit() => await SaveAsync(
        Company.Id,
        () => OrgService.CreateCompanyAsync(Company),
        () => OrgService.UpdateCompanyAsync(Company),
        Loc["employeeProfile.company"]);
}
