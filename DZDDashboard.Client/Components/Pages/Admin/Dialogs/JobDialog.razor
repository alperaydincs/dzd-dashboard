@using DZDDashboard.Common.DTOs
@using DZDDashboard.Client.Services
@using DZDDashboard.Client.Components.Shared
@using MudBlazor
@inherits CrudDialogBase
@inject IOrganizationClientService OrgService

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Job.Name" Label="@Loc["dialogField.title"]" Required="true" Immediate="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@Loc["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="@(!IsFormValid || _saving)">@Loc["common.save"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public JobDto Job { get; set; } = new();

    private bool IsFormValid => !string.IsNullOrWhiteSpace(Job.Name);

    private async Task Submit() => await SaveAsync(
        Job.Id,
        () => OrgService.CreateJobAsync(Job),
        () => OrgService.UpdateJobAsync(Job),
        Loc["settings.jobTitle"]);
}
