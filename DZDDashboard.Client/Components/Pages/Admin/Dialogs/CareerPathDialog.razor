@using DZDDashboard.Common.DTOs
@using MudBlazor
@inject DZDDashboard.Client.Localization.AppLocalizer Loc

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEdit ? Loc["careerPathDialog.editTitle"] : Loc["careerPathDialog.addTitle"])</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_name" Label="@Loc["careerPathDialog.nameLabel"]" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Required="true"
                          Placeholder="@(IsEdit ? "" : Loc["careerPathDialog.namePlaceholder"])" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">@Loc["common.cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(_name))">
            @(IsEdit ? Loc["common.save"] : Loc["careerPathDialog.create"])
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public CareerPathDto? ExistingPath { get; set; }

    private string _name = string.Empty;

    private bool IsEdit => ExistingPath is not null;

    protected override void OnInitialized()
    {
        if (ExistingPath is not null)
            _name = ExistingPath.Name;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;

        MudDialog.Close(DialogResult.Ok(new CareerPathDto
        {
            Id = ExistingPath?.Id ?? 0,
            Name = _name.Trim()
        }));
    }
}
