@using DZDDashboard.Common.DTOs
@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Add Career Path</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_name" Label="Career Path Name" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Required="true" Placeholder="e.g. Business Analyst Career Path" />

            <MudSelect @bind-Value="_selectedGroupId" Label="Employee Group" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Required="true" FullWidth="true">
                @foreach (var g in UserGroups)
                {
                    <MudSelectItem Value="@g.Id">@g.GroupName</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(_name) || _selectedGroupId == 0)">
            Create
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public List<UserGroupDto> UserGroups { get; set; } = new();

    private string _name = string.Empty;
    private int _selectedGroupId;

    protected override void OnInitialized()
    {
        if (UserGroups.Count > 0) _selectedGroupId = UserGroups[0].Id;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(_name) || _selectedGroupId == 0) return;
        MudDialog.Close(DialogResult.Ok(new CareerPathDto
        {
            Name = _name.Trim(),
            UserGroupId = _selectedGroupId
        }));
    }
}
