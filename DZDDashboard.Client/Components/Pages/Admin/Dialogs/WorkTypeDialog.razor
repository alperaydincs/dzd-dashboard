@using DZDDashboard.Common.DTOs
@using DZDDashboard.Client.Services
@using DZDDashboard.Client.Components.Shared
@using MudBlazor
@inherits CrudDialogBase
@inject IOrganizationClientService OrgService

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="WorkType.Name" Label="Name" Required="true" />
        <MudTextField @bind-Value="WorkType.Description" Label="Description" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!IsFormValid || _saving)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public WorkTypeDto WorkType { get; set; } = new();

    private bool IsFormValid => !string.IsNullOrWhiteSpace(WorkType.Name);

    private async Task Submit() => await SaveAsync(
        WorkType.Id,
        () => OrgService.CreateWorkTypeAsync(WorkType),
        () => OrgService.UpdateWorkTypeAsync(WorkType),
        "work type");
}
