@using DZDDashboard.Common.DTOs
@using DZDDashboard.Client.Services
@using DZDDashboard.Client.Components.Shared
@using MudBlazor
@inherits CrudDialogBase
@inject IOrganizationClientService OrgService

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Grade.Level" Label="@Loc["gradeDialog.level"]" Required="true" />
        <MudNumericField @bind-Value="Grade.MinSalary" Label="@Loc["gradeDialog.minSalary"]" Required="true" Format="N2" />
        <MudNumericField @bind-Value="Grade.MaxSalary" Label="@Loc["gradeDialog.maxSalary"]" Required="true" Format="N2" />
        <MudTextField @bind-Value="Grade.Currency" Label="@Loc["payment.currency"]" Required="true" />
        <MudSelect T="int?" Label="@Loc["gradeDialog.nextStep"]" @bind-Value="Grade.NextStepId">
            <MudSelectItem T="int?" Value="null">@Loc["careerAssignmentDialog.none"]</MudSelectItem>
            @foreach (var g in Grades)
            {
                if (g.Id != Grade.Id)
                {
                    <MudSelectItem T="int?" Value="@g.Id">@g.Level</MudSelectItem>
                }
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@Loc["common.cancel"]</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!IsFormValid || _saving)">@Loc["common.save"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public GradeDto Grade { get; set; } = new();
    [Parameter] public List<GradeDto> Grades { get; set; } = new();

    private bool IsFormValid =>
        !string.IsNullOrWhiteSpace(Grade.Level) &&
        !string.IsNullOrWhiteSpace(Grade.Currency) &&
        Grade.MinSalary >= 0 &&
        Grade.MaxSalary >= Grade.MinSalary;

    private async Task Submit() => await SaveAsync(
        Grade.Id,
        () => OrgService.CreateGradeAsync(Grade),
        () => OrgService.UpdateGradeAsync(Grade),
        Loc["employeeProfile.grade"]);
}
