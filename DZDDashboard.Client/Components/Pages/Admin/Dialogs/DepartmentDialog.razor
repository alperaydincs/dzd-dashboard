@using DZDDashboard.Common.DTOs
@using DZDDashboard.Client.Services
@using DZDDashboard.Client.Components.Shared
@using MudBlazor
@inherits CrudDialogBase
@inject IOrganizationClientService OrgService

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Department.Name" Label="Name" Required="true" Variant="Variant.Outlined"/>
        <MudSelect T="int?" Label="Company" @bind-Value="Department.CompanyId" Class="mt-3" Variant="Variant.Outlined">
            @foreach (var company in Companies)
            {
                <MudSelectItem Value="@((int?)company.Id)">@company.Name</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!IsFormValid || _saving)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public DepartmentDto Department { get; set; } = new();
    [Parameter] public List<CompanyDto> Companies { get; set; } = new();

    private bool IsFormValid =>
        !string.IsNullOrWhiteSpace(Department.Name) &&
        Department.CompanyId is > 0;

    private async Task Submit() => await SaveAsync(
        Department.Id,
        () => OrgService.CreateDepartmentAsync(Department),
        () => OrgService.UpdateDepartmentAsync(Department),
        "department",
        () =>
        {
            if (!IsFormValid)
            {
                Snackbar.Add("Name and Company are required", Severity.Warning);
                return false;
            }
            return true;
        });
}
