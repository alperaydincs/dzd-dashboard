@using DZDDashboard.Common.DTOs
@using DZDDashboard.Client.Services
@using DZDDashboard.Client.Components.Shared
@using MudBlazor
@inherits CrudDialogBase
@inject IOrganizationClientService OrgService

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="UserGroup.GroupName"
                      Label="@Loc["dialogField.groupName"]"
                      Variant="Variant.Outlined"
                      Required="true"
                      FullWidth="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@Loc["common.cancel"]</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!IsFormValid || _saving)">@Loc["common.save"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public UserGroupDto UserGroup { get; set; } = new();

    private bool IsFormValid => !string.IsNullOrWhiteSpace(UserGroup.GroupName);

    private async Task Submit() => await SaveAsync(
        UserGroup.Id,
        () => OrgService.CreateUserGroupAsync(UserGroup),
        () => OrgService.UpdateUserGroupAsync(UserGroup),
        Loc["settings.employeeGroupSingular"],
        () =>
        {
            if (!IsFormValid)
            {
                Snackbar.Add(Loc["settings.groupNameRequired"], Severity.Warning);
                return false;
            }
            return true;
        });
}
