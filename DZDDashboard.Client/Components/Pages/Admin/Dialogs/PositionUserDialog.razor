@using DZDDashboard.Client.Services
@using DZDDashboard.Client.Utils
@using DZDDashboard.Common.Utils


@inject IUserClientService UserService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">Edit Position & Assign User</MudText>
            
            
            <MudTextField @bind-Value="_positionName" 
                          Label="Position Name" 
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense" />
            
            <MudDivider />
            
            
            <MudText Typo="Typo.subtitle2" Style="margin-top: 8px;">User Assignment</MudText>
            
            @if (_users == null)
            {
                <MudProgressCircular Indeterminate="true" />
            }
            else if (_users.Count == 0)
            {
                <MudAlert Severity="Severity.Info">No users available</MudAlert>
            }
            else
            {
                @if (_totalUserCount > _users.Count)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                        Showing @_users.Count of @_totalUserCount users. Search is limited to this page.
                    </MudAlert>
                }
                @if (_currentUser != null)
                {
                    <div style="margin-bottom: 16px;">
                        <MudText Typo="Typo.caption" Style="opacity:.6;">Current Assignment</MudText>
                        <MudPaper Class="pa-3 d-flex justify-space-between align-center" Outlined="true" Style="background-color: #E3F2FD; border-color: #2196F3;">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudAvatar Size="Size.Medium" Color="@GetAvatarColor(_currentUser)">
                                    @AppFormatter.GetInitials(AppFormatter.BuildFullName(_currentUser.FirstName, _currentUser.LastName))
                                </MudAvatar>
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2" Style="font-weight:500;">@AppFormatter.BuildFullName(_currentUser.FirstName, _currentUser.LastName)</MudText>
                                    <MudText Typo="Typo.caption">@_currentUser.Email</MudText>
                                </MudStack>
                            </MudStack>
                            <MudButton 
                                Variant="Variant.Filled" 
                                Color="Color.Error" 
                                Size="Size.Small"
                                OnClick="RemoveUser">
                                Remove
                            </MudButton>
                        </MudPaper>
                    </div>
                }
                
                <div style="max-height: @UserListMaxHeight; overflow-y: auto;">
                    @if (AvailableUsers.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info">All users are assigned</MudAlert>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Style="opacity:.6; margin-bottom: 8px;">Available Users</MudText>
                        <MudStack Spacing="2">
                            @foreach (var user in AvailableUsers)
                        {
                            <MudPaper Class="pa-3 d-flex justify-space-between align-center" Outlined="true">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudAvatar Size="Size.Medium" Color="@GetAvatarColor(user)">
                                        @AppFormatter.GetInitials(AppFormatter.BuildFullName(user.FirstName, user.LastName))
                                    </MudAvatar>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2" Style="font-weight:500;">@AppFormatter.BuildFullName(user.FirstName, user.LastName)</MudText>
                                        <MudText Typo="Typo.caption">@user.Email</MudText>
                                    </MudStack>
                                </MudStack>
                                <MudButton 
                                    Variant="Variant.Filled" 
                                    Color="Color.Primary" 
                                    Size="Size.Small"
                                    OnClick="@(() => SelectUser(user))">
                                    Select
                                </MudButton>
                            </MudPaper>
                        }
                        </MudStack>
                    }
                </div>
            } @* end available users *@
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save"
                   Disabled="@(_users is null)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string PositionName { get; set; } = string.Empty;
    [Parameter] public int? CurrentUserId { get; set; }

    private const int    UserListPageSize  = 200;
    private const string UserListMaxHeight = "300px";

    private string _positionName  = string.Empty;
    private List<UserSummaryDto>? _users;
    private int                   _totalUserCount;
    private UserSummaryDto?       _currentUser;
    private UserSummaryDto?       _originalUser;
    private UserSummaryDto?       _selectedUser;
    private bool                  _removeRequested;

    private List<UserSummaryDto> AvailableUsers => _users?
        .Where(u => !u.OrganizationPositionId.HasValue && u.Id != CurrentUserId)
        .OrderBy(u => u.FirstName)
        .ThenBy(u => u.LastName)
        .ToList() ?? [];

    protected override async Task OnInitializedAsync()
    {
        _positionName = PositionName;
        var paged = await UserService.GetAllUsersAsync(pageSize: UserListPageSize);
        _users          = paged?.Items?.ToList() ?? [];
        _totalUserCount = paged?.TotalCount ?? 0;
        if (CurrentUserId.HasValue)
        {
            _currentUser  = _users.FirstOrDefault(u => u.Id == CurrentUserId.Value);
            _originalUser = _currentUser;
        }
    }

    private void SelectUser(UserSummaryDto user)
    {
        _selectedUser    = user;
        _currentUser     = user;
        _removeRequested = false;
    }

    private void RemoveUser()
    {
        _selectedUser    = null;
        _currentUser     = null;
        _removeRequested = true;
    }

    public sealed record PositionUserDialogResult(string PositionName, UserSummaryDto? User);

    private void Save()
    {
        var userToSave = _removeRequested ? null : (_selectedUser ?? _originalUser);
        MudDialog.Close(DialogResult.Ok(new PositionUserDialogResult(_positionName, userToSave)));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private static Color GetAvatarColor(UserSummaryDto? user) => UiHelpers.GetAvatarColor(user);
}

