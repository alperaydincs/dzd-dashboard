@using DZDDashboard.Common.DTOs
@using DZDDashboard.Client.Services
@using DZDDashboard.Client.Components.Shared
@using MudBlazor
@inherits CrudDialogBase
@inject IOrganizationClientService OrgService

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_locationName"
                      Label="Location Name"
                      Variant="Variant.Outlined"
                      Required="true"
                      FullWidth="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!IsFormValid || _saving)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public PayrollLocationDto PayrollLocation { get; set; } = new();

    private string _locationName = string.Empty;
    private bool   _initialized;

    private bool IsFormValid => !string.IsNullOrWhiteSpace(_locationName);

    protected override void OnParametersSet()
    {
        if (_initialized) return;
        _initialized  = true;
        _locationName = PayrollLocation.Name ?? string.Empty;
    }

    private async Task Submit()
    {
        var dto = new PayrollLocationDto { Id = PayrollLocation.Id, Name = _locationName.Trim() };
        await SaveAsync(
            dto.Id,
            () => OrgService.CreatePayrollLocationAsync(dto),
            () => OrgService.UpdatePayrollLocationAsync(dto),
            "location",
            () =>
            {
                if (!IsFormValid)
                {
                    Snackbar.Add("Location name is required", Severity.Warning);
                    return false;
                }
                return true;
            });
    }
}
