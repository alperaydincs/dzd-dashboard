@using DZDDashboard.Common.DTOs
@using MudBlazor
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="4">
            <MudTextField @bind-Value="Team.Name" 
                          Label="Name" 
                          Variant="Variant.Outlined"
                          Required="true" />

            <MudSelect T="int?" 
                       Label="Company" 
                       @bind-Value="_selectedCompanyId"
                       Variant="Variant.Outlined"
                       Required="true">
                @foreach (var company in Companies)
                {
                    <MudSelectItem Value="@((int?)company.Id)">@company.Name</MudSelectItem>
                }
            </MudSelect>

            @if (_selectedCompanyId != null)
            {
                <MudSelect T="int?" 
                           Label="Department" 
                           @bind-Value="Team.DepartmentId"
                           Variant="Variant.Outlined"
                           Required="true">
                    @foreach (var dept in FilteredDepartments)
                    {
                        <MudSelectItem Value="@((int?)dept.Id)">@dept.Name</MudSelectItem>
                    }
                </MudSelect>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!IsFormValid)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public TeamDto Team { get; set; } = new();
    [Parameter] public List<CompanyDto> Companies { get; set; } = new();
    [Parameter] public List<DepartmentDto> Departments { get; set; } = new();

    private int? _selectedCompanyId;

    private List<DepartmentDto> FilteredDepartments =>
        _selectedCompanyId == null
            ? new List<DepartmentDto>()
            : Departments.Where(d => d.CompanyId == _selectedCompanyId).ToList();

    private bool IsFormValid =>
        !string.IsNullOrWhiteSpace(Team.Name) &&
        _selectedCompanyId != null &&
        Team.DepartmentId != null &&
        Team.DepartmentId > 0;

    protected override void OnInitialized()
    {
        if (Team.DepartmentId > 0)
        {
            var existingDepartment = Departments.FirstOrDefault(d => d.Id == Team.DepartmentId);
            if (existingDepartment != null)
            {
                _selectedCompanyId = existingDepartment.CompanyId;
            }
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(Team.Name))
        {
            Snackbar.Add("Name is required", Severity.Warning);
            return;
        }

        try
        {
            var client = HttpClientFactory.CreateClient("Api");
            if (Team.Id == 0)
            {
                await client.PostAsJsonAsync("api/organization/teams", Team);
            }
            else
            {
                await client.PutAsJsonAsync("api/organization/teams", Team);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving: {ex.Message}", Severity.Error);
        }
    }
}

