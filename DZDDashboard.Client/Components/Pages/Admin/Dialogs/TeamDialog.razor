@using DZDDashboard.Common.DTOs
@using DZDDashboard.Client.Services
@using DZDDashboard.Client.Components.Shared
@using MudBlazor
@inherits CrudDialogBase
@inject IOrganizationClientService OrgService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="4">
            <MudTextField @bind-Value="Team.Name" Label="@Loc["dialogField.name"]" Variant="Variant.Outlined" Required="true" />

            <MudSelect T="int?" Label="@Loc["employeeProfile.company"]" @bind-Value="_selectedCompanyId" Variant="Variant.Outlined" Required="true">
                @foreach (var company in Companies)
                {
                    <MudSelectItem Value="@((int?)company.Id)">@company.Name</MudSelectItem>
                }
            </MudSelect>

            @if (_selectedCompanyId != null)
            {
                <MudSelect T="int?" Label="@Loc["employeeProfile.department"]" @bind-Value="Team.DepartmentId" Variant="Variant.Outlined" Required="true">
                    @foreach (var dept in FilteredDepartments)
                    {
                        <MudSelectItem Value="@((int?)dept.Id)">@dept.Name</MudSelectItem>
                    }
                </MudSelect>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@Loc["common.cancel"]</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!IsFormValid || _saving)">@Loc["common.save"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public TeamDto Team { get; set; } = new();
    [Parameter] public List<CompanyDto> Companies { get; set; } = new();
    [Parameter] public List<DepartmentDto> Departments { get; set; } = new();

    private int? _selectedCompanyId;

    private List<DepartmentDto> FilteredDepartments =>
        _selectedCompanyId == null
            ? new List<DepartmentDto>()
            : Departments.Where(d => d.CompanyId == _selectedCompanyId).ToList();

    private bool IsFormValid =>
        !string.IsNullOrWhiteSpace(Team.Name) &&
        _selectedCompanyId != null &&
        Team.DepartmentId is > 0;

    protected override void OnInitialized()
    {
        if (Team.DepartmentId > 0)
        {
            var dept = Departments.FirstOrDefault(d => d.Id == Team.DepartmentId);
            if (dept != null)
                _selectedCompanyId = dept.CompanyId;
        }
    }

    private async Task Submit() => await SaveAsync(
        Team.Id,
        () => OrgService.CreateTeamAsync(Team),
        () => OrgService.UpdateTeamAsync(Team),
        Loc["settings.team"],
        () =>
        {
            if (!IsFormValid)
            {
                Snackbar.Add(Loc["settings.nameDeptRequired"], Severity.Warning);
                return false;
            }
            return true;
        });
}
