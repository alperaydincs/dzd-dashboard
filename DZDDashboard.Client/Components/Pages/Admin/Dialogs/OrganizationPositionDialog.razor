@using MudBlazor
@inject DZDDashboard.Client.Localization.AppLocalizer Loc

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="@Loc["dialogField.name"]" Required="true" Immediate="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@Loc["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="@(string.IsNullOrWhiteSpace(_name))">@Loc["common.save"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    public record Result(string Name, int? ParentId);

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public int? ParentId { get; set; }

    private string _name = string.Empty;
    private int? _parentId;

    protected override void OnInitialized()
    {
        _name = Name;
        _parentId = ParentId;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;
        MudDialog.Close(DialogResult.Ok(new Result(_name.Trim(), _parentId)));
    }
}
