    // --- Inline add: Team ---

    private void StartAddTeam(int deptId)
    {
        _addingTeamForDeptId = deptId;
        _newTeamName = string.Empty;
        if (!_expandedDeptIds.Contains(deptId))
            _expandedDeptIds.Add(deptId);
    }

    private void CancelAddTeam()
    {
        _addingTeamForDeptId = null;
        _newTeamName = string.Empty;
    }

    private async Task OnTeamKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && _addingTeamForDeptId.HasValue)
            await SaveTeam(_addingTeamForDeptId.Value);
        else if (e.Key == "Escape")
            CancelAddTeam();
    }

    private async Task SaveTeam(int deptId)
    {
        if (string.IsNullOrWhiteSpace(_newTeamName)) return;
        var dto = new TeamDto { Name = _newTeamName.Trim(), DepartmentId = deptId };
        var response = await OrgService.CreateTeamAsync(dto);
        if (response.IsSuccessStatusCode)
        {
            _addingTeamForDeptId = null;
            _newTeamName = string.Empty;
            await LoadData();
            Snackbar.Add("Team created.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to create team.", Severity.Error);
        }
    }

