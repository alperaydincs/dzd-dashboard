@page "/settings"
@using Microsoft.AspNetCore.Authorization
@using DZDDashboard.Client.Components.OrgChart
@using DZDDashboard.Client.Components.Pages.Admin.Dialogs
@using DZDDashboard.Client.Components.Pages.Employees
@using DZDDashboard.Client.Services
@using DZDDashboard.Common.DTOs
@attribute [Authorize(Roles = "Admin,HR")]

@inject IDialogService DialogServiceRef
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject OrganizationService OrgService

<div class="settings-scope">
<MudContainer MaxWidth="MaxWidth.False" Class="settings-page mt-4">
    <MudStack Spacing="5">
        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </MudStack>
        }
        else
        {
            <MudStack Spacing="4">
                <div class="@($"settings-tabs-shell active-{_activeSettingsTabIndex}")" role="tablist" aria-label="Settings tabs">
                    <button type="button" class="settings-tab-segment" role="tab" aria-selected="@(_activeSettingsTabIndex == 0 ? "true" : "false")" @onclick="() => SetSettingsTab(0)">
                        <MudIcon Icon="@DzdIcons.Workflow" Size="Size.Small" Class="settings-tab-icon" />
                        Organization
                    </button>
                    <button type="button" class="settings-tab-segment" role="tab" aria-selected="@(_activeSettingsTabIndex == 1 ? "true" : "false")" @onclick="() => SetSettingsTab(1)">
                        <MudIcon Icon="@DzdIcons.SlidersHorizontal" Size="Size.Small" Class="settings-tab-icon" />
                        More Settings
                    </button>
                </div>

                @if (_activeSettingsTabIndex == 0)
                {
                    <MudStack Spacing="2">

                        <!-- ===== Company / Departments / Teams ===== -->
                        <div class="sacc-paper">
                            <div class="sacc-section-hdr" @onclick="() => _orgStructureExpanded = !_orgStructureExpanded">
                                <button type="button" class="sacc-toggle-btn" @onclick:stopPropagation="false">
                                    <MudIcon Icon="@(_orgStructureExpanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" />
                                </button>
                                <div class="sacc-icon-wrap sacc-blue">
                                    <MudIcon Icon="@DzdIcons.Building2" Size="Size.Small" />
                                </div>
                                <div class="sacc-title-group">
                                    <span class="sacc-title">Company / Departments / Teams</span>
                                    <span class="sacc-subtitle">@_companies.Count companies, @_departments.Count departments, @_teams.Count teams</span>
                                </div>
                            </div>

                            @if (_orgStructureExpanded)
                            {
                                <div class="sacc-body">
                                    @if (_addingCompany)
                                    {
                                        <div class="sacc-inline-row sacc-inline-add-row">
                                            <div class="sacc-icon-wrap sacc-blue">
                                                <MudIcon Icon="@DzdIcons.Building2" Size="Size.Small" />
                                            </div>
                                            <input class="sacc-inline-input"
                                                   value="@_newCompanyName"
                                                   @oninput="e => _newCompanyName = e.Value?.ToString() ?? string.Empty"
                                                   placeholder="Enter company name"
                                                   @onkeydown="OnCompanyKeyDown" />
                                            <button type="button" class="sacc-inline-confirm" @onclick="SaveCompany">
                                                <MudIcon Icon="@DzdIcons.Check" Size="Size.Small" />
                                            </button>
                                            <button type="button" class="sacc-inline-cancel" @onclick="CancelAddCompany">
                                                <MudIcon Icon="@DzdIcons.X" Size="Size.Small" />
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <button type="button" class="sacc-add-top-btn" @onclick="() => { _addingCompany = true; _newCompanyName = string.Empty; }">
                                            <MudIcon Icon="@DzdIcons.Plus" Size="Size.Small" Class="sacc-add-icon" /> Add Company
                                        </button>
                                    }

                                    @foreach (var company in _companies)
                                    {
                                        var companyCapture = company;
                                        var companyDepts = _departments.Where(d => d.CompanyId == company.Id).ToList();
                                        var isCompanyExpanded = _expandedCompanyIds.Contains(company.Id);

                                        <div class="sacc-item-block">
                                            <div class="sacc-row">
                                                <button type="button" class="sacc-toggle-btn" @onclick="() => ToggleCompany(companyCapture.Id)" @onclick:stopPropagation>
                                                    <MudIcon Icon="@(isCompanyExpanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" />
                                                </button>
                                                <div class="sacc-icon-wrap sacc-blue">
                                                    <MudIcon Icon="@DzdIcons.Building2" Size="Size.Small" />
                                                </div>
                                                <span class="sacc-row-name">@company.Name</span>
                                                <div class="sacc-row-actions">
                                                    <button type="button" class="sacc-pill-btn sacc-pill-blue" @onclick="() => StartAddDept(companyCapture.Id)" @onclick:stopPropagation>Add Department</button>
                                                    <button type="button" class="sacc-icon-btn" title="Edit" @onclick="() => OpenEditCompanyDialog(companyCapture)" @onclick:stopPropagation>
                                                        <MudIcon Icon="@DzdIcons.Pencil" Size="Size.Small" />
                                                    </button>
                                                    <button type="button" class="sacc-icon-btn sacc-icon-btn-danger" title="Delete" @onclick="() => DeleteCompany(companyCapture)" @onclick:stopPropagation>
                                                        <MudIcon Icon="@DzdIcons.Trash2" Size="Size.Small" />
                                                    </button>
                                                </div>
                                            </div>

                                            @if (isCompanyExpanded)
                                            {
                                                <div class="sacc-nested">
                                                    @foreach (var dept in companyDepts)
                                                    {
                                                        var deptCapture = dept;
                                                        var deptTeams = _teams.Where(t => t.DepartmentId == dept.Id).ToList();
                                                        var isDeptExpanded = _expandedDeptIds.Contains(dept.Id);

                                                        <div class="sacc-item-block">
                                                            <div class="sacc-row">
                                                                <button type="button" class="sacc-toggle-btn" @onclick="() => ToggleDept(deptCapture.Id)" @onclick:stopPropagation>
                                                                    <MudIcon Icon="@(isDeptExpanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" />
                                                                </button>
                                                                <div class="sacc-icon-wrap sacc-green">
                                                                    <MudIcon Icon="@DzdIcons.Building" Size="Size.Small" />
                                                                </div>
                                                                <span class="sacc-row-name">@dept.Name</span>
                                                                <div class="sacc-row-actions">
                                                                    <button type="button" class="sacc-pill-btn sacc-pill-green" @onclick="() => StartAddTeam(deptCapture.Id)" @onclick:stopPropagation>Add Team</button>
                                                                    <button type="button" class="sacc-icon-btn" title="Edit" @onclick="() => OpenEditDeptDialog(deptCapture)" @onclick:stopPropagation>
                                                                        <MudIcon Icon="@DzdIcons.Pencil" Size="Size.Small" />
                                                                    </button>
                                                                    <button type="button" class="sacc-icon-btn sacc-icon-btn-danger" title="Delete" @onclick="() => DeleteDepartment(deptCapture)" @onclick:stopPropagation>
                                                                        <MudIcon Icon="@DzdIcons.Trash2" Size="Size.Small" />
                                                                    </button>
                                                                </div>
                                                            </div>

                                                            @if (isDeptExpanded)
                                                            {
                                                                <div class="sacc-nested">
                                                                    @foreach (var team in deptTeams)
                                                                    {
                                                                        var teamCapture = team;
                                                                        <div class="sacc-row">
                                                                            <div class="sacc-row-spacer"></div>
                                                                            <div class="sacc-icon-wrap sacc-orange">
                                                                                <MudIcon Icon="@DzdIcons.Users" Size="Size.Small" />
                                                                            </div>
                                                                            <span class="sacc-row-name">@team.Name</span>
                                                                            <div class="sacc-row-actions">
                                                                                <button type="button" class="sacc-icon-btn" title="Edit" @onclick="() => OpenEditTeamDialog(teamCapture)">
                                                                                    <MudIcon Icon="@DzdIcons.Pencil" Size="Size.Small" />
                                                                                </button>
                                                                                <button type="button" class="sacc-icon-btn sacc-icon-btn-danger" title="Delete" @onclick="() => DeleteTeam(teamCapture)">
                                                                                    <MudIcon Icon="@DzdIcons.Trash2" Size="Size.Small" />
                                                                                </button>
                                                                            </div>
                                                                        </div>
                                                                    }

                                                                    @if (_addingTeamForDeptId == dept.Id)
                                                                    {
                                                                        <div class="sacc-inline-row">
                                                                            <div class="sacc-row-spacer"></div>
                                                                            <div class="sacc-icon-wrap sacc-orange">
                                                                                <MudIcon Icon="@DzdIcons.Users" Size="Size.Small" />
                                                                            </div>
                                                                            <input class="sacc-inline-input"
                                                                                   value="@_newTeamName"
                                                                                   @oninput="e => _newTeamName = e.Value?.ToString() ?? string.Empty"
                                                                                   placeholder="Enter team name"
                                                                                   @onkeydown="OnTeamKeyDown" />
                                                                            <button type="button" class="sacc-inline-confirm" @onclick="() => SaveTeam(deptCapture.Id)">
                                                                                <MudIcon Icon="@DzdIcons.Check" Size="Size.Small" />
                                                                            </button>
                                                                            <button type="button" class="sacc-inline-cancel" @onclick="CancelAddTeam">
                                                                                <MudIcon Icon="@DzdIcons.X" Size="Size.Small" />
                                                                            </button>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    }

                                                    @if (_addingDeptForCompanyId == company.Id)
                                                    {
                                                        <div class="sacc-inline-row">
                                                            <div class="sacc-toggle-placeholder"></div>
                                                            <div class="sacc-icon-wrap sacc-green">
                                                                <MudIcon Icon="@DzdIcons.Building" Size="Size.Small" />
                                                            </div>
                                                            <input class="sacc-inline-input"
                                                                   value="@_newDeptName"
                                                                   @oninput="e => _newDeptName = e.Value?.ToString() ?? string.Empty"
                                                                   placeholder="Enter department name"
                                                                   @onkeydown="e => OnDeptKeyDown(e, companyCapture.Id)" />
                                                            <button type="button" class="sacc-inline-confirm" @onclick="() => SaveDept(companyCapture.Id)">
                                                                <MudIcon Icon="@DzdIcons.Check" Size="Size.Small" />
                                                            </button>
                                                            <button type="button" class="sacc-inline-cancel" @onclick="CancelAddDept">
                                                                <MudIcon Icon="@DzdIcons.X" Size="Size.Small" />
                                                            </button>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <!-- ===== Job Titles ===== -->
                        <div class="sacc-paper">
                            <div class="sacc-section-hdr" @onclick="() => _jobTitlesExpanded = !_jobTitlesExpanded">
                                <button type="button" class="sacc-toggle-btn">
                                    <MudIcon Icon="@(_jobTitlesExpanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" />
                                </button>
                                <div class="sacc-icon-wrap sacc-purple">
                                    <MudIcon Icon="@DzdIcons.Briefcase" Size="Size.Small" />
                                </div>
                                <div class="sacc-title-group">
                                    <span class="sacc-title">Job Titles</span>
                                    <span class="sacc-subtitle">@_jobs.Count items</span>
                                </div>
                            </div>
                            @if (_jobTitlesExpanded)
                            {
                                <div class="sacc-body">
                                    @foreach (var job in _jobs)
                                    {
                                        var jobCapture = job;
                                        <div class="sacc-row sacc-flat-row">
                                            <div class="sacc-icon-wrap sacc-purple">
                                                <MudIcon Icon="@DzdIcons.Briefcase" Size="Size.Small" />
                                            </div>
                                            <span class="sacc-row-name">@job.Name</span>
                                            <div class="sacc-row-actions">
                                                <button type="button" class="sacc-icon-btn" title="Edit" @onclick="() => OpenEditJobDialog(jobCapture)">
                                                    <MudIcon Icon="@DzdIcons.Pencil" Size="Size.Small" />
                                                </button>
                                                <button type="button" class="sacc-icon-btn sacc-icon-btn-danger" title="Delete" @onclick="() => DeleteJob(jobCapture)">
                                                    <MudIcon Icon="@DzdIcons.Trash2" Size="Size.Small" />
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    <button type="button" class="sacc-add-bottom-btn" @onclick="OpenAddJobDialog">
                                        <MudIcon Icon="@DzdIcons.Plus" Size="Size.Small" Class="sacc-add-icon" /> Add Job Title
                                    </button>
                                </div>
                            }
                        </div>

                        <!-- ===== Employee Groups ===== -->
                        <div class="sacc-paper">
                            <div class="sacc-section-hdr" @onclick="() => _employeeGroupsExpanded = !_employeeGroupsExpanded">
                                <button type="button" class="sacc-toggle-btn">
                                    <MudIcon Icon="@(_employeeGroupsExpanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" />
                                </button>
                                <div class="sacc-icon-wrap sacc-red">
                                    <MudIcon Icon="@DzdIcons.UsersRound" Size="Size.Small" />
                                </div>
                                <div class="sacc-title-group">
                                    <span class="sacc-title">Employee Groups</span>
                                    <span class="sacc-subtitle">@_userGroups.Count items</span>
                                </div>
                            </div>
                            @if (_employeeGroupsExpanded)
                            {
                                <div class="sacc-body">
                                    @foreach (var group in _userGroups)
                                    {
                                        var groupCapture = group;
                                        <div class="sacc-row sacc-flat-row">
                                            <div class="sacc-icon-wrap sacc-red">
                                                <MudIcon Icon="@DzdIcons.UsersRound" Size="Size.Small" />
                                            </div>
                                            <span class="sacc-row-name">@group.GroupName</span>
                                            <div class="sacc-row-actions">
                                                <button type="button" class="sacc-icon-btn" title="Edit" @onclick="() => OpenEditUserGroupDialog(groupCapture)">
                                                    <MudIcon Icon="@DzdIcons.Pencil" Size="Size.Small" />
                                                </button>
                                                <button type="button" class="sacc-icon-btn sacc-icon-btn-danger" title="Delete" @onclick="() => DeleteUserGroup(groupCapture)">
                                                    <MudIcon Icon="@DzdIcons.Trash2" Size="Size.Small" />
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    <button type="button" class="sacc-add-bottom-btn" @onclick="OpenAddUserGroupDialog">
                                        <MudIcon Icon="@DzdIcons.Plus" Size="Size.Small" Class="sacc-add-icon" /> Add Employee Group
                                    </button>
                                </div>
                            }
                        </div>

                        <!-- ===== Payroll Locations ===== -->
                        <div class="sacc-paper">
                            <div class="sacc-section-hdr" @onclick="() => _payrollLocationsExpanded = !_payrollLocationsExpanded">
                                <button type="button" class="sacc-toggle-btn">
                                    <MudIcon Icon="@(_payrollLocationsExpanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" />
                                </button>
                                <div class="sacc-icon-wrap sacc-teal">
                                    <MudIcon Icon="@DzdIcons.MapPin" Size="Size.Small" />
                                </div>
                                <div class="sacc-title-group">
                                    <span class="sacc-title">Payroll Locations</span>
                                    <span class="sacc-subtitle">@_payrollLocations.Count items</span>
                                </div>
                            </div>
                            @if (_payrollLocationsExpanded)
                            {
                                <div class="sacc-body">
                                    @foreach (var loc in _payrollLocations)
                                    {
                                        var locCapture = loc;
                                        <div class="sacc-row sacc-flat-row">
                                            <div class="sacc-icon-wrap sacc-teal">
                                                <MudIcon Icon="@DzdIcons.MapPin" Size="Size.Small" />
                                            </div>
                                            <span class="sacc-row-name">@loc.Name</span>
                                            <div class="sacc-row-actions">
                                                <button type="button" class="sacc-icon-btn" title="Edit" @onclick="() => OpenEditPayrollLocationDialog(locCapture)">
                                                    <MudIcon Icon="@DzdIcons.Pencil" Size="Size.Small" />
                                                </button>
                                                <button type="button" class="sacc-icon-btn sacc-icon-btn-danger" title="Delete" @onclick="() => DeletePayrollLocation(locCapture)">
                                                    <MudIcon Icon="@DzdIcons.Trash2" Size="Size.Small" />
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    <button type="button" class="sacc-add-bottom-btn" @onclick="OpenAddPayrollLocationDialog">
                                        <MudIcon Icon="@DzdIcons.Plus" Size="Size.Small" Class="sacc-add-icon" /> Add Payroll Location
                                    </button>
                                </div>
                            }
                        </div>

                        <!-- ===== Work Types ===== -->
                        <div class="sacc-paper">
                            <div class="sacc-section-hdr" @onclick="() => _workTypesExpanded = !_workTypesExpanded">
                                <button type="button" class="sacc-toggle-btn">
                                    <MudIcon Icon="@(_workTypesExpanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" />
                                </button>
                                <div class="sacc-icon-wrap sacc-amber">
                                    <MudIcon Icon="@DzdIcons.Clock" Size="Size.Small" />
                                </div>
                                <div class="sacc-title-group">
                                    <span class="sacc-title">Work Types</span>
                                    <span class="sacc-subtitle">@_workTypes.Count items</span>
                                </div>
                            </div>
                            @if (_workTypesExpanded)
                            {
                                <div class="sacc-body">
                                    @foreach (var wt in _workTypes)
                                    {
                                        var wtCapture = wt;
                                        <div class="sacc-row sacc-flat-row">
                                            <div class="sacc-icon-wrap sacc-amber">
                                                <MudIcon Icon="@DzdIcons.Clock" Size="Size.Small" />
                                            </div>
                                            <span class="sacc-row-name">@wt.Name</span>
                                            <div class="sacc-row-actions">
                                                <button type="button" class="sacc-icon-btn" title="Edit" @onclick="() => OpenEditWorkTypeDialog(wtCapture)">
                                                    <MudIcon Icon="@DzdIcons.Pencil" Size="Size.Small" />
                                                </button>
                                                <button type="button" class="sacc-icon-btn sacc-icon-btn-danger" title="Delete" @onclick="() => DeleteWorkType(wtCapture)">
                                                    <MudIcon Icon="@DzdIcons.Trash2" Size="Size.Small" />
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    <button type="button" class="sacc-add-bottom-btn" @onclick="OpenAddWorkTypeDialog">
                                        <MudIcon Icon="@DzdIcons.Plus" Size="Size.Small" Class="sacc-add-icon" /> Add Work Type
                                    </button>
                                </div>
                            }
                        </div>

                        <!-- ===== Organization Tree Management ===== -->
                        <MudPaper Elevation="1" Class="pa-4">
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@DzdIcons.Network" Size="Size.Small" Class="mr-2" />
                                Organization Tree Management
                            </MudText>

                            @if (!_orgNodes.Any())
                            {
                                <MudStack Class="pa-4" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">No organization positions defined yet.</MudText>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenPositionAddDialog())">Add Root Position</MudButton>
                                </MudStack>
                            }
                            else
                            {
                                <div style="overflow-x: auto; padding-bottom: 20px;">
                                    <OrgChartTree Nodes="_orgNodes"
                                                  IsEditMode="true"
                                                  OnAddChild="AddChildNode"
                                                  OnEditNode="EditNode"
                                                  OnDeleteNode="DeleteNode" />
                                </div>
                            }
                        </MudPaper>

                    </MudStack>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">Additional settings tabs will be added here.</MudAlert>
                }
            </MudStack>
        }
    </MudStack>
</MudContainer>
</div>

@code {
    private bool _loading = true;
    private int _activeSettingsTabIndex = 0;

    // Org chart
    private List<OrgChartNodeItem> _orgNodes = new();
    private List<OrganizationPositionDto> _organizationPositions = new();

    // Data
    private List<CompanyDto> _companies = new();
    private List<DepartmentDto> _departments = new();
    private List<TeamDto> _teams = new();
    private List<PayrollLocationDto> _payrollLocations = new();
    private List<UserGroupDto> _userGroups = new();
    private List<JobDto> _jobs = new();
    private List<WorkTypeDto> _workTypes = new();

    // Section expand state
    private bool _orgStructureExpanded = false;
    private bool _jobTitlesExpanded = false;
    private bool _employeeGroupsExpanded = false;
    private bool _payrollLocationsExpanded = false;
    private bool _workTypesExpanded = false;

    // Nested expand state
    private HashSet<int> _expandedCompanyIds = new();
    private HashSet<int> _expandedDeptIds = new();

    // Inline add state
    private bool _addingCompany = false;
    private string _newCompanyName = string.Empty;
    private int? _addingDeptForCompanyId = null;
    private string _newDeptName = string.Empty;
    private int? _addingTeamForDeptId = null;
    private string _newTeamName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _organizationPositions = await OrgService.GetOrganizationPositionsAsync();
            BuildOrgChart(_organizationPositions);

            _companies = await OrgService.GetCompaniesAsync();
            _departments = await OrgService.GetDepartmentsAsync();
            _teams = await OrgService.GetTeamsAsync();
            _payrollLocations = await OrgService.GetPayrollLocationsAsync();
            _userGroups = await OrgService.GetUserGroupsAsync();
            _jobs = await OrgService.GetJobsAsync();
            _workTypes = await OrgService.GetWorkTypesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Settings data could not be loaded: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void SetSettingsTab(int index) => _activeSettingsTabIndex = index;

    // --- Toggle expand ---

    private void ToggleCompany(int id)
    {
        if (!_expandedCompanyIds.Add(id))
            _expandedCompanyIds.Remove(id);
    }

    private void ToggleDept(int id)
    {
        if (!_expandedDeptIds.Add(id))
            _expandedDeptIds.Remove(id);
    }

    // --- Inline add: Company ---

    private void CancelAddCompany()
    {
        _addingCompany = false;
        _newCompanyName = string.Empty;
    }

    private async Task OnCompanyKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveCompany();
        else if (e.Key == "Escape") CancelAddCompany();
    }

    private async Task SaveCompany()
    {
        if (string.IsNullOrWhiteSpace(_newCompanyName)) return;
        var dto = new CompanyDto { Name = _newCompanyName.Trim() };
        var response = await OrgService.CreateCompanyAsync(dto);
        if (response.IsSuccessStatusCode)
        {
            _addingCompany = false;
            _newCompanyName = string.Empty;
            await LoadData();
            Snackbar.Add("Company created.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to create company.", Severity.Error);
        }
    }

    // --- Inline add: Department ---

    private void StartAddDept(int companyId)
    {
        _addingDeptForCompanyId = companyId;
        _newDeptName = string.Empty;
        if (!_expandedCompanyIds.Contains(companyId))
            _expandedCompanyIds.Add(companyId);
    }

    private void CancelAddDept()
    {
        _addingDeptForCompanyId = null;
        _newDeptName = string.Empty;
    }

    private async Task OnDeptKeyDown(KeyboardEventArgs e, int companyId)
    {
        if (e.Key == "Enter") await SaveDept(companyId);
        else if (e.Key == "Escape") CancelAddDept();
    }

    private async Task SaveDept(int companyId)
    {
        if (string.IsNullOrWhiteSpace(_newDeptName)) return;
        var dto = new DepartmentDto { Name = _newDeptName.Trim(), CompanyId = companyId };
        var response = await OrgService.CreateDepartmentAsync(dto);
        if (response.IsSuccessStatusCode)
        {
            _addingDeptForCompanyId = null;
            _newDeptName = string.Empty;
            await LoadData();
            Snackbar.Add("Department created.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to create department.", Severity.Error);
        }
