@page "/settings"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,HR")]

<MudContainer MaxWidth="MaxWidth.False" Class="mt-6">
    <MudText Typo="Typo.h5" Class="mb-4">Settings</MudText>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
        <MudTabPanel Text="Organization Management">
            <OrganizationSettings />
        </MudTabPanel>
        <!-- Future settings tabs can be added here -->
    </MudTabs>
</MudContainer>
