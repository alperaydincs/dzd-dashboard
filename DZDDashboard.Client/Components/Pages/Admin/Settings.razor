@page "/settings"
@using Microsoft.AspNetCore.Authorization
@using DZDDashboard.Client.Components.OrgChart
@using DZDDashboard.Common.Constants
@attribute [Authorize(Policy = Roles.AdminOrHrPolicy)]

<div class="settings-scope">
<MudContainer MaxWidth="MaxWidth.False" Class="settings-page mt-4">
    <MudStack Spacing="5">
        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </MudStack>
        }
        else
        {
            <MudStack Spacing="4">
                <div class="@($"settings-tabs-shell settings-tabs-2 active-{_activeSettingsTabIndex}")" role="tablist" aria-label="Settings tabs">
                    <button type="button" class="settings-tab-segment" role="tab" aria-selected="@(_activeSettingsTabIndex == 0 ? "true" : "false")" @onclick="() => SetSettingsTab(0)">
                        <MudIcon Icon="@DzdIcons.Workflow" Size="Size.Small" Class="settings-tab-icon" />
                        @Loc["settings.tabOrganization"]
                    </button>
                    <button type="button" class="settings-tab-segment" role="tab" aria-selected="@(_activeSettingsTabIndex == 1 ? "true" : "false")" @onclick="() => SetSettingsTab(1)">
                        <MudIcon Icon="@DzdIcons.ChartNoAxesCombined" Size="Size.Small" Class="settings-tab-icon" />
                        @Loc["settings.tabCareerPaths"]
                    </button>
                </div>

                @if (_activeSettingsTabIndex == 1)
                {
                    <CareerPathManagementPanel />
                }
                else if (_activeSettingsTabIndex == 0)
                {
                    <MudStack Spacing="2">

                        <div class="settings-header">
                            <MudText Typo="Typo.h5" Class="settings-title">@Loc["settings.orgStructureTitle"]</MudText>
                            <MudText Typo="Typo.body2" Class="settings-subtitle">@Loc["settings.orgStructureSubtitle"]</MudText>
                        </div>

                        <div class="sacc-paper">
                            <div class="sacc-section-hdr" @onclick="() => _orgStructureExpanded = !_orgStructureExpanded">
                                <MudIconButton Icon="@(_orgStructureExpanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" Class="sacc-toggle-btn" OnClick="() => _orgStructureExpanded = !_orgStructureExpanded" />
                                <div class="sacc-icon-wrap sacc-blue">
                                    <MudIcon Icon="@DzdIcons.Building2" Size="Size.Small" />
                                </div>
                                <div class="sacc-title-group">
                                    <span class="sacc-title">@Loc["settings.companyDeptTeam"]</span>
                                    <span class="sacc-subtitle">@string.Format(Loc["settings.orgSummary"], _companies.Count, _departments.Count, _teams.Count)</span>
                                </div>
                            </div>

                            @if (_orgStructureExpanded)
                            {
                                <div class="sacc-body">
                                    @if (_addingCompany)
                                    {
                                        <div class="sacc-inline-row sacc-inline-add-row">
                                            <div class="sacc-icon-wrap sacc-blue">
                                                <MudIcon Icon="@DzdIcons.Building2" Size="Size.Small" />
                                            </div>
                                            <input class="sacc-inline-input"
                                                   value="@_newCompanyName"
                                                   @oninput="e => _newCompanyName = e.Value?.ToString() ?? string.Empty"
                                                   placeholder="@Loc["settings.enterCompanyName"]"
                                                   @onkeydown="OnCompanyKeyDown" />
                                            <MudIconButton Icon="@DzdIcons.Check" Size="Size.Small" Color="Color.Success" Class="sacc-inline-confirm" OnClick="SaveCompany" />
                                            <MudIconButton Icon="@DzdIcons.X" Size="Size.Small" Color="Color.Error" Class="sacc-inline-cancel" OnClick="CancelAddCompany" />
                                        </div>
                                    }
                                    else
                                    {
                                        <MudButton Variant="Variant.Text" Color="Color.Dark" StartIcon="@DzdIcons.Plus" Class="sacc-add-top-btn" OnClick="@(() => { _addingCompany = true; _newCompanyName = string.Empty; })">@Loc["settings.addCompany"]</MudButton>
                                    }

                                    @foreach (var company in _companies)
                                    {
                                        var companyCapture = company;
                                        var companyDepts = _departments.Where(d => d.CompanyId == company.Id).ToList();
                                        var isCompanyExpanded = _expandedCompanyIds.Contains(company.Id);

                                        <div class="sacc-item-block">
                                            <div class="sacc-row" @onclick="() => ToggleCompany(companyCapture.Id)">
                                                <MudIconButton Icon="@(isCompanyExpanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" Class="sacc-toggle-btn" OnClick="() => ToggleCompany(companyCapture.Id)" />
                                                <div class="sacc-icon-wrap sacc-blue">
                                                    <MudIcon Icon="@DzdIcons.Building2" Size="Size.Small" />
                                                </div>
                                                <span class="sacc-row-name">@company.Name</span>
                                                <div class="sacc-row-actions" @onclick:stopPropagation="true">
                                                    <MudButton Variant="Variant.Text" Color="Color.Primary" Class="sacc-pill-btn sacc-pill-blue" OnClick="() => StartAddDept(companyCapture.Id)">@Loc["settings.addDepartment"]</MudButton>
                                                    <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" title="@Loc["common.edit"]" OnClick="() => OpenEditCompanyDialog(companyCapture)" />
                                                    <MudIconButton Icon="@DzdIcons.Trash2" Size="Size.Small" Color="Color.Error" title="@Loc["payment.delete"]" OnClick="() => DeleteCompany(companyCapture)" />
                                                </div>
                                            </div>

                                            @if (isCompanyExpanded)
                                            {
                                                <div class="sacc-nested">
                                                    @foreach (var dept in companyDepts)
                                                    {
                                                        var deptCapture = dept;
                                                        var deptTeams = _teams.Where(t => t.DepartmentId == dept.Id).ToList();
                                                        var isDeptExpanded = _expandedDeptIds.Contains(dept.Id);

                                                        <div class="sacc-item-block">
                                                            <div class="sacc-row" @onclick="() => ToggleDept(deptCapture.Id)">
                                                                <MudIconButton Icon="@(isDeptExpanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" Class="sacc-toggle-btn" OnClick="() => ToggleDept(deptCapture.Id)" />
                                                                <div class="sacc-icon-wrap sacc-green">
                                                                    <MudIcon Icon="@DzdIcons.Building" Size="Size.Small" />
                                                                </div>
                                                                <span class="sacc-row-name">@dept.Name</span>
                                                                <div class="sacc-row-actions" @onclick:stopPropagation="true">
                                                                    <MudButton Variant="Variant.Text" Color="Color.Secondary" Class="sacc-pill-btn sacc-pill-green" OnClick="() => StartAddTeam(deptCapture.Id)">@Loc["settings.addTeam"]</MudButton>
                                                                    <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" title="@Loc["common.edit"]" OnClick="() => OpenEditDeptDialog(deptCapture)" />
                                                                    <MudIconButton Icon="@DzdIcons.Trash2" Size="Size.Small" Color="Color.Error" title="@Loc["payment.delete"]" OnClick="() => DeleteDepartment(deptCapture)" />
                                                                </div>
                                                            </div>

                                                            @if (isDeptExpanded)
                                                            {
                                                                <div class="sacc-nested">
                                                                    @foreach (var team in deptTeams)
                                                                    {
                                                                        var teamCapture = team;
                                                                        <div class="sacc-row">
                                                                            <div class="sacc-row-spacer"></div>
                                                                            <div class="sacc-icon-wrap sacc-orange">
                                                                                <MudIcon Icon="@DzdIcons.Users" Size="Size.Small" />
                                                                            </div>
                                                                            <span class="sacc-row-name">@team.Name</span>
                                                                            <div class="sacc-row-actions">
                                                                                <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" title="@Loc["common.edit"]" OnClick="() => OpenEditTeamDialog(teamCapture)" />
                                                                                <MudIconButton Icon="@DzdIcons.Trash2" Size="Size.Small" Color="Color.Error" title="@Loc["payment.delete"]" OnClick="() => DeleteTeam(teamCapture)" />
                                                                            </div>
                                                                        </div>
                                                                    }

                                                                    @if (_addingTeamForDeptId == dept.Id)
                                                                    {
                                                                        <div class="sacc-inline-row">
                                                                            <div class="sacc-row-spacer"></div>
                                                                            <div class="sacc-icon-wrap sacc-orange">
                                                                                <MudIcon Icon="@DzdIcons.Users" Size="Size.Small" />
                                                                            </div>
                                                                            <input class="sacc-inline-input"
                                                                                   value="@_newTeamName"
                                                                                   @oninput="e => _newTeamName = e.Value?.ToString() ?? string.Empty"
                                                                                   placeholder="@Loc["settings.enterTeamName"]"
                                                                                   @onkeydown="OnTeamKeyDown" />
                                                                            <MudIconButton Icon="@DzdIcons.Check" Size="Size.Small" Color="Color.Success" Class="sacc-inline-confirm" OnClick="() => SaveTeam(deptCapture.Id)" />
                                                                            <MudIconButton Icon="@DzdIcons.X" Size="Size.Small" Color="Color.Error" Class="sacc-inline-cancel" OnClick="CancelAddTeam" />
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    }

                                                    @if (_addingDeptForCompanyId == company.Id)
                                                    {
                                                        <div class="sacc-inline-row">
                                                            <div class="sacc-toggle-placeholder"></div>
                                                            <div class="sacc-icon-wrap sacc-green">
                                                                <MudIcon Icon="@DzdIcons.Building" Size="Size.Small" />
                                                            </div>
                                                            <input class="sacc-inline-input"
                                                                   value="@_newDeptName"
                                                                   @oninput="e => _newDeptName = e.Value?.ToString() ?? string.Empty"
                                                                   placeholder="@Loc["settings.enterDeptName"]"
                                                                   @onkeydown="e => OnDeptKeyDown(e, companyCapture.Id)" />
                                                            <MudIconButton Icon="@DzdIcons.Check" Size="Size.Small" Color="Color.Success" Class="sacc-inline-confirm" OnClick="() => SaveDept(companyCapture.Id)" />
                                                            <MudIconButton Icon="@DzdIcons.X" Size="Size.Small" Color="Color.Error" Class="sacc-inline-cancel" OnClick="CancelAddDept" />
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="sacc-paper">
                            <div class="sacc-section-hdr" @onclick="() => _jobTitlesExpanded = !_jobTitlesExpanded">
                                <MudIconButton Icon="@(_jobTitlesExpanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" Class="sacc-toggle-btn" OnClick="() => _jobTitlesExpanded = !_jobTitlesExpanded" />
                                <div class="sacc-icon-wrap sacc-purple">
                                    <MudIcon Icon="@DzdIcons.Briefcase" Size="Size.Small" />
                                </div>
                                <div class="sacc-title-group">
                                    <span class="sacc-title">@Loc["settings.jobTitles"]</span>
                                    <span class="sacc-subtitle">@string.Format(Loc["settings.itemsCount"], _jobs.Count)</span>
                                </div>
                            </div>
                            @if (_jobTitlesExpanded)
                            {
                                <div class="sacc-body">
                                    @foreach (var job in _jobs)
                                    {
                                        var jobCapture = job;
                                        <div class="sacc-row sacc-flat-row">
                                            <div class="sacc-icon-wrap sacc-purple">
                                                <MudIcon Icon="@DzdIcons.Briefcase" Size="Size.Small" />
                                            </div>
                                            <span class="sacc-row-name">@job.Name</span>
                                            <div class="sacc-row-actions">
                                                <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" title="@Loc["common.edit"]" OnClick="() => OpenEditJobDialog(jobCapture)" />
                                                <MudIconButton Icon="@DzdIcons.Trash2" Size="Size.Small" Color="Color.Error" title="@Loc["payment.delete"]" OnClick="() => DeleteJob(jobCapture)" />
                                            </div>
                                        </div>
                                    }
                                    <MudButton Variant="Variant.Text" Color="Color.Dark" StartIcon="@DzdIcons.Plus" Class="sacc-add-bottom-btn" OnClick="OpenAddJobDialog">@Loc["settings.addJobTitle"]</MudButton>
                                </div>
                            }
                        </div>

                        <div class="sacc-paper">
                            <div class="sacc-section-hdr" @onclick="() => _payrollLocationsExpanded = !_payrollLocationsExpanded">
                                <MudIconButton Icon="@(_payrollLocationsExpanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" Class="sacc-toggle-btn" OnClick="() => _payrollLocationsExpanded = !_payrollLocationsExpanded" />
                                <div class="sacc-icon-wrap sacc-teal">
                                    <MudIcon Icon="@DzdIcons.MapPin" Size="Size.Small" />
                                </div>
                                <div class="sacc-title-group">
                                    <span class="sacc-title">@Loc["settings.payrollLocations"]</span>
                                    <span class="sacc-subtitle">@string.Format(Loc["settings.itemsCount"], _payrollLocations.Count)</span>
                                </div>
                            </div>
                            @if (_payrollLocationsExpanded)
                            {
                                <div class="sacc-body">
                                    @foreach (var loc in _payrollLocations)
                                    {
                                        var locCapture = loc;
                                        <div class="sacc-row sacc-flat-row">
                                            <div class="sacc-icon-wrap sacc-teal">
                                                <MudIcon Icon="@DzdIcons.MapPin" Size="Size.Small" />
                                            </div>
                                            <span class="sacc-row-name">@loc.Name</span>
                                            <div class="sacc-row-actions">
                                                <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" title="@Loc["common.edit"]" OnClick="() => OpenEditPayrollLocationDialog(locCapture)" />
                                                <MudIconButton Icon="@DzdIcons.Trash2" Size="Size.Small" Color="Color.Error" title="@Loc["payment.delete"]" OnClick="() => DeletePayrollLocation(locCapture)" />
                                            </div>
                                        </div>
                                    }
                                    <MudButton Variant="Variant.Text" Color="Color.Dark" StartIcon="@DzdIcons.Plus" Class="sacc-add-bottom-btn" OnClick="OpenAddPayrollLocationDialog">@Loc["settings.addPayrollLocation"]</MudButton>
                                </div>
                            }
                        </div>
                        <MudPaper Elevation="1" Class="pa-4">
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@DzdIcons.Network" Size="Size.Small" Class="mr-2" />
                                @Loc["settings.orgTreeManagement"]
                            </MudText>

                            @if (!_orgNodes.Any())
                            {
                                <MudStack Class="pa-4" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenPositionAddDialog())">@Loc["settings.addRootPosition"]</MudButton>
                                </MudStack>
                            }
                            else
                            {
                                <div style="overflow-x: auto; padding-bottom: 20px;">
                                    <OrgChartTree Nodes="_orgNodes"
                                                  IsEditMode="true"
                                                  OnAddChild="AddChildNode"
                                                  OnEditNode="EditNode"
                                                  OnDeleteNode="DeleteNode" />
                                </div>
                            }
                        </MudPaper>
                    </MudStack>
                }
            </MudStack>
        }
    </MudStack>
</MudContainer>
</div>
