@using DZDDashboard.Client.Services
@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@inject ILookupClientService Lookups
@inject ISnackbar Snackbar

@foreach (var cat in Categories)
{
    var catKey = cat.Key;
    var expanded = _expanded.Contains(catKey);
    var items = _data.TryGetValue(catKey, out var list) ? list : [];

    <div class="sacc-paper">
        <div class="sacc-section-hdr" @onclick="@(() => ToggleAsync(catKey))">
            <button type="button" class="sacc-toggle-btn">
                <MudIcon Icon="@(expanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" />
            </button>
            <div class="sacc-icon-wrap sacc-blue">
                <MudIcon Icon="@DzdIcons.Tag" Size="Size.Small" />
            </div>
            <div class="sacc-title-group">
                <span class="sacc-title">@cat.Label</span>
                <span class="sacc-subtitle">@items.Count items</span>
            </div>
        </div>

        @if (expanded)
        {
            <div class="sacc-body">
                @foreach (var v in items)
                {
                    var capture = v;
                    @if (_editingId == v.Id)
                    {
                        <div class="sacc-inline-row">
                            <input class="sacc-inline-input" @bind="_editBuffer" @bind:event="oninput"
                                   @onkeydown="@(e => OnEditKey(e, capture))" />
                            <button type="button" class="sacc-inline-confirm" @onclick="@(() => ConfirmEditAsync(capture))">
                                <MudIcon Icon="@DzdIcons.Check" Size="Size.Small" />
                            </button>
                            <button type="button" class="sacc-inline-cancel" @onclick="CancelEdit">
                                <MudIcon Icon="@DzdIcons.X" Size="Size.Small" />
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="sacc-row sacc-flat-row">
                            <div class="sacc-icon-wrap sacc-blue">
                                <MudIcon Icon="@DzdIcons.Tag" Size="Size.Small" />
                            </div>
                            <span class="sacc-row-name">@v.Value</span>
                            <div class="sacc-row-actions">
                                <button type="button" class="sacc-icon-btn" title="Edit" @onclick="@(() => StartEdit(capture))">
                                    <MudIcon Icon="@DzdIcons.Pencil" Size="Size.Small" />
                                </button>
                                <button type="button" class="sacc-icon-btn sacc-icon-btn-danger" title="Delete" @onclick="@(() => DeleteAsync(capture))">
                                    <MudIcon Icon="@DzdIcons.Trash2" Size="Size.Small" />
                                </button>
                            </div>
                        </div>
                    }
                }

                @if (_addingCategory == catKey)
                {
                    <div class="sacc-inline-row sacc-inline-add-row">
                        <input class="sacc-inline-input" placeholder="Yeni değer" @bind="_addBuffer" @bind:event="oninput"
                               @onkeydown="@(e => OnAddKey(e, catKey))" />
                        <button type="button" class="sacc-inline-confirm" @onclick="@(() => ConfirmAddAsync(catKey))">
                            <MudIcon Icon="@DzdIcons.Check" Size="Size.Small" />
                        </button>
                        <button type="button" class="sacc-inline-cancel" @onclick="CancelAdd">
                            <MudIcon Icon="@DzdIcons.X" Size="Size.Small" />
                        </button>
                    </div>
                }
                else
                {
                    <button type="button" class="sacc-add-bottom-btn" @onclick="@(() => StartAdd(catKey))">
                        <MudIcon Icon="@DzdIcons.Plus" Size="Size.Small" Class="sacc-add-icon" /> @cat.AddLabel
                    </button>
                }
            </div>
        }
    </div>
}

@code {
    private record Category(string Key, string Label, string AddLabel);

    private static readonly IReadOnlyList<Category> Categories =
    [
        new(LookupCategories.AdditionalPaymentType, "Ek Ödeme Tipi",   "Ek Ödeme Tipi Ekle"),
        new(LookupCategories.DeductionType,         "Kesinti Tipi",    "Kesinti Tipi Ekle"),
        new(LookupCategories.ContractType,          "Sözleşme Tipi",   "Sözleşme Tipi Ekle"),
        new(LookupCategories.WorkModel,             "Çalışma Modeli",  "Çalışma Modeli Ekle"),
        new(LookupCategories.EducationLevel,        "Eğitim Düzeyi",   "Eğitim Düzeyi Ekle"),
        new(LookupCategories.DependentType,         "Bağımlı Tipi",    "Bağımlı Tipi Ekle"),
    ];

    private readonly HashSet<string> _expanded = [];
    private readonly Dictionary<string, List<LookupValueDto>> _data = [];

    private int?    _editingId;
    private string  _editBuffer = string.Empty;
    private string? _addingCategory;
    private string  _addBuffer = string.Empty;

    private async Task ToggleAsync(string category)
    {
        if (!_expanded.Add(category))
        {
            _expanded.Remove(category);
            return;
        }
        if (!_data.ContainsKey(category))
            _data[category] = await Lookups.GetAllAsync(category) ?? [];
    }

    private void StartEdit(LookupValueDto v)
    {
        CancelAdd();
        _editingId = v.Id;
        _editBuffer = v.Value;
    }

    private void CancelEdit()
    {
        _editingId = null;
        _editBuffer = string.Empty;
    }

    private async Task OnEditKey(KeyboardEventArgs e, LookupValueDto v)
    {
        if (e.Key == "Enter") await ConfirmEditAsync(v);
        else if (e.Key == "Escape") CancelEdit();
    }

    private async Task ConfirmEditAsync(LookupValueDto v)
    {
        var value = _editBuffer.Trim();
        if (string.IsNullOrWhiteSpace(value)) { Snackbar.Add("Değer boş olamaz.", Severity.Warning); return; }

        var updated = v with { Value = value };
        var resp = await Lookups.UpdateAsync(v.Id, updated);
        if (!resp.IsSuccessStatusCode)
        {
            var detail = await ApiServiceBase.TryReadProblemDetailAsync(resp);
            Snackbar.Add(detail ?? "Kaydedilemedi.", Severity.Error);
            return;
        }
        v.Value = value;
        CancelEdit();
    }

    private void StartAdd(string category)
    {
        CancelEdit();
        _addingCategory = category;
        _addBuffer = string.Empty;
    }

    private void CancelAdd()
    {
        _addingCategory = null;
        _addBuffer = string.Empty;
    }

    private async Task OnAddKey(KeyboardEventArgs e, string category)
    {
        if (e.Key == "Enter") await ConfirmAddAsync(category);
        else if (e.Key == "Escape") CancelAdd();
    }

    private async Task ConfirmAddAsync(string category)
    {
        var value = _addBuffer.Trim();
        if (string.IsNullOrWhiteSpace(value)) { Snackbar.Add("Değer boş olamaz.", Severity.Warning); return; }

        var list = _data.TryGetValue(category, out var existing) ? existing : [];
        var dto = new LookupValueDto
        {
            Category = category,
            Value    = value,
            Sequence = (list.Count == 0 ? 0 : list.Max(i => i.Sequence)) + 1
        };
        var created = await Lookups.CreateAsync(dto);
        if (created is null) { Snackbar.Add("Eklenemedi (aynı değer olabilir).", Severity.Error); return; }

        if (!_data.ContainsKey(category)) _data[category] = [];
        _data[category].Add(created);
        CancelAdd();
    }

    private async Task DeleteAsync(LookupValueDto v)
    {
        var resp = await Lookups.DeleteAsync(v.Id);
        if (!resp.IsSuccessStatusCode) { Snackbar.Add("Silinemedi.", Severity.Error); return; }
        if (_data.TryGetValue(v.Category, out var list)) list.Remove(v);
    }
}
