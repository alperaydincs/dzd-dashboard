@using DZDDashboard.Client.Services
@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@inject ILookupClientService Lookups
@inject ISnackbar Snackbar

<div class="sacc-paper">
    <div class="sacc-section-hdr" @onclick="ToggleAsync">
        <button type="button" class="sacc-toggle-btn" @onclick:stopPropagation="false">
            <MudIcon Icon="@(_expanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" />
        </button>
        <div class="sacc-icon-wrap sacc-blue">
            <MudIcon Icon="@DzdIcons.SlidersHorizontal" Size="Size.Small" />
        </div>
        <div class="sacc-title-group">
            <span class="sacc-title">Seçim Listeleri (Lookup)</span>
            <span class="sacc-subtitle">Ödeme tipi, kesinti tipi, sözleşme tipi vb. açılır liste değerleri</span>
        </div>
    </div>

    @if (_expanded)
    {
        <div class="sacc-body">
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4" ActivePanelIndex="_tabIndex" ActivePanelIndexChanged="OnTabChanged">
                @foreach (var cat in Categories)
                {
                    <MudTabPanel Text="@cat.Label" />
                }
            </MudTabs>

            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else
            {
                <MudStack Spacing="2" Class="mt-2">
                    @foreach (var v in _items)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudNumericField T="int" @bind-Value="v.Sequence" Variant="Variant.Text" Margin="Margin.Dense" HideSpinButtons="true" Style="width:64px;" />
                            <MudTextField T="string" @bind-Value="v.Value" Variant="Variant.Text" Margin="Margin.Dense" Class="flex-grow-1" />
                            <MudSwitch T="bool" @bind-Value="v.IsActive" Color="Color.Primary" Label="Aktif" />
                            <MudIconButton Icon="@DzdIcons.Check" Color="Color.Success" Size="Size.Small" OnClick="@(() => SaveAsync(v))" />
                            <MudIconButton Icon="@DzdIcons.Trash2" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteAsync(v))" />
                        </MudStack>
                    }

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-2">
                        <MudTextField T="string" Label="Yeni değer" @bind-Value="_newValue" Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@DzdIcons.Plus" OnClick="AddAsync">Ekle</MudButton>
                    </MudStack>
                </MudStack>
            }
        </div>
    }
</div>

@code {
    private record Category(string Key, string Label);

    private static readonly IReadOnlyList<Category> Categories =
    [
        new(LookupCategories.AdditionalPaymentType, "Ek Ödeme Tipi"),
        new(LookupCategories.DeductionType,         "Kesinti Tipi"),
        new(LookupCategories.ContractType,          "Sözleşme Tipi"),
        new(LookupCategories.WorkModel,             "Çalışma Modeli"),
        new(LookupCategories.EducationLevel,        "Eğitim Düzeyi"),
        new(LookupCategories.DependentType,         "Bağımlı Tipi"),
    ];

    private bool _expanded;
    private int _tabIndex;
    private int _lastTab = -1;
    private bool _loaded;
    private bool _loading;
    private List<LookupValueDto> _items = [];
    private string _newValue = string.Empty;

    private string CurrentCategory => Categories[_tabIndex].Key;

    private async Task ToggleAsync()
    {
        _expanded = !_expanded;
        if (_expanded && !_loaded)
        {
            _loaded = true;
            _lastTab = _tabIndex;
            await LoadAsync();
        }
    }

    private async Task OnTabChanged(int index)
    {
        _tabIndex = index;
        _lastTab = index;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _items = await Lookups.GetAllAsync(CurrentCategory) ?? [];
        _loading = false;
    }

    private async Task SaveAsync(LookupValueDto v)
    {
        var resp = await Lookups.UpdateAsync(v.Id, v);
        if (!resp.IsSuccessStatusCode) { Snackbar.Add("Kaydedilemedi.", Severity.Error); return; }
        Snackbar.Add("Güncellendi.", Severity.Success);
    }

    private async Task DeleteAsync(LookupValueDto v)
    {
        var resp = await Lookups.DeleteAsync(v.Id);
        if (!resp.IsSuccessStatusCode) { Snackbar.Add("Silinemedi.", Severity.Error); return; }
        _items.Remove(v);
    }

    private async Task AddAsync()
    {
        if (string.IsNullOrWhiteSpace(_newValue)) { Snackbar.Add("Değer zorunludur.", Severity.Warning); return; }
        var dto = new LookupValueDto
        {
            Category = CurrentCategory,
            Value    = _newValue.Trim(),
            Sequence = (_items.Count == 0 ? 0 : _items.Max(i => i.Sequence)) + 1,
            IsActive = true
        };
        var created = await Lookups.CreateAsync(dto);
        if (created is null) { Snackbar.Add("Eklenemedi.", Severity.Error); return; }
        _items.Add(created);
        _newValue = string.Empty;
        Snackbar.Add("Eklendi.", Severity.Success);
    }
}
