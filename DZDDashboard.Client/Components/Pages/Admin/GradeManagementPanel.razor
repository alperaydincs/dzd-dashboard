@using DZDDashboard.Common.DTOs
@using DZDDashboard.Client.Theme

@if (_loading)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </MudStack>
}
else if (_loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="my-4">@_loadError</MudAlert>
}
else
{
    <MudStack Spacing="4">

        <div class="gm-header">
            <div>
                <MudText Typo="Typo.h5" Class="gm-title">@Loc["gradeManagement.careerPathSettings"]</MudText>
                <MudText Typo="Typo.body2" Class="gm-subtitle">@Loc["gradeManagement.careerPathSettingsSubtitle"]</MudText>
            </div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@DzdIcons.Plus" Disabled="@(_editPathId is not null)"
                       OnClick="OpenAddCareerPathDialog">
                @Loc["careerPathDialog.addTitle"]
            </MudButton>
        </div>

        @foreach (var path in _careerPaths)
        {
            var pathCapture = path;
            var isExpanded  = _expandedIds.Contains(path.Id);
            var isEditing   = IsEditingPath(path.Id);

            <MudPaper Elevation="0" Outlined="true" Class="gm-job-card">

                <div class="gm-job-hdr @(isExpanded ? "gm-job-hdr-expanded" : "")">
                    <MudIconButton Icon="@(isExpanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)"
                                   Size="Size.Small" Disabled="@isEditing"
                                   OnClick="() => TogglePath(pathCapture.Id)" />

                    <div class="gm-icon-wrap">
                        <MudIcon Icon="@DzdIcons.Route" Size="Size.Small" />
                    </div>

                    @if (isEditing)
                    {
                        <div class="gm-edit-hdr-fields">
                            <MudTextField @bind-Value="_editPathName" Placeholder="@Loc["gradeManagement.careerPathNamePlaceholder"]"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                          Class="gm-hdr-name" />
                            <MudSelect T="int" @bind-Value="_editPathGroupId" Placeholder="@Loc["gradeManagement.employeeGroupPlaceholder"]"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                                       Class="gm-hdr-group">
                                @foreach (var g in _userGroups)
                                {
                                    <MudSelectItem T="int" Value="@g.Id">@g.GroupName</MudSelectItem>
                                }
                            </MudSelect>
                        </div>
                        <div class="gm-job-actions">
                            <MudIconButton Icon="@DzdIcons.Check" Color="Color.Success" Size="Size.Small"
                                           title="@Loc["common.save"]" Disabled="@(!CanSavePath)" OnClick="SavePathEdit" />
                            <MudIconButton Icon="@DzdIcons.X" Color="Color.Error" Size="Size.Small"
                                           title="@Loc["common.cancel"]" Disabled="@_saving" OnClick="CancelPathEdit" />
                        </div>
                    }
                    else
                    {
                        <div class="gm-job-title-group" @onclick="() => TogglePath(pathCapture.Id)">
                            <span class="gm-job-name">@path.Name</span>
                            <span class="gm-job-meta">
                                @path.UserGroupName
                                <span class="gm-meta-sep">·</span>
                                @string.Format(Loc["gradeManagement.gradeLevelsCount"], path.Rules.Count)
                            </span>
                        </div>
                        <div class="gm-job-actions">
                            <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" title="@Loc["common.edit"]"
                                           Disabled="@(_editPathId is not null)" OnClick="() => BeginEditPath(pathCapture)" />
                            <MudIconButton Icon="@DzdIcons.Trash2" Color="Color.Error" Size="Size.Small" title="@Loc["payment.delete"]"
                                           Disabled="@(_editPathId is not null)" OnClick="() => DeleteCareerPath(pathCapture)" />
                        </div>
                    }
                </div>

                <MudCollapse Expanded="isExpanded">
                    @if (isEditing)
                    {
                        <div class="gm-table-wrap">
                        <MudTable Items="_editRules.OrderBy(r => r.Grade)" Hover="true" Bordered="true"
                                  Dense="true" Elevation="0" Class="gm-table" Breakpoint="Breakpoint.None">
                            <HeaderContent>
                                <MudTh Class="gm-th-grade">@Loc["gradeManagement.colGrade"]</MudTh>
                                <MudTh Class="gm-th-pos">@Loc["gradeManagement.colJobTitles"]</MudTh>
                                <MudTh Class="gm-th-dur">@Loc["gradeManagement.colMinTimeInRole"]</MudTh>
                                <MudTh Class="gm-th-dur">@Loc["gradeManagement.colMinExperience"]</MudTh>
                                <MudTh Class="gm-th-check">@Loc["gradeManagement.colManagerEval"]</MudTh>
                                <MudTh Class="gm-th-check">@Loc["gradeManagement.colAssessmentCenter"]</MudTh>
                                <MudTh Class="gm-th-check">@Loc["gradeManagement.colTechnicalInterview"]</MudTh>
                                <MudTh Class="gm-th-check">@Loc["gradeManagement.colCaseStudy"]</MudTh>
                                <MudTh Class="gm-th-check">@Loc["gradeManagement.colEnglishProficiency"]</MudTh>
                                <MudTh Class="gm-th-check">@Loc["gradeManagement.colCommitteeApproval"]</MudTh>
                                <MudTh>@Loc["gradeManagement.colProjectTarget"]</MudTh>
                                <MudTh Class="gm-th-actions"></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Loc["gradeManagement.colGrade"]" Class="gm-cell-center">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Class="gm-grade-badge">G@(context.Grade)</MudChip>
                                </MudTd>
                                <MudTd DataLabel="@Loc["gradeManagement.colJobTitles"]">
                                    <JobTitleSelector AllJobs="_allJobs" SelectedIds="context.JobIds" OnChanged="StateHasChanged" />
                                </MudTd>
                                <MudTd DataLabel="@Loc["gradeManagement.colMinTimeInRole"]">
                                    <div class="gm-edit-duration">
                                        <MudNumericField T="int?" @bind-Value="context.RetYears"  Min="0" Placeholder="@Loc["gradeManagement.yearPlaceholder"]" Variant="Variant.Outlined" Margin="Margin.Dense" Class="gm-cell-dur" />
                                        <MudNumericField T="int?" @bind-Value="context.RetMonths" Min="0" Placeholder="@Loc["gradeManagement.monthPlaceholder"]" Variant="Variant.Outlined" Margin="Margin.Dense" Class="gm-cell-dur" />
                                    </div>
                                </MudTd>
                                <MudTd DataLabel="@Loc["gradeManagement.colMinExperience"]">
                                    <div class="gm-edit-duration">
                                        <MudNumericField T="int?" @bind-Value="context.ExpYears"  Min="0" Placeholder="@Loc["gradeManagement.yearPlaceholder"]" Variant="Variant.Outlined" Margin="Margin.Dense" Class="gm-cell-dur" />
                                        <MudNumericField T="int?" @bind-Value="context.ExpMonths" Min="0" Placeholder="@Loc["gradeManagement.monthPlaceholder"]" Variant="Variant.Outlined" Margin="Margin.Dense" Class="gm-cell-dur" />
                                    </div>
                                </MudTd>
                                <MudTd Class="gm-cell-center"><MudCheckBox T="bool" @bind-Value="context.Manager"   Dense="true" /></MudTd>
                                <MudTd Class="gm-cell-center"><MudCheckBox T="bool" @bind-Value="context.Assess"    Dense="true" /></MudTd>
                                <MudTd Class="gm-cell-center"><MudCheckBox T="bool" @bind-Value="context.Tech"      Dense="true" /></MudTd>
                                <MudTd Class="gm-cell-center"><MudCheckBox T="bool" @bind-Value="context.Case"      Dense="true" /></MudTd>
                                <MudTd Class="gm-cell-center"><MudCheckBox T="bool" @bind-Value="context.English"   Dense="true" /></MudTd>
                                <MudTd Class="gm-cell-center"><MudCheckBox T="bool" @bind-Value="context.Committee" Dense="true" /></MudTd>
                                <MudTd DataLabel="@Loc["gradeManagement.colProjectTarget"]">
                                    <MudNumericField T="int?" @bind-Value="context.ProjectTarget" Min="0" Variant="Variant.Outlined" Margin="Margin.Dense" Class="gm-cell-target" />
                                </MudTd>
                                <MudTd Class="gm-cell-center">
                                    @if (IsLastRule(context))
                                    {
                                        <MudIconButton Icon="@DzdIcons.Trash2" Color="Color.Error" Size="Size.Small"
                                                       title="@Loc["gradeManagement.deleteLastGrade"]" Disabled="@_saving" OnClick="RemoveLastRuleRow" />
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                        </div>

                        <div class="gm-add-grade-row">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@DzdIcons.Plus" OnClick="AddRuleRow" Class="gm-add-grade-btn">
                                @Loc["gradeManagement.addGradeLevel"]
                            </MudButton>
                        </div>
                    }
                    else if (path.Rules.Count == 0)
                    {
                        <div class="gm-no-grades">@Loc["gradeManagement.noGradesYet"]</div>
                    }
                    else
                    {
                        <div class="gm-table-wrap">
                        <MudTable Items="path.Rules.OrderBy(r => r.Grade)" Hover="true" Bordered="true"
                                  Dense="true" Elevation="0" Class="gm-table" Breakpoint="Breakpoint.None">
                            <HeaderContent>
                                <MudTh Class="gm-th-grade">@Loc["gradeManagement.colGrade"]</MudTh>
                                <MudTh Class="gm-th-pos">@Loc["gradeManagement.colJobTitles"]</MudTh>
                                <MudTh Class="gm-th-dur">@Loc["gradeManagement.colMinTimeInRole"]</MudTh>
                                <MudTh Class="gm-th-dur">@Loc["gradeManagement.colMinExperience"]</MudTh>
                                <MudTh Class="gm-th-check">@Loc["gradeManagement.colManagerEval"]</MudTh>
                                <MudTh Class="gm-th-check">@Loc["gradeManagement.colAssessmentCenter"]</MudTh>
                                <MudTh Class="gm-th-check">@Loc["gradeManagement.colTechnicalInterview"]</MudTh>
                                <MudTh Class="gm-th-check">@Loc["gradeManagement.colCaseStudy"]</MudTh>
                                <MudTh Class="gm-th-check">@Loc["gradeManagement.colEnglishProficiency"]</MudTh>
                                <MudTh Class="gm-th-check">@Loc["gradeManagement.colCommitteeApproval"]</MudTh>
                                <MudTh>@Loc["gradeManagement.colProjectTarget"]</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Loc["gradeManagement.colGrade"]" Class="gm-cell-center">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Class="gm-grade-badge">G@(context.Grade)</MudChip>
                                </MudTd>
                                <MudTd DataLabel="@Loc["gradeManagement.colJobTitles"]">
                                    @if (context.PositionJobs.Count > 0)
                                    {
                                        <div class="gm-pos-chips">
                                            @foreach (var j in context.PositionJobs)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">@j.Name</MudChip>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="gm-empty-dash">—</span>
                                    }
                                </MudTd>
                                <MudTd DataLabel="@Loc["gradeManagement.colMinTimeInRole"]" Class="gm-cell-center">@FormatRetention(context)</MudTd>
                                <MudTd DataLabel="@Loc["gradeManagement.colMinExperience"]" Class="gm-cell-center">@FormatMinExperience(context)</MudTd>
                                <MudTd Class="gm-cell-center">@CheckIcon(context.ManagerPerformanceEvaluation)</MudTd>
                                <MudTd Class="gm-cell-center">@CheckIcon(context.AssessmentCenterApplication)</MudTd>
                                <MudTd Class="gm-cell-center">@CheckIcon(context.TechnicalInterview)</MudTd>
                                <MudTd Class="gm-cell-center">@CheckIcon(context.CaseStudy)</MudTd>
                                <MudTd Class="gm-cell-center">@CheckIcon(context.EnglishProficiency)</MudTd>
                                <MudTd Class="gm-cell-center">@CheckIcon(context.CommitteeApproval)</MudTd>
                                <MudTd DataLabel="@Loc["gradeManagement.colProjectTarget"]" Class="gm-cell-center">@(context.ProjectObjective?.ToString() ?? "—")</MudTd>
                            </RowTemplate>
                        </MudTable>
                        </div>
                    }
                </MudCollapse>
            </MudPaper>
        }

        @if (_careerPaths.Count == 0)
        {
            <MudPaper Elevation="0" Outlined="true" Class="gm-empty-state">
                <MudIcon Icon="@DzdIcons.Route" Size="Size.Large" Class="gm-empty-icon" />
                <MudText Typo="Typo.subtitle1" Class="gm-empty-text">@Loc["gradeManagement.noCareerPaths"]</MudText>
                <MudText Typo="Typo.body2" Class="gm-empty-sub">@Loc["gradeManagement.clickToAddCareerPath"]</MudText>
            </MudPaper>
        }

    </MudStack>
}

@code {
    private RenderFragment CheckIcon(bool value) => value
        ? @<MudIcon Icon="@DzdIcons.Check" Size="Size.Small" Class="gm-check-yes" />
        : @<MudIcon Icon="@DzdIcons.X"     Size="Size.Small" Class="gm-check-no"  />;
}
