@using DZDDashboard.Client.Components.Pages.Admin.Dialogs
@using DZDDashboard.Common.DTOs
@using DZDDashboard.Client.Theme

@if (_loading)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </MudStack>
}
else if (_loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="my-4">@_loadError</MudAlert>
}
else
{
    <MudStack Spacing="4">

        <!-- Header -->
        <div class="gm-header">
            <div>
                <div class="gm-title">Grade Management by Career Path</div>
                <div class="gm-subtitle">Define career paths per employee group, then add grade levels and assign job titles to each grade</div>
            </div>
            <button type="button" class="gm-add-btn" @onclick="OpenAddCareerPathDialog">
                <MudIcon Icon="@DzdIcons.Plus" Size="Size.Small" />
                Add Career Path
            </button>
        </div>

        <!-- Career Path Cards -->
        @foreach (var path in _careerPaths)
        {
            var pathCapture = path;
            var isExpanded = _expandedIds.Contains(path.Id);

            <div class="gm-job-card">
                <!-- Card Header -->
                <div class="gm-job-hdr @(isExpanded ? "gm-job-hdr-expanded" : "")">
                    <button type="button" class="gm-toggle-btn" @onclick="() => TogglePath(pathCapture.Id)">
                        <MudIcon Icon="@(isExpanded ? DzdIcons.ChevronDown : DzdIcons.ChevronRight)" Size="Size.Small" />
                    </button>
                    <div class="gm-icon-wrap">
                        <MudIcon Icon="@DzdIcons.Route" Size="Size.Small" />
                    </div>
                    <div class="gm-job-title-group" @onclick="() => TogglePath(pathCapture.Id)" style="cursor:pointer">
                        <span class="gm-job-name">@path.Name</span>
                        <span class="gm-job-meta">
                            @path.UserGroupName
                            <span class="gm-meta-sep">·</span>
                            @path.Rules.Count grade levels
                        </span>
                    </div>
                    <div class="gm-job-actions">
                        <button type="button" class="gm-icon-btn" title="Edit" @onclick="() => OpenEditCareerPathDialog(pathCapture)" @onclick:stopPropagation>
                            <MudIcon Icon="@DzdIcons.Pencil" Size="Size.Small" />
                        </button>
                        <button type="button" class="gm-icon-btn gm-icon-btn-danger" title="Delete" @onclick="() => DeleteCareerPath(pathCapture)" @onclick:stopPropagation>
                            <MudIcon Icon="@DzdIcons.Trash2" Size="Size.Small" />
                        </button>
                    </div>
                </div>

                <!-- Grade Table -->
                @if (isExpanded)
                {
                    @if (path.Rules.Count == 0)
                    {
                        <div class="gm-no-grades">
                            <span>No grade levels yet.</span>
                        </div>
                    }
                    else
                    {
                        <div class="gm-table-wrap">
                            <table class="gm-table">
                                <thead>
                                    <tr>
                                        <th class="gm-th gm-th-grade">Grade</th>
                                        <th class="gm-th gm-th-pos">Job Titles</th>
                                        <th class="gm-th">Min. Time in Role</th>
                                        <th class="gm-th">Min. Experience</th>
                                        <th class="gm-th gm-th-check">Manager Performance Eval.</th>
                                        <th class="gm-th gm-th-check">Assessment Center</th>
                                        <th class="gm-th gm-th-check">Technical Interview</th>
                                        <th class="gm-th gm-th-check">Case Study</th>
                                        <th class="gm-th gm-th-check">English Proficiency</th>
                                        <th class="gm-th gm-th-check">Committee Approval</th>
                                        <th class="gm-th">Project Target</th>
                                        <th class="gm-th gm-th-actions">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var rule in path.Rules.OrderBy(r => r.Grade))
                                    {
                                        var ruleCapture = rule;
                                        <tr class="gm-tr">
                                            <td class="gm-td gm-td-grade">
                                                <span class="gm-grade-badge">G@(rule.Grade)</span>
                                            </td>
                                            <td class="gm-td gm-td-pos">
                                                @if (rule.PositionJobs.Count > 0)
                                                {
                                                    <div class="gm-pos-chips">
                                                        @foreach (var j in rule.PositionJobs)
                                                        {
                                                            <span class="gm-pos-chip">@j.Name</span>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="gm-empty-dash">—</span>
                                                }
                                            </td>
                                            <td class="gm-td">@FormatRetention(rule)</td>
                                            <td class="gm-td">@FormatMinExperience(rule)</td>
                                            <td class="gm-td gm-td-check">@CheckIcon(rule.ManagerPerformanceEvaluation)</td>
                                            <td class="gm-td gm-td-check">@CheckIcon(rule.AssessmentCenterApplication)</td>
                                            <td class="gm-td gm-td-check">@CheckIcon(rule.TechnicalInterview)</td>
                                            <td class="gm-td gm-td-check">@CheckIcon(rule.CaseStudy)</td>
                                            <td class="gm-td gm-td-check">@CheckIcon(rule.EnglishProficiency)</td>
                                            <td class="gm-td gm-td-check">@CheckIcon(rule.CommitteeApproval)</td>
                                            <td class="gm-td">@(rule.ProjectObjective?.ToString() ?? "—")</td>
                                            <td class="gm-td gm-td-actions">
                                                <div class="gm-actions-wrap">
                                                    <button type="button" class="gm-icon-btn" title="Edit" @onclick="() => OpenEditRuleDialog(pathCapture, ruleCapture)">
                                                        <MudIcon Icon="@DzdIcons.Pencil" Size="Size.Small" />
                                                    </button>
                                                    <button type="button" class="gm-icon-btn gm-icon-btn-danger" title="Delete" @onclick="() => DeleteRule(ruleCapture)">
                                                        <MudIcon Icon="@DzdIcons.Trash2" Size="Size.Small" />
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <div class="gm-add-grade-row">
                        <button type="button" class="gm-add-grade-btn" @onclick="() => OpenAddRuleDialog(pathCapture)">
                            <MudIcon Icon="@DzdIcons.Plus" Size="Size.Small" />
                            Add Grade Level
                        </button>
                    </div>
                }
            </div>
        }

        @if (_careerPaths.Count == 0)
        {
            <div class="gm-empty-state">
                <MudIcon Icon="@DzdIcons.Route" Size="Size.Large" Class="gm-empty-icon" />
                <div class="gm-empty-text">No career paths defined yet.</div>
                <div class="gm-empty-sub">Click "+ Add Career Path" to get started.</div>
            </div>
        }

    </MudStack>
}

@code {
    // CheckIcon uses inline Razor syntax — must remain in .razor file; all other logic in .razor.cs
    private RenderFragment CheckIcon(bool value) => value
        ? @<MudIcon Icon="@DzdIcons.Check" Size="Size.Small" Class="gm-check-yes" />
        : @<MudIcon Icon="@DzdIcons.X"     Size="Size.Small" Class="gm-check-no"  />;
}
