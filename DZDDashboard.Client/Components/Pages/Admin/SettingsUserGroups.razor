@page "/settings/usergroups"
@using Microsoft.AspNetCore.Authorization
@using DZDDashboard.Common.DTOs
@using DZDDashboard.Common.DTOs.Users
@using DZDDashboard.Client.Components.Pages.Admin.Dialogs
@using DZDDashboard.Client.Services
@attribute [Authorize(Roles = "Admin,HR")]

@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject OrganizationService OrgService
@inject UserService UserService
@inject IDialogService DialogServiceRef

<div class="settings-detail-page">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 mb-4">
        <!-- Header with Back Button -->
        <MudStack Spacing="0" Class="settings-detail-header mb-6">
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" 
                      Color="Color.Primary" 
                      Variant="Variant.Text"
                          @onclick="GoBack"
                      Class="mb-3">
                Back to Settings
            </MudButton>
            <MudText Typo="Typo.h4" Class="settings-detail-title">User Groups</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">Manage custom user groups and their members</MudText>
        </MudStack>

        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </MudStack>
        }
        else if (!_userGroups.Any())
        {
            <MudPaper Elevation="2" Class="pa-6 text-center">
                <MudIcon Icon="@Icons.Material.Filled.PeopleOutline" Style="font-size: 3rem; color: var(--dzd-text-secondary);" />
                <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-3">No User Groups Yet</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">Create user groups to organize employees for special projects or functions across organizational boundaries.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="() => OpenUserGroupDialog()" Class="mt-4">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" />
                    Create User Group
                </MudButton>
            </MudPaper>
        }
        else
        {
            <MudStack Spacing="3">
                <!-- Add Button -->
                <MudButton Variant="Variant.Filled" 
                          Color="Color.Primary" 
                          StartIcon="@Icons.Material.Filled.Add"
                          OnClick="() => OpenUserGroupDialog()">
                    Add New User Group
                </MudButton>

                <!-- Search Bar -->
                <MudTextField @bind-Value="_searchTerm"
                            Placeholder="Search user groups..."
                            Adornment="Adornment.Start"
                            AdornmentIcon="@Icons.Material.Filled.Search"
                            Variant="Variant.Outlined"
                            Immediate="true" />

                <!-- User Groups List -->
                @foreach (var group in FilteredUserGroups)
                {
                    var groupUsers = _allUsers.Where(u => u.UserGroupId == group.Id).ToList();
                    
                    <MudPaper Elevation="2" Class="usergroup-card pa-4">
                        <!-- Group Header -->
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.h6" Class="group-name">
                                    <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Size="Size.Small" Class="mr-2" />
                                    @group.GroupName
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@groupUsers.Count member@(groupUsers.Count != 1 ? "s" : "")</MudText>
                            </MudStack>
                            <MudStack Row="true" Spacing="1">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                             Size="Size.Small"
                                             Color="Color.Primary"
                                             OnClick="() => OpenUserGroupDialog(group)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                             Size="Size.Small"
                                             Color="Color.Error"
                                             OnClick="() => DeleteUserGroup(group.Id)" />
                            </MudStack>
                        </MudStack>

                        <!-- Group Members Section -->
                        <MudDivider Class="my-3" />
                        
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-2" />
                                Members (@groupUsers.Count)
                            </MudText>

                            @if (!groupUsers.Any())
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-2">
                                    No members in this group yet.
                                </MudText>
                            }
                            else
                            {
                                <MudList T="UserDto" Style="background: transparent;">
                                    @foreach (var user in groupUsers.Take(5))
                                    {
                                        <MudListItem T="UserDto" Class="user-item">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="width: 100%;">
                                                <MudAvatar Size="Size.Small" Style="background-color: var(--dzd-primary); color: white;">
                                                    @GetUserInitials(user)
                                                </MudAvatar>
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2">@GetDisplayName(user)</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@user.Email</MudText>
                                                </MudStack>
                                            </MudStack>
                                        </MudListItem>
                                    }
                                </MudList>
                                
                                @if (groupUsers.Count > 5)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="pa-2">
                                        ... and @(groupUsers.Count - 5) more member@(groupUsers.Count - 5 != 1 ? "s" : "")
                                    </MudText>
                                }
                            }
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        }
    </MudContainer>
</div>

@code {
    private bool _loading = true;
    private List<UserGroupDto> _userGroups = new();
    private List<UserDto> _allUsers = new();
    private string _searchTerm = "";

    private List<UserGroupDto> FilteredUserGroups
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_searchTerm))
                return _userGroups;
            
            return _userGroups
                .Where(g => g.GroupName?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
                .ToList();
        }
    }

    private void GoBack() => Nav.NavigateTo("/settings");

    private string GetDisplayName(UserDto user)
    {
        return string.IsNullOrWhiteSpace(user.LastName) 
            ? user.FirstName ?? "Unknown"
            : $"{user.FirstName} {user.LastName}".Trim();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _userGroups = await OrgService.GetUserGroupsAsync();
            _allUsers = await UserService.GetAllUsersAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenUserGroupDialog(UserGroupDto? userGroup = null)
    {
        var parameters = new DialogParameters { ["UserGroup"] = userGroup ?? new UserGroupDto() };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogServiceRef.ShowAsync<UserGroupDialog>("Add User Group", parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task DeleteUserGroup(int id)
    {
        var result = await DialogServiceRef.ShowMessageBox("Delete User Group", 
            "Are you sure you want to delete this user group?", 
            yesText: "Delete", cancelText: "Cancel");
        if (result == true)
        {
            try
            {
                await OrgService.DeleteUserGroupAsync(id);
                await LoadData();
                Snackbar.Add("User group deleted successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }

    private string GetUserInitials(UserDto user)
    {
        var initials = "";
        if (!string.IsNullOrWhiteSpace(user.FirstName))
            initials += user.FirstName[0];
        if (!string.IsNullOrWhiteSpace(user.LastName))
            initials += user.LastName[0];
        return initials;
    }
}
