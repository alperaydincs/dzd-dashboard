@page "/settings/teams"
@using Microsoft.AspNetCore.Authorization
@using DZDDashboard.Client.Components.Pages.Admin.Dialogs
@using DZDDashboard.Client.Services
@attribute [Authorize(Roles = "Admin,HR")]

@inject IDialogService DialogServiceRef
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject OrganizationService OrgService

<div class="settings-detail-page">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
            <MudText Typo="Typo.h4">Teams</MudText>
            <MudButton StartIcon="@DzdIcons.ArrowLeft"
                       Color="Color.Primary"
                       Variant="Variant.Text"
                       @onclick="NavigateToSettings">
                Back to Settings
            </MudButton>
        </MudStack>

        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </MudStack>
        }
        else if (!_teams.Any())
        {
            <MudPaper Elevation="2" Class="pa-6 text-center">
                <MudIcon Icon="@DzdIcons.Users" Style="font-size: 3rem; color: var(--dzd-text-secondary);" />
                <MudText Typo="Typo.h6" Style="color: var(--dzd-text-tertiary)" Class="mt-3">No Teams Yet</MudText>
                @if (_departments.Any())
                {
                    <MudText Typo="Typo.body2" Style="color: var(--dzd-text-tertiary)" Class="mt-2">Create your first team to get started.</MudText>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               OnClick="OpenTeamDialogFromSelection"
                               Class="mt-4">
                        <MudIcon Icon="@DzdIcons.Plus" Class="mr-2" />
                        Add New Team
                    </MudButton>
                }
                else
                {
                    <MudText Typo="Typo.body2" Style="color: var(--dzd-text-tertiary)" Class="mt-2">Create a department first, then add teams to it.</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" @onclick="GoToDepartments" Class="mt-4">
                        <MudIcon Icon="@DzdIcons.Building" Class="mr-2" />
                        Go to Departments
                    </MudButton>
                }
            </MudPaper>
        }
        else
        {
            <MudStack Spacing="3">
                <MudAutocomplete T="CompanyDto"
                                 Value="_selectedCompany"
                                 ValueChanged="OnCompanyChanged"
                                 SearchFunc="SearchCompany"
                                 Label="Filter by Company"
                                 Dense="true"
                                 Clearable="true"
                                 ShowProgressIndicator="_loading"
                                 ToStringFunc="@(c => c == null ? "" : c.Name)"
                                 Variant="Variant.Outlined">
                </MudAutocomplete>

                <MudAutocomplete T="DepartmentDto"
                                 @bind-Value="_selectedDepartment"
                                 SearchFunc="SearchDepartment"
                                 Label="Filter by Department"
                                 Dense="true"
                                 Clearable="true"
                                 ShowProgressIndicator="_loading"
                                 ToStringFunc="@(d => d == null ? "" : d.Name)"
                                 Variant="Variant.Outlined">
                </MudAutocomplete>

                @foreach (var company in VisibleCompanies)
                {
                    var companyDepartments = FilteredDepartments
                        .Where(d => d.CompanyId == company.Id)
                        .OrderBy(d => d.Name)
                        .ToList();

                    if (!companyDepartments.Any())
                    {
                        continue;
                    }

                    <MudPaper Elevation="2" Class="team-card pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                            <MudText Typo="Typo.h6" Class="team-name">
                                <MudIcon Icon="@DzdIcons.Building2" Size="Size.Small" Class="mr-2" />
                                @company.Name
                            </MudText>
                            <MudText Typo="Typo.caption" Style="color: var(--dzd-text-tertiary)">
                                Departments: @companyDepartments.Count
                            </MudText>
                        </MudStack>

                        <MudExpansionPanels MultiExpansion="true" Elevation="0">
                            @foreach (var dept in companyDepartments)
                            {
                                var departmentTeams = FilteredTeams
                                    .Where(t => t.DepartmentId == dept.Id)
                                    .OrderBy(t => t.Name)
                                    .ToList();

                                <MudExpansionPanel Class="mb-2">
                                    <TitleContent>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width: 100%;">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudIcon Icon="@DzdIcons.Building" Size="Size.Small" />
                                                <MudText Typo="Typo.subtitle1">@dept.Name</MudText>
                                            </MudStack>
                                            <MudText Typo="Typo.caption" Style="color: var(--dzd-text-tertiary);" Class="mr-2">
                                                Teams: @departmentTeams.Count
                                            </MudText>
                                        </MudStack>
                                    </TitleContent>

                                    <ChildContent>
                                        <MudStack Spacing="2" Class="pt-1">
                                            @if (departmentTeams.Any())
                                            {
                                                <MudList T="TeamDto" ReadOnly="true" Style="background: transparent;">
                                                    @foreach (var team in departmentTeams)
                                                    {
                                                        <MudListItem T="TeamDto" Class="team-item">
                                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width: 100%;">
                                                                <MudText Typo="Typo.body2">@team.Name</MudText>
                                                                <MudStack Row="true" Spacing="1">
                                                                    <MudIconButton Icon="@DzdIcons.Pencil"
                                                                                   Size="Size.Small"
                                                                                   Color="Color.Primary"
                                                                                   OnClick="() => OpenTeamDialog(team)" />
                                                                    <MudIconButton Icon="@DzdIcons.Trash2"
                                                                                   Size="Size.Small"
                                                                                   Color="Color.Error"
                                                                                   OnClick="() => DeleteTeam(team.Id)" />
                                                                </MudStack>
                                                            </MudStack>
                                                        </MudListItem>
                                                    }
                                                </MudList>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Style="color: var(--dzd-text-tertiary);">
                                                    No teams found in this department.
                                                </MudText>
                                            }

                                            <MudButton Variant="Variant.Outlined"
                                                       Color="Color.Primary"
                                                       StartIcon="@DzdIcons.Plus"
                                                       OnClick="() => OpenTeamDialog(new TeamDto { DepartmentId = dept.Id })"
                                                       Style="width: auto; align-self: flex-start;">
                                                Add Team to @dept.Name
                                            </MudButton>
                                        </MudStack>
                                    </ChildContent>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    </MudPaper>
                }

                @if (!HasVisibleTeams)
                {
                    <MudPaper Elevation="1" Class="pa-4 text-center">
                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-tertiary);">
                            No teams match the selected filters.
                        </MudText>
                    </MudPaper>
                }

                @if (CanShowAddTeamButton)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@DzdIcons.Plus"
                               OnClick="OpenTeamDialogFromSelection"
                               Style="width: auto; align-self: flex-end; margin-top: 12px;">
                        Add New Team
                    </MudButton>
                }
            </MudStack>
        }
    </MudContainer>
</div>

@code {
    private bool _loading = true;
    private List<CompanyDto> _companies = new();
    private List<DepartmentDto> _departments = new();
    private List<TeamDto> _teams = new();
    private CompanyDto? _selectedCompany;
    private DepartmentDto? _selectedDepartment;

    private void NavigateToSettings() => Nav.NavigateTo("/settings");

    private List<DepartmentDto> FilteredDepartments =>
        _selectedCompany == null
            ? _departments
            : _departments.Where(d => d.CompanyId == _selectedCompany.Id).ToList();

    private List<TeamDto> FilteredTeams =>
        _selectedDepartment == null
            ? _teams
            : _teams.Where(t => t.DepartmentId == _selectedDepartment.Id).ToList();

    private List<CompanyDto> VisibleCompanies =>
        _selectedCompany == null
            ? _companies.OrderBy(c => c.Name).ToList()
            : _companies.Where(c => c.Id == _selectedCompany.Id).ToList();

    private bool CanShowAddTeamButton => FilteredDepartments.Any();

    private bool HasVisibleTeams =>
        VisibleCompanies.Any(company =>
            FilteredDepartments.Any(dept =>
                dept.CompanyId == company.Id && FilteredTeams.Any(team => team.DepartmentId == dept.Id)));

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _companies = await OrgService.GetCompaniesAsync();
            _departments = await OrgService.GetDepartmentsAsync();
            _teams = await OrgService.GetTeamsAsync();

            if (_selectedCompany != null)
            {
                _selectedCompany = _companies.FirstOrDefault(c => c.Id == _selectedCompany.Id);
            }

            if (_selectedDepartment != null)
            {
                _selectedDepartment = _departments.FirstOrDefault(d => d.Id == _selectedDepartment.Id);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<IEnumerable<CompanyDto>> SearchCompany(string value, CancellationToken cancellationToken = default)
    {
        var source = _companies.OrderBy(c => c.Name).ToList();

        if (string.IsNullOrWhiteSpace(value))
        {
            return await Task.FromResult(source);
        }

        return await Task.FromResult(source.Where(c => c.Name?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private async Task<IEnumerable<DepartmentDto>> SearchDepartment(string value, CancellationToken cancellationToken = default)
    {
        var source = FilteredDepartments.OrderBy(d => d.Name).ToList();

        if (string.IsNullOrWhiteSpace(value))
        {
            return await Task.FromResult(source);
        }

        return await Task.FromResult(source.Where(d => d.Name?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private void GoToDepartments() => Nav.NavigateTo("/settings/departments");

    private Task OnCompanyChanged(CompanyDto? company)
    {
        _selectedCompany = company;

        if (_selectedDepartment != null)
        {
            var departmentStillVisible = _departments.Any(d =>
                d.Id == _selectedDepartment.Id &&
                (_selectedCompany == null || d.CompanyId == _selectedCompany.Id));

            if (!departmentStillVisible)
            {
                _selectedDepartment = null;
            }
        }

        return Task.CompletedTask;
    }

    private Task OpenTeamDialogFromSelection()
    {
        TeamDto? model = _selectedDepartment is null
            ? null
            : new TeamDto { DepartmentId = _selectedDepartment.Id };

        return OpenTeamDialog(model);
    }

    private async Task OpenTeamDialog(TeamDto? team = null)
    {
        var availableDepartments = FilteredDepartments.Any() ? FilteredDepartments : _departments;
        var parameters = new DialogParameters
        {
            ["Team"] = team ?? new TeamDto(),
            ["Companies"] = _companies,
            ["Departments"] = availableDepartments
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialogTitle = team is null || team.Id == 0 ? "Add Team" : "Edit Team";
        var dialog = await DialogServiceRef.ShowAsync<TeamDialog>(dialogTitle, parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task DeleteTeam(int id)
    {
        var result = await DialogServiceRef.ShowMessageBox("Delete Team",
            "Are you sure you want to delete this team?",
            yesText: "Delete", cancelText: "Cancel");
        if (result == true)
        {
            try
            {
                await OrgService.DeleteTeamAsync(id);
                await LoadData();
                Snackbar.Add("Team deleted successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }
}



