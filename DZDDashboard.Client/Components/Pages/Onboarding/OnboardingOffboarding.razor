@page "/onboarding-offboarding"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Roles.AdminOrHrPolicy)]
@using DZDDashboard.Client.Components.Pages.Onboarding.Dialogs
@using DZDDashboard.Client.Components.Pages.Offboarding.Dialogs
@using DZDDashboard.Client.Services
@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@using DZDDashboard.Common.Utils
@inject IOnboardingClientService OnboardingService
@inject IOffboardingClientService OffboardingService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject DZDDashboard.Client.Localization.AppLocalizer Loc

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
    <MudStack Spacing="1" Class="mb-4">
        <MudText Typo="Typo.h4">@Loc["lifecyclePage.title"]</MudText>
        <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["lifecyclePage.subtitle"]</MudText>
    </MudStack>

    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="3" Class="pa-4"><MudText Typo="Typo.caption">@Loc["lifecyclePage.activeOnboarding"]</MudText><MudText Typo="Typo.h4">@_onboardingItems.Count(i => i.Status == ProcessStatuses.InProgress)</MudText></MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="3" Class="pa-4"><MudText Typo="Typo.caption">@Loc["lifecyclePage.activeOffboarding"]</MudText><MudText Typo="Typo.h4">@_offboardingItems.Count(i => i.Status == ProcessStatuses.InProgress)</MudText></MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="3" Class="pa-4"><MudText Typo="Typo.caption">@Loc["lifecyclePage.completedThisMonth"]</MudText><MudText Typo="Typo.h4">@CompletedThisMonth()</MudText></MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="3" Class="pa-4"><MudText Typo="Typo.caption">@Loc["lifecyclePage.pendingTasks"]</MudText><MudText Typo="Typo.h4">@PendingTaskCount()</MudText></MudPaper>
        </MudItem>
    </MudGrid>

    <div class="@($"view-tabs-shell active-{_activeTab}")" role="tablist">
        <button type="button" class="tab-segment" role="tab" @onclick="() => _activeTab = 0"><MudIcon Icon="@DzdIcons.UserPlus" Size="Size.Small" /> @Loc["nav.onboarding"]</button>
        <button type="button" class="tab-segment" role="tab" @onclick="() => _activeTab = 1"><MudIcon Icon="@DzdIcons.UserMinus" Size="Size.Small" /> @Loc["nav.offboarding"]</button>
    </div>

    <MudPaper Elevation="3" Class="pa-4 mt-3">
        @if (_activeTab == 0)
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h6">@Loc["lifecyclePage.onboardingList"]</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@DzdIcons.UserPlus" OnClick="StartOnboarding">@Loc["onboarding.start"]</MudButton>
            </MudStack>
            <MudTable Items="_onboardingItems" Hover="true" Loading="_loading" OnRowClick="@(args => OpenOnboarding(args.Item!.Id))" T="OnboardingListItemDto">
                <HeaderContent>
                    <MudTh>@Loc["lifecycle.employee"]</MudTh>
                    <MudTh>@Loc["lifecycle.startDate"]</MudTh>
                    <MudTh>@Loc["lifecycle.progress"]</MudTh>
                    <MudTh>@Loc["lifecycle.status"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.EmployeeName</MudTd>
                    <MudTd>@AppFormatter.FormatDate(context.StartDate)</MudTd>
                    <MudTd>@context.CompletedCount/@context.TotalCount</MudTd>
                    <MudTd><MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)" Variant="Variant.Text">@StatusLabel(context.Status)</MudChip></MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h6">@Loc["lifecyclePage.offboardingList"]</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@DzdIcons.UserMinus" OnClick="StartOffboarding">@Loc["nav.offboarding"]</MudButton>
            </MudStack>
            <MudTable Items="_offboardingItems" Hover="true" Loading="_loading" OnRowClick="@(args => OpenOffboarding(args.Item!.Id))" T="OffboardingListItemDto">
                <HeaderContent>
                    <MudTh>@Loc["lifecycle.employee"]</MudTh>
                    <MudTh>@Loc["offboarding.scenario"]</MudTh>
                    <MudTh>@Loc["lifecycle.progress"]</MudTh>
                    <MudTh>@Loc["lifecycle.status"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.EmployeeName</MudTd>
                    <MudTd>@context.TemplateName</MudTd>
                    <MudTd>@context.CompletedCount/@context.TotalCount</MudTd>
                    <MudTd><MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)" Variant="Variant.Text">@StatusLabel(context.Status)</MudChip></MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
</MudContainer>

<LifecycleProcessDrawer @bind-IsOpen="_drawerOpen" Process="_drawerProcess" Actions="_drawerActions" />

@code {
    private List<OnboardingListItemDto> _onboardingItems = [];
    private List<OffboardingListItemDto> _offboardingItems = [];
    private int _activeTab;
    private bool _loading = true;

    private bool _drawerOpen;
    private LifecycleProcessView? _drawerProcess;
    private LifecycleDrawerActions _drawerActions = new();
    private int? _openOnboardingId;
    private int? _openOffboardingId;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _onboardingItems = await OnboardingService.GetAllAsync() ?? [];
        _offboardingItems = await OffboardingService.GetAllAsync() ?? [];
        _loading = false;
    }

    private int CompletedThisMonth()
    {
        var now = DateTime.UtcNow;
        return _onboardingItems.Count(i => i.Status == ProcessStatuses.Completed && i.StartDate.Year == now.Year && i.StartDate.Month == now.Month)
             + _offboardingItems.Count(i => i.Status == ProcessStatuses.Completed && i.ExitDate.Year == now.Year && i.ExitDate.Month == now.Month);
    }

    private int PendingTaskCount()
        => _onboardingItems.Where(i => i.Status == ProcessStatuses.InProgress).Sum(i => i.TotalCount - i.CompletedCount)
         + _offboardingItems.Where(i => i.Status == ProcessStatuses.InProgress).Sum(i => i.TotalCount - i.CompletedCount);

    private async Task StartOnboarding()
    {
        var dialog = await DialogService.ShowAsync<StartOnboardingDialog>(Loc["onboarding.dialogTitle"]);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: StartOnboardingDto dto })
        {
            var created = await OnboardingService.StartAsync(dto);
            if (created is null) { Snackbar.Add(Loc["onboarding.startFailed"], Severity.Error); return; }
            Snackbar.Add(Loc["onboarding.startSuccess"], Severity.Success);
            await LoadAsync();
            await OpenOnboarding(created.Id);
        }
    }

    private async Task StartOffboarding()
    {
        var dialog = await DialogService.ShowAsync<StartOffboardingDialog>(Loc["startOffboardingDialog.title"]);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: StartOffboardingDto dto })
        {
            var created = await OffboardingService.StartAsync(dto);
            if (created is null) { Snackbar.Add(Loc["onboarding.startFailed"], Severity.Error); return; }
            Snackbar.Add(Loc["onboarding.startSuccess"], Severity.Success);
            await LoadAsync();
            await OpenOffboarding(created.Id);
        }
    }

    private async Task OpenOnboarding(int id)
    {
        _openOnboardingId = id;
        _openOffboardingId = null;
        var process = await OnboardingService.GetAsync(id);
        if (process is null) return;

        _drawerProcess = new LifecycleProcessView(process.Id, Loc["lifecycle.startDate"], process.EmployeeName, process.ManagerName, process.StartDate, StatusLabel(process.Status), process.Items, process.Documents, process.AuditLog);
        _drawerActions = new LifecycleDrawerActions
        {
            CompleteItem = async itemId => await ReloadOnboarding(await OnboardingService.CompleteItemAsync(id, itemId)),
            ReopenItem = async itemId => await ReloadOnboarding(await OnboardingService.ReopenItemAsync(id, itemId)),
            AddDocument = async dto => await ReloadOnboarding(await OnboardingService.AddDocumentAsync(id, dto)),
            UploadDocument = async (docId, file) =>
            {
                await using var stream = file.OpenReadStream(DocumentConstants.MaxFileSizeBytes);
                var resp = await OnboardingService.UploadDocumentAsync(id, docId, file.Name, file.ContentType, stream);
                if (resp.IsSuccessStatusCode) await ReloadOnboardingFetch(id);
                else Snackbar.Add(Loc["onboardingDetail.documentUploadFailed"], Severity.Error);
            },
            ApproveDocument = async docId => await ReloadOnboarding(await OnboardingService.ApproveDocumentAsync(id, docId)),
            RequestCorrection = async docId => await ReloadOnboarding(await OnboardingService.RequestDocumentCorrectionAsync(id, docId)),
            ReopenDocument = async docId => await ReloadOnboarding(await OnboardingService.ReopenDocumentAsync(id, docId)),
            DeleteDocument = async docId => await ReloadOnboarding(await OnboardingService.DeleteDocumentAsync(id, docId)),
            DownloadDocument = async docId =>
            {
                var bytes = await OnboardingService.DownloadDocumentAsync(id, docId);
                var doc = _drawerProcess?.Documents.FirstOrDefault(d => d.Id == docId);
                if (bytes is null) { Snackbar.Add(Loc["onboardingDetail.downloadFailed"], Severity.Error); return; }
                await JS.InvokeVoidAsync("dzdDownloadFile", doc?.FileName ?? "document", Convert.ToBase64String(bytes), "application/octet-stream");
            }
        };
        _drawerOpen = true;
    }

    private async Task OpenOffboarding(int id)
    {
        _openOffboardingId = id;
        _openOnboardingId = null;
        var process = await OffboardingService.GetAsync(id);
        if (process is null) return;

        _drawerProcess = new LifecycleProcessView(process.Id, Loc["offboarding.scenario"], process.EmployeeName, null, process.ExitDate, StatusLabel(process.Status), process.Items, process.Documents, process.AuditLog);
        _drawerActions = new LifecycleDrawerActions
        {
            CompleteItem = async itemId => await ReloadOffboarding(await OffboardingService.CompleteItemAsync(id, itemId)),
            ReopenItem = async itemId => await ReloadOffboarding(await OffboardingService.ReopenItemAsync(id, itemId)),
            AddDocument = async dto => await ReloadOffboarding(await OffboardingService.AddDocumentAsync(id, dto)),
            UploadDocument = async (docId, file) =>
            {
                await using var stream = file.OpenReadStream(DocumentConstants.MaxFileSizeBytes);
                var resp = await OffboardingService.UploadDocumentAsync(id, docId, file.Name, file.ContentType, stream);
                if (resp.IsSuccessStatusCode) await ReloadOffboardingFetch(id);
                else Snackbar.Add(Loc["onboardingDetail.documentUploadFailed"], Severity.Error);
            },
            ApproveDocument = async docId => await ReloadOffboarding(await OffboardingService.ApproveDocumentAsync(id, docId)),
            RequestCorrection = async docId => await ReloadOffboarding(await OffboardingService.RequestDocumentCorrectionAsync(id, docId)),
            ReopenDocument = async docId => await ReloadOffboarding(await OffboardingService.ReopenDocumentAsync(id, docId)),
            DeleteDocument = async docId => await ReloadOffboarding(await OffboardingService.DeleteDocumentAsync(id, docId)),
            DownloadDocument = async docId =>
            {
                var bytes = await OffboardingService.DownloadDocumentAsync(id, docId);
                var doc = _drawerProcess?.Documents.FirstOrDefault(d => d.Id == docId);
                if (bytes is null) { Snackbar.Add(Loc["onboardingDetail.downloadFailed"], Severity.Error); return; }
                await JS.InvokeVoidAsync("dzdDownloadFile", doc?.FileName ?? "document", Convert.ToBase64String(bytes), "application/octet-stream");
            }
        };
        _drawerOpen = true;
    }

    private async Task ReloadOnboarding(OnboardingProcessDto? process)
    {
        if (process is null) { Snackbar.Add(Loc["onboardingDetail.actionFailed"], Severity.Error); return; }
        _drawerProcess = new LifecycleProcessView(process.Id, Loc["lifecycle.startDate"], process.EmployeeName, process.ManagerName, process.StartDate, StatusLabel(process.Status), process.Items, process.Documents, process.AuditLog);
        await LoadAsync();
    }

    private async Task ReloadOnboardingFetch(int id) => await ReloadOnboarding(await OnboardingService.GetAsync(id));

    private async Task ReloadOffboarding(OffboardingProcessDto? process)
    {
        if (process is null) { Snackbar.Add(Loc["onboardingDetail.actionFailed"], Severity.Error); return; }
        _drawerProcess = new LifecycleProcessView(process.Id, Loc["offboarding.scenario"], process.EmployeeName, null, process.ExitDate, StatusLabel(process.Status), process.Items, process.Documents, process.AuditLog);
        await LoadAsync();
    }

    private async Task ReloadOffboardingFetch(int id) => await ReloadOffboarding(await OffboardingService.GetAsync(id));

    private static Color StatusColor(string status) => status switch
    {
        ProcessStatuses.Completed => Color.Success,
        ProcessStatuses.Cancelled => Color.Error,
        _                         => Color.Info
    };

    private string StatusLabel(string status) => status switch
    {
        ProcessStatuses.Completed => Loc["lifecycle.completed"],
        ProcessStatuses.Cancelled => Loc["lifecycle.cancelled"],
        _                         => Loc["lifecycle.inProgress"]
    };
}
