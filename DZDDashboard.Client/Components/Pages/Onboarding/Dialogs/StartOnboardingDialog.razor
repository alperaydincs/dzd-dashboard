@using DZDDashboard.Common.DTOs
@using DZDDashboard.Common.Utils
@using DZDDashboard.Client.Services
@inject ISnackbar Snackbar
@inject IUserClientService UserService
@inject DZDDashboard.Client.Localization.AppLocalizer Loc

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@DzdIcons.UserPlus" Color="Color.Primary" Size="Size.Small" />
            <MudText Typo="Typo.h6">@Loc["startOnboardingDialog.title"]</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="@Loc["startOnboardingDialog.firstName"]" @bind-Value="_dto.FirstName" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="@Loc["startOnboardingDialog.lastName"]" @bind-Value="_dto.LastName" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="@Loc["startOnboardingDialog.workEmail"]" @bind-Value="_dto.Email" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="@Loc["startOnboardingDialog.personalEmail"]" @bind-Value="_dto.PersonalEmail" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="@Loc["startOnboardingDialog.phone"]" @bind-Value="_dto.PhoneNumber" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker Label="@Loc["onboardingDetail.startDateLabel"]" Date="@_startDate" DateChanged="@(d => _startDate = d)"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" DateFormat="dd.MM.yyyy" />
            </MudItem>
            <MudItem xs="12">
                <MudAutocomplete T="UserSearchResultDto" Label="@Loc["startOnboardingDialog.managerOptional"]" @bind-Value="_manager"
                                 SearchFunc="SearchUsers" ToStringFunc="@(u => u is null ? string.Empty : AppFormatter.BuildFullName(u.FirstName, u.LastName))"
                                 Variant="Variant.Outlined" Margin="Margin.Dense" ResetValueOnEmptyText="true" Clearable="true" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">@Loc["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">@Loc["startOnboardingDialog.start"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private StartOnboardingDto _dto = new();
    private DateTime? _startDate = DateTime.Today;
    private UserSearchResultDto? _manager;

    private async Task<IEnumerable<UserSearchResultDto>> SearchUsers(string value, CancellationToken token)
        => await UserService.SearchUsersAsync(value) ?? [];

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(_dto.FirstName) || string.IsNullOrWhiteSpace(_dto.LastName))
        {
            Snackbar.Add(Loc["startOnboardingDialog.nameRequired"], Severity.Warning);
            return;
        }
        if (_startDate is null)
        {
            Snackbar.Add(Loc["startOnboardingDialog.startDateRequired"], Severity.Warning);
            return;
        }

        _dto.StartDate = _startDate.Value;
        _dto.ManagerId = _manager?.Id;
        MudDialog.Close(DialogResult.Ok(_dto));
    }

    private void Cancel() => MudDialog.Cancel();
}
