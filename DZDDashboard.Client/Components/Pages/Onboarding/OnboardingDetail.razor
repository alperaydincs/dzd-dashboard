@page "/onboarding/{Id:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Roles.AdminOrHrPolicy)]
@using DZDDashboard.Client.Components.Pages.Lifecycle
@using DZDDashboard.Client.Components.Pages.Onboarding.Dialogs
@using DZDDashboard.Client.Services
@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@using DZDDashboard.Common.Utils
@using Microsoft.AspNetCore.Components.Forms
@inject IOnboardingClientService OnboardingService
@inject IUserClientService UserService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject DZDDashboard.Client.Localization.AppLocalizer Loc

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudButton Variant="Variant.Text" StartIcon="@DzdIcons.ArrowLeft" OnClick="@(() => Nav.NavigateTo("/onboarding"))" Class="mb-2">@Loc["onboardingDetail.backToList"]</MudButton>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_process is null)
    {
        <MudAlert Severity="Severity.Error">@Loc["onboardingDetail.notFound"]</MudAlert>
    }
    else
    {
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                <MudText Typo="Typo.h5">@_process.EmployeeName</MudText>
                <MudChip T="string" Color="@StatusColor(_process.Status)" Variant="Variant.Text">@StatusLabel(_process.Status)</MudChip>
            </MudStack>

            <MudGrid Spacing="3">
                <MudItem xs="12" sm="5">
                    <MudDatePicker Label="@Loc["onboardingDetail.startDateLabel"]" Date="@_startDate" DateChanged="@(d => _startDate = d)"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="dd.MM.yyyy" />
                </MudItem>
                <MudItem xs="12" sm="5">
                    <MudAutocomplete T="UserSearchResultDto" Label="@Loc["onboardingDetail.managerLabel"]" @bind-Value="_manager"
                                     SearchFunc="SearchUsers" ToStringFunc="@(u => u is null ? string.Empty : AppFormatter.BuildFullName(u.FirstName, u.LastName))"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" OnClick="SaveHeader" Disabled="@(_process.Status != ProcessStatuses.InProgress)">@Loc["common.save"]</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudExpansionPanels Elevation="1" Class="mb-4">
            <MudExpansionPanel Expanded="true">
                <TitleContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@DzdIcons.FileText" Size="Size.Small" />
                        <MudText Typo="Typo.subtitle1">@string.Format(Loc["onboardingDetail.documentsTitle"], _documents.Count)</MudText>
                        @if (_documents.Any(d => d.ReviewStatus == DocumentReviewStatuses.Pending))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">@Loc["onboardingDetail.pendingReview"]</MudChip>
                        }
                    </MudStack>
                </TitleContent>
                <ChildContent>
                    @if (_documents.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["onboardingDetail.noDocuments"]</MudText>
                    }
                    else
                    {
                        <MudStack Spacing="2">
                            @foreach (var doc in _documents)
                            {
                                <MudPaper Elevation="0" Class="pa-3" Style="border:1px solid var(--mud-palette-lines-default);">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudIcon Icon="@DzdIcons.Paperclip" Size="Size.Small" />
                                            <MudText Typo="Typo.body2">@doc.FileName</MudText>
                                            <MudChip T="string" Size="Size.Small" Color="@ReviewColor(doc.ReviewStatus)" Variant="Variant.Text">@ReviewLabel(doc.ReviewStatus)</MudChip>
                                        </MudStack>
                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Success"
                                                       OnClick="@(() => ApproveDoc(doc))" Disabled="@(doc.ReviewStatus == DocumentReviewStatuses.Approved)">@Loc["onboardingDetail.approve"]</MudButton>
                                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                                                       OnClick="@(() => RequestCorrection(doc))">@Loc["onboardingDetail.requestCorrection"]</MudButton>
                                            <MudIconButton Icon="@DzdIcons.Download" Size="Size.Small" OnClick="@(() => DownloadDoc(doc))" />
                                            <MudIconButton Icon="@DzdIcons.Trash2" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteDoc(doc))" />
                                        </MudStack>
                                    </MudStack>
                                    @if (doc.ReviewStatus == DocumentReviewStatuses.NeedsCorrection && !string.IsNullOrWhiteSpace(doc.ReviewNote))
                                    {
                                        <MudText Typo="Typo.caption" Class="mt-1" Style="color:var(--mud-palette-warning);">@string.Format(Loc["onboardingDetail.reasonLabel"], doc.ReviewNote)</MudText>
                                    }
                                </MudPaper>
                            }
                        </MudStack>
                    }
                </ChildContent>
            </MudExpansionPanel>
        </MudExpansionPanels>

        <ChecklistPanel Items="_process.Items"
                        OnComplete="HandleComplete"
                        OnSkip="HandleSkip"
                        OnReopen="HandleReopen"
                        OnSaveNote="HandleSaveNote"
                        OnUploadDocument="HandleUploadDocument"
                        OnDeleteDocument="HandleDeleteDocument"
                        OnDownloadDocument="HandleDownloadDocument" />

        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@DzdIcons.Trash2"
                       OnClick="CancelOnboarding" Disabled="@(_process.Status == ProcessStatuses.Completed)">@Loc["onboardingDetail.cancelOnboarding"]</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@DzdIcons.CircleCheck"
                       OnClick="CompleteOnboarding" Disabled="@(!_process.CanComplete)">@Loc["onboardingDetail.completeOnboarding"]</MudButton>
        </MudStack>
    }
</MudContainer>

@code {
    [Parameter] public int Id { get; set; }

    private OnboardingProcessDto? _process;
    private List<UserDocumentDto> _documents = [];
    private bool _loading = true;

    private DateTime? _startDate;
    private UserSearchResultDto? _manager;

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _process = await OnboardingService.GetAsync(Id);
        if (_process is not null)
        {
            _startDate = _process.StartDate;
            _manager = _process.ManagerId is { } mid
                ? new UserSearchResultDto { Id = mid, FirstName = _process.ManagerName }
                : null;
            _documents = await UserService.GetUserDocumentsAsync(_process.UserId);
        }
        _loading = false;
    }

    private async Task ReloadDocsAsync()
    {
        if (_process is not null)
            _documents = await UserService.GetUserDocumentsAsync(_process.UserId);
    }

    private async Task<IEnumerable<UserSearchResultDto>> SearchUsers(string value, CancellationToken token)
        => await UserService.SearchUsersAsync(value) ?? [];

    private async Task SaveHeader()
    {
        if (_process is null || _startDate is null) return;
        var result = await OnboardingService.UpdateProcessAsync(Id, new UpdateOnboardingProcessDto { StartDate = _startDate.Value, ManagerId = _manager?.Id });
        if (result is null) { Snackbar.Add(Loc["onboardingDetail.saveFailed"], Severity.Error); return; }
        _process = result;
        Snackbar.Add(Loc["onboardingDetail.infoUpdated"], Severity.Success);
    }

    private async Task ApproveDoc(UserDocumentDto doc)
    {
        if (_process is null) return;
        var resp = await UserService.ReviewUserDocumentAsync(_process.UserId, doc.Id, new ReviewDocumentDto { Status = DocumentReviewStatuses.Approved });
        if (!resp.IsSuccessStatusCode) { Snackbar.Add(Loc["onboardingDetail.approveFailed"], Severity.Error); return; }
        await ReloadDocsAsync();
    }

    private async Task RequestCorrection(UserDocumentDto doc)
    {
        if (_process is null) return;
        var parameters = new DialogParameters<RequestCorrectionDialog> { { x => x.FileName, doc.FileName } };
        var dialog = await DialogService.ShowAsync<RequestCorrectionDialog>(Loc["onboardingDetail.requestCorrection"], parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: string note })
        {
            var resp = await UserService.ReviewUserDocumentAsync(_process.UserId, doc.Id, new ReviewDocumentDto { Status = DocumentReviewStatuses.NeedsCorrection, Note = note });
            if (!resp.IsSuccessStatusCode) { Snackbar.Add(Loc["onboardingDetail.actionFailed"], Severity.Error); return; }
            await ReloadDocsAsync();
        }
    }

    private async Task DownloadDoc(UserDocumentDto doc)
    {
        if (_process is null) return;
        var bytes = await UserService.DownloadUserDocumentAsync(_process.UserId, doc.Id);
        if (bytes is null) { Snackbar.Add(Loc["onboardingDetail.downloadFailed"], Severity.Error); return; }
        await JS.InvokeVoidAsync("dzdDownloadFile", doc.FileName, Convert.ToBase64String(bytes), doc.ContentType);
    }

    private async Task DeleteDoc(UserDocumentDto doc)
    {
        if (_process is null) return;
        var resp = await UserService.DeleteUserDocumentAsync(_process.UserId, doc.Id);
        if (!resp.IsSuccessStatusCode) { Snackbar.Add(Loc["onboardingDetail.deleteFailed"], Severity.Error); return; }
        await ReloadDocsAsync();
    }

    private async Task HandleComplete((int ItemId, CompleteChecklistItemDto Dto) e)
        => await Apply(await OnboardingService.CompleteItemAsync(Id, e.ItemId, e.Dto), Loc["onboardingDetail.stepCompleted"]);

    private async Task HandleSkip(int itemId)
        => await Apply(await OnboardingService.SkipItemAsync(Id, itemId), Loc["onboardingDetail.stepSkipped"]);

    private async Task HandleReopen(int itemId)
        => await Apply(await OnboardingService.ReopenItemAsync(Id, itemId), Loc["onboardingDetail.stepReopened"]);

    private async Task HandleSaveNote((int ItemId, string? Note) e)
    {
        var response = await OnboardingService.UpdateNoteAsync(Id, e.ItemId, new UpdateChecklistNoteDto { Note = e.Note });
        if (!response.IsSuccessStatusCode) { Snackbar.Add(Loc["onboardingDetail.noteSaveFailed"], Severity.Error); return; }
        await LoadAsync();
    }

    private async Task HandleUploadDocument((int ItemId, IBrowserFile File) e)
    {
        await using var stream = e.File.OpenReadStream(DocumentConstants.MaxFileSizeBytes);
        var response = await OnboardingService.UploadDocumentAsync(Id, e.ItemId, e.File.Name, e.File.ContentType, stream);
        if (!response.IsSuccessStatusCode)
        {
            var detail = await ApiServiceBase.TryReadProblemDetailAsync(response);
            Snackbar.Add(detail ?? Loc["onboardingDetail.documentUploadFailed"], Severity.Error);
            return;
        }
        Snackbar.Add(Loc["onboardingDetail.documentUploaded"], Severity.Success);
        await LoadAsync();
    }

    private async Task HandleDeleteDocument(int itemId)
        => await Apply(await OnboardingService.DeleteDocumentAsync(Id, itemId), Loc["onboardingDetail.documentDeleted"]);

    private async Task HandleDownloadDocument(int itemId)
    {
        var item = _process?.Items.FirstOrDefault(i => i.Id == itemId);
        var bytes = await OnboardingService.DownloadDocumentAsync(Id, itemId);
        if (bytes is null) { Snackbar.Add(Loc["onboardingDetail.downloadFailed"], Severity.Error); return; }
        await JS.InvokeVoidAsync("dzdDownloadFile", item?.DocumentFileName ?? Loc["onboardingDetail.evidenceFallbackName"], Convert.ToBase64String(bytes), "application/octet-stream");
    }

    private async Task CompleteOnboarding()
    {
        if (_process is null) return;
        var parameters = new DialogParameters<CompleteOnboardingDialog> { { x => x.Process, _process } };
        var dialog = await DialogService.ShowAsync<CompleteOnboardingDialog>(Loc["onboardingDetail.completeOnboarding"], parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            try
            {
                var done = await OnboardingService.CompleteProcessAsync(Id);
                if (done is null) { Snackbar.Add(Loc["onboardingDetail.completeFailed"], Severity.Error); return; }
                _process = done;
                Snackbar.Add(Loc["onboardingDetail.completed"], Severity.Success);
            }
            catch { Snackbar.Add(Loc["onboardingDetail.completeFailedSteps"], Severity.Error); }
        }
    }

    private async Task CancelOnboarding()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            Loc["onboardingDetail.cancelOnboarding"],
            Loc["onboardingDetail.cancelDialogMessage"],
            yesText: Loc["onboardingDetail.cancelYes"], cancelText: Loc["common.cancel"]);
        if (confirmed == true)
        {
            var resp = await OnboardingService.CancelAsync(Id);
            if (!resp.IsSuccessStatusCode) { Snackbar.Add(Loc["onboardingDetail.cancelFailed"], Severity.Error); return; }
            Snackbar.Add(Loc["onboardingDetail.cancelled"], Severity.Success);
            Nav.NavigateTo("/onboarding");
        }
    }

    private async Task Apply(OnboardingProcessDto? result, string successMessage)
    {
        if (result is null) { Snackbar.Add(Loc["onboardingDetail.actionFailed"], Severity.Error); await LoadAsync(); return; }
        _process = result;
        Snackbar.Add(successMessage, Severity.Success);
        StateHasChanged();
    }

    private static Color StatusColor(string status) => status switch
    {
        ProcessStatuses.Completed => Color.Success,
        ProcessStatuses.Cancelled => Color.Error,
        _                         => Color.Info
    };

    private string StatusLabel(string status) => status switch
    {
        ProcessStatuses.Completed => Loc["lifecycle.completed"],
        ProcessStatuses.Cancelled => Loc["lifecycle.cancelled"],
        _                         => Loc["lifecycle.inProgress"]
    };

    private static Color ReviewColor(string status) => status switch
    {
        DocumentReviewStatuses.Approved        => Color.Success,
        DocumentReviewStatuses.NeedsCorrection => Color.Warning,
        _                                      => Color.Default
    };

    private string ReviewLabel(string status) => status switch
    {
        DocumentReviewStatuses.Approved        => Loc["review.approved"],
        DocumentReviewStatuses.NeedsCorrection => Loc["review.needsCorrection"],
        _                                      => Loc["review.pending"]
    };
}
