@page "/onboarding/{Id:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Roles.AdminOrHrPolicy)]
@using DZDDashboard.Client.Components.Pages.Lifecycle
@using DZDDashboard.Client.Services
@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@using DZDDashboard.Common.Utils
@using Microsoft.AspNetCore.Components.Forms
@inject IOnboardingClientService OnboardingService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudButton Variant="Variant.Text" StartIcon="@DzdIcons.ArrowLeft" OnClick="@(() => Nav.NavigateTo("/onboarding"))" Class="mb-2">Onboarding listesine dön</MudButton>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_process is null)
    {
        <MudAlert Severity="Severity.Error">Süreç bulunamadı.</MudAlert>
    }
    else
    {
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h5">@_process.EmployeeName</MudText>
                    <MudText Typo="Typo.caption" Style="color:var(--dzd-text-secondary);">
                        Başlangıç: @AppFormatter.FormatDate(_process.StartDate)
                        @(string.IsNullOrWhiteSpace(_process.ManagerName) ? "" : $" · Yönetici: {_process.ManagerName}")
                    </MudText>
                </MudStack>
                <MudChip T="string" Color="@StatusColor(_process.Status)" Variant="Variant.Text">@StatusLabel(_process.Status)</MudChip>
            </MudStack>
            @if (_process.Status == ProcessStatuses.Completed && !string.IsNullOrWhiteSpace(_process.EmployeeSlug))
            {
                <MudButton Variant="Variant.Outlined" Class="mt-3" StartIcon="@DzdIcons.User"
                           OnClick="@(() => Nav.NavigateTo($"/employee/{_process.EmployeeSlug}"))">Çalışan profilini aç</MudButton>
            }
        </MudPaper>

        <ChecklistPanel Items="_process.Items"
                        OnComplete="HandleComplete"
                        OnSkip="HandleSkip"
                        OnReopen="HandleReopen"
                        OnSaveNote="HandleSaveNote"
                        OnUploadEvidence="HandleUploadEvidence"
                        EvidenceUrlFactory="@(itemId => OnboardingService.EvidenceUrl(Id, itemId))" />
    }
</MudContainer>

@code {
    [Parameter] public int Id { get; set; }

    private OnboardingProcessDto? _process;
    private bool _loading = true;

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _process = await OnboardingService.GetAsync(Id);
        _loading = false;
    }

    private async Task HandleComplete((int ItemId, CompleteChecklistItemDto Dto) e)
        => await Apply(await OnboardingService.CompleteItemAsync(Id, e.ItemId, e.Dto), "Adım tamamlandı.");

    private async Task HandleSkip(int itemId)
        => await Apply(await OnboardingService.SkipItemAsync(Id, itemId), "Adım atlandı.");

    private async Task HandleReopen(int itemId)
        => await Apply(await OnboardingService.ReopenItemAsync(Id, itemId), "Adım yeniden açıldı.");

    private async Task HandleSaveNote((int ItemId, string? Note) e)
    {
        var response = await OnboardingService.UpdateNoteAsync(Id, e.ItemId, new UpdateChecklistNoteDto { Note = e.Note });
        if (!response.IsSuccessStatusCode) { Snackbar.Add("Not kaydedilemedi.", Severity.Error); return; }
        await LoadAsync();
    }

    private async Task HandleUploadEvidence((int ItemId, IBrowserFile File) e)
    {
        await using var stream = e.File.OpenReadStream(DocumentConstants.MaxFileSizeBytes);
        var response = await OnboardingService.UploadEvidenceAsync(Id, e.ItemId, e.File.Name, e.File.ContentType, stream);
        if (!response.IsSuccessStatusCode)
        {
            var detail = await DZDDashboard.Client.Services.ApiServiceBase.TryReadProblemDetailAsync(response);
            Snackbar.Add(detail ?? "Kanıt yüklenemedi.", Severity.Error);
            return;
        }
        Snackbar.Add("Kanıt yüklendi.", Severity.Success);
        await LoadAsync();
    }

    private async Task Apply(OnboardingProcessDto? result, string successMessage)
    {
        if (result is null) { Snackbar.Add("İşlem başarısız.", Severity.Error); await LoadAsync(); return; }
        _process = result;
        Snackbar.Add(successMessage, Severity.Success);
        StateHasChanged();
    }

    private static Color StatusColor(string status) => status switch
    {
        ProcessStatuses.Completed => Color.Success,
        ProcessStatuses.Cancelled => Color.Error,
        _                         => Color.Info
    };

    private static string StatusLabel(string status) => status switch
    {
        ProcessStatuses.Completed => "Tamamlandı",
        ProcessStatuses.Cancelled => "İptal",
        _                         => "Devam ediyor"
    };
}
