@page "/employees"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Roles.AdminOrHrPolicy)]
@using DZDDashboard.Client.Components.OrgChart
@using DZDDashboard.Client.Services
@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.Utils
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IOrganizationClientService OrgService
@inject IUserClientService UserService

<div class="employees-scope">
<MudContainer MaxWidth="MaxWidth.False" Class="employees-page mt-4">
    @{
        <MudStack Spacing="5">
            <MudGrid Class="employees-stats-grid">
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Class="stat-card pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Class="stat-label">Total Employees</MudText>
                                <MudText Typo="Typo.h4" Class="stat-value">@_totalEmployeeCount</MudText>
                            </MudStack>
                            <MudAvatar Size="Size.Large" Class="stat-avatar stat-avatar-blue" Variant="Variant.Text">
                                <MudIcon Icon="@DzdIcons.Users" Size="Size.Large" />
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Class="stat-card pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Class="stat-label">Active</MudText>
                                <MudText Typo="Typo.h4" Class="stat-value">@_activeEmployees</MudText>
                            </MudStack>
                            <MudAvatar Size="Size.Large" Class="stat-avatar stat-avatar-green" Variant="Variant.Text">
                                <MudIcon Icon="@DzdIcons.User" Size="Size.Large" />
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Class="stat-card pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Class="stat-label">On Leave</MudText>
                                <MudText Typo="Typo.h4" Class="stat-value">@_inactiveEmployees</MudText>
                            </MudStack>
                            <MudAvatar Size="Size.Large" Class="stat-avatar stat-avatar-orange" Variant="Variant.Text">
                                <MudIcon Icon="@DzdIcons.UserX" Size="Size.Large" />
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Class="stat-card pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Class="stat-label">Departments</MudText>
                                <MudText Typo="Typo.h4" Class="stat-value">@_totalDepartments</MudText>
                            </MudStack>
                            <MudAvatar Size="Size.Large" Class="stat-avatar stat-avatar-red" Variant="Variant.Text">
                                <MudIcon Icon="@DzdIcons.Building" Size="Size.Large" />
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            @if (_totalEmployeeCount > _users.Count)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                    Showing @_users.Count of @_totalEmployeeCount employees. Active/Inactive counts and search reflect this page only.
                </MudAlert>
            }

            <MudPaper Elevation="3" Class="filters-shell pa-5">
                <MudGrid>
                    <MudItem xs="12" md="7">
                        <MudTextField @bind-Value="_search"
                                      Variant="Variant.Outlined"
                                      Placeholder="Search employees..."
                                      Immediate="true"
                                      Clearable="true"
                                      Class="filter-field"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@DzdIcons.Search" />
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudSelect T="string" @bind-Value="_statusFilter" Variant="Variant.Outlined" Class="filter-field">
                            <MudSelectItem Value=@("All")>All</MudSelectItem>
                            <MudSelectItem Value=@("Active")>Active</MudSelectItem>
                            <MudSelectItem Value=@("OnLeave")>On Leave</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudSelect T="string" @bind-Value="_roleFilter" Variant="Variant.Outlined" Class="filter-field">
                            <MudSelectItem Value=@("All")>All</MudSelectItem>
                            @foreach (var department in _departmentOptions)
                            {
                                <MudSelectItem Value="@department">@department</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <div class="@($"view-tabs-shell active-{_activeViewIndex}")" role="tablist" aria-label="Employees views">
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 0 ? "true" : "false")" @onclick="() => SetView(0)">Table View</button>
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 1 ? "true" : "false")" @onclick="() => SetView(1)">Card View</button>
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 2 ? "true" : "false")" @onclick="() => SetView(2)">Org Chart View</button>
            </div>

            @if (_activeViewIndex == 0)
            {
                <MudStack Spacing="2">
                    @if (!string.IsNullOrWhiteSpace(_error))
                    {
                        <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
                    }
                    <MudPaper Elevation="3" Class="employees-table-shell">
                        <MudTable Items="_filteredUsers" Dense="true" Hover="true" Loading="@_loading" LoadingProgressColor="Color.Primary" OnRowClick="@((TableRowClickEventArgs<UserSummaryDto> e) => View(e.Item!))" Class="clickable-table">
                            <HeaderContent>
                                <MudTh style="min-width:280px">Employee</MudTh>
                                <MudTh>Department</MudTh>
                                <MudTh>Position</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Join Date</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Employee">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <InitialsAvatar FullName="@AppFormatter.BuildFullName(context.FirstName, context.LastName)" ColorIndex="@context.AvatarColorIndex" Size="48" Class="employee-avatar" />
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.subtitle2" Class="employee-name">@AppFormatter.BuildFullName(context.FirstName, context.LastName)</MudText>
                                            <MudText Typo="Typo.caption" Class="employee-email">@context.Email</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudTd>

                                <MudTd DataLabel="Department">@(context.Department?.Name ?? "-")</MudTd>
                                <MudTd DataLabel="Position">@(context.Job?.Name ?? "-")</MudTd>

                                <MudTd DataLabel="Status">
                                    <MudChip T="string" Class="@GetStatusChipClass(context.IsActive)" Variant="Variant.Text" Size="Size.Small">
                                        @(context.IsActive ? "Active" : "On Leave")
                                    </MudChip>
                                </MudTd>

                                <MudTd DataLabel="Join Date">@AppFormatter.FormatDate(context.UserStartDate, "dd.MM.yyyy")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                </MudStack>
            }
            else if (_activeViewIndex == 1)
            {
                <MudGrid>
                    @foreach (var user in _filteredUsers)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudPaper Elevation="3" Class="employee-card pa-4" @onclick="@(() => View(user))">
                                <div class="employee-card-header">
                                    <div class="employee-card-profile">
                                        <InitialsAvatar FullName="@AppFormatter.BuildFullName(user.FirstName, user.LastName)" ColorIndex="@user.AvatarColorIndex" Size="72" Class="employee-avatar employee-card-avatar" />
                                        <div class="employee-card-titles">
                                            <MudText Typo="Typo.subtitle1" Class="employee-card-name">@AppFormatter.BuildFullName(user.FirstName, user.LastName)</MudText>
                                            <MudText Typo="Typo.body2" Class="employee-card-role">@(user.Job?.Name ?? "-")</MudText>
                                        </div>
                                    </div>
                                    <MudChip T="string" Class="@GetCardStatusChipClass(user.IsActive)" Variant="Variant.Text" Size="Size.Small">
                                        @(user.IsActive ? "Active" : "On Leave")
                                    </MudChip>
                                </div>

                                <div class="employee-card-meta">
                                    <div class="employee-card-meta-row">
                                        <MudIcon Icon="@DzdIcons.Building2" Class="employee-card-meta-icon" Size="Size.Small" />
                                        <span>@(user.Department?.Name ?? "-")</span>
                                    </div>
                                    <div class="employee-card-meta-row">
                                        <MudIcon Icon="@GetCardContactIcon(user)" Class="employee-card-meta-icon" Size="Size.Small" />
                                        <span>@GetCardContact(user)</span>
                                    </div>
                                    <div class="employee-card-meta-row">
                                        <MudIcon Icon="@DzdIcons.MapPin" Class="employee-card-meta-icon" Size="Size.Small" />
                                        <span>@(string.IsNullOrWhiteSpace(user.City) ? "-" : user.City)</span>
                                    </div>
                                </div>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
            else
            {
                <MudPaper Elevation="3" Class="org-chart-shell pa-3">
                    <div style="overflow-x: auto; padding-bottom: 20px;">
                        <OrgChartTree Nodes="_orgNodes" />
                    </div>
                </MudPaper>
            }
        </MudStack>
    }
</MudContainer>
</div>

@code {
    private bool _loading;
    private string? _error;
    private List<UserSummaryDto> _users = [];
    private int _totalEmployeeCount;
    private string _search = string.Empty;
    private string _statusFilter = "All";
    private string _roleFilter = "All";
    private int _activeViewIndex;
    private List<OrgChartNodeItem> _orgNodes = [];
    private List<string> _departmentOptions = [];
    private int _activeEmployees   => _users.Count(u => u.IsActive);
    private int _inactiveEmployees => _users.Count(u => !u.IsActive);
    private int _totalDepartments  => _users
        .Select(u => u.Department?.Name)
        .Where(n => !string.IsNullOrWhiteSpace(n))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();

    private IEnumerable<UserSummaryDto> _filteredUsers =>
        _users
            .Where(u => MatchesSearch(u, _search))
            .Where(u => _statusFilter == "All" ||
                        (_statusFilter == "Active"   && u.IsActive) ||
                        (_statusFilter == "OnLeave"  && !u.IsActive))
            .Where(u => MatchesDepartment(u, _roleFilter));

    protected override async Task OnInitializedAsync()
        => await LoadUsers();

    private async Task LoadUsers()
    {
        _error = null;
        _loading = true;
        try
        {
            var usersTask     = UserService.GetAllUsersAsync();
            var positionsTask = OrgService.GetOrganizationPositionsAsync();

            await Task.WhenAll(usersTask, positionsTask);

            var usersResult = await usersTask;
            _users = usersResult?.Items?.ToList() ?? [];
            _totalEmployeeCount = usersResult?.TotalCount ?? _users.Count;
            _departmentOptions = _users
                .Select(u => u.Department?.Name)
                .Where(n => !string.IsNullOrWhiteSpace(n))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(n => n)
                .Cast<string>()
                .ToList();

            var positions = await positionsTask;
            BuildOrgChart(positions);
        }
        catch (Exception)
        {
            _error = "Failed to load data.";
            Snackbar.Add(_error, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void BuildOrgChart(List<OrganizationPositionDto> positions)
        => _orgNodes = OrgChartBuilder.Build(positions);

    private static bool MatchesSearch(UserSummaryDto u, string term)
    {
        if (string.IsNullOrWhiteSpace(term))
        {
            return true;
        }

        term = term.Trim();
        return (u.FirstName?.Contains(term, StringComparison.OrdinalIgnoreCase) == true)
            || (u.LastName?.Contains(term, StringComparison.OrdinalIgnoreCase) == true)
            || (u.Email?.Contains(term, StringComparison.OrdinalIgnoreCase) == true);
    }

    private static bool MatchesDepartment(UserSummaryDto u, string filter)
    {
        if (string.IsNullOrWhiteSpace(filter) || filter == "All")
        {
            return true;
        }

        return string.Equals(u.Department?.Name, filter, StringComparison.OrdinalIgnoreCase);
    }

    private static string GetStatusChipClass(bool isActive)
    {
        return isActive ? "status-chip status-active" : "status-chip status-leave";
    }

    private static string GetCardStatusChipClass(bool isActive)
    {
        return $"{GetStatusChipClass(isActive)} employee-card-status";
    }

    private static string GetCardContact(UserSummaryDto u)
        => !string.IsNullOrWhiteSpace(u.PhoneNumber) ? u.PhoneNumber
         : !string.IsNullOrWhiteSpace(u.Email)       ? u.Email
         : "-";

    private static string GetCardContactIcon(UserSummaryDto u)
        => !string.IsNullOrWhiteSpace(u.PhoneNumber) ? DzdIcons.Phone : DzdIcons.Mail;

    private void SetView(int index)
    {
        _activeViewIndex = index;
    }

    private void View(UserSummaryDto user)
    {
        if (string.IsNullOrWhiteSpace(user.Slug)) return;
        Nav.NavigateTo($"/employee/{user.Slug}");
    }
}


