@page "/employees"
@using DZDDashboard.Client.Components.OrgChart
@using DZDDashboard.Client.Services
@using DZDDashboard.Common.Utils
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject OrganizationService OrgService
@inject UserService UserService
@inject EmployeeNavigationState EmployeeNavigationState

<div class="employees-scope">
<MudContainer MaxWidth="MaxWidth.False" Class="employees-page mt-4">
    @if (!_authorizedChecked)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </MudStack>
    }
    else if (!_isAdmin)
    {
        <MudAlert Severity="Severity.Error">Admin or HR Role is required for this page.</MudAlert>
    }
    else
    {
        <MudStack Spacing="5">
            <MudGrid Class="employees-stats-grid">
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Class="stat-card pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Class="stat-label">Total Employees</MudText>
                                <MudText Typo="Typo.h4" Class="stat-value">@_users.Count</MudText>
                            </MudStack>
                            <MudAvatar Size="Size.Large" Class="stat-avatar stat-avatar-blue" Variant="Variant.Text">
                                <MudIcon Icon="@DzdIcons.Users" Size="Size.Large" />
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Class="stat-card pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Class="stat-label">Active</MudText>
                                <MudText Typo="Typo.h4" Class="stat-value">@_activeEmployees</MudText>
                            </MudStack>
                            <MudAvatar Size="Size.Large" Class="stat-avatar stat-avatar-green" Variant="Variant.Text">
                                <MudIcon Icon="@DzdIcons.User" Size="Size.Large" />
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Class="stat-card pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Class="stat-label">On Leave</MudText>
                                <MudText Typo="Typo.h4" Class="stat-value">@_onLeaveEmployees</MudText>
                            </MudStack>
                            <MudAvatar Size="Size.Large" Class="stat-avatar stat-avatar-orange" Variant="Variant.Text">
                                <MudIcon Icon="@DzdIcons.UserX" Size="Size.Large" />
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Class="stat-card pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Class="stat-label">Departments</MudText>
                                <MudText Typo="Typo.h4" Class="stat-value">@_totalDepartments</MudText>
                            </MudStack>
                            <MudAvatar Size="Size.Large" Class="stat-avatar stat-avatar-red" Variant="Variant.Text">
                                <MudIcon Icon="@DzdIcons.Building" Size="Size.Large" />
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Elevation="3" Class="filters-shell pa-5">
                <MudGrid>
                    <MudItem xs="12" md="7">
                        <MudTextField @bind-Value="_search"
                                      Variant="Variant.Outlined"
                                      Placeholder="Search employees..."
                                      Immediate="true"
                                      Clearable="true"
                                      Class="filter-field"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@DzdIcons.Search" />
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudSelect T="string" @bind-Value="_statusFilter" Variant="Variant.Outlined" Class="filter-field">
                            <MudSelectItem Value=@("All")>All</MudSelectItem>
                            <MudSelectItem Value=@("Active")>Active</MudSelectItem>
                            <MudSelectItem Value=@("OnLeave")>On Leave</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudSelect T="string" @bind-Value="_roleFilter" Variant="Variant.Outlined" Class="filter-field">
                            <MudSelectItem Value=@("All")>All</MudSelectItem>
                            @foreach (var department in _departmentOptions)
                            {
                                <MudSelectItem Value="@department">@department</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <div class="@($"view-tabs-shell active-{_activeViewIndex}")" role="tablist" aria-label="Employees views">
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 0 ? "true" : "false")" @onclick="() => SetView(0)">Table View</button>
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 1 ? "true" : "false")" @onclick="() => SetView(1)">Card View</button>
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 2 ? "true" : "false")" @onclick="() => SetView(2)">Org Chart View</button>
            </div>

            @if (_activeViewIndex == 0)
            {
                <MudStack Spacing="2">
                    @if (!string.IsNullOrWhiteSpace(_error))
                    {
                        <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
                    }
                    <MudPaper Elevation="3" Class="employees-table-shell">
                        <MudTable Items="_filteredUsers" Dense="true" Hover="true" Loading="@_loading" LoadingProgressColor="Color.Primary" OnRowClick="@((TableRowClickEventArgs<UserDto> e) => View(e.Item!.Id))" Class="clickable-table">
                            <HeaderContent>
                                <MudTh style="min-width:280px">Employee</MudTh>
                                <MudTh>Department</MudTh>
                                <MudTh>Position</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Join Date</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Employee">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudAvatar Size="Size.Medium" Class="employee-avatar dzd-avatar dzd-avatar-md" Color="@GetAvatarColor(context)" Variant="Variant.Filled">
                                            @if (context.Avatar != null && !string.IsNullOrEmpty(context.Avatar.ContentBase64))
                                            {
                                                <MudImage Src="@($"data:{context.Avatar.ContentType};base64,{context.Avatar.ContentBase64}")" />
                                            }
                                            else
                                            {
                                                @AppFormatter.GetInitials(AppFormatter.BuildFullName(context.FirstName, context.LastName))
                                            }
                                        </MudAvatar>
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.subtitle2" Class="employee-name">@AppFormatter.BuildFullName(context.FirstName, context.LastName)</MudText>
                                            <MudText Typo="Typo.caption" Class="employee-email">@context.Email</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudTd>

                                <MudTd DataLabel="Department">@(context.Department?.Name ?? "-")</MudTd>
                                <MudTd DataLabel="Position">@(context.Job?.Name ?? "-")</MudTd>

                                <MudTd DataLabel="Status">
                                    <MudChip T="string" Class="@GetStatusChipClass(context.IsActive)" Variant="Variant.Text" Size="Size.Small">
                                        @(context.IsActive ? "Active" : "On Leave")
                                    </MudChip>
                                </MudTd>

                                <MudTd DataLabel="Join Date">@AppFormatter.FormatDate(context.UserStartDate, "dd.MM.yyyy")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                </MudStack>
            }
            else if (_activeViewIndex == 1)
            {
                <MudGrid>
                    @foreach (var user in _filteredUsers)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudPaper Elevation="3" Class="employee-card pa-4" @onclick="@(() => View(user.Id))">
                                <div class="employee-card-header">
                                    <div class="employee-card-profile">
                                        <MudAvatar Size="Size.Large" Class="employee-avatar employee-card-avatar dzd-avatar dzd-avatar-card" Color="@GetAvatarColor(user)">
                                            @if (user.Avatar != null && !string.IsNullOrEmpty(user.Avatar.ContentBase64))
                                            {
                                                <MudImage Src="@($"data:{user.Avatar.ContentType};base64,{user.Avatar.ContentBase64}")"
                                                          Alt="@($"{AppFormatter.BuildFullName(user.FirstName, user.LastName)} avatar")"
                                                          Class="employee-card-avatar-image" />
                                            }
                                            else
                                            {
                                                @AppFormatter.GetInitials(AppFormatter.BuildFullName(user.FirstName, user.LastName))
                                            }
                                        </MudAvatar>
                                        <div class="employee-card-titles">
                                            <MudText Typo="Typo.subtitle1" Class="employee-card-name">@AppFormatter.BuildFullName(user.FirstName, user.LastName)</MudText>
                                            <MudText Typo="Typo.body2" Class="employee-card-role">@(user.Department?.Name ?? "-")</MudText>
                                        </div>
                                    </div>
                                    <MudChip T="string" Class="@GetCardStatusChipClass(user.IsActive)" Variant="Variant.Text" Size="Size.Small">
                                        @(user.IsActive ? "Active" : "On Leave")
                                    </MudChip>
                                </div>

                                <div class="employee-card-meta">
                                    <div class="employee-card-meta-row">
                                        <MudIcon Icon="@DzdIcons.FileText" Class="employee-card-meta-icon" Size="Size.Small" />
                                        <span>@(user.Job?.Name ?? "Employee")</span>
                                    </div>
                                    <div class="employee-card-meta-row">
                                        <MudIcon Icon="@DzdIcons.Phone" Class="employee-card-meta-icon" Size="Size.Small" />
                                        <span>@GetCardContact(user)</span>
                                    </div>
                                    <div class="employee-card-meta-row">
                                        <MudIcon Icon="@DzdIcons.MapPin" Class="employee-card-meta-icon" Size="Size.Small" />
                                        <span>@GetCardLocation(user)</span>
                                    </div>
                                </div>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
            else
            {
                <MudPaper Elevation="3" Class="org-chart-shell pa-3">
                    <OrgChartTree Nodes="_orgNodes" />
                </MudPaper>
            }
        </MudStack>
    }
</MudContainer>
</div>

@code {
    private bool _isAdmin;
    private bool _authorizedChecked;
    private bool _loading;
    private string? _error;
    private List<UserDto> _users = new();
    private string _search = string.Empty;
    private string _statusFilter = "All";
    private string _roleFilter = "All";
    private int _activeViewIndex;
    private List<OrgChartNodeItem> _orgNodes = new();
    private List<string> _departmentOptions = new();
    private int _activeEmployees => _users.Count(u => u.IsActive);
    private int _onLeaveEmployees => _users.Count(u => !u.IsActive);
    private int _totalDepartments => _users
        .Select(u => u.Department?.Name)
        .Where(n => !string.IsNullOrWhiteSpace(n))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();

    private IEnumerable<UserDto> _filteredUsers =>
        _users
            .Where(u => MatchesSearch(u, _search))
            .Where(u => _statusFilter == "All" ||
                        (_statusFilter == "Active" && u.IsActive) ||
                        (_statusFilter == "OnLeave" && !u.IsActive))
            .Where(u => MatchesDepartment(u, _roleFilter));

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _isAdmin = user.Identity?.IsAuthenticated == true && user.IsInRole("Admin");
        _authorizedChecked = true;

        if (_isAdmin)
        {
            await LoadUsers();
        }
    }

    private async Task LoadUsers()
    {
        _error = null;
        _loading = true;
        try
        {
            var usersTask = UserService.GetAllUsersAsync();
            var positionsTask = OrgService.GetOrganizationPositionsAsync();

            await Task.WhenAll(usersTask, positionsTask);

            _users = await usersTask;
            _departmentOptions = _users
                .Select(u => u.Department?.Name)
                .Where(n => !string.IsNullOrWhiteSpace(n))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(n => n)
                .Cast<string>()
                .ToList();

            var positions = await positionsTask;
            BuildOrgChart(positions, _users);
        }
        catch (Exception ex)
        {
            _error = "Failed to load data.";
            Snackbar.Add($"{_error} {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void BuildOrgChart(List<OrganizationPositionDto> positions, List<UserDto> users)
    {
        _orgNodes = new List<OrgChartNodeItem>();

        var usersByPosition = users
            .Where(u => u.OrganizationPositionId.HasValue)
            .GroupBy(u => u.OrganizationPositionId!.Value)
            .ToDictionary(g => g.Key, g => g.ToList());

        var childPositionsMap = positions
            .Where(p => p.ParentId.HasValue)
            .GroupBy(p => p.ParentId!.Value)
            .ToDictionary(g => g.Key, g => g.OrderBy(p => p.Name).ToList());

        var rootPositions = positions.Where(p => p.ParentId == null).OrderBy(p => p.Name).ToList();

        foreach (var rootPos in rootPositions)
        {
            _orgNodes.Add(CreateNode(rootPos, childPositionsMap, usersByPosition));
        }
    }

    private static OrgChartNodeItem CreateNode(
        OrganizationPositionDto position,
        Dictionary<int, List<OrganizationPositionDto>> childPositionsMap,
        Dictionary<int, List<UserDto>> usersByPosition)
    {
        var node = new OrgChartNodeItem
        {
            Position = position,
            User = ResolveAssignedUser(position, usersByPosition),
            Children = new List<OrgChartNodeItem>(),
            IsExpanded = true
        };

        if (childPositionsMap.TryGetValue(position.Id, out var children))
        {
            foreach (var child in children)
            {
                node.Children.Add(CreateNode(child, childPositionsMap, usersByPosition));
            }
        }

        return node;
    }

    private static UserDto? ResolveAssignedUser(
        OrganizationPositionDto position,
        Dictionary<int, List<UserDto>> usersByPosition)
    {
        if (position.User != null)
        {
            return position.User;
        }

        if (!usersByPosition.TryGetValue(position.Id, out var users) || users.Count == 0)
        {
            return null;
        }

        if (position.UserId.HasValue)
        {
            var exactUser = users.FirstOrDefault(u => u.Id == position.UserId.Value);
            if (exactUser != null)
            {
                return exactUser;
            }
        }

        return users.OrderBy(u => u.Id).FirstOrDefault();
    }

    private static bool MatchesSearch(UserDto u, string term)
    {
        if (string.IsNullOrWhiteSpace(term))
        {
            return true;
        }

        term = term.Trim();
        return (u.FirstName?.Contains(term, StringComparison.OrdinalIgnoreCase) == true)
            || (u.LastName?.Contains(term, StringComparison.OrdinalIgnoreCase) == true)
            || (u.Email?.Contains(term, StringComparison.OrdinalIgnoreCase) == true);
    }

    private static bool MatchesDepartment(UserDto u, string filter)
    {
        if (string.IsNullOrWhiteSpace(filter) || filter == "All")
        {
            return true;
        }

        return string.Equals(u.Department?.Name, filter, StringComparison.OrdinalIgnoreCase);
    }

    private static Color GetAvatarColor(UserDto u)
    {
        return (u.Id % 6) switch
        {
            0 => Color.Primary,
            1 => Color.Secondary,
            2 => Color.Info,
            3 => Color.Success,
            4 => Color.Warning,
            _ => Color.Tertiary
        };
    }

    private static string GetStatusChipClass(bool isActive)
    {
        return isActive ? "status-chip status-active" : "status-chip status-leave";
    }

    private static string GetCardStatusChipClass(bool isActive)
    {
        return $"{GetStatusChipClass(isActive)} employee-card-status";
    }

    private static string GetCardContact(UserDto u)
    {
        if (!string.IsNullOrWhiteSpace(u.PhoneNumber))
        {
            return u.PhoneNumber;
        }

        return !string.IsNullOrWhiteSpace(u.Email) ? u.Email : "-";
    }

    private static string GetCardLocation(UserDto u)
    {
        if (!string.IsNullOrWhiteSpace(u.City) && !string.IsNullOrWhiteSpace(u.Country))
        {
            return $"{u.City}, {u.Country}";
        }

        if (!string.IsNullOrWhiteSpace(u.City))
        {
            return u.City;
        }

        if (!string.IsNullOrWhiteSpace(u.Country))
        {
            return u.Country;
        }

        return !string.IsNullOrWhiteSpace(u.Team?.Name) ? u.Team!.Name! : "-";
    }

    private void SetView(int index)
    {
        _activeViewIndex = index;
    }

    private void Edit(int id)
    {
        EmployeeNavigationState.SelectedEmployeeId = id;
        Nav.NavigateTo("/employee/card");
    }

    private void View(int id)
    {
        EmployeeNavigationState.SelectedEmployeeId = id;
        Nav.NavigateTo("/employee/card");
    }
}


