@page "/employee/card/{Id:int}"
@using DZDDashboard.Common.DTOs.Users
@using DZDDashboard.Common.DTOs.Organization
@using DZDDashboard.Client.Components.Pages.Employees.Dialogs
@using DZDDashboard.Client.Services
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider
@inject UserService UserService
@inject OrganizationService OrgService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    @if (!_authorizedChecked)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else if (!_isAdmin)
    {
        <MudAlert Severity="Severity.Error">This page requires Admin role.</MudAlert>
    }
    else if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else if (_profile is not null)
    {
        
        <div class="dzd-header-container mb-4">
            <MudPaper Elevation="0" Class="dzd-header-card">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="2" Class="d-flex justify-center align-center">
                        <MudAvatar Class="elevation-3" Style="width:100px;height:100px;font-size:36px;box-shadow:0 6px 16px rgba(0,0,0,.15);border:4px solid #fff;display:flex;align-items:center;justify-content:center;">
                            @if (!string.IsNullOrEmpty(_avatarDataUrl))
                            {
                                <MudImage Src="@_avatarDataUrl" Alt="Avatar" Style="border-radius:50%;width:100%;height:100%;object-fit:cover;" />
                            }
                            else
                            {
                                @_initials
                            }
                        </MudAvatar>    
                    </MudItem>
                    <MudItem xs="12" md="10">
                        <MudStack Spacing="1">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudText Typo="Typo.h5">@_fullName</MudText>
                                <MudSpacer />
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@Back" StartIcon="@Icons.Material.Filled.ArrowBack">Back</MudButton>
                            </MudStack>
                            <MudDivider />
                            
                            
                            <MudGrid Spacing="1" Class="mt-1">
                                <MudItem xs="6" md="4">
                                    <MudStack Spacing="0">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.Work" Size="Size.Small" Style="font-size: 16px; opacity: 0.7;" />
                                            <MudText Typo="Typo.caption" Style="opacity:.6">Job Title</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Class="ml-6">@(_profile.Job?.Name ?? "-")</MudText>
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="6" md="4">
                                    <MudStack Spacing="0">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.Apartment" Size="Size.Small" Style="font-size: 16px; opacity: 0.7;" />
                                            <MudText Typo="Typo.caption" Style="opacity:.6">Department</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Class="ml-6">@(_profile.Department?.Name ?? "-")</MudText>
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="6" md="4">
                                    <MudStack Spacing="0">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount" Size="Size.Small" Style="font-size: 16px; opacity: 0.7;" />
                                            <MudText Typo="Typo.caption" Style="opacity:.6">Reporting To</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Class="ml-6">@((_profile.ReportsTo?.FirstName != null) ? (_profile.ReportsTo.FirstName + " " + _profile.ReportsTo.LastName) : "-")</MudText>
                                    </MudStack>
                                </MudItem>
                            </MudGrid>

                            
                            <MudGrid Spacing="1" Class="mt-0">
                                <MudItem xs="6" md="4">
                                    <MudStack Spacing="0">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.Grade" Size="Size.Small" Style="font-size: 16px; opacity: 0.7;" />
                                            <MudText Typo="Typo.caption" Style="opacity:.6">Grade</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Class="ml-6">@(_profile.Grade is null ? "-" : $"{_profile.Grade}")</MudText>
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="6" md="4">
                                    <MudStack Spacing="0">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.WorkHistory" Size="Size.Small" Style="font-size: 16px; opacity: 0.7;" />
                                            <MudText Typo="Typo.caption" Style="opacity:.6">Work Type</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Class="ml-6">@(_profile.WorkModel ?? "-")</MudText>
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="6" md="4">
                                    <MudStack Spacing="0">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Style="font-size: 16px; opacity: 0.7;" />
                                            <MudText Typo="Typo.caption" Style="opacity:.6">Location</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Class="ml-6">@(_profile.PayrollLocation?.Name ?? "-")</MudText>
                                    </MudStack>
                                </MudItem>
                            </MudGrid>

                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </div>

        
        <MudTabs Elevation="0" Rounded="true">
            <MudTabPanel Text="Overview">
                <MudGrid Class="mt-1 mb-5">
                    <MudItem xs="12" md="4">
                        <MudPaper Elevation="1" Class="pa-3">
                            <MudStack>  
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Event" Color="Color.Primary" />
                                    <MudText Typo="Typo.subtitle2">Position Start Date</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body1" Class="value">
                                    @FormatDate(_profile.PositionStartDate)
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudPaper Elevation="1" Class="pa-3">
                            <MudStack>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Success" />
                                    <MudText Typo="Typo.subtitle2">Job Start Date</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body1" Class="value">
                                    @FormatDate(_profile.UserStartDate)
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudPaper Elevation="1" Class="pa-3">
                            <MudStack>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Info" />
                                    <MudText Typo="Typo.subtitle2">Employment Duration</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body1" Class="value">
                                    @(_employmentDuration ?? "-")
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
                

                
                <MudGrid Class="mt-2 mb-4">
                    <MudItem xs="12" md="6">
                        <MudCard Class="pa-2">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.subtitle1">Contact Information</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudGrid>
                                    <MudItem xs="12">
                                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                            <MudIcon Icon="@Icons.Material.Filled.Email" Color="Color.Primary" />
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.caption" Style="opacity:.6">Email</MudText>
                                                <MudText>@(_profile.Email ?? "-")</MudText>
                                            </MudStack>
                                        </MudStack>
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                            <MudIcon Icon="@Icons.Material.Filled.Phone" Color="Color.Success" />
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.caption" Style="opacity:.6">Phone</MudText>
                                                <MudText>@(_profile.PhoneNumber ?? "-")</MudText>
                                            </MudStack>
                                        </MudStack>
                                    </MudItem>
                                </MudGrid>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudCard Class="pa-2">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.subtitle1">Work Information</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudGrid>
                                    <MudItem xs="12" md="6">
                                        <MudText Typo="Typo.caption" Style="opacity:.6">Contract Type</MudText>
                                        <MudText>@(_profile.ContractType ?? "-")</MudText>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudText Typo="Typo.caption" Style="opacity:.6">Contract End Date</MudText>
                                        <MudText>@FormatDate(_profile.ContractEndDate)</MudText>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudText Typo="Typo.caption" Style="opacity:.6">Work Type</MudText>
                                        <MudText>@(_profile.WorkModel ?? "-")</MudText>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudText Typo="Typo.caption" Style="opacity:.6">Payroll Location</MudText>
                                        <MudText>@(_profile.PayrollLocation?.Name ?? "-")</MudText>
                                    </MudItem>
                                </MudGrid>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="Personal Info">
                @if (_personalInfoLoading)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="ml-4 mt-6" />
                }
                else if (_personalInfo is null)
                {
                    <MudAlert Severity="Severity.Warning" Class="mt-4">No personal information available.</MudAlert>
                }
                else
                {
                    <div class="dzd-personal-info-bg pa-6">
                        
                        <MudText Typo="Typo.h6" Class="mb-1" Style="font-weight:600; color:#111827;">Personal Information</MudText>
                        <MudText Typo="Typo.body2" Class="mb-6" Style="color:#6B7280;">Manage employee's personal details and contact information</MudText>

                        
                        <div class="dzd-section-title">
                            <span>•</span> Employee Details
                        </div>
                        <div class="dzd-card">
                            <MudGrid Spacing="4">
                                
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Person" Size="Size.Small" /> Full Name</div>
                                    <MudTextField Value="@(BuildFullName(_profile.FirstName, _profile.LastName))" ReadOnly="true" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" />
                                </MudItem>
                                
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Badge" Size="Size.Small" /> Registry Number (Sicil No)</div>
                                    <MudTextField Value="@(_personalInfo.RegistrationNumber)" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" />
                                </MudItem>
                                
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.CalendarToday" Size="Size.Small" /> Job Start Date</div>
                                    <MudDatePicker Date="@_personalInfo.UserStartDate" DateChanged="@(d => _personalInfo.UserStartDate = d)" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Timer" Size="Size.Small" /> Employment Duration</div>
                                    <MudTextField Value="@FormatDurationFrom(_personalInfo.UserStartDate)" ReadOnly="true" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" />
                                </MudItem>
                                
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Description" Size="Size.Small" /> Contract Type</div>
                                    <MudTextField @bind-Value="_personalInfo.ContractType" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.KeyboardArrowDown"/>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Event" Size="Size.Small" /> Contract End Date</div>
                                     <MudDatePicker Date="@_personalInfo.ContractEndDate" DateChanged="@(d => _personalInfo.ContractEndDate = d)" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" Placeholder="N/A" />
                                </MudItem>
                                
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.WorkHistory" Size="Size.Small" /> Work Type</div>
                                    <MudTextField @bind-Value="_personalInfo.WorkModel" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Place" Size="Size.Small" /> Payroll Location</div>
                                    <MudTextField Value="@(_profile.PayrollLocation?.Name)" ReadOnly="true" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" />
                                </MudItem>
                            </MudGrid>
                        </div>

                        
                        <div class="dzd-section-title">
                            <span>•</span> Manager Information
                        </div>
                        <div class="dzd-card">
                            <MudGrid Spacing="4">
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Person" Size="Size.Small" /> Manager</div>
                                    <MudTextField Value="@((_profile.ReportsTo != null) ? $"{_profile.ReportsTo.FirstName} {_profile.ReportsTo.LastName}" : "-")" ReadOnly="true" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Approval" Size="Size.Small" /> Approval Process Department</div>
                                    <MudTextField Value="@(_personalInfo.ApprovalProcessUnit)" ReadOnly="true" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.KeyboardArrowDown"/>
                                </MudItem>
                            </MudGrid>
                        </div>

                        
                        <div class="dzd-section-title">
                            <span>•</span> Contact Information
                        </div>
                        <MudGrid Spacing="4">
                            <MudItem xs="12" md="6">
                                <div class="dzd-card h-100">
                                    <MudText Typo="Typo.subtitle2" Class="mb-4">Work Contact</MudText>
                                    <MudStack Spacing="3">
                                        <div>
                                            <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Email" Size="Size.Small" /> Work Email</div>
                                            <MudTextField Value="@(_profile.Email)" ReadOnly="true" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Outlined.ContentCopy" AdornmentColor="Color.Primary" />
                                        </div>
                                        <div>
                                            <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Phone" Size="Size.Small" /> Work Phone</div>
                                            <MudTextField Value="@(_profile.PhoneNumber)" ReadOnly="true" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Outlined.ContentCopy" AdornmentColor="Color.Success"/>
                                        </div>
                                    </MudStack>
                                </div>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <div class="dzd-card h-100">
                                    <MudText Typo="Typo.subtitle2" Class="mb-4">Personal Contact</MudText>
                                    <MudStack Spacing="3">
                                        <div>
                                            <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Email" Size="Size.Small" /> Personal Email</div>
                                            <MudTextField @bind-Value="@_personalInfo.PersonalEmail" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense"  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Outlined.ContentCopy" AdornmentColor="Color.Primary"/>
                                        </div>
                                        <div>
                                            <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Phone" Size="Size.Small" /> Personal Phone</div>
                                            <MudTextField @bind-Value="@_personalInfo.PersonalPhoneNumber" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Outlined.ContentCopy" AdornmentColor="Color.Success"/>
                                        </div>
                                    </MudStack>
                                </div>
                            </MudItem>
                        </MudGrid>

                        
                        <div class="dzd-section-title">
                            <span>•</span> Citizenship Information
                        </div>
                        <div class="dzd-card">
                             <MudGrid Spacing="4">
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.CalendarToday" Size="Size.Small" /> Date of Birth</div>
                                    <MudDatePicker Date="@_personalInfo.DateOfBirth" DateChanged="@(d => _personalInfo.DateOfBirth = d)" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Person" Size="Size.Small" /> Gender</div>
                                    <MudTextField @bind-Value="_personalInfo.Gender" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.KeyboardArrowDown"/>
                                </MudItem>
                                 <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Accessible" Size="Size.Small" /> Disability Status</div>
                                    
                                     <MudSelect T="bool" @bind-Value="_personalInfo.DisabilityStatus" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter">
                                        <MudSelectItem Value="false">No</MudSelectItem>
                                        <MudSelectItem Value="true">Yes</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                 <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Flag" Size="Size.Small" /> Nationality</div>
                                    <MudTextField @bind-Value="_personalInfo.Nationality" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" />
                                </MudItem>
                                 <MudItem xs="12" md="12">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Badge" Size="Size.Small" /> ID Number (TC Kimlik No)</div>
                                    <MudTextField @bind-Value="_personalInfo.CitizenshipNumber" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Outlined.ContentCopy" AdornmentColor="Color.Primary"/>
                                </MudItem>
                             </MudGrid>
                        </div>
                        
                        
                         <div class="dzd-section-title">
                            <span>•</span> Emergency Contact
                        </div>
                        <div class="dzd-card">
                             <MudGrid Spacing="4">
                                <MudItem xs="12" md="4">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Person" Size="Size.Small" /> Full Name</div>
                                    <MudTextField @bind-Value="_personalInfo.EmergencyContactFullName" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Favorite" Size="Size.Small" /> Relationship</div>
                                    <MudTextField @bind-Value="_personalInfo.EmergencyContactRelationship" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Phone" Size="Size.Small" /> Phone Number</div>
                                    <MudTextField @bind-Value="_personalInfo.EmergencyContactPhoneNumber" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" />
                                </MudItem>
                             </MudGrid>
                        </div>

                         
                         <div class="dzd-section-title">
                            <span>•</span> Family Information
                        </div>
                        <div class="dzd-card">
                             <MudGrid Spacing="4">
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.FamilyRestroom" Size="Size.Small" /> Marital Status</div>
                                    <MudTextField @bind-Value="_personalInfo.MaritalStatus" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.KeyboardArrowDown"/>
                                </MudItem>
                                 <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Person" Size="Size.Small" /> Spouse Name</div>
                                    <MudTextField @bind-Value="_personalInfo.SpouseFullName" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" />
                                </MudItem>
                                 <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.ChildCare" Size="Size.Small" /> Number of Children</div>
                                    <MudNumericField @bind-Value="_personalInfo.ChildrenCount" ReadOnly="@(!_editingPersonalInfo)" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" Min="0" />
                                </MudItem>
                                
                                 <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@Icons.Material.Outlined.Cake" Size="Size.Small" /> Children Birth Dates</div>
                                    <MudTextField Value="@("2020-05-12")" ReadOnly="true" Variant="Variant.Outlined" Class="dzd-input" Margin="Margin.Dense" />
                                </MudItem>
                             </MudGrid>
                        </div>
                        
                        
                        <div class="dzd-section-title">
                            <span>•</span> Address Information
                        </div>
                        <div class="dzd-card">
                             <MudGrid Spacing="4">
                                  <MudItem xs="12" md="12">
