    private static Color GetEducationStatusColor(string? status)
    {
        if (string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase)) return Color.Success;
        if (string.Equals(status, "In Progress", StringComparison.OrdinalIgnoreCase)) return Color.Warning;
        if (string.Equals(status, "Planned", StringComparison.OrdinalIgnoreCase)) return Color.Info;
        return Color.Default;
    }

    private static Color GetEducationLevelColor(string? level)
    {
        if (string.Equals(level, "High School", StringComparison.OrdinalIgnoreCase)) return Color.Success;
        if (string.Equals(level, "Associate", StringComparison.OrdinalIgnoreCase)) return Color.Info;
        if (string.Equals(level, "Bachelor's Degree", StringComparison.OrdinalIgnoreCase)) return Color.Primary;
        if (string.Equals(level, "Master's Degree", StringComparison.OrdinalIgnoreCase)) return Color.Secondary;
        if (string.Equals(level, "PhD", StringComparison.OrdinalIgnoreCase) || string.Equals(level, "Doctorate", StringComparison.OrdinalIgnoreCase)) return Color.Error;
        return Color.Default;
    }

