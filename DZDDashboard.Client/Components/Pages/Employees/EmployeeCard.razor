    private async Task SaveEmergencyInfoAsync()
    {
        if (_personalInfo is null || _employeeId is null) return;

        // Sync IntlTel values back into the DTO model.
        if (_personalInfo.EmergencyContacts != null)
        {
            foreach (var contact in _personalInfo.EmergencyContacts)
            {
                if (_emergencyContactPhones.TryGetValue(contact, out var intl))
                {
                    contact.PhoneNumber = intl.Number;
                }
            }
        }

        try
        {
            var dto = new UpdateEmergencyContactsDto
            {
                UserId = _employeeId.Value,
                EmergencyContacts = _personalInfo.EmergencyContacts?.Select(c => new EmergencyContactDto
                {
                    Id = c.Id,
                    UserId = c.UserId,
                    FullName = c.FullName,
                    Relationship = c.Relationship,
                    PhoneNumber = c.PhoneNumber
                }).ToList() ?? new List<EmergencyContactDto>()
            };
            var response = await UserService.UpdateEmergencyContactsAsync(_employeeId.Value, dto);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Emergency contact updated successfully.", Severity.Success);
                _editingEmergencyInfo = false;
                _emergencyInfoBackup = null;
                _emergencyContactPhones.Clear();
