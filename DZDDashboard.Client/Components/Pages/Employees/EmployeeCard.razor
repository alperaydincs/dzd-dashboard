@code {
    private bool _isAdmin;
    private bool _authorizedChecked;
    private bool _loading;
    private bool _personalInfoLoading;
    private string? _error;
    private EmployeeDetailDto? _profile;
    private PersonalInfoDto? _personalInfo;
    private PersonalInfoDto? _personalInfoBackup;
    private string _avatarDataUrl = string.Empty;
    private string _fullName = string.Empty;
    private string _initials = "?";
    private string? _employmentDuration;
    private int? _selectedManagerId;
    private List<UserDto> _allUsers = new();
    private double _performanceScore = 0;
    private int _completedTrainings = 0;
    private int _totalTrainings = 0;
    private double _trainingsProgress = 0;
    private bool _editingPersonalInfo;
    private bool _editingBasicInfo;
    private int _activeViewIndex;
    private int? _employeeId;
    private List<PayrollLocationDto> _payrollLocations = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _isAdmin = user.Identity?.IsAuthenticated == true && user.IsInRole("Admin");
        _authorizedChecked = true;

        if (_isAdmin)
        {
            _employeeId = EmployeeNavigationState.SelectedEmployeeId;
            if (_employeeId is null)
            {
                _error = "Employee not selected. Please open a profile from the Employees page.";
                return;
            }

            await LoadData();
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;

        try
        {
            var selectedId = _employeeId!.Value;
            var profileTask = UserService.GetEmployeeDetailsAsync(selectedId);
            var avatarTask = UserService.GetUserAvatarAsync(selectedId);

            try { _allUsers = await UserService.GetAllUsersAsync(); } catch {}
            try { _payrollLocations = await OrgService.GetPayrollLocationsAsync(); } catch {}

            _profile = await profileTask;


            if (_profile is null)
            {
                _error = "User profile not found.";
                return;
            }


            if (_profile.ReportsTo != null)
            {
                _selectedManagerId = _profile.ReportsTo.Id;
            }

            _fullName = BuildFullName(_profile.FirstName, _profile.LastName);
            _initials = GetInitials(_fullName);
            _employmentDuration = FormatDurationFrom(_profile.UserStartDate ?? _profile.PositionStartDate);

            if (_profile.TargetEfforts is { Count: > 0 })
            {
                var latest = _profile.TargetEfforts.OrderByDescending(t => t.Id).First();
                if (latest.Target > 0)
                    _performanceScore = Math.Clamp((double)(latest.CompletedTarget / latest.Target) * 100d, 0d, 100d);
            }

            if (_profile.UserTrainings is { Count: > 0 })
            {
                _totalTrainings = _profile.UserTrainings.Count;
                _completedTrainings = _profile.UserTrainings.Count(t => t.CompletionDate is not null || string.Equals(t.Status, "Completed", StringComparison.OrdinalIgnoreCase));
                _trainingsProgress = _totalTrainings == 0 ? 0 : Math.Clamp((_completedTrainings * 100d) / _totalTrainings, 0, 100);
            }

            try
            {
                if (_profile.Avatar != null && !string.IsNullOrEmpty(_profile.Avatar.ContentBase64))
                {
                    _avatarDataUrl = $"data:{(_profile.Avatar.ContentType ?? "image/png")};base64,{_profile.Avatar.ContentBase64}";
                }
                else
                {
                    var avatar = await avatarTask;
                    if (avatar != null && !string.IsNullOrEmpty(avatar.ContentBase64))
                        _avatarDataUrl = $"data:{(avatar.ContentType ?? "image/png")};base64,{avatar.ContentBase64}";
                }
            }
            catch { }

            await LoadPersonalInfo();
        }
        catch (HttpRequestException ex)
        {
            _error = "Failed to load employee profile.";
            Snackbar.Add($"{_error} {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            _error = "Unexpected error while loading profile.";
            Snackbar.Add($"{_error} {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadPersonalInfo()
    {
        if (_employeeId is null)
            return;

        _personalInfoLoading = true;
        try
        {
            _personalInfo = await UserService.GetPersonalInfoAsync(_employeeId.Value);

            if (_personalInfo != null)
            {
                StartEdit();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Personal info fetch failed: {ex.Message}");
        }
        finally
        {
            _personalInfoLoading = false;
        }
    }

    private void StartEdit()
    {
        _personalInfoBackup = new PersonalInfoDto
        {
            Id = _personalInfo!.Id,
            FirstName = _personalInfo.FirstName,
            LastName = _personalInfo.LastName,
            CompanyName = _personalInfo.CompanyName,
            RegistrationNumber = _personalInfo.RegistrationNumber,
            Grade = _personalInfo.Grade,
            JobId = _personalInfo.JobId,
            DepartmentId = _personalInfo.DepartmentId,
            TeamId = _personalInfo.TeamId,
            PositionStartDate = _personalInfo.PositionStartDate,
            UserStartDate = _personalInfo.UserStartDate,
            ContractType = _personalInfo.ContractType,
            ContractEndDate = _personalInfo.ContractEndDate,
            WorkModel = _personalInfo.WorkModel,
            PayrollLocationId = _personalInfo.PayrollLocationId,
            ReportsToId = _personalInfo.ReportsToId,
            ApprovalProcessUnit = _personalInfo.ApprovalProcessUnit,
            Email = _personalInfo.Email,
            PhoneNumber = _personalInfo.PhoneNumber,
            PersonalEmail = _personalInfo.PersonalEmail,
            PersonalPhoneNumber = _personalInfo.PersonalPhoneNumber,
            DateOfBirth = _personalInfo.DateOfBirth,
            Gender = _personalInfo.Gender,
            DisabilityStatus = _personalInfo.DisabilityStatus,
            DisabilityDegree = _personalInfo.DisabilityDegree,
            Nationality = _personalInfo.Nationality,
            CitizenshipNumber = _personalInfo.CitizenshipNumber,
            EmergencyContactFullName = _personalInfo.EmergencyContactFullName,
            EmergencyContactRelationship = _personalInfo.EmergencyContactRelationship,
            EmergencyContactPhoneNumber = _personalInfo.EmergencyContactPhoneNumber,
            MaritalStatus = _personalInfo.MaritalStatus,
            SpouseFullName = _personalInfo.SpouseFullName,
            ChildrenCount = _personalInfo.ChildrenCount,
            LegalAddress = _personalInfo.LegalAddress,
            CurrentAddress = _personalInfo.CurrentAddress,
            City = _personalInfo.City,
            Country = _personalInfo.Country,
            HighSchoolName = _personalInfo.HighSchoolName,
            BachelorsUniversityName = _personalInfo.BachelorsUniversityName,
            BachelorsProgramName = _personalInfo.BachelorsProgramName,
            MastersUniversityName = _personalInfo.MastersUniversityName,
            MastersProgramName = _personalInfo.MastersProgramName,
            BachelorsGraduatedDate = _personalInfo.BachelorsGraduatedDate,
            MastersGraduatedDate = _personalInfo.MastersGraduatedDate
        };

        _editingPersonalInfo = false;
    }

    private void StartBasicInfoEdit()
    {
        if (_personalInfo is null)
            return;

        StartEdit();
        _editingBasicInfo = true;
    }

    private void CancelBasicInfoEdit()
    {
        if (_personalInfoBackup is not null && _personalInfo is not null)
        {
            _personalInfo.FirstName = _personalInfoBackup.FirstName;
            _personalInfo.LastName = _personalInfoBackup.LastName;
            _personalInfo.RegistrationNumber = _personalInfoBackup.RegistrationNumber;
            _personalInfo.UserStartDate = _personalInfoBackup.UserStartDate;
            _personalInfo.PositionStartDate = _personalInfoBackup.PositionStartDate;
            _personalInfo.ContractType = _personalInfoBackup.ContractType;
            _personalInfo.ContractEndDate = _personalInfoBackup.ContractEndDate;
            _personalInfo.WorkModel = _personalInfoBackup.WorkModel;
            _personalInfo.PayrollLocationId = _personalInfoBackup.PayrollLocationId;
        }

        _editingBasicInfo = false;
    }

    private async Task SaveBasicInfoAsync()
    {
        if (_personalInfo is null || _employeeId is null)
            return;

        try
        {
            var response = await UserService.UpdatePersonalInfoAsync(_employeeId.Value, _personalInfo);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Basic information updated successfully.", Severity.Success);
                StartEdit();
                _editingBasicInfo = false;
            }
            else
            {
                Snackbar.Add("Failed to update basic information.", Severity.Error);
            }
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Unexpected error: {ex.Message}", Severity.Error);
        }
    }

    private void CancelEdit()
    {
        if (_personalInfoBackup is not null && _personalInfo is not null)
        {
            _personalInfo.DateOfBirth = _personalInfoBackup.DateOfBirth;
            _personalInfo.Gender = _personalInfoBackup.Gender;
            _personalInfo.Nationality = _personalInfoBackup.Nationality;
            _personalInfo.CitizenshipNumber = _personalInfoBackup.CitizenshipNumber;
            _personalInfo.DisabilityStatus = _personalInfoBackup.DisabilityStatus;
            _personalInfo.DisabilityDegree = _personalInfoBackup.DisabilityDegree;
            _personalInfo.PersonalPhoneNumber = _personalInfoBackup.PersonalPhoneNumber;
            _personalInfo.PersonalEmail = _personalInfoBackup.PersonalEmail;
