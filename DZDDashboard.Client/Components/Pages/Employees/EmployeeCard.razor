            }
        </div>
    }
</MudContainer>

@code {
    private bool _isAdmin;
    private bool _authorizedChecked;
    private bool _loading;
    private string? _error;
    private EmployeeCardDto? _profile;
    private EmployeeCardDto? _personalInfo;
    private EmployeeCardDto? _basicInfoBackup;
    private EmployeeCardDto? _contactsBackup;
    private EmployeeCardDto? _citizenshipInfoBackup;
    private EmployeeCardDto? _emergencyInfoBackup;
    private EmployeeCardDto? _addressInfoBackup;
    private string _avatarDataUrl = string.Empty;
    private string _fullName = string.Empty;
    private string _initials = "?";
    private string? _employmentDuration;
    private bool _editingBasicInfo;
    private bool _editingContacts;
    private bool _editingCitizenshipInfo;
    private bool _editingEmergencyInfo;
    private bool _editingFamilyInfo;
    private EmployeeCardDto? _familyInfoBackup;
    private bool _editingAddressInfo;
    private bool _editingEducationInfo;
    private readonly List<string> _educationLevelOptions = new() { "High School", "Associate", "Bachelor's Degree", "Master's Degree", "PhD", "Other" };
    private List<EducationHistoryRecord> _educationHistoryRecords = new();
    private List<EducationHistoryRecord> _educationHistoryBackup = new();
    private IntlTel _workPhoneIntl = new();
    private IntlTel _personalPhoneIntl = new();
    private Dictionary<EmergencyContactDto, IntlTel> _emergencyContactPhones = new();
    private int _activeViewIndex;
    private int? _employeeId;
    private List<PayrollLocationDto> _payrollLocations = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _isAdmin = user.Identity?.IsAuthenticated == true && user.IsInRole("Admin");
        _authorizedChecked = true;

        if (_isAdmin)
        {
            _employeeId = EmployeeNavigationState.SelectedEmployeeId;
            if (_employeeId is null)
            {
                _error = "Employee not selected. Please open a profile from the Employees page.";
                return;
            }

            await LoadData();
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;

        try
        {
            var selectedId = _employeeId!.Value;
            var profileTask = UserService.GetEmployeeCardAsync(selectedId);
            var avatarTask = UserService.GetUserAvatarAsync(selectedId);

            try { _payrollLocations = await OrgService.GetPayrollLocationsAsync(); } catch {}

            _profile = await profileTask;
            _personalInfo = _profile;


            if (_profile is null)
            {
                _error = "User profile not found.";
                return;
            }

            _fullName = AppFormatter.BuildFullName(_profile.FirstName, _profile.LastName);
            _initials = AppFormatter.GetInitials(_fullName);
            _employmentDuration = AppFormatter.FormatDurationFrom(_profile.UserStartDate ?? _profile.PositionStartDate);

            try
            {
                if (_profile.Avatar != null && !string.IsNullOrEmpty(_profile.Avatar.ContentBase64))
                {
                    _avatarDataUrl = $"data:{(_profile.Avatar.ContentType ?? "image/png")};base64,{_profile.Avatar.ContentBase64}";
                }
                else
                {
                    var avatar = await avatarTask;
                    if (avatar != null && !string.IsNullOrEmpty(avatar.ContentBase64))
                        _avatarDataUrl = $"data:{(avatar.ContentType ?? "image/png")};base64,{avatar.ContentBase64}";
                }
            }
            catch { }

            SyncIntlPhoneInputsFromPersonalInfo();
            _educationHistoryRecords = (_personalInfo?.EducationHistories ?? new List<EducationHistoryDto>())
                .Select(x => new EducationHistoryRecord
                {
                    Id = x.Id,
                    Level = x.Level ?? string.Empty,
                    Institution = x.Institution ?? string.Empty,
                    Program = x.Program,
                    GraduationDate = x.GraduationDate,
                    Status = x.Status
                })
                .ToList();
        }
        catch (HttpRequestException ex)
        {
            _error = "Failed to load employee profile.";
            Snackbar.Add($"{_error} {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            _error = "Unexpected error while loading profile.";
            Snackbar.Add($"{_error} {ex.Message}", Severity.Error);
        }
        finally
        {   
            _loading = false;
        }
    }

    private async Task RefreshProfileAsync()
    {
        if (_employeeId is null)
            return;

        var latestProfile = await UserService.GetEmployeeCardAsync(_employeeId.Value);
        if (latestProfile is null)
            return;

        _profile = latestProfile;
        _personalInfo = _profile;

        _fullName = AppFormatter.BuildFullName(_profile.FirstName, _profile.LastName);
        _initials = AppFormatter.GetInitials(_fullName);
        _employmentDuration = AppFormatter.FormatDurationFrom(_profile.UserStartDate ?? _profile.PositionStartDate);

        SyncIntlPhoneInputsFromPersonalInfo();
        _educationHistoryRecords = (_personalInfo?.EducationHistories ?? new List<EducationHistoryDto>())
            .Select(x => new EducationHistoryRecord
            {
                Id = x.Id,
                Level = x.Level ?? string.Empty,
                Institution = x.Institution ?? string.Empty,
                Program = x.Program,
                GraduationDate = x.GraduationDate,
                Status = x.Status
            })
            .ToList();
    }

    private bool _isEditingActionInProgress;
    
    private async Task StartBasicInfoEdit()
    {
        if (_isEditingActionInProgress || _personalInfo is null) return;
        _isEditingActionInProgress = true;
        try
        {
            _basicInfoBackup = new EmployeeCardDto
            {
                FirstName = _personalInfo.FirstName,
                LastName = _personalInfo.LastName,
                RegistrationNumber = _personalInfo.RegistrationNumber,
                UserStartDate = _personalInfo.UserStartDate,
                PositionStartDate = _personalInfo.PositionStartDate,
                ContractType = _personalInfo.ContractType,
                ContractEndDate = _personalInfo.ContractEndDate,
                WorkModel = _personalInfo.WorkModel,
                PayrollLocationId = _personalInfo.PayrollLocationId
            };
            _editingBasicInfo = true;
            await InvokeAsync(StateHasChanged);
        }
        finally { _isEditingActionInProgress = false; }
    }

    private async Task StartContactsEdit()
    {
        if (_isEditingActionInProgress || _personalInfo is null) return;
        _isEditingActionInProgress = true;
        try
        {
            _contactsBackup = new EmployeeCardDto
            {
                Email = _personalInfo.Email,
                PhoneNumber = _personalInfo.PhoneNumber,
                PersonalEmail = _personalInfo.PersonalEmail,
                PersonalPhoneNumber = _personalInfo.PersonalPhoneNumber
            };
            SyncIntlPhoneInputsFromPersonalInfo();
            _editingContacts = true;
            await InvokeAsync(StateHasChanged);
        }
        finally { _isEditingActionInProgress = false; }
    }

    private async Task StartCitizenshipInfoEdit()
    {
        if (_isEditingActionInProgress || _personalInfo is null) return;
        _isEditingActionInProgress = true;
        try
        {
            _citizenshipInfoBackup = new EmployeeCardDto
            {
                DateOfBirth = _personalInfo.DateOfBirth,
                Gender = _personalInfo.Gender,
                Nationality = _personalInfo.Nationality,
                CitizenshipNumber = _personalInfo.CitizenshipNumber,
                DisabilityStatus = _personalInfo.DisabilityStatus,
                DisabilityDegree = _personalInfo.DisabilityDegree
            };
            _editingCitizenshipInfo = true;
            await InvokeAsync(StateHasChanged);
        }
        finally { _isEditingActionInProgress = false; }
    }

    private async Task StartEmergencyInfoEdit()
    {
        if (_isEditingActionInProgress || _personalInfo is null) return;
        _isEditingActionInProgress = true;
        try
        {
            _emergencyInfoBackup = new EmployeeCardDto
            {
                EmergencyContacts = _personalInfo.EmergencyContacts?.Select(c => new EmergencyContactDto
                {
                    Id = c.Id,
                    UserId = c.UserId,
                    FullName = c.FullName,
                    Relationship = c.Relationship,
                    PhoneNumber = c.PhoneNumber
                }).ToList() ?? new List<EmergencyContactDto>()
            };

            _emergencyContactPhones = _personalInfo.EmergencyContacts?
                .ToDictionary(c => c, c => new IntlTel { Number = c.PhoneNumber })
                ?? new Dictionary<EmergencyContactDto, IntlTel>();

            _editingEmergencyInfo = true;
            await InvokeAsync(StateHasChanged);
        }
        finally { _isEditingActionInProgress = false; }
    }

    private void OnEmergencyPhoneChanged(EmergencyContactDto contact, IntlTel newValue)
    {
        _emergencyContactPhones[contact] = newValue;
        contact.PhoneNumber = newValue.Number;
    }
    private async Task StartAddressInfoEdit()
    {
        if (_isEditingActionInProgress || _personalInfo is null) return;
        _isEditingActionInProgress = true;
        try
        {
            _addressInfoBackup = new EmployeeCardDto
            {
                LegalAddress = _personalInfo.LegalAddress,
                CurrentAddress = _personalInfo.CurrentAddress,
                City = _personalInfo.City,
                Country = _personalInfo.Country
            };
            _editingAddressInfo = true;
            await InvokeAsync(StateHasChanged);
        }
        finally { _isEditingActionInProgress = false; }
    }

    private async Task StartEducationInfoEdit()
    {
        if (_isEditingActionInProgress || _personalInfo is null) return;
        _isEditingActionInProgress = true;
        try
        {
            _educationHistoryBackup = _educationHistoryRecords.Select(CloneEducationHistoryRecord).ToList();
            _editingEducationInfo = true;
            await InvokeAsync(StateHasChanged);
        }
        finally { _isEditingActionInProgress = false; }
    }

    private void CancelBasicInfoEdit()
    {
        if (_basicInfoBackup is not null && _personalInfo is not null)
        {
            _personalInfo.FirstName = _basicInfoBackup.FirstName;
            _personalInfo.LastName = _basicInfoBackup.LastName;
            _personalInfo.RegistrationNumber = _basicInfoBackup.RegistrationNumber;
            _personalInfo.UserStartDate = _basicInfoBackup.UserStartDate;
            _personalInfo.PositionStartDate = _basicInfoBackup.PositionStartDate;
            _personalInfo.ContractType = _basicInfoBackup.ContractType;
            _personalInfo.ContractEndDate = _basicInfoBackup.ContractEndDate;
            _personalInfo.WorkModel = _basicInfoBackup.WorkModel;
            _personalInfo.PayrollLocationId = _basicInfoBackup.PayrollLocationId;
        }
        _editingBasicInfo = false;
        _basicInfoBackup = null;
    }

    private void CancelContactsEdit()
    {
        if (_contactsBackup is not null && _personalInfo is not null)
        {
            _personalInfo.Email = _contactsBackup.Email;
            _personalInfo.PhoneNumber = _contactsBackup.PhoneNumber;
            _personalInfo.PersonalEmail = _contactsBackup.PersonalEmail;
            _personalInfo.PersonalPhoneNumber = _contactsBackup.PersonalPhoneNumber;
            SyncIntlPhoneInputsFromPersonalInfo();
        }
        _editingContacts = false;
        _contactsBackup = null;
    }

    private void CancelCitizenshipInfoEdit()
    {
        if (_citizenshipInfoBackup is not null && _personalInfo is not null)
        {
            _personalInfo.DateOfBirth = _citizenshipInfoBackup.DateOfBirth;
            _personalInfo.Gender = _citizenshipInfoBackup.Gender;
            _personalInfo.Nationality = _citizenshipInfoBackup.Nationality;
            _personalInfo.CitizenshipNumber = _citizenshipInfoBackup.CitizenshipNumber;
            _personalInfo.DisabilityStatus = _citizenshipInfoBackup.DisabilityStatus;
            _personalInfo.DisabilityDegree = _citizenshipInfoBackup.DisabilityDegree;
        }
        _editingCitizenshipInfo = false;
        _citizenshipInfoBackup = null;
    }

    private void CancelEmergencyInfoEdit()
    {
        if (_emergencyInfoBackup is not null && _personalInfo is not null)
        {
            _personalInfo.MaritalStatus = _emergencyInfoBackup.MaritalStatus;
            _personalInfo.SpouseFullName = _emergencyInfoBackup.SpouseFullName;
            _personalInfo.EmergencyContacts = _emergencyInfoBackup.EmergencyContacts?.Select(c => new EmergencyContactDto
            {
                Id = c.Id,
                UserId = c.UserId,
                FullName = c.FullName,
                Relationship = c.Relationship,
                PhoneNumber = c.PhoneNumber
            }).ToList() ?? new List<EmergencyContactDto>();
        }
        _editingEmergencyInfo = false;
        _emergencyInfoBackup = null;
        _emergencyContactPhones.Clear();
    }

    private void AddEmergencyContact()
    {
        if (_personalInfo == null) return;
        _personalInfo.EmergencyContacts ??= new List<EmergencyContactDto>();

        var newContact = new EmergencyContactDto { UserId = _employeeId ?? 0 };
        _personalInfo.EmergencyContacts.Add(newContact);
        _emergencyContactPhones[newContact] = new IntlTel();
    }

    private async Task StartFamilyInfoEdit()
    {
        if (_isEditingActionInProgress || _personalInfo is null) return;
        _isEditingActionInProgress = true;
        try
        {
            _familyInfoBackup = new EmployeeCardDto
            {
                MaritalStatus = _personalInfo.MaritalStatus,
                SpouseFullName = _personalInfo.SpouseFullName,
                Children = _personalInfo.Children?.Select(c => new ChildInfoDto
                {
                    Id = c.Id,
                    FullName = c.FullName,
                    DateOfBirth = c.DateOfBirth
                }).ToList() ?? new List<ChildInfoDto>()
            };
            _editingFamilyInfo = true;
            await InvokeAsync(StateHasChanged);
        }
        finally { _isEditingActionInProgress = false; }
    }

    private void AddChild()
    {
        if (_personalInfo == null) return;
        _personalInfo.Children ??= new List<ChildInfoDto>();
        _personalInfo.Children.Add(new ChildInfoDto { DateOfBirth = null });
    }

    private void RemoveChild(ChildInfoDto child)
    {
        if (_personalInfo?.Children == null) return;
        _personalInfo.Children.Remove(child);
    }

    private void CancelFamilyInfoEdit()
    {
        if (_familyInfoBackup is not null && _personalInfo is not null)
        {
            _personalInfo.MaritalStatus = _familyInfoBackup.MaritalStatus;
            _personalInfo.SpouseFullName = _familyInfoBackup.SpouseFullName;
            _personalInfo.Children = _familyInfoBackup.Children?.Select(c => new ChildInfoDto
            {
                Id = c.Id,
                FullName = c.FullName,
                DateOfBirth = c.DateOfBirth
            }).ToList() ?? new List<ChildInfoDto>();
        }
        _editingFamilyInfo = false;
        _familyInfoBackup = null;
    }

    private async Task SaveFamilyInfoAsync()
    {
        if (_personalInfo is null || _employeeId is null) return;
        var dto = new UpdateFamilyInfoDto
        {
            UserId = _employeeId.Value,
            MaritalStatus = _personalInfo.MaritalStatus,
            SpouseFullName = _personalInfo.SpouseFullName,
            Children = _personalInfo.Children?.Select(c => new ChildInfoDto
            {
                Id = c.Id,
                FullName = c.FullName,
                DateOfBirth = c.DateOfBirth
            }).ToList() ?? new List<ChildInfoDto>()
        };

        await ExecuteSaveRequestAsync(
            () => UserService.UpdateFamilyInfoAsync(_employeeId.Value, dto),
            successMessage: "Family information updated successfully.",
            failureMessage: "Failed to update family information.",
            refreshProfileOnSuccess: true,
            onSuccess: () =>
            {
                _editingFamilyInfo = false;
                _familyInfoBackup = null;
            });
    }

    private void RemoveEmergencyContact(EmergencyContactDto contact)
    {
        if (_personalInfo?.EmergencyContacts == null || contact is null) return;

        _personalInfo.EmergencyContacts.Remove(contact);
        _emergencyContactPhones.Remove(contact);
    }

    private void CancelAddressInfoEdit()
    {
        if (_addressInfoBackup is not null && _personalInfo is not null)
        {
            _personalInfo.LegalAddress = _addressInfoBackup.LegalAddress;
            _personalInfo.CurrentAddress = _addressInfoBackup.CurrentAddress;
            _personalInfo.City = _addressInfoBackup.City;
            _personalInfo.Country = _addressInfoBackup.Country;
        }
        _editingAddressInfo = false;
        _addressInfoBackup = null;
    }

    private void CancelEducationInfoEdit()
    {
        _editingEducationInfo = false;
        _educationHistoryRecords = _educationHistoryBackup.Select(CloneEducationHistoryRecord).ToList();
        _educationHistoryBackup = new List<EducationHistoryRecord>();
    }

    private async Task SaveBasicInfoAsync()
    {
        if (_personalInfo is null || _employeeId is null) return;
        var dto = new UpdateBasicInfoDto
        {
            UserId = _employeeId.Value,
            FirstName = _personalInfo.FirstName,
            LastName = _personalInfo.LastName,
            RegistrationNumber = _personalInfo.RegistrationNumber,
            UserStartDate = _personalInfo.UserStartDate,
            PositionStartDate = _personalInfo.PositionStartDate,
            ContractType = _personalInfo.ContractType,
            ContractEndDate = _personalInfo.ContractEndDate,
            WorkModel = _personalInfo.WorkModel,
            PayrollLocationId = _personalInfo.PayrollLocationId
        };

        await ExecuteSaveRequestAsync(
            () => UserService.UpdateBasicInfoAsync(_employeeId.Value, dto),
            successMessage: "Basic information updated successfully.",
            failureMessage: "Failed to update basic information.",
            refreshProfileOnSuccess: true,
            onSuccess: () =>
            {
                _editingBasicInfo = false;
                _basicInfoBackup = null;
            });
