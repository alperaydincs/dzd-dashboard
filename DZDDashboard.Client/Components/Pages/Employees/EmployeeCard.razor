    private async Task SaveContactsAsync()
    {
        if (_personalInfo is null || _employeeId is null) return;
        var workPhone = _workPhoneIntl?.Number;
        var personalPhone = _personalPhoneIntl?.Number;

        var dto = new UpdateContactsDto
        {
            UserId = _employeeId.Value,
            Email = _personalInfo.Email,
            PhoneNumber = workPhone,
            PersonalEmail = _personalInfo.PersonalEmail,
            PersonalPhoneNumber = personalPhone
        };

        if (!IsEmailValidOrEmpty(dto.Email))
        {
            Snackbar.Add("Please enter a valid work email address.", Severity.Error);
            return;
        }

        if (!IsEmailValidOrEmpty(dto.PersonalEmail))
        {
            Snackbar.Add("Please enter a valid personal email address.", Severity.Error);
            return;
        }

        await ExecuteSaveRequestAsync(
            () => UserService.UpdateContactsAsync(_employeeId.Value, dto),
            successMessage: "Contact information updated successfully.",
            failureMessage: "Failed to update contact information.",
            refreshProfileOnSuccess: true,
            onSuccess: () =>
            {
                _editingContacts = false;
                _contactsBackup = null;
            });
    }

