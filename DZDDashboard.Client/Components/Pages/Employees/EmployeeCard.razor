                            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4 mb-4">
                                <MudButton Variant="Variant.Outlined" OnClick="CancelEmergencyInfoEdit">Cancel</MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEmergencyInfoAsync">Save</MudButton>
                            </MudStack>
                        }

                        <MudDivider Class="my-4" />
                         
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2 mt-4">
                            <div class="dzd-section-title" style="margin:0;">
                                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background-color:var(--dzd-brand-primary);margin-left:4px;margin-right:5px;vertical-align:middle;" aria-hidden="true"></span> Family Information
                            </div>
                            @if (!_familyEdit.IsEditing)
                            {
                                <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="StartFamilyInfoEdit" />
                            }
                        </MudStack>
                        <MudPaper Elevation="1" Class="dzd-card pa-6">
                             <MudGrid Spacing="4">
                                 <MudItem xs="12" md="6" Class="dzd-family-align-item">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.House" Size="Size.Small" /> Marital Status</div>
                                    @if (_familyEdit.IsEditing)
                                    {
                                        <MudSelect T="string" @bind-Value="_profile!.MaritalStatus" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input" AnchorOrigin="Origin.BottomLeft">
                                            <MudSelectItem Value=@("Single")>Single</MudSelectItem>
                                            <MudSelectItem Value=@("Married")>Married</MudSelectItem>
                                            <MudSelectItem Value=@("Divorced")>Divorced</MudSelectItem>
                                            <MudSelectItem Value=@("Widowed")>Widowed</MudSelectItem>
                                        </MudSelect>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.MaritalStatus ?? "-")</MudText>
                                    }
                                </MudItem>
                                   <MudItem xs="12" md="6" Class="dzd-family-align-item">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.User" Size="Size.Small" /> Spouse Name</div>
                                    @if (_familyEdit.IsEditing)
                                    {
                                        <MudTextField @bind-Value="_profile!.SpouseFullName" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input"  />
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.SpouseFullName ?? "-")</MudText>
                                    }
                                </MudItem>

                                @if (_profile?.Children != null && _profile.Children.Count > 0)
                                {
                                    @foreach (var child in _profile.Children)
                                    {
                                            <MudItem xs="12" md="6">
                                                <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.User" Size="Size.Small" /> Child Full Name</div>
                                                @if (_familyEdit.IsEditing)
                                                {
                                                    <MudTextField @bind-Value="child.FullName" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input"  />
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary);">@child.FullName</MudText>
                                                }
                                            </MudItem>
                                            <MudItem xs="12" md="6">
                                                <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.Cake" Size="Size.Small" /> Child Birth Date</div>
                                                <div class="dzd-inline-edit-row">
                                                    @if (_familyEdit.IsEditing)
                                                    {
                                                        <MudDatePicker AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" @bind-Date="child.DateOfBirth" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input dzd-inline-edit-control"  />
                                                        <MudIconButton Icon="@DzdIcons.Trash" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveChild(child))" Class="dzd-inline-edit-action" />
                                                    }
                                                    else
                                                    {
                                                        <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary);">@AppFormatter.FormatDate(child.DateOfBirth)</MudText>
                                                    }
                                                </div>
                                            </MudItem>
                                    }
                                }
                                else if (!_familyEdit.IsEditing)
                                {
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary italic">No children recorded.</MudText>
                                    </MudItem>
                                }

                                @if (_familyEdit.IsEditing)
                                {
                                    <MudItem xs="12">
                                        <MudButton Variant="Variant.Outlined" StartIcon="@DzdIcons.Plus" OnClick="AddChild" Class="d-flex align-center gap-2">Add Child</MudButton>
                                    </MudItem>
                                }

                            
                             </MudGrid>
                        </MudPaper>

                        @if (_familyEdit.IsEditing)
                        {
                            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4 mb-4">
                                <MudButton Variant="Variant.Outlined" OnClick="CancelFamilyInfoEdit">Cancel</MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveFamilyInfoAsync">Save</MudButton>
                            </MudStack>
                        }
                        
                        <MudDivider Class="my-4" />

                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3 mt-4">
                            <div class="dzd-section-title" style="margin:0;">
                                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background-color:var(--dzd-brand-primary);margin-left:4px;margin-right:5px;vertical-align:middle;" aria-hidden="true"></span> Address Information
                            </div>
                            @if (!_addressEdit.IsEditing)
                            {
                                <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="StartAddressInfoEdit" />
                            }
                        </MudStack>
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudPaper Elevation="1" Class="dzd-card pa-6 h-100">
                                    <MudStack Spacing="4">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudIcon Icon="@DzdIcons.House" Size="Size.Small" Style="color: var(--dzd-brand-primary); font-size: 18px;" />
                                            <MudText Typo="Typo.subtitle2" Style="font-weight: 600; color: var(--dzd-text-secondary); margin: 0;">Registered Address</MudText>
                                        </MudStack>
                                        <MudDivider Class="my-0" />
                                        
                                        <MudStack Spacing="3">
                                            <div>
                                                <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500; margin-bottom: 6px; display: block;">
                                                    <MudIcon Icon="@DzdIcons.House" Size="Size.Small" Style="margin-right: 4px; vertical-align: middle;" /> Address
                                                </MudText>
                                                @if (_addressEdit.IsEditing)
                                                {
                                                    <MudTextField @bind-Value="_profile!.LegalAddress" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input" Placeholder="Enter registered address" />
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.LegalAddress ?? "-")</MudText>
                                                }
                                            </div>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            </MudItem>

                            @* City and Country belong to the current/living address; they are not duplicated here.
                               The domain model has a single City/Country field — see User.PersonalInfo.cs. *@
                            <MudItem xs="12" md="6">
                                <MudPaper Elevation="1" Class="dzd-card pa-6 h-100">
                                    <MudStack Spacing="4">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudIcon Icon="@DzdIcons.MapPin" Size="Size.Small" Style="color: var(--dzd-brand-primary); font-size: 18px;" />
                                            <MudText Typo="Typo.subtitle2" Style="font-weight: 600; color: var(--dzd-text-secondary); margin: 0;">Current Address</MudText>
                                        </MudStack>
                                        <MudDivider Class="my-0" />
                                        
                                        <MudStack Spacing="3">
                                            <div>
                                                <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500; margin-bottom: 6px; display: block;">
                                                    <MudIcon Icon="@DzdIcons.MapPin" Size="Size.Small" Style="margin-right: 4px; vertical-align: middle;" /> Address
                                                </MudText>
                                                @if (_addressEdit.IsEditing)
                                                {
                                                    <MudTextField @bind-Value="_profile.CurrentAddress" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input" Placeholder="Enter current address" />
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.CurrentAddress ?? "-")</MudText>
                                                }
                                            </div>
                                            <div>
                                                <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500; margin-bottom: 6px; display: block;">
                                                    <MudIcon Icon="@DzdIcons.Building" Size="Size.Small" Style="margin-right: 4px; vertical-align: middle;" /> City
                                                </MudText>
                                                @if (_addressEdit.IsEditing)
                                                {
                                                    <MudTextField @bind-Value="_profile.City" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input" Placeholder="Enter city" />
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.City ?? "-")</MudText>
                                                }
                                            </div>
                                            <div>
                                                <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500; margin-bottom: 6px; display: block;">
                                                    <MudIcon Icon="@DzdIcons.Globe" Size="Size.Small" Style="margin-right: 4px; vertical-align: middle;" /> Country
                                                </MudText>
                                                @if (_addressEdit.IsEditing)
                                                {
                                                    <MudTextField @bind-Value="_profile.Country" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input" Placeholder="Enter country" />
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.Country ?? "-")</MudText>
                                                }
                                            </div>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>
                        @if (_addressEdit.IsEditing)
                        {
                            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                                <MudButton Variant="Variant.Outlined" OnClick="CancelAddressInfoEdit">Cancel</MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAddressInfoAsync">Save</MudButton>
                            </MudStack>
                        }

                        <MudDivider Class="my-4" />

                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2 mt-4">
                            <div class="dzd-section-title" style="margin:0;">
                                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background-color:var(--dzd-brand-primary);margin-left:4px;margin-right:5px;vertical-align:middle;" aria-hidden="true"></span> Education Information
                            </div>
                            @if (!_educationEdit.IsEditing)
                            {
                                <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="StartEducationInfoEdit" />
                            }
                        </MudStack>
                        <MudPaper Elevation="1" Class="dzd-card pa-6">
                            @if (!_educationEdit.IsEditing)
                            {
                                @if (_educationHistoryRecords.Count == 0)
                                {
                                    <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">No education history added yet.</MudText>
                                }
                                else
                                {
                                    <MudStack Spacing="3">
                                        @foreach (var record in _educationHistoryRecords)
                                        {
                                            <MudPaper Class="pa-3 d-flex align-center gap-4" Elevation="0" Outlined="true" Style="border-radius:8px;">
                                                <MudAvatar Color="@GetEducationLevelColor(record.Level)" Variant="Variant.Outlined" Size="Size.Medium"><MudIcon Icon="@DzdIcons.GraduationCap" /></MudAvatar>
                                                <div style="flex-grow:1;">
                                                    <MudText Typo="Typo.subtitle2">@record.Level <MudChip T="string" Size="Size.Small" Color="@GetEducationStatusColor(record.Status)" Variant="Variant.Text">@(record.Status ?? "-" )</MudChip></MudText>
                                                    <MudText Typo="Typo.body2">@record.Institution@(string.IsNullOrWhiteSpace(record.Program) ? string.Empty : $" - {record.Program}")</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Default">@AppFormatter.FormatDate(record.GraduationDate)</MudText>
                                                </div>
                                                @if (_educationEdit.IsEditing)
                                                {
                                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                        <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="@(async () => await EditEducationHistoryRecordAsync(record))" />
                                                        <MudIconButton Icon="@DzdIcons.Trash" Size="Size.Small" Color="Color.Error" OnClick="@(async () => await RemoveEducationHistoryRecordAsync(record))" />
                                                    </MudStack>
                                                }
                                            </MudPaper>
                                        }
                                    </MudStack>
                                }
                            }
                            else
                            {
                                @if (_educationHistoryRecords.Count == 0)
                                {
                                    <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">No education history added yet.</MudText>
                                }
                                else
                                {
                                    <MudStack Spacing="3">
                                        @foreach (var record in _educationHistoryRecords)
                                        {
                                            <MudPaper Class="pa-3 d-flex align-center gap-4" Elevation="0" Outlined="true" Style="border-radius:8px;">
                                                <MudAvatar Color="@GetEducationLevelColor(record.Level)" Variant="Variant.Outlined" Size="Size.Medium"><MudIcon Icon="@DzdIcons.GraduationCap" /></MudAvatar>
                                                <div style="flex-grow:1;">
                                                    <MudText Typo="Typo.subtitle2">@record.Level <MudChip T="string" Size="Size.Small" Color="@GetEducationStatusColor(record.Status)" Variant="Variant.Text">@(record.Status ?? "-")</MudChip></MudText>
                                                    <MudText Typo="Typo.body2">@record.Institution@(string.IsNullOrWhiteSpace(record.Program) ? string.Empty : $" - {record.Program}")</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Default">@AppFormatter.FormatDate(record.GraduationDate)</MudText>
                                                </div>
                                                @if (_educationEdit.IsEditing)
                                                {
                                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                        <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="@(async () => await EditEducationHistoryRecordAsync(record))" />
                                                        <MudIconButton Icon="@DzdIcons.Trash" Size="Size.Small" Color="Color.Error" OnClick="@(async () => await RemoveEducationHistoryRecordAsync(record))" />
                                                    </MudStack>
                                                }
                                            </MudPaper>
                                        }
                                    </MudStack>
                                }

                                <MudStack Row="true" Justify="Justify.FlexStart" Class="mt-3">
                                    <MudButton Variant="Variant.Outlined" StartIcon="@DzdIcons.Plus" OnClick="OpenAddEducationHistoryDialogAsync" Class="d-flex align-center gap-2">Add Education Record</MudButton>
                                </MudStack>
                            }
                        </MudPaper>
                        @if (_educationEdit.IsEditing)
                        {
                            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4 mb-4">
                                <MudButton Variant="Variant.Outlined" OnClick="CancelEducationInfoEdit">Cancel</MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEducationInfoAsync">Save</MudButton>
                            </MudStack>
                        }

                        <MudDivider Class="my-4" />
                        <PaymentSection UserId="@EmployeeId" />
                    </div>
                }
            }
        </div>
    }
</MudContainer>

