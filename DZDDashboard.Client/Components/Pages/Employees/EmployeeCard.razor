                                                <MudAvatar Color="@GetEducationLevelColor(record.Level)" Variant="Variant.Outlined" Size="Size.Medium"><MudIcon Icon="@DzdIcons.GraduationCap" /></MudAvatar>
                                                <div style="flex-grow:1;">
                                                    <MudText Typo="Typo.subtitle2">@record.Level <MudChip T="string" Size="Size.Small" Color="@GetEducationStatusColor(record.Status)" Variant="Variant.Text">@(record.Status ?? "-")</MudChip></MudText>
                                                    <MudText Typo="Typo.body2">@record.Institution@(string.IsNullOrWhiteSpace(record.Program) ? string.Empty : $" - {record.Program}")</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Default">@AppFormatter.FormatDate(record.GraduationDate)</MudText>
                                                </div>
                                                @if (_editingEducationInfo)
