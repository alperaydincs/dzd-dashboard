@using DZDDashboard.Client.OrgChart
@using DZDDashboard.Common.DTOs.Organization
@using DZDDashboard.Common.DTOs.Users

<div class="tree">
    <ul>
        @foreach (var root in Nodes)
        {
            <OrgChartNode Node="root" 
                          IsEditMode="IsEditMode" 
                          IsSelectionMode="IsSelectionMode"
                          OnAddChild="OnAddChild"
                          OnEditNode="OnEditNode"
                          OnDeleteNode="OnDeleteNode"
                          OnNodeSelected="OnNodeSelected" />
        }
    </ul>
</div>

@code {
    [Parameter] public List<OrgChartNodeItem> Nodes { get; set; } = new();
    [Parameter] public bool IsEditMode { get; set; }
    [Parameter] public bool IsSelectionMode { get; set; }
    [Parameter] public EventCallback<OrgChartNodeItem> OnAddChild { get; set; }
    [Parameter] public EventCallback<OrgChartNodeItem> OnEditNode { get; set; }
    [Parameter] public EventCallback<OrgChartNodeItem> OnDeleteNode { get; set; }
    [Parameter] public EventCallback<OrgChartNodeItem> OnNodeSelected { get; set; }
}

<style>
    
    .tree ul {
        padding-top: 20px;
        position: relative;
        transition: all 0.5s;
        -webkit-transition: all 0.5s;
        -moz-transition: all 0.5s;
        display: flex;
        justify-content: center;
    }

    .tree > ul > li {
        padding-top: 0 !important;
    }

    .tree > ul > li::before,
    .tree > ul > li::after {
        display: none !important;
    }

    .tree li {
        float: left;
        text-align: center;
        list-style-type: none;
        position: relative;
        padding: 20px 5px 0 5px;
        transition: all 0.5s;
        -webkit-transition: all 0.5s;
        -moz-transition: all 0.5s;
    }

    .tree li::before, .tree li::after {
        content: '';
        position: absolute;
        top: 0;
        right: 50%;
        border-top: 1px solid #ccc;
        width: 50%;
        height: 20px;
    }

    .tree li::after {
        right: auto;
        left: 50%;
        border-left: 1px solid #ccc;
    }

    .tree li:only-child::after, .tree li:only-child::before {
        display: none;
    }

    .tree li:only-child {
        padding-top: 0;
    }

    .tree li:first-child::before, .tree li:last-child::after {
        border: 0 none;
    }

    .tree li:last-child::before {
        border-right: 1px solid #ccc;
        border-radius: 0 5px 0 0;
        -webkit-border-radius: 0 5px 0 0;
        -moz-border-radius: 0 5px 0 0;
    }

    .tree li:first-child::after {
        border-radius: 5px 0 0 0;
        -webkit-border-radius: 5px 0 0 0;
        -moz-border-radius: 5px 0 0 0;
    }

    .tree ul ul::before {
        content: '';
        position: absolute;
        top: 0;
        left: 50%;
        border-left: 1px solid #ccc;
        width: 0;
        height: 20px;
    }

    .tree li .node-container {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        z-index: 2;
    }

    .tree li .node-row {
        align-items: stretch;
    }

    .tree li .node-card {
        border: 1px solid #d7dbe4;
        text-decoration: none;
        color: #101828;
        display: inline-block;
        border-radius: 14px;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        background-color: #ffffff;
        min-width: 260px;
        max-width: 300px;
        margin-bottom: 0;
        box-shadow: 0 6px 16px rgba(15, 23, 42, 0.06);
    }

    .tree li .node-card:hover {
        border-color: #a8b1c2;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.12);
        transform: translateY(-1px);
    }

    .tree li .node-card.node-card-empty {
        border-style: dashed;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    }

    .tree li .node-card-content {
        width: 100%;
        align-items: center;
    }

    .tree li .node-avatar {
        width: 50px;
        height: 50px;
        font-size: 0.95rem;
        font-weight: 600;
    }

    .tree li .node-avatar-empty {
        background-color: #e5e7eb;
        color: #4b5563;
    }

    .tree li .node-texts {
        min-width: 0;
        text-align: left;
    }

    .tree li .node-primary {
        font-weight: 700;
        color: #111827;
        line-height: 1.15;
        margin-bottom: 2px;
    }

    .tree li .node-primary-empty {
        color: #b45309;
    }

    .tree li .node-position {
        color: #6b7280;
        margin-bottom: 6px;
    }

    .tree li .node-meta-chip {
        border-color: #d1d5db;
        color: #374151;
        background: #f9fafb;
        font-size: 0.72rem;
        max-width: 100%;
        white-space: normal;
        height: auto;
        line-height: 1.2;
    }

    .tree li .node-card:hover + ul li::after,
    .tree li .node-card:hover + ul li::before,
    .tree li .node-card:hover + ul::before,
    .tree li .node-card:hover + ul ul::before {
        border-color: #94a0b4;
    }
    
    .expand-btn {
        margin-top: 0;
        background-color: #ffffff;
        border: 1px solid #d1d5db;
        z-index: 3;
        box-shadow: 0 4px 10px rgba(15, 23, 42, 0.1);
    }
    
    .expand-btn:hover {
        background-color: #f3f4f6;
    }
</style>
