                                                else
                                                {
                                                    <MudText Typo="Typo.body2" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.CurrentAddress ?? Loc["common.notAvailable"])</MudText>
                                                }
                                            </div>
                                            <div>
                                                <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500; margin-bottom: 6px; display: block;">
                                                    <MudIcon Icon="@DzdIcons.Building" Size="Size.Small" Style="margin-right: 4px; vertical-align: middle; color: var(--dzd-brand-secondary);" /> @Loc["employeeProfile.city"]
                                                </MudText>
                                                @if (_addressEdit.IsEditing)
                                                {
                                                    <MudTextField @bind-Value="_profile.City" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input" Placeholder="@Loc["employeeProfile.enterCity"]" />
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.City ?? Loc["common.notAvailable"])</MudText>
                                                }
                                            </div>
                                            <div>
                                                <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500; margin-bottom: 6px; display: block;">
                                                    <MudIcon Icon="@DzdIcons.Globe" Size="Size.Small" Style="margin-right: 4px; vertical-align: middle; color: var(--dzd-brand-secondary);" /> @Loc["employeeProfile.country"]
                                                </MudText>
                                                @if (_addressEdit.IsEditing)
                                                {
                                                    <MudTextField @bind-Value="_profile.Country" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input" Placeholder="@Loc["employeeProfile.enterCountry"]" />
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.Country ?? Loc["common.notAvailable"])</MudText>
                                                }
                                            </div>
                                            <div>
                                                <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500; margin-bottom: 6px; display: block;">
                                                    <MudIcon Icon="@DzdIcons.Timer" Size="Size.Small" Style="margin-right: 4px; vertical-align: middle; color: var(--dzd-purple-500);" /> @Loc["employeeProfile.currentAddressWorkPeriod"]
                                                </MudText>
                                                <MudText Typo="Typo.body2" Style="font-weight:500; color:var(--dzd-text-primary);">@(FormatDurationLocalized(_profile.CurrentAddressChangedAt) ?? Loc["common.notAvailable"])</MudText>
                                            </div>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>
                        @if (_addressEdit.IsEditing)
                        {
                            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                                <MudButton Variant="Variant.Outlined" OnClick="CancelAddressInfoEdit">@Loc["common.cancel"]</MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAddressInfoAsync">@Loc["common.save"]</MudButton>
                            </MudStack>
                        }

                        <MudDivider Class="my-4" />

                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2 mt-4">
                            <div class="dzd-section-title" style="margin:0;">
                                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background-color:var(--dzd-blue-500);margin-left:4px;margin-right:5px;vertical-align:middle;" aria-hidden="true"></span> @Loc["employeeProfile.educationInformation"]
                            </div>
                            @if (!_educationEdit.IsEditing)
                            {
                                <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="StartEducationInfoEdit" />
                            }
                        </MudStack>
                        <MudPaper Elevation="1" Class="dzd-card pa-6">
                            @if (!_educationEdit.IsEditing)
                            {
                                @if (_educationHistoryRecords.Count == 0)
                                {
                                    <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["employeeProfile.noEducationHistory"]</MudText>
                                }
                                else
                                {
                                    <MudStack Spacing="3">
                                        @foreach (var record in _educationHistoryRecords)
                                        {
                                            <MudPaper Class="pa-3 d-flex align-center gap-4" Elevation="0" Outlined="true" Style="border-radius:8px;">
                                                <MudAvatar Class="@GetEducationLevelAvatarClass(record.EducationLevel)" Variant="Variant.Outlined" Size="Size.Medium"><MudIcon Icon="@DzdIcons.GraduationCap" /></MudAvatar>
                                                <div style="flex-grow:1;">
                                                    <MudText Typo="Typo.subtitle2">@GetEducationLevelName(record.EducationLevel) <MudChip T="string" Size="Size.Small" Class="@GetEducationLevelChipClass(record.EducationLevel)" Variant="Variant.Text">@GetEducationStatusName(record.Status)</MudChip></MudText>
                                                    <MudText Typo="Typo.body2">@record.Institution@(string.IsNullOrWhiteSpace(record.Program) ? string.Empty : $" - {record.Program}")</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Default">@AppFormatter.FormatDate(record.GraduationDate)</MudText>
                                                </div>
                                                @if (_educationEdit.IsEditing)
                                                {
                                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                        <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="@(async () => await EditEducationHistoryRecordAsync(record))" />
                                                        <MudIconButton Icon="@DzdIcons.Trash" Size="Size.Small" Color="Color.Error" OnClick="@(async () => await RemoveEducationHistoryRecordAsync(record))" />
                                                    </MudStack>
                                                }
                                            </MudPaper>
                                        }
                                    </MudStack>
                                }
                            }
                            else
                            {
                                @if (_educationHistoryRecords.Count == 0)
                                {
                                    <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["employeeProfile.noEducationHistory"]</MudText>
                                }
                                else
                                {
                                    <MudStack Spacing="3">
                                        @foreach (var record in _educationHistoryRecords)
                                        {
                                            <MudPaper Class="pa-3 d-flex align-center gap-4" Elevation="0" Outlined="true" Style="border-radius:8px;">
                                                <MudAvatar Class="@GetEducationLevelAvatarClass(record.EducationLevel)" Variant="Variant.Outlined" Size="Size.Medium"><MudIcon Icon="@DzdIcons.GraduationCap" /></MudAvatar>
                                                <div style="flex-grow:1;">
                                                    <MudText Typo="Typo.subtitle2">@GetEducationLevelName(record.EducationLevel) <MudChip T="string" Size="Size.Small" Class="@GetEducationLevelChipClass(record.EducationLevel)" Variant="Variant.Text">@GetEducationStatusName(record.Status)</MudChip></MudText>
                                                    <MudText Typo="Typo.body2">@record.Institution@(string.IsNullOrWhiteSpace(record.Program) ? string.Empty : $" - {record.Program}")</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Default">@AppFormatter.FormatDate(record.GraduationDate)</MudText>
                                                </div>
                                                @if (_educationEdit.IsEditing)
                                                {
                                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                        <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="@(async () => await EditEducationHistoryRecordAsync(record))" />
                                                        <MudIconButton Icon="@DzdIcons.Trash" Size="Size.Small" Color="Color.Error" OnClick="@(async () => await RemoveEducationHistoryRecordAsync(record))" />
                                                    </MudStack>
                                                }
                                            </MudPaper>
                                        }
                                    </MudStack>
                                }

                                <MudStack Row="true" Justify="Justify.FlexStart" Class="mt-3">
                                    <MudButton Variant="Variant.Outlined" StartIcon="@DzdIcons.Plus" OnClick="OpenAddEducationHistoryDialogAsync" Class="d-flex align-center gap-2">@Loc["employeeProfile.addEducationRecord"]</MudButton>
                                </MudStack>
                            }
                        </MudPaper>
                        @if (_educationEdit.IsEditing)
                        {
                            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4 mb-4">
                                <MudButton Variant="Variant.Outlined" OnClick="CancelEducationInfoEdit">@Loc["common.cancel"]</MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEducationInfoAsync">@Loc["common.save"]</MudButton>
                            </MudStack>
                        }

                    </div>
                }
            }
            else if (_activeViewIndex == 3)
            {
                <PaymentSection UserId="@_userId" SelfService="@SelfService" />
            }
            else if (_activeViewIndex == 4)
            {
                <div class="trainings-pane mt-4">
                    @if (_trainingLoading)
                    {
                        <MudStack AlignItems="AlignItems.Center" Class="py-8">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </MudStack>
                    }
                    else if (_trainingProgress is null || !_trainingProgress.IsLinked)
                    {
                        <MudPaper Elevation="0" Class="pa-8" Style="border-radius:14px; border:1px dashed var(--dzd-bg-input); text-align:center;">
                            <MudIcon Icon="@DzdIcons.GraduationCap" Style="font-size:42px; color:var(--dzd-text-secondary);" />
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mt-2">@Loc["trainings.notLinkedTitle"]</MudText>
                            <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["trainings.notLinkedHint"]</MudText>
                        </MudPaper>
                    }
                    else
                    {
                        <MudStack Spacing="1" Class="mb-3">
                            <MudText Typo="Typo.h5" Style="font-weight:400;">@Loc["trainings.title"]</MudText>
                            <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["trainings.subtitle"]</MudText>
                        </MudStack>

                        <div class="trn-summary-head">
                            <span class="trn-dot"></span>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:400;">@Loc["trainings.progressTitle"]</MudText>
                        </div>
                        <MudPaper Elevation="2" Class="pa-5 mb-4" Style="border-radius:14px; border:1px solid var(--dzd-bg-input);">
                            <div class="trn-summary-body">
                                <div class="trn-ring">
                                    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Value="@_trainingProgress.CompletionPercent" Style="height:120px; width:120px;" />
                                    <div class="trn-ring-center">
                                        <span class="trn-ring-pct">@_trainingProgress.CompletionPercent%</span>
                                        <span class="trn-ring-label">@Loc["trainings.statusCompleted"]</span>
                                    </div>
                                </div>
                                <div class="trn-bars">
                                    @{
                                        var total = Math.Max(1, _trainingProgress.TotalCount);
                                    }
                                    <div class="trn-bar-row">
                                        <span class="trn-bar-label">@Loc["trainings.statusCompleted"]</span>
                                        <div class="trn-bar-track"><div class="trn-bar-fill trn-fill-done" style="@($"width:{_trainingProgress.CompletedCount * 100 / total}%;")"></div></div>
                                        <span class="trn-bar-count">@_trainingProgress.CompletedCount / @_trainingProgress.TotalCount</span>
                                    </div>
                                    <div class="trn-bar-row">
                                        <span class="trn-bar-label">@Loc["trainings.statusInProgress"]</span>
                                        <div class="trn-bar-track"><div class="trn-bar-fill trn-fill-progress" style="@($"width:{_trainingProgress.InProgressCount * 100 / total}%;")"></div></div>
                                        <span class="trn-bar-count">@_trainingProgress.InProgressCount / @_trainingProgress.TotalCount</span>
                                    </div>
                                    <div class="trn-bar-row">
                                        <span class="trn-bar-label">@Loc["trainings.statusUpcoming"]</span>
                                        <div class="trn-bar-track"><div class="trn-bar-fill trn-fill-upcoming" style="@($"width:{_trainingProgress.UpcomingCount * 100 / total}%;")"></div></div>
                                        <span class="trn-bar-count">@_trainingProgress.UpcomingCount / @_trainingProgress.TotalCount</span>
                                    </div>
                                </div>
                            </div>
                        </MudPaper>

                        <MudStack Spacing="2" Class="mb-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <span class="trn-dot"></span>
                                <MudText Typo="Typo.subtitle1" Style="font-weight:400;">@Loc["trainings.allPrograms"]</MudText>
                            </MudStack>
                            <div class="trn-filter trn-filter--full">
                                @foreach (var f in _trainingFilters)
                                {
                                    <button type="button" class="trn-filter-seg @(f.Value == _trainingFilter ? "active" : "")" @onclick="() => _trainingFilter = f.Value">@Loc[f.LabelKey]</button>
                                }
                            </div>
                        </MudStack>

                        @if (FilteredTrainings().Count == 0)
                        {
                            <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);" Class="py-4">@Loc["trainings.noneInFilter"]</MudText>
                        }
                        else
                        {
                            <MudStack Spacing="3">
                                @foreach (var c in FilteredTrainings())
                                {
                                    <MudPaper Elevation="0" Class="pa-4" Style="border-radius:12px; border:1px solid var(--dzd-bg-input);">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Spacing="2" Class="mb-2">
                                            <MudStack Spacing="1">
                                                <MudText Typo="Typo.subtitle2" Style="font-weight:600;">@c.CourseTitle</MudText>
                                                @if (!string.IsNullOrWhiteSpace(c.CourseCategory))
                                                {
                                                    <MudText Typo="Typo.caption" Style="color:var(--dzd-text-secondary);">@c.CourseCategory</MudText>
                                                }
                                            </MudStack>
                                            @{
                                                var (chipText, chipIcon, chipClass) = TrainingStatusChip(c.Status);
                                            }
                                            <span class="trn-status-chip @chipClass"><MudIcon Icon="@chipIcon" Size="Size.Small" /> @chipText</span>
                                        </MudStack>
                                        <div class="trn-course-progress">
                                            <div class="trn-bar-track">
                                                <div class="trn-bar-fill @(c.Status == TrainingProgressStatus.Completed ? "trn-fill-done" : "trn-fill-progress")" style="@($"width:{c.ProgressPercent}%;")"></div>
                                            </div>
                                            <span class="trn-course-pct">@c.ProgressPercent%</span>
                                        </div>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mt-2" Wrap="Wrap.Wrap">
                                            @if (c.CompletionDate is { } cd)
                                            {
                                                <span class="trn-meta"><MudIcon Icon="@DzdIcons.CircleCheck" Size="Size.Small" /> @string.Format(Loc["trainings.completedOn"], AppFormatter.FormatDate(cd))</span>
                                            }
                                            else if (c.LastAccessedDate is { } la)
                                            {
                                                <span class="trn-meta"><MudIcon Icon="@DzdIcons.History" Size="Size.Small" /> @string.Format(Loc["trainings.lastAccessed"], AppFormatter.FormatDate(la))</span>
                                            }
                                            @if (c.IsAssigned && !string.IsNullOrWhiteSpace(c.AssignedBy))
                                            {
                                                <span class="trn-meta"><MudIcon Icon="@DzdIcons.User" Size="Size.Small" /> @string.Format(Loc["trainings.assignedBy"], c.AssignedBy)</span>
                                            }
                                        </MudStack>
                                    </MudPaper>
                                }
                            </MudStack>

                            @if (_trainingProgress.LastSyncedAt is { } synced)
                            {
                                <MudText Typo="Typo.caption" Style="color:var(--dzd-text-secondary);" Class="mt-3 d-block">@string.Format(Loc["trainings.lastSynced"], AppFormatter.FormatDate(synced))</MudText>
                            }
                        }
                    }
                </div>
            }
        </div>
    }
</MudContainer>

