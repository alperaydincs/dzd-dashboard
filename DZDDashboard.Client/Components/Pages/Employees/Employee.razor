                            </MudStack>
                        }

                        <MudDivider Class="my-4" />

                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                            <div class="dzd-section-title" style="margin:0;">
                                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background-color:var(--dzd-blue-500);margin-left:4px;margin-right:5px;vertical-align:middle;" aria-hidden="true"></span> Citizenship Information
                            </div>
