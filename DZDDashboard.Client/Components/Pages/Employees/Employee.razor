                                {
                                    <MudStack Spacing="3">
                                        @foreach (var record in _educationHistoryRecords)
                                        {
                                            <MudPaper Class="pa-3 d-flex align-center gap-4" Elevation="0" Outlined="true" Style="border-radius:8px;">
                                                <MudAvatar Color="@GetEducationLevelColor(record.Level)" Variant="Variant.Outlined" Size="Size.Medium"><MudIcon Icon="@DzdIcons.GraduationCap" /></MudAvatar>
                                                <div style="flex-grow:1;">
                                                    <MudText Typo="Typo.subtitle2">@record.Level <MudChip T="string" Size="Size.Small" Color="@GetEducationStatusColor(record.Status)" Variant="Variant.Text">@(record.Status ?? "-")</MudChip></MudText>
                                                    <MudText Typo="Typo.body2">@record.Institution@(string.IsNullOrWhiteSpace(record.Program) ? string.Empty : $" - {record.Program}")</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Default">@AppFormatter.FormatDate(record.GraduationDate)</MudText>
                                                </div>
                                                @if (_educationEdit.IsEditing)
                                                {
                                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                        <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="@(async () => await EditEducationHistoryRecordAsync(record))" />
                                                        <MudIconButton Icon="@DzdIcons.Trash" Size="Size.Small" Color="Color.Error" OnClick="@(async () => await RemoveEducationHistoryRecordAsync(record))" />
                                                    </MudStack>
                                                }
                                            </MudPaper>
                                        }
                                    </MudStack>
                                }

                                <MudStack Row="true" Justify="Justify.FlexStart" Class="mt-3">
                                    <MudButton Variant="Variant.Outlined" StartIcon="@DzdIcons.Plus" OnClick="OpenAddEducationHistoryDialogAsync" Class="d-flex align-center gap-2">Add Education Record</MudButton>
                                </MudStack>
                            }
                        </MudPaper>
                        @if (_educationEdit.IsEditing)
                        {
                            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4 mb-4">
                                <MudButton Variant="Variant.Outlined" OnClick="CancelEducationInfoEdit">Cancel</MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEducationInfoAsync">Save</MudButton>
                            </MudStack>
                        }

                    </div>
                }
            }
            else if (_activeViewIndex == 3)
            {
                @if (SelfService)
                {
                    <MudPaper Elevation="1" Class="dzd-card pa-6 mt-4">
                        <MudStack Spacing="1" Class="mb-4">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600; color:var(--dzd-text-primary);">My Salary &amp; Pension (BES)</MudText>
                            <MudText Typo="Typo.caption" Style="color:var(--dzd-text-secondary);">View-only — salary and BES updates are managed by HR.</MudText>
                        </MudStack>

                        @if (_myPaymentSummaryLoading)
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                        }
                        else if (_myPaymentSummary is null)
                        {
                            <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">Could not load payment information.</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.subtitle2" GutterBottom="true">Active Salary</MudText>
                            @if (_myPaymentSummary.ActiveSalary is { } salary)
                            {
                                <MudPaper Class="pa-3 mb-4" Elevation="0" Outlined="true" Style="border-radius:8px;max-width:420px;">
                                    <MudText Typo="Typo.h6">@($"{salary.NetAmount:N2} {salary.Currency}") <MudText Typo="Typo.caption" Style="color:var(--dzd-text-secondary);" Inline="true">/ @salary.Period</MudText></MudText>
                                    <MudText Typo="Typo.body2">Effective since @AppFormatter.FormatDate(salary.StartDate)</MudText>
                                </MudPaper>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Class="mb-4" Style="color:var(--dzd-text-secondary);">No active salary record found.</MudText>
                            }

                            <MudText Typo="Typo.subtitle2" GutterBottom="true">Active BES (Private Pension)</MudText>
                            @if (_myPaymentSummary.PensionBenefits.Count == 0)
                            {
                                <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">No active BES benefit found.</MudText>
                            }
                            else
                            {
                                <MudStack Spacing="2">
                                    @foreach (var benefit in _myPaymentSummary.PensionBenefits)
                                    {
                                        <MudPaper Class="pa-3" Elevation="0" Outlined="true" Style="border-radius:8px;max-width:420px;">
                                            <MudText Typo="Typo.h6">@($"{benefit.Amount:N2} {benefit.Currency}") <MudText Typo="Typo.caption" Style="color:var(--dzd-text-secondary);" Inline="true">/ @benefit.Period</MudText></MudText>
                                            <MudText Typo="Typo.body2">Effective since @AppFormatter.FormatDate(benefit.StartDate)</MudText>
                                        </MudPaper>
                                    }
                                </MudStack>
                            }
                        }
                    </MudPaper>
                }
                else
                {
                    <PaymentSection UserId="@_userId" />
                }
            }
        </div>
    }
</MudContainer>

