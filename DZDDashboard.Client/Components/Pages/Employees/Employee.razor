                                            </MudItem>
                                            <MudItem xs="12" sm="6">
                                                <MudTextField @bind-Value="_profile!.LastName" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input"  Placeholder="Last name" />
                                            </MudItem>
                                        </MudGrid>
                                    }
