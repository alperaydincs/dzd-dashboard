@page "/employee/{Slug}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = DZDDashboard.Common.Constants.Roles.AdminOrHr)]
@using DZDDashboard.Client.Components.Pages.Employees.Dialogs
@using DZDDashboard.Client.Components.Shared
@using DZDDashboard.Client.Services
@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.Utils
@using IntlTelInputBlazor
@using Microsoft.AspNetCore.Components.Forms

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-3">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else if (_profile is not null)
    {
        @if (!SelfService)
        {
            <MudButton Variant="Variant.Text" Color="Color.Dark" OnClick="@Back" StartIcon="@DzdIcons.ArrowLeft" Class="mb-3" Style="text-transform:none; min-width:auto;">
                @Loc["common.back"]
            </MudButton>
        }

        <div class="dzd-header-container mb-6">
            <MudPaper Elevation="2" Class="dzd-header-card pa-6" Style="border-radius: 12px; border: 1px solid #e0e0e0;">
                <MudGrid Spacing="4" Style="align-items: center;">
                    <MudItem xs="12" sm="4" md="2" Class="d-flex justify-center align-center">
                        @if (SelfService)
                        {
                            <MudTooltip Text="@Loc["employeeProfile.changePhoto"]">
                                <InitialsAvatar FullName="@_fullName"
                                                ImageSrc="@(string.IsNullOrEmpty(_avatarDataUrl) ? null : _avatarDataUrl)"
                                                ColorIndex="@_profile.AvatarColorIndex"
                                                Size="118" Class="employee-header-avatar clickable" @onclick="OpenAvatarUploadDialog" />
                            </MudTooltip>
                        }
                        else
                        {
                            <InitialsAvatar FullName="@_fullName"
                                            ImageSrc="@(string.IsNullOrEmpty(_avatarDataUrl) ? null : _avatarDataUrl)"
                                            ColorIndex="@_profile.AvatarColorIndex"
                                            Size="118" Class="employee-header-avatar" />
                        }
                    </MudItem>
                    <MudItem xs="12" sm="8" md="10">
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-2">
                                <MudText Typo="Typo.h5" Style="font-weight: 600; color: var(--dzd-text-primary);">@_fullName</MudText>
                                <MudChip T="string" Color="@LifecycleColor(_profile.LifecycleStatus, _profile.IsActive)" Variant="Variant.Text" Size="Size.Small">@LifecycleLabel(_profile.LifecycleStatus, _profile.IsActive)</MudChip>
                                <MudSpacer />
                                <MudChip T="string" Variant="Variant.Text" Size="Size.Small" Style="background-color:var(--dzd-bg-input); color:var(--dzd-text-secondary);">@(_profile.CompanyName ?? "-")</MudChip>
                            </MudStack>
                            <MudDivider Class="my-1" />
                            
                            <MudGrid Spacing="2" Class="mt-2">
                                <MudItem xs="6" sm="4" md="4">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@DzdIcons.Briefcase" Size="Size.Small" Style="color: #6c757d; font-size: 16px;" />
                                            <MudText Typo="Typo.caption" Style="color: #6c757d; font-weight: 500;">@Loc["employeeProfile.jobTitle"]</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(_profile.Job?.Name ?? Loc["common.notAvailable"])</MudText>
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="6" sm="4" md="4">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@DzdIcons.Building" Size="Size.Small" Style="color: #6c757d; font-size: 16px;" />
                                            <MudText Typo="Typo.caption" Style="color: #6c757d; font-weight: 500;">@Loc["employeeProfile.department"]</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(_profile.Department?.Name ?? Loc["common.notAvailable"])</MudText>
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="6" sm="4" md="4">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@DzdIcons.User" Size="Size.Small" Style="color: #6c757d; font-size: 16px;" />
                                            <MudText Typo="Typo.caption" Style="color: #6c757d; font-weight: 500;">@Loc["employeeProfile.reportingTo"]</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(AppFormatter.BuildFullName(_profile.ReportsTo?.FirstName, _profile.ReportsTo?.LastName) is { Length: > 0 } n ? n : Loc["common.notAvailable"])</MudText>
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="6" sm="4" md="4">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@DzdIcons.History" Size="Size.Small" Style="color: #6c757d; font-size: 16px;" />
                                            <MudText Typo="Typo.caption" Style="color: #6c757d; font-weight: 500;">@Loc["employeeProfile.workModel"]</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(GetWorkModelName(_profile.WorkModel) ?? Loc["common.notAvailable"])</MudText>
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="6" sm="4" md="4">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@DzdIcons.BadgeCheck" Size="Size.Small" Style="color: #6c757d; font-size: 16px;" />
                                            <MudText Typo="Typo.caption" Style="color: #6c757d; font-weight: 500;">@Loc["employeeProfile.grade"]</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(_profile.Grade is null ? Loc["common.notAvailable"] : $"{_profile.Grade}")</MudText>
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="6" sm="4" md="4">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@DzdIcons.MapPin" Size="Size.Small" Style="color: #6c757d; font-size: 16px;" />
                                            <MudText Typo="Typo.caption" Style="color: #6c757d; font-weight: 500;">@Loc["employeeProfile.location"]</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(_profile.PayrollLocation?.Name ?? Loc["common.notAvailable"])</MudText>
                                    </MudStack>
                                </MudItem>
                            </MudGrid>

                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </div>

        <div class="employee-card-tabs-scope">
            <div class="view-tabs-shell active-@_activeViewIndex view-tabs-5" role="tablist" aria-label="@(SelfService ? Loc["employeeProfile.viewsAriaMine"] : Loc["employeeProfile.viewsAriaOther"])">
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 0 ? "true" : "false")" @onclick="() => SetView(0)">@Loc["employeeProfile.tabOverview"]</button>
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 1 ? "true" : "false")" @onclick="() => SetView(1)">@Loc["employeeProfile.tabPersonalInfo"]</button>
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 2 ? "true" : "false")" @onclick="() => SetView(2)">@Loc["employeeProfile.tabCareer"]</button>
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 3 ? "true" : "false")" @onclick="() => SetView(3)">@Loc["employeeProfile.tabPayments"]</button>
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 4 ? "true" : "false")" @onclick="() => SetView(4)">@Loc["employeeProfile.tabTrainings"]</button>
            </div>

            @if (_activeViewIndex == 0)
            {
                <MudGrid Class="mt-3 mb-3" Spacing="3">
                    <MudItem xs="12" sm="6" md="4">
                        <InfoCard Label="@Loc["employeeProfile.positionStartDate"]"
                                  Value="@AppFormatter.FormatDate(_profile.PositionStartDate)"
                                  Icon="@DzdIcons.Calendar"
                                  Accent="InfoCard.AccentColor.Blue" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <InfoCard Label="@Loc["employeeProfile.jobStartDate"]"
                                  Value="@AppFormatter.FormatDate(_profile.UserStartDate)"
                                  Icon="@DzdIcons.CalendarDays"
                                  Accent="InfoCard.AccentColor.CambridgeBlue" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <InfoCard Label="@Loc["employeeProfile.employmentDuration"]"
                                  Value="@(_employmentDuration ?? Loc["common.notAvailable"])"
                                  Icon="@DzdIcons.ChartLine"
                                  Accent="InfoCard.AccentColor.Orange" />
                    </MudItem>
                </MudGrid>

                <MudGrid Class="mt-3 mb-3" Spacing="3">
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="2" Class="pa-4" Style="border-radius: 12px; border: 1px solid var(--dzd-bg-input); background-color: var(--dzd-surface-primary);">
                            <MudStack Spacing="3">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 500; color: var(--dzd-text-primary);">@Loc["employeeProfile.contactInformation"]</MudText>
                                <MudStack Spacing="2">
                                    <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 10px; background-color: var(--dzd-surface-primary); border: 1px solid var(--dzd-bg-input);">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <div Style="width: 40px; height: 40px; background-color: var(--dzd-blue-icon-bg); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                    <MudIcon Icon="@DzdIcons.Mail" Style="color: #2B38F5; font-size: 20px;" />
                                                </div>
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500;">@Loc["employeeProfile.email"]</MudText>
                                                    <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 400;">@(_profile.Email ?? Loc["common.notAvailable"])</MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudIconButton Icon="@DzdIcons.Copy" Size="Size.Small" Color="Color.Dark" OnClick="@(async () => await CopyToClipboard(_profile.Email))" />
                                        </MudStack>
                                    </MudPaper>
                                    <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 10px; background-color: var(--dzd-surface-primary); border: 1px solid var(--dzd-bg-input);">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <div Style="width: 40px; height: 40px; background-color: var(--dzd-cambridge-icon-bg); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                    <MudIcon Icon="@DzdIcons.Phone" Style="color: #70A37F; font-size: 20px;" />
                                                </div>
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500;">@Loc["employeeProfile.phone"]</MudText>
                                                    <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 400;">@(GetWorkPhoneDisplay())</MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudIconButton Icon="@DzdIcons.Copy" Size="Size.Small" Color="Color.Dark" OnClick="@(async () => await CopyToClipboard(GetWorkPhoneValue()))" />
                                        </MudStack>
                                    </MudPaper>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="2" Class="pa-4" Style="border-radius: 12px; border: 1px solid var(--dzd-bg-input); background-color: var(--dzd-surface-primary);">
                            <MudStack Spacing="3">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 500; color: var(--dzd-text-primary);">@Loc["employeeProfile.workInformation"]</MudText>
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" sm="6">
                                        <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 10px; background-color: var(--dzd-surface-primary); border: 1px solid var(--dzd-bg-input);">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <div Style="width: 40px; height: 40px; background-color: var(--dzd-blue-icon-bg); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                    <MudIcon Icon="@DzdIcons.FileText" Style="color: #2B38F5; font-size: 20px;" />
                                                </div>
                                                <MudStack Spacing="0" Style="flex-grow: 1;">
                                                    <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500;">@Loc["employeeProfile.contractType"]</MudText>
                                                    <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 400;">@(GetContractTypeName(_profile.ContractType) ?? Loc["common.notAvailable"])</MudText>
                                                </MudStack>
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 10px; background-color: var(--dzd-surface-primary); border: 1px solid var(--dzd-bg-input);">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <div Style="width: 40px; height: 40px; background-color: var(--dzd-orange-icon-bg); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                    <MudIcon Icon="@DzdIcons.CalendarX" Style="color: #F46036; font-size: 20px;" />
                                                </div>
                                                <MudStack Spacing="0" Style="flex-grow: 1;">
                                                    <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500;">@Loc["employeeProfile.contractEndDate"]</MudText>
                                                    <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 400;">@AppFormatter.FormatDate(_profile.ContractEndDate)</MudText>
                                                </MudStack>
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 10px; background-color: var(--dzd-surface-primary); border: 1px solid var(--dzd-bg-input);">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <div Style="width: 40px; height: 40px; background-color: var(--dzd-cambridge-icon-bg); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                    <MudIcon Icon="@DzdIcons.Briefcase" Style="color: #70A37F; font-size: 20px;" />
                                                </div>
                                                <MudStack Spacing="0" Style="flex-grow: 1;">
                                                    <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500;">@Loc["employeeProfile.workModel"]</MudText>
                                                    <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 400;">@(GetWorkModelName(_profile.WorkModel) ?? Loc["common.notAvailable"])</MudText>
                                                </MudStack>
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 10px; background-color: var(--dzd-surface-primary); border: 1px solid var(--dzd-bg-input);">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <div Style="width: 40px; height: 40px; background-color: var(--dzd-amber-icon-bg); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                    <MudIcon Icon="@DzdIcons.MapPin" Style="color: #FEA82F; font-size: 20px;" />
                                                </div>
                                                <MudStack Spacing="0" Style="flex-grow: 1;">
                                                    <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500;">@Loc["employeeProfile.payrollLocation"]</MudText>
                                                    <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 400;">@(_profile.PayrollLocation?.Name ?? Loc["common.notAvailable"])</MudText>
                                                </MudStack>
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                </MudGrid>
                            </MudStack>
                        </MudPaper>
                    </MudItem>

                    @if (_profile.ReportsTo is not null)
                    {
                    <MudItem xs="12">
                        <MudPaper Elevation="2" Class="pa-4" Style="border-radius: 12px; border: 1px solid var(--dzd-bg-input); background-color: var(--dzd-surface-primary);">
                            <MudStack Spacing="3">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 500; color: var(--dzd-text-primary);">@Loc["employeeProfile.managerInformation"]</MudText>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="6">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexStart" Spacing="3" Style="flex: 0 0 auto; padding-left: 16px; padding-right: 40px;">
                                        <InitialsAvatar FullName="@GetManagerDisplayName()"
                                                        ImageSrc="@GetManagerAvatarUrl()"
                                                        ColorIndex="@_profile.ReportsTo.AvatarColorIndex"
                                                        Size="88" />
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.h5" Style="font-weight: 400; color: var(--dzd-text-primary);">@GetManagerDisplayName()</MudText>
                                            @if (_profile.ReportsTo.Department?.Name is { Length: > 0 } managerDepartment)
                                            {
                                                <MudText Typo="Typo.h6" Style="font-weight: 400; color: var(--dzd-text-secondary);">@managerDepartment</MudText>
                                            }
                                        </MudStack>
                                    </MudStack>

                                    <MudDivider Vertical="true" FlexItem="true" />

                                    <MudStack Spacing="2" Style="flex: 1 1 0;">
                                        <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 10px; background-color: var(--dzd-surface-primary); border: 1px solid var(--dzd-bg-input);">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                    <div Style="width: 40px; height: 40px; background-color: var(--dzd-blue-icon-bg); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                        <MudIcon Icon="@DzdIcons.Mail" Style="color: #2B38F5; font-size: 20px;" />
                                                    </div>
                                                    <MudStack Spacing="0">
                                                        <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500;">@Loc["employeeProfile.email"]</MudText>
                                                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 400;">@GetManagerEmailDisplay()</MudText>
                                                    </MudStack>
                                                </MudStack>
                                                <MudIconButton Icon="@DzdIcons.Copy" Size="Size.Small" Color="Color.Dark" OnClick="@(async () => await CopyToClipboard(_profile.ReportsTo.Email))" />
                                            </MudStack>
                                        </MudPaper>
                                        <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 10px; background-color: var(--dzd-surface-primary); border: 1px solid var(--dzd-bg-input);">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                    <div Style="width: 40px; height: 40px; background-color: var(--dzd-cambridge-icon-bg); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                        <MudIcon Icon="@DzdIcons.Phone" Style="color: #70A37F; font-size: 20px;" />
                                                    </div>
                                                    <MudStack Spacing="0">
                                                        <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500;">@Loc["employeeProfile.phone"]</MudText>
                                                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 400;">@GetManagerPhoneDisplay()</MudText>
                                                    </MudStack>
                                                </MudStack>
                                                <MudIconButton Icon="@DzdIcons.Copy" Size="Size.Small" Color="Color.Dark" OnClick="@(async () => await CopyToClipboard(_profile.ReportsTo.PhoneNumber))" />
                                            </MudStack>
                                        </MudPaper>
                                    </MudStack>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    }
                </MudGrid>
            }
            else if (_activeViewIndex == 2)
            {
                @if (!_career.IsLoaded)
                {
                    <MudStack AlignItems="AlignItems.Center" Class="py-8">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    </MudStack>
                }
                else
                {
                <MudStack Spacing="4" Class="mt-4">

                    @{
                        var currentPos = _positionHistory.FirstOrDefault(x => x.IsCurrent);
                    }

                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight:400;">@Loc["employeeProfile.careerHistory"]</MudText>
                        <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["employeeProfile.careerHistorySubtitle"]</MudText>
                    </div>

                    @if (_positionHistory.Count == 0)
                    {
                        <MudPaper Elevation="0" Class="pa-4" Style="border-radius:12px; border:1px solid var(--dzd-bg-input);">
                            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="3" Class="py-8">
                                <div style="width:72px;height:72px;background-color:var(--dzd-bg-secondary);border-radius:16px;display:flex;align-items:center;justify-content:center;">
                                    <MudIcon Icon="@DzdIcons.Briefcase" Style="font-size:32px;color:var(--dzd-text-secondary);" />
                                </div>
                                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@Loc["employeeProfile.noPositionHistoryTitle"]</MudText>
                                <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["employeeProfile.noPositionHistorySubtitle"]</MudText>
                                @if (!SelfService)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Medium"
                                               StartIcon="@DzdIcons.Plus" OnClick="@(() => OpenCareerAssignmentDialogAsync(null))"
                                               Style="border-radius:999px;">@Loc["employeeProfile.addFirstPosition"]</MudButton>
                                }
                            </MudStack>
                        </MudPaper>
                    }
                    else
                    {
                        <MudPaper Elevation="0" Class="pa-4" Style="border-radius:12px; border:1px solid var(--dzd-bg-input);">
                            @if (!SelfService && currentPos is null)
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mb-3">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                               StartIcon="@DzdIcons.Plus" OnClick="@(() => OpenCareerAssignmentDialogAsync(null))">@Loc["employeeProfile.assignPosition"]</MudButton>
                                </MudStack>
                            }

                            <MudStack Spacing="3">
                                @foreach (var p in _positionHistory)
                                {
                                    <MudPaper Elevation="0" Class="pa-3"
                                              Style="@($"border-radius:12px; border:1px solid {(p.IsCurrent ? "#2B38F5" : "var(--dzd-bg-input)")};")">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Spacing="2">
                                            <MudStack Spacing="2">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                                                    <MudText Typo="Typo.subtitle2" Style="font-weight:600;">@(p.JobTitle ?? Loc["common.notAvailable"])</MudText>
                                                    @if (p.IsCurrent)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">@Loc["employeeProfile.current"]</MudChip>
                                                    }
                                                    @if (!string.IsNullOrEmpty(p.ChangeType))
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                                                 Style="background-color:var(--dzd-brand-secondary); color:#fff;">@GetPositionChangeTypeName(p.ChangeType)</MudChip>
                                                    }
                                                    @if (p.Grade.HasValue)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Icon="@DzdIcons.Award"
                                                                 Style="background-color:rgba(254, 168, 47, 0.1); color:#FEA82F;">@p.Grade</MudChip>
                                                    }
                                                </MudStack>
                                                <MudStack Row="true" Spacing="8" Wrap="Wrap.Wrap">
                                                    <span style="color:var(--dzd-text-secondary);font-size:13px;display:inline-flex;align-items:center;gap:4px;">
                                                        <MudIcon Icon="@DzdIcons.Building2" Size="Size.Small" Style="color:var(--dzd-brand-primary);" /> @(p.DepartmentName ?? p.CompanyName ?? Loc["common.notAvailable"])
                                                    </span>
                                                    @if (!string.IsNullOrEmpty(p.TeamName))
                                                    {
                                                        <span style="color:var(--dzd-text-secondary);font-size:13px;display:inline-flex;align-items:center;gap:4px;">
                                                            <MudIcon Icon="@DzdIcons.Users" Size="Size.Small" Style="color:var(--dzd-brand-secondary);" /> @p.TeamName
                                                        </span>
                                                    }
                                                    <span style="color:var(--dzd-text-secondary);font-size:13px;display:inline-flex;align-items:center;gap:4px;">
                                                        <MudIcon Icon="@DzdIcons.CalendarDays" Size="Size.Small" Style="color:var(--dzd-brand-amber);" /> @FormatPositionRange(p)
                                                    </span>
                                                </MudStack>
                                            </MudStack>
                                            @if (!SelfService && p.IsCurrent)
                                            {
                                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Style="align-self:center;">
                                                    <MudButton Variant="Variant.Filled" Size="Size.Medium"
                                                               StartIcon="@DzdIcons.TrendingUp" OnClick="OpenPromotionDialogAsync"
                                                               Style="background-color:#FEA82F;color:#fff;">@Loc["employeeProfile.promote"]</MudButton>
                                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Medium"
                                                               StartIcon="@DzdIcons.Pencil" OnClick="@(() => OpenCareerAssignmentDialogAsync(p))">@Loc["common.edit"]</MudButton>
                                                </MudStack>
                                            }
                                        </MudStack>
                                    </MudPaper>
                                }
                            </MudStack>
                        </MudPaper>
                    }

                    @if (_positionHistory.Count > 0)
                    {
                    <MudPaper Elevation="0" Class="pa-6 clp-card" Style="border-radius:14px; border:1px solid var(--dzd-bg-input);">
                        <div class="clp-head">
                            <div>
                                <MudText Typo="Typo.h6" Style="font-weight:600;">@Loc["employeeProfile.careerLevelProgress"]</MudText>
                                <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["employeeProfile.trackGradeProgression"]</MudText>
                            </div>
                            @if (_profile?.Grade is int g)
                            {
                                <div class="clp-grade-badge">
                                    <MudIcon Icon="@DzdIcons.Award" Size="Size.Small" />
                                    <span>@string.Format(Loc["employeeProfile.gradeChip"], g)</span>
                                </div>
                            }
                        </div>

                        @{
                            var rules = PathRulesOrdered();
                        }
                        @if (rules.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);" Class="mt-3">
                                @Loc["employeeProfile.assignCareerPathHint"]
                            </MudText>
                        }
                        else
                        {
                            <div class="clp-stepper">
                                @for (var i = 0; i < rules.Count; i++)
                                {
                                    var r        = rules[i];
                                    var done     = _profile?.Grade is int cg && r.Grade < cg;
                                    var current  = _profile?.Grade == r.Grade;
                                    var state    = current ? "current" : done ? "done" : "next";
                                    var lineDone = _profile?.Grade is int lg && r.Grade <= lg;
                                    <div class="clp-step clp-step--@state">
                                        @if (i > 0)
                                        {
                                            <span class="clp-line @(lineDone ? "clp-line--done" : "")"></span>
                                        }
                                        <div class="clp-node">
                                            @if (done)
                                            {
                                                <MudIcon Icon="@DzdIcons.Check" Size="Size.Small" />
                                            }
                                            else
                                            {
                                                <span>@r.Grade</span>
                                            }
                                        </div>
                                        <span class="clp-step-label">
                                            @if (current)
                                            {
                                                <span class="clp-dot"></span>
                                            }
                                            @(current ? Loc["employeeProfile.stepNow"] : done ? Loc["employeeProfile.stepDone"] : Loc["employeeProfile.stepNext"])
                                        </span>
                                    </div>
                                }
                            </div>

                            @if (NextGradeRule() is { } next)
                            {
                                var reqs  = NextGradeRequirements();
                                var total = reqs.Count;
                                var met   = reqs.Count(x => x.Status == ReqStatus.Completed);
                                var pct   = total == 0 ? 0 : (int)Math.Round(met * 100.0 / total);

                                <div class="clp-req-box">
                                    <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@Loc["employeeProfile.nextGradeRequirements"]</MudText>
                                    <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@string.Format(Loc["employeeProfile.requirementsToAdvance"], next.Grade)</MudText>

                                    <div class="clp-overall-head">
                                        <span>@string.Format(Loc["employeeProfile.metOfTotal"], met, total)</span>
                                        <span>@pct%</span>
                                    </div>
                                    <div class="clp-overall-track">
                                        <div class="clp-overall-fill" style="@($"width:{pct}%;")"></div>
                                    </div>

                                    @if (total > 0)
                                    {
                                        <table class="clp-table">
                                            <thead>
                                                <tr>
                                                    <th>@Loc["employeeProfile.colRequirement"]</th>
                                                    <th>@Loc["employeeProfile.colRequired"]</th>
                                                    <th>@Loc["employeeProfile.colCurrentStatus"]</th>
                                                    <th>@Loc["employeeProfile.colProgress"]</th>
                                                    <th>@Loc["employeeProfile.colStatus"]</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var req in reqs)
                                                {
                                                    <tr>
                                                        <td>
                                                            <div class="clp-req-name">
                                                                <span class="clp-req-icon" style="@($"background:{req.IconBg};color:{req.IconColor};")">
                                                                    <MudIcon Icon="@req.Icon" Size="Size.Small" />
                                                                </span>
                                                                <span>@req.Name</span>
                                                            </div>
                                                        </td>
                                                        <td class="clp-muted">@req.Required</td>
                                                        <td>@req.CurrentStatus</td>
                                                        <td>
                                                            <div class="clp-progress-cell">
                                                                <div class="clp-row-track">
                                                                    <div class="clp-row-fill clp-row-fill--@req.Status.ToString().ToLower()" style="@($"width:{req.Progress}%;")"></div>
                                                                </div>
                                                                <span class="clp-row-pct">@req.Progress%</span>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            @switch (req.Status)
                                                            {
                                                                case ReqStatus.Completed:
                                                                    <span class="clp-chip clp-chip--done"><MudIcon Icon="@DzdIcons.CircleCheck" Size="Size.Small" /> @Loc["lifecycle.completed"]</span>
                                                                    break;
                                                                case ReqStatus.InProgress:
                                                                    <span class="clp-chip clp-chip--progress"><MudIcon Icon="@DzdIcons.Loader" Size="Size.Small" /> @Loc["lifecycle.inProgress"]</span>
                                                                    break;
                                                                default:
                                                                    <span class="clp-chip clp-chip--pending"><MudIcon Icon="@DzdIcons.Clock" Size="Size.Small" /> @Loc["employeeProfile.pending"]</span>
                                                                    break;
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                </div>
                            }
                        }
                    </MudPaper>

                    <MudPaper Elevation="0" Class="pa-4" Style="border-radius:12px; border:1px solid var(--dzd-bg-input);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-1">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@DzdIcons.FileText" Style="color:#2B38F5;" />
                                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@Loc["employeeProfile.cvManagement"]</MudText>
                            </MudStack>
                            @if (!SelfService)
                            {
                                <MudFileUpload T="IBrowserFile" Accept="@CvAcceptList" MaximumFileCount="1" OnFilesChanged="OnCvFileSelected">
                                    <ActivatorContent>
                                        <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Medium"
                                                   StartIcon="@DzdIcons.Upload" Disabled="@_cvUploading">@Loc["employeeProfile.uploadNewCv"]</MudButton>
                                    </ActivatorContent>
                                </MudFileUpload>
                            }
                        </MudStack>

                        @if (_cvUploading)
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-2" />
                        }

                        @if (_cvDocuments.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["employeeProfile.noDocumentsUploaded"]</MudText>
                        }
                        else
                        {
                            <MudStack Spacing="2">
                                @foreach (var doc in _cvDocuments)
                                {
                                    <MudPaper Elevation="0" Class="pa-3" Style="border-radius:10px; border:1px solid var(--dzd-bg-input);">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                                <MudIcon Icon="@DzdIcons.FileText" Style="color:#E5484D;" />
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2" Style="font-weight:600;">@doc.FileName</MudText>
                                                    <MudText Typo="Typo.caption" Style="color:var(--dzd-text-secondary);">
                                                        @(doc.UploadedAt is { } u ? string.Format(Loc["employeeProfile.uploadedOn"], u.ToString("MMM d, yyyy")) : "") · @FormatFileSize(doc.SizeBytes)
                                                    </MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudStack Row="true" Spacing="1">
                                                <MudIconButton Icon="@DzdIcons.Download" Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(() => DownloadDocumentAsync(doc))" />
                                                @if (!SelfService)
                                                {
                                                    <MudIconButton Icon="@DzdIcons.Trash2" Size="Size.Small" Color="Color.Error"
                                                                   OnClick="@(() => DeleteDocumentAsync(doc))" />
                                                }
                                            </MudStack>
                                        </MudStack>
                                    </MudPaper>
                                }
                            </MudStack>
                        }
                    </MudPaper>
                    }

                </MudStack>
                }
            }
            else if (_activeViewIndex == 1)
            {
                @if (_profile is null)
                {
                    <MudAlert Severity="Severity.Warning" Class="mt-4">@Loc["employeeProfile.noPersonalInfo"]</MudAlert>
                }
                else
                {
                    <div class="dzd-personal-info-bg pa-0">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                            <div class="dzd-section-title" style="margin:0;">
                                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background-color:var(--dzd-blue-500);margin-left:4px;margin-right:2px;vertical-align:middle;" aria-hidden="true"></span> @Loc["employeeProfile.employeeDetails"]
                            </div>
                            @if (!SelfService && !_basicInfoEdit.IsEditing)
                            {
                                <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="StartBasicInfoEdit" />
                            }
                        </MudStack>

                        <MudPaper Elevation="1" Class="dzd-card pa-6">
                            <MudGrid Spacing="4">
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.User" Size="Size.Small" /> @Loc["employeeProfile.fullName"]</div>
                                    @if (_basicInfoEdit.IsEditing)
                                    {
                                        <MudGrid Spacing="2">
                                            <MudItem xs="12" sm="6">
                                                <MudTextField @bind-Value="_profile!.FirstName" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input"  Placeholder="@Loc["employeeProfile.firstNamePlaceholder"]" />
                                            </MudItem>
                                            <MudItem xs="12" sm="6">
                                                <MudTextField @bind-Value="_profile!.LastName" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input"  Placeholder="@Loc["employeeProfile.lastNamePlaceholder"]" />
                                            </MudItem>
                                        </MudGrid>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary); padding:2px 2px;">@AppFormatter.BuildFullName(_profile.FirstName, _profile.LastName)</MudText>
                                    }
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.IdCard" Size="Size.Small" /> @Loc["employeeProfile.registryNumber"]</div>
                                    @if (_basicInfoEdit.IsEditing)
                                    {
                                        <MudTextField @bind-Value="_profile!.RegistrationNumber" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input"  />
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary); padding:2px 2px;">@(_profile.RegistrationNumber ?? Loc["common.notAvailable"])</MudText>
                                    }
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.CalendarDays" Size="Size.Small" Style="color: var(--dzd-brand-secondary) !important;" /> @Loc["employeeProfile.jobStartDate"]</div>
                                    @if (_basicInfoEdit.IsEditing)
                                    {
                                        <MudDatePicker AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" Date="@_profile.UserStartDate" DateChanged="@(d => _profile.UserStartDate = d)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input" DateFormat="dd.MM.yyyy" />
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary); padding:2px 2px;">@AppFormatter.FormatDate(_profile.UserStartDate)</MudText>
                                    }
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.Calendar" Size="Size.Small" Style="color: var(--dzd-brand-primary) !important;" /> @Loc["employeeProfile.positionStartDate"]</div>
                                    @if (_basicInfoEdit.IsEditing)
                                    {
                                        <MudDatePicker AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" Date="@_profile.PositionStartDate" DateChanged="@(d => _profile.PositionStartDate = d)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input" DateFormat="dd.MM.yyyy" />
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary); padding:2px 2px;">@AppFormatter.FormatDate(_profile.PositionStartDate)</MudText>
                                    }
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.Timer" Size="Size.Small" Style="color: var(--dzd-orange-500) !important;" /> @Loc["employeeProfile.employmentDuration"]</div>
                                    <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary); padding:2px 2px;">@(FormatDurationLocalized(_profile.UserStartDate) ?? Loc["common.notAvailable"])</MudText>
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.FileText" Size="Size.Small" Style="color: #2B38F5 !important;" /> @Loc["employeeProfile.contractType"]</div>
                                    @if (_basicInfoEdit.IsEditing)
                                    {
                                        <MudSelect T="string" @bind-Value="_profile!.ContractType" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input"  AnchorOrigin="Origin.BottomLeft">
                                            @foreach (var ct in Domain.Options(DomainCategories.ContractType))
                                            {
                                                <MudSelectItem Value="@ct.Code">@ct.Label</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary); padding:2px 2px;">@(GetContractTypeName(_profile.ContractType) ?? Loc["common.notAvailable"])</MudText>
                                    }
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.CalendarX" Size="Size.Small" Style="color: #F46036 !important;" /> @Loc["employeeProfile.contractEndDate"]</div>
                                    @if (_basicInfoEdit.IsEditing)
                                    {
                                        <MudDatePicker AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" Date="@_profile.ContractEndDate" DateChanged="@(d => _profile.ContractEndDate = d)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input" DateFormat="dd.MM.yyyy" />
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary); padding:2px 2px;">@AppFormatter.FormatDate(_profile.ContractEndDate)</MudText>
                                    }
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.Briefcase" Size="Size.Small" Style="color: #70A37F !important;" /> @Loc["employeeProfile.workModel"]</div>
                                    @if (_basicInfoEdit.IsEditing)
                                    {
                                        <MudSelect T="string" @bind-Value="_profile!.WorkModel" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input"  AnchorOrigin="Origin.BottomLeft">
                                            @foreach (var wm in Domain.Options(DomainCategories.WorkModel))
                                            {
                                                <MudSelectItem Value="@wm.Code">@wm.Label</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary); padding:2px 2px;">@(GetWorkModelName(_profile.WorkModel) ?? Loc["common.notAvailable"])</MudText>
                                    }
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.MapPin" Size="Size.Small" Style="color: #FEA82F !important;" /> @Loc["employeeProfile.payrollLocation"]</div>
                                    @if (_basicInfoEdit.IsEditing)
                                    {
                                        <MudSelect T="int?" @bind-Value="_profile!.PayrollLocationId" 
                                                   Variant="Variant.Outlined" 
                                                   AnchorOrigin="Origin.BottomLeft" Class="dzd-input"
                                                   Margin="Margin.Dense">
                                            @foreach (var location in _payrollLocations)
                                            {
                                                <MudSelectItem T="int?" Value="@location.Id">@location.Name</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary); padding:2px 2px;">@(_profile.PayrollLocation?.Name ?? Loc["common.notAvailable"])</MudText>
                                    }
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                         @if (_basicInfoEdit.IsEditing)
                            {
                                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                                    <MudButton Variant="Variant.Outlined" OnClick="CancelBasicInfoEdit">@Loc["common.cancel"]</MudButton>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveBasicInfoAsync">@Loc["common.save"]</MudButton>
                                </MudStack>
                            }

                        <MudDivider Class="my-4" />

                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                            <div class="dzd-section-title" style="margin:0;">
                                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background-color:var(--dzd-blue-500);margin-left:4px;margin-right:5px;vertical-align:middle;" aria-hidden="true"></span> @Loc["employeeProfile.contactInformation"]
                            </div>
                            @if (!_contactsEdit.IsEditing)
                            {
                                <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="StartContactsEdit" />
                            }
                        </MudStack>
                        <MudGrid Spacing="4">
                            <MudItem xs="12" md="6">
                                <MudPaper Elevation="1" Class="dzd-card h-100 pa-6">
                                    <MudText Typo="Typo.subtitle2" Class="mb-4">@Loc["employeeProfile.workContact"]</MudText>
                                    <MudStack Spacing="3">
                                        <div>
                                            <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.Mail" Size="Size.Small" Style="color: #2B38F5 !important;" /> @Loc["startOnboardingDialog.workEmail"]</div>
                                            @if (_contactsEdit.IsEditing && !SelfService)
                                            {
                                                <MudTextField @bind-Value="_profile!.Email" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input"  Immediate="true" />
                                            }
                                            else
                                            {
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="dzd-contact-display">
                                                    <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile?.Email ?? Loc["common.notAvailable"])</MudText>
                                                    <MudIconButton Icon="@DzdIcons.Copy" Size="Size.Small" Color="Color.Dark" OnClick="@(async () => await CopyToClipboard(_profile?.Email))" />
                                                </MudStack>
                                            }
                                        </div>
                                        <div>
                                            <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.Phone" Size="Size.Small" Style="color: #70A37F !important;" /> @Loc["employeeProfile.workPhone"]</div>
                                            @if (_contactsEdit.IsEditing)
                                            {
                                                <div class="dzd-intl-phone dzd-input">
                                                    <MudIntlTelInput T="IntlTel" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="_workPhoneIntl" />
                                                </div>
                                            }
                                            else
                                            {
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="dzd-contact-display">
                                                    <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary);">@(GetWorkPhoneDisplay())</MudText>
                                                    <MudIconButton Icon="@DzdIcons.Copy" Size="Size.Small" Color="Color.Dark" OnClick="@(async () => await CopyToClipboard(GetWorkPhoneValue()))" />
                                                </MudStack>
                                            }
                                        </div>
