                                    }
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.CalendarX" Size="Size.Small" /> Contract End Date</div>
                                    @if (_basicInfoEdit.IsEditing)
                                    {
                                        <MudDatePicker AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" Date="@_profile.ContractEndDate" DateChanged="@(d => _profile.ContractEndDate = d)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="dzd-input"  />
                                    }
                                    else
