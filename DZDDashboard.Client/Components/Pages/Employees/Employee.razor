@page "/employee/{Slug}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = DZDDashboard.Common.Constants.Roles.AdminOrHr)]
@using DZDDashboard.Client.Components.Pages.Employees.Dialogs
@using DZDDashboard.Client.Components.Shared
@using DZDDashboard.Client.Services
@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.Utils
@using IntlTelInputBlazor
@using Microsoft.AspNetCore.Components.Forms

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-3">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else if (_profile is not null)
    {
        @if (!SelfService)
        {
            <MudButton Variant="Variant.Text" Color="Color.Dark" OnClick="@Back" StartIcon="@DzdIcons.ArrowLeft" Class="mb-3" Style="text-transform:none; min-width:auto;">
                Back
            </MudButton>
        }

        <div class="dzd-header-container mb-6">
            <MudPaper Elevation="2" Class="dzd-header-card pa-6" Style="border-radius: 12px; border: 1px solid #e0e0e0;">
                <MudGrid Spacing="4" Style="align-items: center;">
                    <MudItem xs="12" sm="4" md="2" Class="d-flex justify-center align-center">
                        @if (SelfService)
                        {
                            <MudTooltip Text="Click to change photo">
                                <InitialsAvatar FullName="@_fullName"
                                                ImageSrc="@(string.IsNullOrEmpty(_avatarDataUrl) ? null : _avatarDataUrl)"
                                                ColorIndex="@_profile.AvatarColorIndex"
                                                Size="118" Class="employee-header-avatar clickable" @onclick="OpenAvatarUploadDialog" />
                            </MudTooltip>
                        }
                        else
                        {
                            <InitialsAvatar FullName="@_fullName"
                                            ImageSrc="@(string.IsNullOrEmpty(_avatarDataUrl) ? null : _avatarDataUrl)"
                                            ColorIndex="@_profile.AvatarColorIndex"
                                            Size="118" Class="employee-header-avatar" />
                        }
                    </MudItem>
                    <MudItem xs="12" sm="8" md="10">
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-2">
                                <MudText Typo="Typo.h5" Style="font-weight: 600; color: var(--dzd-text-primary);">@_fullName</MudText>
                                <MudChip T="string" Color="@LifecycleColor(_profile.LifecycleStatus, _profile.IsActive)" Variant="Variant.Text" Size="Size.Small">@LifecycleLabel(_profile.LifecycleStatus, _profile.IsActive)</MudChip>
                                <MudSpacer />
                                <MudChip T="string" Variant="Variant.Text" Size="Size.Small" Style="background-color:var(--dzd-bg-input); color:var(--dzd-text-secondary);">@(_profile.CompanyName ?? "-")</MudChip>
                            </MudStack>
                            <MudDivider Class="my-1" />
                            
                            <MudGrid Spacing="2" Class="mt-2">
                                <MudItem xs="6" sm="4" md="3">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@DzdIcons.Briefcase" Size="Size.Small" Style="color: #6c757d; font-size: 16px;" />
                                            <MudText Typo="Typo.caption" Style="color: #6c757d; font-weight: 500;">Job Title</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(_profile.Job?.Name ?? "-")</MudText>
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="6" sm="4" md="3">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@DzdIcons.Building" Size="Size.Small" Style="color: #6c757d; font-size: 16px;" />
                                            <MudText Typo="Typo.caption" Style="color: #6c757d; font-weight: 500;">Department</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(_profile.Department?.Name ?? "-")</MudText>
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="6" sm="4" md="3">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@DzdIcons.User" Size="Size.Small" Style="color: #6c757d; font-size: 16px;" />
                                            <MudText Typo="Typo.caption" Style="color: #6c757d; font-weight: 500;">Reporting To</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(AppFormatter.BuildFullName(_profile.ReportsTo?.FirstName, _profile.ReportsTo?.LastName) is { Length: > 0 } n ? n : "-")</MudText>
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="6" sm="4" md="3">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@DzdIcons.History" Size="Size.Small" Style="color: #6c757d; font-size: 16px;" />
                                            <MudText Typo="Typo.caption" Style="color: #6c757d; font-weight: 500;">Work Type</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(_profile.WorkModel ?? "-")</MudText>
                                    </MudStack>
                                </MudItem>
                            </MudGrid>

                            <MudGrid Spacing="2" Class="mt-4">
                                <MudItem xs="6" sm="4" md="3">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@DzdIcons.BadgeCheck" Size="Size.Small" Style="color: #6c757d; font-size: 16px;" />
                                            <MudText Typo="Typo.caption" Style="color: #6c757d; font-weight: 500;">Grade</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(_profile.Grade is null ? "-" : $"{_profile.Grade}")</MudText>
                                    </MudStack>
                                </MudItem>
                                <MudItem xs="6" sm="4" md="3">
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@DzdIcons.MapPin" Size="Size.Small" Style="color: #6c757d; font-size: 16px;" />
                                            <MudText Typo="Typo.caption" Style="color: #6c757d; font-weight: 500;">Location</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(_profile.PayrollLocation?.Name ?? "-")</MudText>
                                    </MudStack>
                                </MudItem>
                            </MudGrid>

                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </div>

        <div class="employee-card-tabs-scope">
            <div class="view-tabs-shell active-@_activeViewIndex view-tabs-4" role="tablist" aria-label="@(SelfService ? "My profile views" : "Employee page views")">
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 0 ? "true" : "false")" @onclick="() => SetView(0)">Overview</button>
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 1 ? "true" : "false")" @onclick="() => SetView(1)">Personal Info</button>
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 2 ? "true" : "false")" @onclick="() => SetView(2)">Career</button>
                <button type="button" class="tab-segment" role="tab" aria-selected="@(_activeViewIndex == 3 ? "true" : "false")" @onclick="() => SetView(3)">Payments</button>
            </div>

            @if (_activeViewIndex == 0)
            {
                <MudGrid Class="mt-3 mb-3" Spacing="3">
                    <MudItem xs="12" sm="6" md="4">
                        <InfoCard Label="Position Start Date"
                                  Value="@AppFormatter.FormatDate(_profile.PositionStartDate)"
                                  Icon="@DzdIcons.Calendar"
                                  Accent="InfoCard.AccentColor.Blue" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <InfoCard Label="Job Start Date"
                                  Value="@AppFormatter.FormatDate(_profile.UserStartDate)"
                                  Icon="@DzdIcons.CalendarDays"
                                  Accent="InfoCard.AccentColor.Green" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <InfoCard Label="Employment Duration"
                                  Value="@(_employmentDuration ?? "-")"
                                  Icon="@DzdIcons.ChartLine"
                                  Accent="InfoCard.AccentColor.Orange" />
                    </MudItem>
                </MudGrid>

                <MudGrid Class="mt-3 mb-3" Spacing="3">
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="2" Class="pa-4" Style="border-radius: 12px; border: 1px solid var(--dzd-bg-input); background-color: var(--dzd-surface-primary);">
                            <MudStack Spacing="3">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 500; color: var(--dzd-text-primary);">Contact Information</MudText>
                                <MudStack Spacing="2">
                                    <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 10px; background-color: var(--dzd-surface-primary); border: 1px solid var(--dzd-bg-input);">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <div Style="width: 40px; height: 40px; background-color: #E8EBFF; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                <MudIcon Icon="@DzdIcons.Mail" Style="color: #2B38F5; font-size: 20px;" />
                                            </div>
                                            <MudStack Spacing="0" Style="flex-grow: 1;">
                                                <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500;">Email</MudText>
                                                <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(_profile.Email ?? "-")</MudText>
                                            </MudStack>
                                        </MudStack>
                                    </MudPaper>
                                    <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 10px; background-color: var(--dzd-surface-primary); border: 1px solid var(--dzd-bg-input);">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <div Style="width: 40px; height: 40px; background-color: #E3F0EE; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                <MudIcon Icon="@DzdIcons.Phone" Style="color: #70A37F; font-size: 20px;" />
                                            </div>
                                            <MudStack Spacing="0" Style="flex-grow: 1;">
                                                <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500;">Phone</MudText>
                                                <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(GetWorkPhoneDisplay())</MudText>
                                            </MudStack>
                                        </MudStack>
                                    </MudPaper>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="2" Class="pa-4" Style="border-radius: 12px; border: 1px solid var(--dzd-bg-input); background-color: var(--dzd-surface-primary);">
                            <MudStack Spacing="3">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 500; color: var(--dzd-text-primary);">Work Information</MudText>
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" sm="6">
                                        <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 10px; background-color: var(--dzd-surface-primary); border: 1px solid var(--dzd-bg-input);">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <div Style="width: 40px; height: 40px; background-color: #E8EBFF; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                    <MudIcon Icon="@DzdIcons.FileText" Style="color: #2B38F5; font-size: 20px;" />
                                                </div>
                                                <MudStack Spacing="0" Style="flex-grow: 1;">
                                                    <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500;">Contract Type</MudText>
                                                    <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(_profile.ContractType ?? "-")</MudText>
                                                </MudStack>
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 10px; background-color: var(--dzd-surface-primary); border: 1px solid var(--dzd-bg-input);">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <div Style="width: 40px; height: 40px; background-color: #FFE8E0; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                    <MudIcon Icon="@DzdIcons.CalendarX" Style="color: #F46036; font-size: 20px;" />
                                                </div>
                                                <MudStack Spacing="0" Style="flex-grow: 1;">
                                                    <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500;">Contract End Date</MudText>
                                                    <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@AppFormatter.FormatDate(_profile.ContractEndDate)</MudText>
                                                </MudStack>
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 10px; background-color: var(--dzd-surface-primary); border: 1px solid var(--dzd-bg-input);">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <div Style="width: 40px; height: 40px; background-color: #E3F0EE; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                    <MudIcon Icon="@DzdIcons.Briefcase" Style="color: #70A37F; font-size: 20px;" />
                                                </div>
                                                <MudStack Spacing="0" Style="flex-grow: 1;">
                                                    <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500;">Work Type</MudText>
                                                    <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(_profile.WorkModel ?? "-")</MudText>
                                                </MudStack>
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudPaper Elevation="0" Class="pa-3" Style="border-radius: 10px; background-color: var(--dzd-surface-primary); border: 1px solid var(--dzd-bg-input);">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <div Style="width: 40px; height: 40px; background-color: #FFF8E8; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                    <MudIcon Icon="@DzdIcons.MapPin" Style="color: #FEA82F; font-size: 20px;" />
                                                </div>
                                                <MudStack Spacing="0" Style="flex-grow: 1;">
                                                    <MudText Typo="Typo.caption" Style="color: var(--dzd-text-secondary); font-weight: 500;">Payroll Location</MudText>
                                                    <MudText Typo="Typo.body2" Style="color: var(--dzd-text-primary); font-weight: 500;">@(_profile.PayrollLocation?.Name ?? "-")</MudText>
                                                </MudStack>
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                </MudGrid>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            }
            else if (_activeViewIndex == 2 && SelfService)
            {
                <MudStack Spacing="4" Class="mt-4">
                    <MudPaper Elevation="0" Class="pa-4" Style="border-radius:12px; border:1px solid var(--dzd-bg-input);">
                        <MudStack Spacing="3">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <div Style="width:36px;height:36px;background:#E8EBFF;border-radius:8px;display:flex;align-items:center;justify-content:center;">
                                    <MudIcon Icon="@DzdIcons.Building2" Style="color:#2B38F5;font-size:18px;" />
                                </div>
                                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Organization Placement</MudText>
                            </MudStack>
                            <MudDivider />
                            <MudGrid Spacing="2">
                                <MudItem xs="12" Class="mb-3">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.UserRound" Size="Size.Small" /> Manager</div>
                                    <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary);">@GetManagerDisplayName()</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.Building2" Size="Size.Small" /> Company</div>
                                    <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.CompanyName ?? "-")</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.Building" Size="Size.Small" /> Department</div>
                                    <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.Department?.Name ?? "-")</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.Users" Size="Size.Small" /> Team</div>
                                    <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.Team?.Name ?? "-")</MudText>
                                </MudItem>
                            </MudGrid>
                        </MudStack>
                    </MudPaper>

                    <MudPaper Elevation="0" Class="pa-4" Style="border-radius:12px; border:1px solid var(--dzd-bg-input);">
                        <MudStack Spacing="3">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <div Style="width:36px;height:36px;background:#E3F0EE;border-radius:8px;display:flex;align-items:center;justify-content:center;">
                                    <MudIcon Icon="@DzdIcons.Route" Style="color:#70A37F;font-size:18px;" />
                                </div>
                                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Career Path Assignment</MudText>
                            </MudStack>
                            <MudDivider />
                            <MudGrid Spacing="2">
                                <MudItem xs="12" sm="4">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.Route" Size="Size.Small" /> Career Path</div>
                                    <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.CareerPathName ?? "-")</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.Briefcase" Size="Size.Small" /> Job Title</div>
                                    <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.Job?.Name ?? "-")</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.BadgeCheck" Size="Size.Small" /> Grade Level</div>
                                    <MudText Typo="Typo.body1" Style="font-weight:500; color:var(--dzd-text-primary);">@(_profile.Grade?.ToString() ?? "-")</MudText>
                                </MudItem>
                            </MudGrid>
                        </MudStack>
                    </MudPaper>
                </MudStack>
            }
            else if (_activeViewIndex == 2)
            {
                @if (!_career.IsLoaded)
                {
                    <MudStack AlignItems="AlignItems.Center" Class="py-8">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    </MudStack>
                }
                else
                {
                <MudStack Spacing="4" Class="mt-4">

                    <MudPaper Elevation="0" Class="pa-4" Style="border-radius:12px; border:1px solid var(--dzd-bg-input);">
                        @{
                            var currentPos = _positionHistory.FirstOrDefault(x => x.IsCurrent);
                        }
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Career History</MudText>
                            </MudStack>
                            @if (!SelfService && currentPos is null)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                           StartIcon="@DzdIcons.Plus" OnClick="@(() => OpenCareerAssignmentDialogAsync(null))">Assign Position</MudButton>
                            }
                        </MudStack>

                        @if (_positionHistory.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">
                                No position assigned yet. Use “Assign Position” to set the employee's company, team, career path and grade.
                            </MudText>
                        }
                        else
                        {
                            <MudStack Spacing="3">
                                @foreach (var p in _positionHistory)
                                {
                                    <MudPaper Elevation="0" Class="pa-3"
                                              Style="@($"border-radius:12px; border:1px solid {(p.IsCurrent ? "#2B38F5" : "var(--dzd-bg-input)")};")">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Spacing="2">
                                            <MudStack Spacing="2">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                                                    <MudText Typo="Typo.subtitle2" Style="font-weight:600;">@(p.JobTitle ?? "-")</MudText>
                                                    @if (p.IsCurrent)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">Current</MudChip>
                                                    }
                                                    @if (!string.IsNullOrEmpty(p.ChangeType))
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">@p.ChangeType</MudChip>
                                                    }
                                                    @if (p.Grade.HasValue)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Grade @p.Grade</MudChip>
                                                    }
                                                </MudStack>
                                                <MudStack Row="true" Spacing="4" Wrap="Wrap.Wrap">
                                                    <span style="color:var(--dzd-text-secondary);font-size:13px;display:inline-flex;align-items:center;gap:4px;">
                                                        <MudIcon Icon="@DzdIcons.Building2" Size="Size.Small" /> @(p.DepartmentName ?? p.CompanyName ?? "-")
                                                    </span>
                                                    @if (!string.IsNullOrEmpty(p.TeamName))
                                                    {
                                                        <span style="color:var(--dzd-text-secondary);font-size:13px;display:inline-flex;align-items:center;gap:4px;">
                                                            <MudIcon Icon="@DzdIcons.Users" Size="Size.Small" /> @p.TeamName
                                                        </span>
                                                    }
                                                    <span style="color:var(--dzd-text-secondary);font-size:13px;display:inline-flex;align-items:center;gap:4px;">
                                                        <MudIcon Icon="@DzdIcons.CalendarDays" Size="Size.Small" /> @FormatPositionRange(p)
                                                    </span>
                                                </MudStack>
                                            </MudStack>
                                            @if (!SelfService && p.IsCurrent)
                                            {
                                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Style="align-self:center;">
                                                    <MudButton Variant="Variant.Filled" Size="Size.Small"
                                                               StartIcon="@DzdIcons.TrendingUp" OnClick="OpenPromotionDialogAsync"
                                                               Style="background-color:#FEA82F;color:#fff;">Promote</MudButton>
                                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                                               StartIcon="@DzdIcons.Pencil" OnClick="@(() => OpenCareerAssignmentDialogAsync(p))">Edit</MudButton>
                                                </MudStack>
                                            }
                                        </MudStack>
                                    </MudPaper>
                                }
                            </MudStack>
                        }
                    </MudPaper>

                    <MudPaper Elevation="0" Class="pa-6 clp-card" Style="border-radius:14px; border:1px solid var(--dzd-bg-input);">
                        <div class="clp-head">
                            <div>
                                <MudText Typo="Typo.h6" Style="font-weight:600;">Career Level Progress</MudText>
                                <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">Track your grade progression</MudText>
                            </div>
                            @if (_profile?.Grade is int g)
                            {
                                <div class="clp-grade-badge">
                                    <MudIcon Icon="@DzdIcons.Award" Size="Size.Small" />
                                    <span>Grade @g</span>
                                </div>
                            }
                        </div>

                        @{
                            var rules = PathRulesOrdered();
                        }
                        @if (rules.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);" Class="mt-3">
                                Assign a career path to see the grade progression and next-level requirements.
                            </MudText>
                        }
                        else
                        {
                            <div class="clp-stepper">
                                @for (var i = 0; i < rules.Count; i++)
                                {
                                    var r        = rules[i];
                                    var done     = _profile?.Grade is int cg && r.Grade < cg;
                                    var current  = _profile?.Grade == r.Grade;
                                    var state    = current ? "current" : done ? "done" : "next";
                                    var lineDone = _profile?.Grade is int lg && r.Grade <= lg;
                                    <div class="clp-step clp-step--@state">
                                        @if (i > 0)
                                        {
                                            <span class="clp-line @(lineDone ? "clp-line--done" : "")"></span>
                                        }
                                        <div class="clp-node">
                                            @if (done)
                                            {
                                                <MudIcon Icon="@DzdIcons.Check" Size="Size.Small" />
                                            }
                                            else
                                            {
                                                <span>@r.Grade</span>
                                            }
                                        </div>
                                        <span class="clp-step-label">
                                            @if (current)
                                            {
                                                <span class="clp-dot"></span>
                                            }
                                            @(current ? "Now" : done ? "Done" : "Next")
                                        </span>
                                    </div>
                                }
                            </div>

                            @if (NextGradeRule() is { } next)
                            {
                                var reqs  = NextGradeRequirements();
                                var total = reqs.Count;
                                var met   = reqs.Count(x => x.Status == ReqStatus.Completed);
                                var pct   = total == 0 ? 0 : (int)Math.Round(met * 100.0 / total);

                                <div class="clp-req-box">
                                    <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Next Grade Requirements</MudText>
                                    <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">Requirements to advance to Grade @next.Grade</MudText>

                                    <div class="clp-overall-head">
                                        <span>@met of @total met</span>
                                        <span>@pct%</span>
                                    </div>
                                    <div class="clp-overall-track">
                                        <div class="clp-overall-fill" style="@($"width:{pct}%;")"></div>
                                    </div>

                                    @if (total > 0)
                                    {
                                        <table class="clp-table">
                                            <thead>
                                                <tr>
                                                    <th>Requirement</th>
                                                    <th>Required</th>
                                                    <th>Current Status</th>
                                                    <th>Progress</th>
                                                    <th>Status</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var req in reqs)
                                                {
                                                    <tr>
                                                        <td>
                                                            <div class="clp-req-name">
                                                                <span class="clp-req-icon" style="@($"background:{req.IconBg};color:{req.IconColor};")">
                                                                    <MudIcon Icon="@req.Icon" Size="Size.Small" />
                                                                </span>
                                                                <span>@req.Name</span>
                                                            </div>
                                                        </td>
                                                        <td class="clp-muted">@req.Required</td>
                                                        <td>@req.CurrentStatus</td>
                                                        <td>
                                                            <div class="clp-progress-cell">
                                                                <div class="clp-row-track">
                                                                    <div class="clp-row-fill clp-row-fill--@req.Status.ToString().ToLower()" style="@($"width:{req.Progress}%;")"></div>
                                                                </div>
                                                                <span class="clp-row-pct">@req.Progress%</span>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            @switch (req.Status)
                                                            {
                                                                case ReqStatus.Completed:
                                                                    <span class="clp-chip clp-chip--done"><MudIcon Icon="@DzdIcons.CircleCheck" Size="Size.Small" /> Completed</span>
                                                                    break;
                                                                case ReqStatus.InProgress:
                                                                    <span class="clp-chip clp-chip--progress"><MudIcon Icon="@DzdIcons.Loader" Size="Size.Small" /> In Progress</span>
                                                                    break;
                                                                default:
                                                                    <span class="clp-chip clp-chip--pending"><MudIcon Icon="@DzdIcons.Clock" Size="Size.Small" /> Pending</span>
                                                                    break;
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                </div>
                            }
                        }
                    </MudPaper>

                    <MudPaper Elevation="0" Class="pa-4" Style="border-radius:12px; border:1px solid var(--dzd-bg-input);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-1">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@DzdIcons.FileText" Style="color:#2B38F5;" />
                                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">CV / Resume Management</MudText>
                            </MudStack>
                            @if (!SelfService)
                            {
                                <MudFileUpload T="IBrowserFile" Accept="@CvAcceptList" MaximumFileCount="1" OnFilesChanged="OnCvFileSelected">
                                    <ActivatorContent>
                                        <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                                   StartIcon="@DzdIcons.Upload" Disabled="@_cvUploading">Upload New CV</MudButton>
                                    </ActivatorContent>
                                </MudFileUpload>
                            }
                        </MudStack>

                        @if (_cvUploading)
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-2" />
                        }

                        @if (_cvDocuments.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">No documents uploaded yet.</MudText>
                        }
                        else
                        {
                            <MudStack Spacing="2">
                                @foreach (var doc in _cvDocuments)
                                {
                                    <MudPaper Elevation="0" Class="pa-3" Style="border-radius:10px; border:1px solid var(--dzd-bg-input);">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                                <MudIcon Icon="@DzdIcons.FileText" Style="color:#E5484D;" />
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2" Style="font-weight:600;">@doc.FileName</MudText>
                                                    <MudText Typo="Typo.caption" Style="color:var(--dzd-text-secondary);">
                                                        @(doc.UploadedAt is { } u ? $"Uploaded: {u:MMM d, yyyy}" : "") · @FormatFileSize(doc.SizeBytes)
                                                    </MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudStack Row="true" Spacing="1">
                                                <MudIconButton Icon="@DzdIcons.Download" Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(() => DownloadDocumentAsync(doc))" />
                                                @if (!SelfService)
                                                {
                                                    <MudIconButton Icon="@DzdIcons.Trash2" Size="Size.Small" Color="Color.Error"
                                                                   OnClick="@(() => DeleteDocumentAsync(doc))" />
                                                }
                                            </MudStack>
                                        </MudStack>
                                    </MudPaper>
                                }
                            </MudStack>
                        }
                    </MudPaper>

                </MudStack>
                }
            }
            else if (_activeViewIndex == 1)
            {
                @if (_profile is null)
                {
                    <MudAlert Severity="Severity.Warning" Class="mt-4">No personal information available.</MudAlert>
                }
                else
                {
                    <div class="dzd-personal-info-bg pa-0">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                            <div class="dzd-section-title" style="margin:0;">
                                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background-color:var(--dzd-blue-500);margin-left:4px;margin-right:2px;vertical-align:middle;" aria-hidden="true"></span> Employee Details
                            </div>
                            @if (!SelfService && !_basicInfoEdit.IsEditing)
                            {
                                <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="StartBasicInfoEdit" />
                            }
                        </MudStack>

                        <MudPaper Elevation="1" Class="dzd-card pa-6">
                            <MudGrid Spacing="4">
                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.User" Size="Size.Small" /> Full Name</div>
