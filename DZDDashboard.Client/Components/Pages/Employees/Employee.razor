                                    }
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.IdCard" Size="Size.Small" /> Registry Number (Sicil No)</div>
                                    @if (_basicInfoEdit.IsEditing)
