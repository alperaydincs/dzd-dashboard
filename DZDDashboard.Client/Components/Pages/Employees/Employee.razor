                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <div class="dzd-field-label"><MudIcon Icon="@DzdIcons.FileText" Size="Size.Small" /> Contract Type</div>
                                    @if (_basicInfoEdit.IsEditing)
