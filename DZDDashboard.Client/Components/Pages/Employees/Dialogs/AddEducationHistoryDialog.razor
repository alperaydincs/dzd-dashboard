@using DZDDashboard.Common.Constants
@using DZDDashboard.Client.Services
@inject ISnackbar Snackbar
@inject ILookupClientService Lookups

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudSelect T="string" Label="Education Level" @bind-Value="_model.Level" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                @foreach (var option in _levelOptions)
                {
                    <MudSelectItem Value="@option">@option</MudSelectItem>
                }
            </MudSelect>

            <MudTextField T="string" Label="Institution" @bind-Value="_model.Institution" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
            <MudTextField T="string" Label="Program / Department" @bind-Value="_model.Program" Variant="Variant.Outlined" Margin="Margin.Dense" />

            <MudDatePicker Label="Graduation Date" Date="@_model.GraduationDate" DateChanged="@(d => _model.GraduationDate = d)"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter"
                           OverflowBehavior="OverflowBehavior.FlipNever" />

            <MudSelect T="string" Label="Status" @bind-Value="_model.Status" Variant="Variant.Outlined" Margin="Margin.Dense">
                @foreach (var status in EducationStatuses.All)
                {
                    <MudSelectItem Value="@status">@status</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save"
                   Disabled="@_submitted">@ConfirmButtonText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<string> _levelOptions = [.. EducationLevels.All];

    protected override async Task OnInitializedAsync()
    {
        var values = await Lookups.GetValuesAsync(LookupCategories.EducationLevel);
        if (values.Count > 0) _levelOptions = values;
    }

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public AddEducationHistoryDialogResult? InitialModel { get; set; }
    [Parameter] public string ConfirmButtonText { get; set; } = "Add";

    private AddEducationHistoryDialogResult _model = new()
    {
        Status = EducationStatuses.Completed
    };

    private bool _initialized;
    private bool _submitted;

    protected override void OnParametersSet()
    {
        if (_initialized || InitialModel is null) return;
        _initialized = true;

        _model = new AddEducationHistoryDialogResult
        {
            Level          = InitialModel.Level,
            Institution    = InitialModel.Institution,
            Program        = InitialModel.Program,
            GraduationDate = InitialModel.GraduationDate,
            Status         = InitialModel.Status
        };
    }

    private void Save()
    {
        if (_submitted) return;
        if (string.IsNullOrWhiteSpace(_model.Level) || string.IsNullOrWhiteSpace(_model.Institution))
        {
            Snackbar.Add("Education level and institution are required.", Severity.Warning);
            return;
        }
        _submitted = true;
        MudDialog.Close(DialogResult.Ok(_model));
    }

    private void Cancel() => MudDialog.Cancel();

    public sealed class AddEducationHistoryDialogResult
    {
        public string    Level          { get; set; } = string.Empty;
        public string    Institution    { get; set; } = string.Empty;
        public string?   Program        { get; set; }
        public DateTime? GraduationDate { get; set; }
        public string    Status         { get; set; } = EducationStatuses.Completed;
    }
}
