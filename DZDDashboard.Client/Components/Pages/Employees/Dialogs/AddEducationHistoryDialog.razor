@using DZDDashboard.Common.Constants
@using DZDDashboard.Client.Services
@inject ISnackbar Snackbar
@inject DZDDashboard.Client.Localization.DomainLocalizer Domain
@inject DZDDashboard.Client.Localization.AppLocalizer Loc

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudSelect T="string" Label="@Loc["educationDialog.educationLevel"]" @bind-Value="_model.EducationLevel" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                @foreach (var option in Domain.Options(DomainCategories.EducationLevel))
                {
                    <MudSelectItem Value="@option.Code">@option.Label</MudSelectItem>
                }
            </MudSelect>

            <MudTextField T="string" Label="@Loc["educationDialog.institution"]" @bind-Value="_model.Institution" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
            <MudTextField T="string" Label="@Loc["educationDialog.programDepartment"]" @bind-Value="_model.Program" Variant="Variant.Outlined" Margin="Margin.Dense" />

            <MudDatePicker Label="@Loc["educationDialog.graduationDate"]" Date="@_model.GraduationDate" DateChanged="@(d => _model.GraduationDate = d)"
                           Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="dd.MM.yyyy"
                           AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter"
                           OverflowBehavior="OverflowBehavior.FlipNever" />

            <MudSelect T="string" Label="@Loc["educationDialog.status"]" @bind-Value="_model.Status" Variant="Variant.Outlined" Margin="Margin.Dense">
                @foreach (var option in Domain.Options(DomainCategories.EducationStatus))
                {
                    <MudSelectItem Value="@option.Code">@option.Label</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@Loc["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save"
                   Disabled="@_submitted">@ConfirmButtonText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public AddEducationHistoryDialogResult? InitialModel { get; set; }
    [Parameter] public string ConfirmButtonText { get; set; } = "Add";

    private AddEducationHistoryDialogResult _model = new()
    {
        Status = EducationStatuses.Completed
    };

    private bool _initialized;
    private bool _submitted;

    protected override void OnParametersSet()
    {
        if (_initialized || InitialModel is null) return;
        _initialized = true;

        _model = new AddEducationHistoryDialogResult
        {
            EducationLevel   = InitialModel.EducationLevel,
            Institution      = InitialModel.Institution,
            Program          = InitialModel.Program,
            GraduationDate   = InitialModel.GraduationDate,
            Status           = InitialModel.Status
        };
    }

    private void Save()
    {
        if (_submitted) return;
        if (string.IsNullOrWhiteSpace(_model.EducationLevel) || string.IsNullOrWhiteSpace(_model.Institution))
        {
            Snackbar.Add(Loc["educationDialog.requiredFields"], Severity.Warning);
            return;
        }
        _submitted = true;
        MudDialog.Close(DialogResult.Ok(_model));
    }

    private void Cancel() => MudDialog.Cancel();

    public sealed class AddEducationHistoryDialogResult
    {
        public string?   EducationLevel   { get; set; }
        public string    Institution      { get; set; } = string.Empty;
        public string?   Program          { get; set; }
        public DateTime? GraduationDate   { get; set; }
        public string    Status           { get; set; } = EducationStatuses.Completed;
    }
}
