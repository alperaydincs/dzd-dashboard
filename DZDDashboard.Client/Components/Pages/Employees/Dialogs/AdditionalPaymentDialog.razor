@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center" style="gap:10px;">
            <MudIcon Icon="@DzdIcons.Award" Size="Size.Small" Style="color:var(--dzd-green-500); font-size:18px;" />
            <MudText Typo="Typo.h6" Style="font-size:16px; font-weight:600;">@MudDialog.Title</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudGrid Spacing="3">
                <MudItem xs="6">
                    <div class="dzd-dialog-label">Payment Type <span class="dzd-required">*</span></div>
                    <MudSelect T="string" @bind-Value="_model.PaymentType" Variant="Variant.Outlined" Margin="Margin.Dense"
                               Required="true" Placeholder="Select payment type">
                        @foreach (var option in AdditionalPaymentTypes.All)
                        {
                            <MudSelectItem Value="@option">@option</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">Amount <span class="dzd-required">*</span></div>
                    <MudNumericField T="decimal" @bind-Value="_model.Amount" Variant="Variant.Outlined" Margin="Margin.Dense"
                                     Required="true" Min="0.01m" Format="N2" Placeholder="0" />
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">Currency <span class="dzd-required">*</span></div>
                    <MudSelect T="string" @bind-Value="_model.Currency" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                        @foreach (var option in Currencies.All)
                        {
                            <MudSelectItem Value="@option">@Currencies.Display(option)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">Period <span class="dzd-required">*</span></div>
                    <MudSelect T="string" @bind-Value="_model.Period" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                        @foreach (var option in AdditionalPaymentPeriods.All)
                        {
                            <MudSelectItem Value="@option">@option</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            @if (_model.Period == AdditionalPaymentPeriods.OneTime)
            {
                <div>
                    <div class="dzd-dialog-label">Payment Date <span class="dzd-required">*</span></div>
                    <MudDatePicker Date="@_model.PaymentDate" DateChanged="@(d => _model.PaymentDate = d)"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Required="true"
                                   AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" />
                </div>
            }
            else
            {
                <MudGrid Spacing="3">
                    <MudItem xs="6">
                        <div class="dzd-dialog-label">Start Date <span class="dzd-required">*</span></div>
                        <MudDatePicker Date="@_model.StartDate" DateChanged="@(d => _model.StartDate = d)"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Required="true"
                                       AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" />
                    </MudItem>
                    <MudItem xs="6">
                        <div class="dzd-dialog-label">End Date (Optional)</div>
                        <MudDatePicker Date="@_model.EndDate" DateChanged="@(d => _model.EndDate = d)"
                                       Variant="Variant.Outlined" Margin="Margin.Dense"
                                       AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" />
                    </MudItem>
                </MudGrid>
            }

            <div>
                <div class="dzd-dialog-label">Description</div>
                <MudTextField T="string" @bind-Value="_model.Description" Variant="Variant.Outlined" Margin="Margin.Dense"
                              Lines="2" Placeholder="Enter description" />
            </div>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_submitted">@ConfirmButtonText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public AdditionalPaymentDto? InitialModel { get; set; }
    [Parameter] public string ConfirmButtonText { get; set; } = "Add Payment";

    private AdditionalPaymentDto _model = new()
    {
        PaymentType = AdditionalPaymentTypes.Bonus,
        Currency    = Currencies.Try,
        Period      = AdditionalPaymentPeriods.OneTime,
        PaymentDate = DateTime.Today
    };

    private bool _initialized;
    private bool _submitted;

    protected override void OnParametersSet()
    {
        if (_initialized || InitialModel is null) return;
        _initialized = true;

        _model = InitialModel with { };
    }

    private void Save()
    {
        if (_submitted) return;

        if (_model.Amount <= 0)
        {
            Snackbar.Add("Amount must be greater than zero.", Severity.Warning);
            return;
        }

        if (_model.Period == AdditionalPaymentPeriods.OneTime)
        {
            if (!_model.PaymentDate.HasValue)
            {
                Snackbar.Add("Payment date is required for one-time payments.", Severity.Warning);
                return;
            }
            _model.StartDate = null;
            _model.EndDate   = null;
        }
        else
        {
            if (!_model.StartDate.HasValue)
            {
                Snackbar.Add("Start date is required for periodic payments.", Severity.Warning);
                return;
            }
            if (_model.EndDate.HasValue && _model.EndDate < _model.StartDate)
            {
                Snackbar.Add("End date cannot be before start date.", Severity.Warning);
                return;
            }
            _model.PaymentDate = null;
        }

        _submitted = true;
        MudDialog.Close(DialogResult.Ok(_model));
    }

    private void Cancel() => MudDialog.Cancel();
}
