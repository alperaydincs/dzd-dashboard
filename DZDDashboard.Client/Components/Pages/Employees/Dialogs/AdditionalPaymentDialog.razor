@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@using DZDDashboard.Client.Services
@inject ISnackbar Snackbar
@inject DZDDashboard.Client.Localization.DomainLocalizer Domain
@inject DZDDashboard.Client.Localization.AppLocalizer Loc

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center" style="gap:10px;">
            <MudIcon Icon="@DzdIcons.Award" Size="Size.Small" Style="color:var(--dzd-green-500); font-size:18px;" />
            <MudText Typo="Typo.h6" Style="font-size:16px; font-weight:600;">@MudDialog.Title</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudGrid Spacing="3">
                <MudItem xs="6">
                    <div class="dzd-dialog-label">@Loc["payment.colPaymentType"] <span class="dzd-required">*</span></div>
                    <MudSelect T="string" @bind-Value="_model.PaymentType" Variant="Variant.Outlined" Margin="Margin.Dense"
                               Required="true" Placeholder="@Loc["dialogField.selectPaymentType"]">
                        @foreach (var option in Domain.Options(DomainCategories.AdditionalPaymentType))
                        {
                            <MudSelectItem Value="@option.Code">@option.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">@Loc["payment.amount"] <span class="dzd-required">*</span></div>
                    <MudNumericField T="decimal" @bind-Value="_model.Amount" Variant="Variant.Outlined" Margin="Margin.Dense"
                                     Required="true" Min="0.01m" Format="N2" Placeholder="0" />
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">@Loc["payment.currency"] <span class="dzd-required">*</span></div>
                    <MudSelect T="string" @bind-Value="_model.Currency" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                        @foreach (var option in Domain.Options(DomainCategories.Currency))
                        {
                            <MudSelectItem Value="@option.Code">@option.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">@Loc["dialogField.period"] <span class="dzd-required">*</span></div>
                    <MudSelect T="string" @bind-Value="_model.Period" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                        @foreach (var option in Domain.Options(DomainCategories.AdditionalPaymentPeriod))
                        {
                            <MudSelectItem Value="@option.Code">@option.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudGrid Spacing="3">
                <MudItem xs="6">
                    <div class="dzd-dialog-label">@Loc["payment.startDate"] <span class="dzd-required">*</span></div>
                    <MudDatePicker Date="@_model.StartDate" DateChanged="@(d => _model.StartDate = d ?? _model.StartDate)"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" DateFormat="dd.MM.yyyy"
                                   AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" />
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">@Loc["salaryDialog.endDateOptional"]</div>
                    <MudDatePicker Date="@_model.EndDate" DateChanged="@(d => _model.EndDate = d)"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="dd.MM.yyyy"
                                   AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" />
                </MudItem>
            </MudGrid>

            <div>
                <div class="dzd-dialog-label">@Loc["dialogField.description"]</div>
                <MudTextField T="string" @bind-Value="_model.Description" Variant="Variant.Outlined" Margin="Margin.Dense"
                              Lines="2" Placeholder="@Loc["dialogField.enterDescription"]" />
            </div>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@Loc["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_submitted">@ConfirmButtonText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    protected override void OnInitialized()
    {
        _model.PaymentType ??= AdditionalPaymentTypes.Bonus;
    }

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public AdditionalPaymentDto? InitialModel { get; set; }
    [Parameter] public string ConfirmButtonText { get; set; } = "Add Payment";

    private AdditionalPaymentDto _model = new()
    {
        Currency  = Currencies.Try,
        Period    = AdditionalPaymentPeriods.OneTime,
        StartDate = DateTime.Today
    };

    private bool _initialized;
    private bool _submitted;

    protected override void OnParametersSet()
    {
        if (_initialized || InitialModel is null) return;
        _initialized = true;

        _model = InitialModel with { };
    }

    private void Save()
    {
        if (_submitted) return;

        if (_model.Amount <= 0)
        {
            Snackbar.Add(Loc["dialogField.amountRequired"], Severity.Warning);
            return;
        }

        if (_model.EndDate.HasValue && _model.EndDate < _model.StartDate)
        {
            Snackbar.Add(Loc["salaryDialog.endDateBeforeStart"], Severity.Warning);
            return;
        }

        _submitted = true;
        MudDialog.Close(DialogResult.Ok(_model));
    }

    private void Cancel() => MudDialog.Cancel();
}
