@using DZDDashboard.Common.Validation

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@DzdIcons.Network" Color="Color.Primary" Size="Size.Small" />
            <MudText Typo="Typo.h6">New Position</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3" Style="color:var(--dzd-text-secondary);">
            A new node will be created under @ManagerName. Name the employee's position.
        </MudText>
        <MudTextField @bind-Value="_name"
                      Label="Position name"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      MaxLength="ValidationConstants.MaxPositionNameLength"
                      Immediate="true"
                      AutoFocus="true" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Confirm" Disabled="@string.IsNullOrWhiteSpace(_name)">Create &amp; Assign</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string ManagerName { get; set; } = "the manager";

    private string _name = string.Empty;

    private void Confirm()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;
        MudDialog.Close(DialogResult.Ok(_name.Trim()));
    }

    private void Cancel() => MudDialog.Cancel();
}
