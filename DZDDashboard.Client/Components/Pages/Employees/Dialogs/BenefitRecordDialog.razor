@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@using DZDDashboard.Common.Validation
@using DZDDashboard.Client.Services
@inject ISnackbar Snackbar
@inject DZDDashboard.Client.Localization.DomainLocalizer Domain
@inject DZDDashboard.Client.Localization.AppLocalizer Loc

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center" style="gap:10px;">
            <MudIcon Icon="@DzdIcons.Gift" Size="Size.Small" Style="color:var(--dzd-orange-500);" />
            <MudText Typo="Typo.h6" Style="font-size:16px; font-weight:600;">@MudDialog.Title</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudGrid Spacing="3">
                <MudItem xs="6">
                    <div class="dzd-dialog-label">@Loc["payment.benefitType"]</div>
                    <MudSelect T="string" @bind-Value="_model.BenefitType" @bind-Value:after="UpdateDialogSizeAsync" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true"
                               Placeholder="@Loc["benefitDialog.selectBenefitType"]">
                        @foreach (var option in Domain.Options(DomainCategories.BenefitType))
                        {
                            <MudSelectItem Value="@option.Code">@option.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">@Loc["benefitDialog.benefitName"]</div>
                    <MudTextField T="string" @bind-Value="_model.BenefitName" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  MaxLength="ValidationConstants.MaxBenefitNameLength" Placeholder="@Loc["benefitDialog.enterBenefitName"]" />
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">@Loc["dialogField.amountTl"]</div>
                    <MudNumericField T="decimal" @bind-Value="_model.Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" Min="0.01m" Format="N2" />
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">@Loc["payment.currency"] <span class="dzd-required">*</span></div>
                    <MudSelect T="string" @bind-Value="_model.Currency" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                        @foreach (var option in Domain.Options(DomainCategories.Currency))
                        {
                            <MudSelectItem Value="@option.Code">@option.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">@Loc["payment.frequency"]</div>
                    <MudSelect T="string" @bind-Value="_model.Period" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                        @foreach (var option in Domain.Options(DomainCategories.PaymentPeriod))
                        {
                            <MudSelectItem Value="@option.Code">@option.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">@Loc["payment.startDate"]</div>
                    <MudDatePicker Date="@_model.StartDate" DateChanged="@(d => _model.StartDate = d ?? _model.StartDate)"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" DateFormat="dd.MM.yyyy"
                                   AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" />
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">@Loc["salaryDialog.endDateOptional"]</div>
                    <MudDatePicker Date="@_model.EndDate" DateChanged="@(d => _model.EndDate = d)"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="dd.MM.yyyy"
                                   AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" />
                </MudItem>
            </MudGrid>

            @if (_model.BenefitType == BenefitTypes.PrivateHealthInsurance)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mt-1">
                    <div class="d-flex align-center" style="gap:8px;">
                        <MudIcon Icon="@DzdIcons.Users" Size="Size.Small" Style="color:var(--dzd-text-secondary); font-size:16px;" />
                        <MudText Typo="Typo.subtitle2">@string.Format(Loc["benefitDialog.dependentsCount"], _model.Dependents.Count, ValidationConstants.MaxBenefitDependents)</MudText>
                    </div>
                    <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@DzdIcons.Plus" OnClick="AddDependent"
                               Disabled="@(_model.Dependents.Count >= ValidationConstants.MaxBenefitDependents)">@Loc["completeStepDialog.addDependent"]</MudButton>
                </MudStack>

                @foreach (var dependent in _model.Dependents)
                {
                    <MudPaper Class="pa-3" Elevation="0" Outlined="true" Style="border-radius:8px;">
                        <MudGrid Spacing="2">
                            <MudItem xs="6" sm="3">
                                <div class="dzd-dialog-label">@Loc["dialogField.name"]</div>
                                <MudTextField T="string" @bind-Value="dependent.DependentName" Variant="Variant.Outlined" Margin="Margin.Dense"
                                              MaxLength="ValidationConstants.MaxShortNameLength" Placeholder="@Loc["benefitDialog.enterName"]" />
                            </MudItem>
                            <MudItem xs="6" sm="2">
                                <div class="dzd-dialog-label">@Loc["dialogField.relation"]</div>
                                <MudSelect T="string" @bind-Value="dependent.RelationType" Variant="Variant.Outlined" Margin="Margin.Dense">
                                    @foreach (var option in Domain.Options(DomainCategories.RelationType))
                                    {
                                        <MudSelectItem Value="@option.Code">@option.Label</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="6" sm="2">
                                <div class="dzd-dialog-label">@Loc["dialogField.amountTl"]</div>
                                <MudNumericField T="decimal" @bind-Value="dependent.Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.01m" Format="N2" />
                            </MudItem>
                            <MudItem xs="6" sm="2">
                                <div class="dzd-dialog-label">@Loc["payment.startDate"]</div>
                                <MudDatePicker Date="@dependent.StartDate" DateChanged="@(d => dependent.StartDate = d ?? dependent.StartDate)"
                                               Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="dd.MM.yyyy"
                                               AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" />
                            </MudItem>
                            <MudItem xs="6" sm="2">
                                <div class="dzd-dialog-label">@Loc["benefitDialog.endDate"]</div>
                                <MudDatePicker Date="@dependent.EndDate" DateChanged="@(d => dependent.EndDate = d)"
                                               Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="dd.MM.yyyy"
                                               AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" />
                            </MudItem>
                            <MudItem xs="6" sm="1" Class="d-flex align-center justify-end">
                                <MudIconButton Icon="@DzdIcons.Trash" Size="Size.Small" Color="Color.Error" OnClick="@(() => RemoveDependent(dependent))" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                }
            }

            @if (_model.BenefitType == BenefitTypes.PrivatePension)
            {
                <div class="mt-1">
                    <MudText Typo="Typo.subtitle2">@Loc["payment.besDetails"]</MudText>
                    <MudText Typo="Typo.caption" Style="color:var(--dzd-text-secondary);">
                        @Loc["benefitDialog.besMaxByGrade"]
                    </MudText>
                </div>
                <MudGrid Spacing="3">
                    <MudItem xs="6">
                        <div class="dzd-dialog-label">@Loc["benefitDialog.employeeContribution"]</div>
                        <MudNumericField T="decimal?" @bind-Value="_model.EmployeeContributionAmount"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Min="0m" Format="N2" Placeholder="0" />
                    </MudItem>
                    <MudItem xs="6">
                        <div class="dzd-dialog-label">@Loc["benefitDialog.employerContribution"]</div>
                        <MudNumericField T="decimal?" @bind-Value="_model.EmployerContributionAmount"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Min="0m" Format="N2" Placeholder="0" />
                    </MudItem>
                    <MudItem xs="6">
                        <div class="dzd-dialog-label">@Loc["payment.provider"]</div>
                        <MudTextField T="string" @bind-Value="_model.ProviderName" Variant="Variant.Outlined" Margin="Margin.Dense"
                                      MaxLength="ValidationConstants.MaxProviderNameLength" Placeholder="@Loc["benefitDialog.providerExample"]" />
                    </MudItem>
                    <MudItem xs="6">
                        <div class="dzd-dialog-label">@Loc["payment.policyNumber"]</div>
                        <MudTextField T="string" @bind-Value="_model.PolicyNumber" Variant="Variant.Outlined" Margin="Margin.Dense"
                                      MaxLength="ValidationConstants.MaxPolicyNumberLength" Placeholder="@Loc["benefitDialog.policyNumberPlaceholder"]" />
                    </MudItem>
                </MudGrid>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">@Loc["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_submitted">@ConfirmButtonText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public BenefitRecordDto? InitialModel { get; set; }
    [Parameter] public string ConfirmButtonText { get; set; } = "Add Benefit";

    private BenefitRecordDto _model = new()
    {
        BenefitType = string.Empty,
        Payer       = BenefitPayers.Employer,
        Currency    = Currencies.Try,
        Period      = PaymentPeriods.Monthly,
        StartDate   = DateTime.Today,
        Source      = PaymentSources.Manual
    };

    private bool _initialized;
    private bool _submitted;

    protected override async Task OnParametersSetAsync()
    {
        if (_initialized || InitialModel is null) return;
        _initialized = true;

        _model = InitialModel with { Dependents = InitialModel.Dependents.Select(d => d with { }).ToList() };
        await UpdateDialogSizeAsync();
    }

    private Task UpdateDialogSizeAsync()
    {
        var options = _model.BenefitType == BenefitTypes.PrivateHealthInsurance
            ? new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true }
            : new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        return MudDialog.SetOptionsAsync(options);
    }

    private void AddDependent()
    {
        if (_model.Dependents.Count >= ValidationConstants.MaxBenefitDependents) return;

        _model.Dependents.Add(new BenefitDependentDto
        {
            Order           = _model.Dependents.Count + 1,
            RelationType    = RelationTypes.Spouse,
            StartDate       = DateTime.Today
        });
    }

    private void RemoveDependent(BenefitDependentDto dependent)
    {
        _model.Dependents.Remove(dependent);
        for (var i = 0; i < _model.Dependents.Count; i++)
            _model.Dependents[i] = _model.Dependents[i] with { Order = i + 1 };
    }

    private void Save()
    {
        if (_submitted) return;

        if (string.IsNullOrWhiteSpace(_model.BenefitType))
        {
            Snackbar.Add(Loc["benefitDialog.benefitTypeRequired"], Severity.Warning);
            return;
        }
        if (_model.Amount <= 0)
        {
            Snackbar.Add(Loc["benefitDialog.amountRequired"], Severity.Warning);
            return;
        }
        if (_model.StartDate == default)
        {
            Snackbar.Add(Loc["salaryDialog.startDateRequired"], Severity.Warning);
            return;
        }
        if (_model.EndDate.HasValue && _model.EndDate < _model.StartDate)
        {
            Snackbar.Add(Loc["salaryDialog.endDateBeforeStart"], Severity.Warning);
            return;
        }
        if (_model.Dependents.Any(d => d.Amount <= 0))
        {
            Snackbar.Add(Loc["benefitDialog.dependentAmountRequired"], Severity.Warning);
            return;
        }
        if (_model.EmployeeContributionAmount is < 0 || _model.EmployerContributionAmount is < 0)
        {
            Snackbar.Add(Loc["benefitDialog.contributionNegative"], Severity.Warning);
            return;
        }

        if (_model.BenefitType != BenefitTypes.PrivateHealthInsurance)
            _model.Dependents.Clear();

        if (_model.BenefitType != BenefitTypes.PrivatePension)
        {
            _model.EmployeeContributionAmount = null;
            _model.EmployerContributionAmount = null;
            _model.PolicyNumber               = null;
        }

        _submitted = true;
        MudDialog.Close(DialogResult.Ok(_model));
    }

    private void Cancel() => MudDialog.Cancel();
}
