@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@using DZDDashboard.Common.Validation
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudGrid>
                <MudItem xs="6">
                    <MudSelect T="string" Label="Benefit Type" @bind-Value="_model.BenefitType" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                        @foreach (var option in BenefitTypes.All)
                        {
                            <MudSelectItem Value="@option">@option</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <MudSelect T="string" Label="Payer" @bind-Value="_model.Payer" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                        @foreach (var option in BenefitPayers.All)
                        {
                            <MudSelectItem Value="@option">@option</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudGrid>
                <MudItem xs="4">
                    <MudNumericField T="decimal" Label="Amount" @bind-Value="_model.Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" Min="0.01m" Format="N2" />
                </MudItem>
                <MudItem xs="4">
                    <MudSelect T="string" Label="Currency" @bind-Value="_model.Currency" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                        @foreach (var option in Currencies.All)
                        {
                            <MudSelectItem Value="@option">@option</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="4">
                    <MudSelect T="string" Label="Period" @bind-Value="_model.Period" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                        @foreach (var option in PaymentPeriods.All)
                        {
                            <MudSelectItem Value="@option">@option</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudGrid>
                <MudItem xs="6">
                    <MudDatePicker Label="Start Date" Date="@_model.StartDate" DateChanged="@(d => _model.StartDate = d ?? _model.StartDate)"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Required="true"
                                   AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" />
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker Label="End Date (optional)" Date="@_model.EndDate" DateChanged="@(d => _model.EndDate = d)"
                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                   AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" />
                </MudItem>
            </MudGrid>

            <MudGrid>
                <MudItem xs="6">
                    <MudTextField T="string" Label="Reference ID (optional)" @bind-Value="_model.ReferenceId" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField T="string" Label="Provider Name (optional)" @bind-Value="_model.ProviderName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>

            <MudTextField T="string" Label="Notes (optional)" @bind-Value="_model.Notes" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />

            @if (_model.BenefitType == BenefitTypes.PrivateHealthInsurance)
            {
                <MudDivider Class="my-2" />
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle2">Dependents (ÖSS)</MudText>
                    <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@DzdIcons.Plus" OnClick="AddDependent"
                               Disabled="@(_model.Dependents.Count >= ValidationConstants.MaxBenefitDependents)">Add Dependent</MudButton>
                </MudStack>

                @if (_model.Dependents.Count == 0)
                {
                    <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">No dependents added.</MudText>
                }
                else
                {
                    @foreach (var dependent in _model.Dependents)
                    {
                        <MudPaper Class="pa-3" Elevation="0" Outlined="true" Style="border-radius:8px;">
                            <MudGrid>
                                <MudItem xs="12" sm="3">
                                    <MudSelect T="string" Label="Type" @bind-Value="dependent.DependentType" Variant="Variant.Outlined" Margin="Margin.Dense">
                                        @foreach (var option in DependentTypes.All)
                                        {
                                            <MudSelectItem Value="@option">@option</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="3">
                                    <MudNumericField T="decimal" Label="Amount" @bind-Value="dependent.Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.01m" Format="N2" />
                                </MudItem>
                                <MudItem xs="12" sm="3">
                                    <MudDatePicker Label="Start Date" Date="@dependent.StartDate" DateChanged="@(d => dependent.StartDate = d ?? dependent.StartDate)"
                                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                                   AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" />
                                </MudItem>
                                <MudItem xs="12" sm="2">
                                    <MudDatePicker Label="End Date" Date="@dependent.EndDate" DateChanged="@(d => dependent.EndDate = d)"
                                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                                   AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" />
                                </MudItem>
                                <MudItem xs="12" sm="1" Class="d-flex align-center justify-end">
                                    <MudIconButton Icon="@DzdIcons.Trash" Size="Size.Small" Color="Color.Error" OnClick="@(() => RemoveDependent(dependent))" />
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    }
                }
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_submitted">@ConfirmButtonText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public BenefitRecordDto? InitialModel { get; set; }
    [Parameter] public string ConfirmButtonText { get; set; } = "Add";

    private BenefitRecordDto _model = new()
    {
        BenefitType = BenefitTypes.Meal,
        Payer       = BenefitPayers.Employer,
        Currency    = Currencies.Try,
        Period      = PaymentPeriods.Monthly,
        StartDate   = DateTime.Today,
        Source      = PaymentSources.Manual
    };

    private bool _initialized;
    private bool _submitted;

    protected override void OnParametersSet()
    {
        // Guard: only seed from InitialModel once — re-renders shouldn't reset in-progress edits.
        if (_initialized || InitialModel is null) return;
        _initialized = true;

        _model = InitialModel with { Dependents = InitialModel.Dependents.Select(d => d with { }).ToList() };
    }

    private void AddDependent()
    {
        if (_model.Dependents.Count >= ValidationConstants.MaxBenefitDependents) return;

        _model.Dependents.Add(new BenefitDependentDto
        {
            Order         = _model.Dependents.Count + 1,
            DependentType = DependentTypes.Spouse,
            StartDate     = DateTime.Today
        });
    }

    private void RemoveDependent(BenefitDependentDto dependent)
    {
        _model.Dependents.Remove(dependent);
        for (var i = 0; i < _model.Dependents.Count; i++)
            _model.Dependents[i] = _model.Dependents[i] with { Order = i + 1 };
    }

    private void Save()
    {
        if (_submitted) return;

        if (_model.Amount <= 0)
        {
            Snackbar.Add("Benefit amount must be greater than zero.", Severity.Warning);
            return;
        }
        if (_model.StartDate == default)
        {
            Snackbar.Add("Start date is required.", Severity.Warning);
            return;
        }
        if (_model.EndDate.HasValue && _model.EndDate < _model.StartDate)
        {
            Snackbar.Add("End date cannot be before start date.", Severity.Warning);
            return;
        }
        if (_model.Dependents.Any(d => d.Amount <= 0))
        {
            Snackbar.Add("Each dependent amount must be greater than zero.", Severity.Warning);
            return;
        }

        // Non-ÖSS benefits don't carry dependents — clear any leftovers from a type switch.
        if (_model.BenefitType != BenefitTypes.PrivateHealthInsurance)
            _model.Dependents.Clear();

        _submitted = true;
        MudDialog.Close(DialogResult.Ok(_model));
    }

    private void Cancel() => MudDialog.Cancel();
}
