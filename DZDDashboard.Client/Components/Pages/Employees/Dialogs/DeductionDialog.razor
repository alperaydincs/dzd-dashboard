@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@using DZDDashboard.Client.Services
@inject ISnackbar Snackbar
@inject ILookupClientService Lookups

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center" style="gap:10px;">
            <MudIcon Icon="@DzdIcons.MinusCircle" Size="Size.Small" Style="color:var(--dzd-red-500); font-size:18px;" />
            <MudText Typo="Typo.h6" Style="font-size:16px; font-weight:600;">@MudDialog.Title</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudGrid Spacing="3">
                <MudItem xs="6">
                    <div class="dzd-dialog-label">Deduction Type <span class="dzd-required">*</span></div>
                    <MudSelect T="string" @bind-Value="_model.DeductionType" Variant="Variant.Outlined" Margin="Margin.Dense"
                               Required="true" Placeholder="Select deduction type">
                        @foreach (var option in _typeOptions)
                        {
                            <MudSelectItem Value="@option">@option</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">Amount <span class="dzd-required">*</span></div>
                    <MudNumericField T="decimal" @bind-Value="_model.Amount" Variant="Variant.Outlined" Margin="Margin.Dense"
                                     Required="true" Min="0.01m" Format="N2" Placeholder="0" />
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">Currency <span class="dzd-required">*</span></div>
                    <MudSelect T="string" @bind-Value="_model.Currency" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                        @foreach (var option in Currencies.All)
                        {
                            <MudSelectItem Value="@option">@Currencies.Display(option)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <div class="dzd-dialog-label">Period <span class="dzd-required">*</span></div>
                    <MudSelect T="string" @bind-Value="_model.Period" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                        @foreach (var option in PaymentPeriods.All)
                        {
                            <MudSelectItem Value="@option">@option</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <div class="dzd-dialog-label">Payment Date <span class="dzd-required">*</span></div>
                    <MudDatePicker Date="@_model.StartDate" DateChanged="@(d => _model.StartDate = d ?? _model.StartDate)"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Required="true"
                                   AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" OverflowBehavior="OverflowBehavior.FlipNever" />
                </MudItem>
            </MudGrid>

            <div>
                <div class="dzd-dialog-label">Description</div>
                <MudTextField T="string" @bind-Value="_model.Notes" Variant="Variant.Outlined" Margin="Margin.Dense"
                              Lines="2" Placeholder="Enter description" />
            </div>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_submitted">@ConfirmButtonText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<string> _typeOptions = [.. DeductionTypes.All];

    protected override async Task OnInitializedAsync()
    {
        var values = await Lookups.GetValuesAsync(LookupCategories.DeductionType);
        if (values.Count > 0) _typeOptions = values;
    }

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public DeductionDto? InitialModel { get; set; }
    [Parameter] public string ConfirmButtonText { get; set; } = "Add Deduction";

    private DeductionDto _model = new()
    {
        DeductionType = DeductionTypes.SocialSecurity,
        Currency      = Currencies.Try,
        Period        = PaymentPeriods.Monthly,
        StartDate     = DateTime.Today
    };

    private bool _initialized;
    private bool _submitted;

    protected override void OnParametersSet()
    {
        if (_initialized || InitialModel is null) return;
        _initialized = true;

        _model = InitialModel with { };
    }

    private void Save()
    {
        if (_submitted) return;

        if (_model.Amount <= 0)
        {
            Snackbar.Add("Amount must be greater than zero.", Severity.Warning);
            return;
        }

        _submitted = true;
        MudDialog.Close(DialogResult.Ok(_model));
    }

    private void Cancel() => MudDialog.Cancel();
}
