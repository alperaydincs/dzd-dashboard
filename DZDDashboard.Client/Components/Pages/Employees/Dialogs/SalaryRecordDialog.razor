@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@inject ISnackbar Snackbar
@inject DZDDashboard.Client.Localization.AppLocalizer Loc
@inject DZDDashboard.Client.Localization.DomainLocalizer Domain

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@DzdIcons.Banknote" Color="Color.Primary" Size="Size.Small" />
            <MudText Typo="Typo.h6">@(InitialModel is null ? Loc["salaryDialog.addTitle"] : Loc["salaryDialog.editTitle"])</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="4">
            <MudItem xs="12" sm="6">
                <MudSelect T="string" Label="@Loc["salaryDialog.salaryType"]" @bind-Value="_model.PayType" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var option in Domain.Options(DomainCategories.PayType))
                    {
                        <MudSelectItem Value="@option.Code">@option.Label</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField T="decimal" Label="@Loc["salaryDialog.salaryAmount"]" @bind-Value="_model.NetAmount" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" Min="0.01m" Format="N2" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect T="string" Label="@Loc["payment.currency"]" @bind-Value="_model.Currency" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                    @foreach (var option in Domain.Options(DomainCategories.Currency))
                    {
                        <MudSelectItem Value="@option.Code">@option.Label</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="string" Label="@Loc["payment.paymentPeriod"]" @bind-Value="_model.Period" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                    @foreach (var option in Domain.Options(DomainCategories.PaymentPeriod))
                    {
                        <MudSelectItem Value="@option.Code">@option.Label</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudDatePicker Label="@Loc["payment.startDate"]" Date="@_model.StartDate" DateChanged="@(d => _model.StartDate = d ?? _model.StartDate)"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" DateFormat="dd.MM.yyyy"
                               AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter"/>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker Label="@Loc["salaryDialog.endDateOptional"]" Date="@_model.EndDate" DateChanged="@(d => _model.EndDate = d)"
                               Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="dd.MM.yyyy"
                               AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" Clearable="true"/>
            </MudItem>

            <MudItem xs="12">
                <MudTextField T="string" Label="@Loc["payment.payrollCycle"]" @bind-Value="_model.PayrollCycle" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField T="string" Label="@Loc["payment.notes"]" @bind-Value="_model.Notes" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@Loc["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@_submitted">@ConfirmButtonText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public SalaryRecordDto? InitialModel { get; set; }
    [Parameter] public string ConfirmButtonText { get; set; } = "Add";

    private SalaryRecordDto _model = new() { Currency = Currencies.Try, Period = PaymentPeriods.Monthly, PayType = PayTypes.Net, StartDate = DateTime.Today };

    private bool _initialized;
    private bool _submitted;

    protected override void OnParametersSet()
    {
        if (_initialized || InitialModel is null) return;
        _initialized = true;

        _model = InitialModel with { };
    }

    private void Save()
    {
        if (_submitted) return;

        if (_model.NetAmount <= 0)
        {
            Snackbar.Add(Loc["salaryDialog.netAmountRequired"], Severity.Warning);
            return;
        }
        if (_model.StartDate == default)
        {
            Snackbar.Add(Loc["salaryDialog.startDateRequired"], Severity.Warning);
            return;
        }
        if (_model.EndDate.HasValue && _model.EndDate < _model.StartDate)
        {
            Snackbar.Add(Loc["salaryDialog.endDateBeforeStart"], Severity.Warning);
            return;
        }

        _submitted = true;
        MudDialog.Close(DialogResult.Ok(_model));
    }

    private void Cancel() => MudDialog.Cancel();
}
