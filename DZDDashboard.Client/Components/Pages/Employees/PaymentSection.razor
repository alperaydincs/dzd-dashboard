@using DZDDashboard.Client.Components.Pages.Employees.Dialogs
@using DZDDashboard.Client.Services
@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@using DZDDashboard.Common.Utils
@using DZDDashboard.Common.Validation

<div class="dzd-payment-section">
    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </MudStack>
    }
    else if (_loadError is not null)
    {
        <MudAlert Severity="Severity.Error">@_loadError</MudAlert>
    }
    else if (_payment is not null)
    {
            <div class="mt-4">
                <MudText Typo="Typo.h5" Style="font-weight:400;">@Loc["payment.managementTitle"]</MudText>
                <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["payment.managementSubtitle"]</MudText>
            </div>

            <MudGrid Class="mt-4 mb-6" Spacing="4">
                <MudItem xs="12" sm="6" md="3">
                    <InfoCard Label="@Loc["payment.currentSalary"]"
                              Value="@(CurrentSalary is not null ? FormatMoney(CurrentSalary.NetAmount, CurrentSalary.Currency) : "0,00")"
                              Icon="@DzdIcons.Briefcase"
                              Accent="InfoCard.AccentColor.Blue"
                              Class="dzd-payment-summary" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <InfoCard Label="@Loc["payment.totalBenefits"]"
                              Value="@FormatMoneyTotals(_payment.Summary.ActiveBenefitsTotal)"
                              Icon="@DzdIcons.Gift"
                              Accent="InfoCard.AccentColor.Orange"
                              Class="dzd-payment-summary" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <InfoCard Label="@Loc["payment.additionalPayments"]"
                              Value="@FormatMoneyTotals(_payment.Summary.ActiveAdditionalPaymentsTotal)"
                              Icon="@DzdIcons.Award"
                              Accent="InfoCard.AccentColor.Green"
                              Class="dzd-payment-summary" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <InfoCard Label="@Loc["payment.totalDeductions"]"
                              Value="@FormatMoneyTotals(_payment.Summary.ActiveDeductionsTotal)"
                              Icon="@DzdIcons.MinusCircle"
                              Accent="InfoCard.AccentColor.Red"
                              Class="dzd-payment-summary" />
                </MudItem>
            </MudGrid>

            <div class="dzd-payment-tabs active-@_activeTab">
                <button type="button" class="dzd-payment-tab @(_activeTab == 0 ? "active" : "")" @onclick="@(() => _activeTab = 0)">
                    <MudIcon Icon="@DzdIcons.Briefcase" Size="Size.Small" /> <span>@Loc["payment.tabSalary"]</span>
                </button>
                <button type="button" class="dzd-payment-tab @(_activeTab == 1 ? "active" : "")" @onclick="@(() => _activeTab = 1)">
                    <MudIcon Icon="@DzdIcons.Gift" Size="Size.Small" /> <span>@Loc["payment.tabBenefits"]</span>
                </button>
                <button type="button" class="dzd-payment-tab @(_activeTab == 2 ? "active" : "")" @onclick="@(() => _activeTab = 2)">
                    <MudIcon Icon="@DzdIcons.Award" Size="Size.Small" /> <span>@Loc["payment.tabAdditionalPayments"]</span>
                </button>
                <button type="button" class="dzd-payment-tab @(_activeTab == 3 ? "active" : "")" @onclick="@(() => _activeTab = 3)">
                    <MudIcon Icon="@DzdIcons.MinusCircle" Size="Size.Small" /> <span>@Loc["payment.tabDeductions"]</span>
                </button>
            </div>

            <div class="pt-4">
            @switch (_activeTab)
            {
                case 0:
                {
                    var currentSalary = CurrentSalary;
                    <text>
                    <MudPaper Class="dzd-card pa-6 mb-6" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-5">
                            <div class="dzd-section-title">
                                <MudIcon Icon="@DzdIcons.Banknote" Size="Size.Small" Style="color:var(--dzd-brand-primary);" /> <span>@Loc["payment.salaryInformation"]</span>
                            </div>
                            @if (!SelfService)
                            {
                                @if (currentSalary is not null)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@DzdIcons.Pencil" OnClick="@(() => OpenEditSalaryDialogAsync(currentSalary))">@Loc["common.edit"]</MudButton>
                                }
                                else
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@DzdIcons.Plus" OnClick="OpenAddSalaryDialogAsync">@Loc["common.add"]</MudButton>
                                }
                            }
                        </MudStack>

                        @if (currentSalary is not null)
                        {
                            <MudGrid Spacing="4">
                                <MudItem xs="12">
                                    <div class="dzd-field-box">
                                        <div class="dzd-field-label">@Loc["payment.currentSalary"]</div>
                                        <span class="dzd-amount-net">@FormatMoney(currentSalary.NetAmount, currentSalary.Currency)</span>
                                        <span class="dzd-amount-suffix">@GetPayTypeName(currentSalary.PayType)</span>
                                    </div>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <div class="dzd-field-box">
                                        <div class="dzd-field-label">@Loc["payment.currency"]</div>
                                        <MudText Typo="Typo.body1">@GetCurrencyName(currentSalary.Currency)</MudText>
                                    </div>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <div class="dzd-field-box">
                                        <div class="dzd-field-label">@Loc["payment.paymentPeriod"]</div>
                                        <MudText Typo="Typo.body1">@GetPaymentPeriodName(currentSalary.Period)</MudText>
                                    </div>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <div class="dzd-field-box">
                                        <div class="dzd-field-label">@Loc["payment.startDate"]</div>
                                        <MudText Typo="Typo.body1">@AppFormatter.FormatDate(currentSalary.StartDate)</MudText>
                                    </div>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <div class="dzd-field-box">
                                        <div class="dzd-field-label">@Loc["payment.endDate"]</div>
                                        <MudText Typo="Typo.body1">@(currentSalary.EndDate.HasValue ? AppFormatter.FormatDate(currentSalary.EndDate) : Loc["payment.ongoing"])</MudText>
                                    </div>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="6">
                                    <div class="dzd-field-box">
                                        <div class="dzd-field-label">@Loc["payment.payrollCycle"]</div>
                                        <MudText Typo="Typo.body1">@(currentSalary.PayrollCycle ?? "—")</MudText>
                                    </div>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="6">
                                    <div class="dzd-field-box dzd-notes-box">
                                        @if (currentSalary.NotesModifiedAt.HasValue)
                                        {
                                            <div class="dzd-notes-date">@AppFormatter.FormatDateLocal(currentSalary.NotesModifiedAt)</div>
                                        }
                                        <div class="dzd-field-label">@Loc["payment.notes"]</div>
                                        <MudText Typo="Typo.body1">@(currentSalary.Notes ?? "—")</MudText>
                                    </div>
                                </MudItem>
                            </MudGrid>
                        }
                    </MudPaper>

                    <MudPaper Class="dzd-card pa-6" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-5">
                            <div class="dzd-section-title">
                                <MudIcon Icon="@DzdIcons.History" Size="Size.Small" Style="color:var(--dzd-brand-primary);" /> <span>@Loc["payment.salaryHistory"]</span>
                            </div>
                        </MudStack>

                        @if (_payment.SalaryHistory.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["payment.noSalaryRecords"]</MudText>
                        }
                        else
                        {
                            <div class="dzd-history-list">
                                @foreach (var record in _payment.SalaryHistory)
                                {
                                    <div class="dzd-history-item">
                                        <div class="dzd-history-field">
                                            <div class="dzd-history-label">@Loc["payment.startDate"]</div>
                                            <div class="dzd-history-value">@AppFormatter.FormatDate(record.StartDate)</div>
                                        </div>
                                        <div class="dzd-history-field">
                                            <div class="dzd-history-label">@Loc["payment.endDate"]</div>
                                            <div class="dzd-history-value">@(record.EndDate.HasValue ? AppFormatter.FormatDate(record.EndDate) : Loc["payment.ongoing"])</div>
                                        </div>
                                        <div class="dzd-history-field">
                                            <div class="dzd-history-label">@Loc["payment.netSalary"]</div>
                                            <div class="dzd-history-amount">@FormatMoney(record.NetAmount, record.Currency)</div>
                                        </div>
                                        <div class="dzd-history-field">
                                            <div class="dzd-history-label">@Loc["payment.currency"]</div>
                                            <div class="dzd-history-value">@GetCurrencyName(record.Currency)</div>
                                        </div>
                                        <div class="dzd-history-field">
                                            <div class="dzd-history-label">@Loc["payment.modifiedBy"]</div>
                                            <div class="dzd-history-value">@(record.ModifiedByName ?? "—")</div>
                                        </div>
                                        <div class="dzd-history-field">
                                            <div class="dzd-history-label">@Loc["payment.modifyDate"]</div>
                                            <div class="dzd-history-value">@(record.ModifiedAt.HasValue ? AppFormatter.FormatDateLocal(record.ModifiedAt) : "—")</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </MudPaper>
                    </text>
                    break;
                }

                case 1:
                {
                    <text>
                    <MudPaper Class="dzd-card pa-6" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-5">
                            <div class="dzd-section-title dzd-title-benefits">
                                <MudIcon Icon="@DzdIcons.Gift" Size="Size.Small" Style="color:#FEA82F;" /> <span>@Loc["payment.employeeBenefits"]</span>
                            </div>
                            @if (!SelfService)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@DzdIcons.Plus" OnClick="OpenAddBenefitDialogAsync">@Loc["payment.addBenefit"]</MudButton>
                            }
                        </MudStack>

                        @if (_payment.Benefits.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["payment.noBenefitRecords"]</MudText>
                        }
                        else
                        {
                            <div class="dzd-benefit-list">
                                @foreach (var record in _payment.Benefits)
                                {
                                    <div class="dzd-benefit-item">
                                        <div class="dzd-benefit-row">
                                            <div class="dzd-benefit-field dzd-benefit-type-field">
                                                <div class="dzd-icon-badge @BenefitBadgeClass(record.BenefitType)"><MudIcon Icon="@BenefitIcon(record.BenefitType)" Size="Size.Small" /></div>
                                                <div>
                                                    <div class="dzd-field-label">@Loc["payment.benefitType"]</div>
                                                    <div class="dzd-benefit-name">@(string.IsNullOrWhiteSpace(record.BenefitName) ? GetBenefitTypeName(record.BenefitType) : record.BenefitName)</div>
                                                </div>
                                            </div>
                                            <div class="dzd-benefit-field">
                                                <div class="dzd-field-label">@Loc["payment.amount"]</div>
                                                <div class="dzd-benefit-value dzd-benefit-amount">@FormatMoney(record.Amount, record.Currency)</div>
                                            </div>
                                            <div class="dzd-benefit-field">
                                                <div class="dzd-field-label">@Loc["payment.frequency"]</div>
                                                <div class="dzd-benefit-value">@GetPaymentPeriodName(record.Period)</div>
                                            </div>
                                            <div class="dzd-benefit-field">
                                                <div class="dzd-field-label">@Loc["payment.startDate"]</div>
                                                <div class="dzd-benefit-value">@AppFormatter.FormatDate(record.StartDate)</div>
                                            </div>
                                            <div class="dzd-benefit-field">
                                                <div class="dzd-field-label">@Loc["payment.endDate"]</div>
                                                <div class="dzd-benefit-value">@(record.EndDate.HasValue ? AppFormatter.FormatDate(record.EndDate) : Loc["payment.ongoing"])</div>
                                            </div>
                                            @if (!SelfService)
                                            {
                                                <div class="dzd-benefit-actions">
                                                    <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="@(() => OpenEditBenefitDialogAsync(record))" />
                                                    <MudIconButton Icon="@DzdIcons.Trash" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteBenefitRecordAsync(record))" />
                                                </div>
                                            }
                                        </div>

                                        @if (record.BenefitType == BenefitTypes.PrivateHealthInsurance)
                                        {
                                            <div class="dzd-benefit-sub">
                                                <div class="dzd-benefit-sub-title">
                                                    <MudIcon Icon="@DzdIcons.Users" Size="Size.Small" /> <span>@string.Format(Loc["payment.dependentsCount2"], record.Dependents.Count, ValidationConstants.MaxBenefitDependents)</span>
                                                </div>
                                                <div class="dzd-dependent-grid">
                                                    @foreach (var dependent in record.Dependents.OrderBy(d => d.Order))
                                                    {
                                                        <div class="dzd-dependent-card">
                                                            @if (!string.IsNullOrWhiteSpace(dependent.DependentName))
                                                            {
                                                                <div class="dzd-dependent-name">@dependent.DependentName</div>
                                                            }
                                                            <div class="dzd-dependent-type">@GetRelationTypeName(dependent.RelationType)</div>
                                                            <div class="dzd-dependent-amount">@FormatMoney(dependent.Amount, record.Currency)</div>
                                                            <div class="dzd-dependent-dates">
                                                                <div>@string.Format(Loc["payment.startLabel"], AppFormatter.FormatDate(dependent.StartDate))</div>
                                                                <div>@string.Format(Loc["payment.endLabel"], dependent.EndDate.HasValue ? AppFormatter.FormatDate(dependent.EndDate) : Loc["payment.ongoing"])</div>
                                                            </div>
                                                        </div>
                                                    }
                                                    @if (!SelfService && record.Dependents.Count < ValidationConstants.MaxBenefitDependents)
                                                    {
                                                        <button type="button" class="dzd-add-dependent" @onclick="@(() => OpenAddDependentDialogAsync(record))">
                                                            <MudIcon Icon="@DzdIcons.Plus" Size="Size.Small" /> <span>@Loc["payment.addDependent"]</span>
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        }

                                        @if (record.BenefitType == BenefitTypes.PrivatePension && HasBesDetails(record))
                                        {
                                            <div class="dzd-benefit-sub dzd-bes-box">
                                                <div class="dzd-bes-title">@Loc["payment.besDetails"]</div>
                                                <div class="dzd-bes-grid">
                                                    <div>
                                                        <div class="dzd-field-label">@Loc["payment.employeeContribution"]</div>
                                                        <div class="dzd-benefit-value dzd-benefit-amount">@(record.EmployeeContributionAmount.HasValue ? FormatMoney(record.EmployeeContributionAmount.Value, record.Currency) : "—")</div>
                                                    </div>
                                                    <div>
                                                        <div class="dzd-field-label">@Loc["payment.employerContribution"]</div>
                                                        <div class="dzd-benefit-value dzd-benefit-amount">@(record.EmployerContributionAmount.HasValue ? FormatMoney(record.EmployerContributionAmount.Value, record.Currency) : "—")</div>
                                                    </div>
                                                    <div>
                                                        <div class="dzd-field-label">@Loc["payment.provider"]</div>
                                                        <div class="dzd-benefit-value">@(record.ProviderName ?? "—")</div>
                                                    </div>
                                                    <div>
                                                        <div class="dzd-field-label">@Loc["payment.policyNumber"]</div>
                                                        <div class="dzd-benefit-value dzd-benefit-policy">@(record.PolicyNumber ?? "—")</div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </MudPaper>
                    </text>
                    break;
                }

                case 2:
                {
                    <text>
                    <MudPaper Class="dzd-card pa-6" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-5">
                            <div class="dzd-section-title dzd-title-additional">
                                <MudIcon Icon="@DzdIcons.Award" Size="Size.Small" Style="color:#70A37F;" /> <span>@Loc["payment.additionalPayments"]</span>
                            </div>
                            @if (!SelfService)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@DzdIcons.Plus" OnClick="OpenAddAdditionalPaymentDialogAsync">@Loc["payment.addPayment"]</MudButton>
                            }
                        </MudStack>

                        @if (_payment.AdditionalPayments.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["payment.noAdditionalPayments"]</MudText>
                        }
                        else
                        {
                            <div class="dzd-table-wrap">
                                <table class="dzd-payment-table">
                                    <thead>
                                        <tr>
                                            <th>@Loc["payment.colPaymentType"]</th>
                                            <th>@Loc["payment.colAmount"]</th>
                                            <th>@Loc["payment.colCurrency"]</th>
                                            <th>@Loc["payment.colPeriod"]</th>
                                            <th>@Loc["payment.startDate"]</th>
                                            <th>@Loc["payment.endDate"]</th>
                                            <th>@Loc["payment.colDescription"]</th>
                                            @if (!SelfService)
                                            {
                                                <th class="dzd-col-actions">@Loc["payment.colActions"]</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var record in _payment.AdditionalPayments)
                                        {
                                            <tr>
                                                <td>@GetAdditionalPaymentTypeName(record.PaymentType)</td>
                                                <td class="dzd-cell-amount">@record.Amount.ToString("N3")</td>
                                                <td>@GetCurrencyName(record.Currency)</td>
                                                <td>@GetAdditionalPaymentPeriodName(record.Period)</td>
                                                <td>@AppFormatter.FormatDate(record.StartDate)</td>
                                                <td>@(record.EndDate.HasValue ? AppFormatter.FormatDate(record.EndDate) : Loc["payment.ongoing"])</td>
                                                <td class="dzd-cell-desc">@(string.IsNullOrWhiteSpace(record.Description) ? "—" : record.Description)</td>
                                                @if (!SelfService)
                                                {
                                                    <td class="dzd-col-actions">
                                                        <div class="dzd-row-actions">
                                                            <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="@(() => OpenEditAdditionalPaymentDialogAsync(record))" />
                                                            <MudIconButton Icon="@DzdIcons.Trash" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAdditionalPaymentAsync(record))" />
                                                        </div>
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </MudPaper>
                    </text>
                    break;
                }

                case 3:
                {
                    <text>
                    <MudPaper Class="dzd-card pa-6" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-5">
                            <div class="dzd-section-title dzd-title-deductions">
                                <MudIcon Icon="@DzdIcons.MinusCircle" Size="Size.Small" Style="color:#F46036;" /> <span>@Loc["payment.deductionsTitle"]</span>
                            </div>
                            @if (!SelfService)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@DzdIcons.Plus" OnClick="OpenAddDeductionDialogAsync">@Loc["payment.addDeduction"]</MudButton>
                            }
                        </MudStack>

                        @if (_payment.Deductions.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Style="color:var(--dzd-text-secondary);">@Loc["payment.noDeductions"]</MudText>
                        }
                        else
                        {
                            <div class="dzd-table-wrap">
                                <table class="dzd-payment-table">
                                    <thead>
                                        <tr>
                                            <th>@Loc["payment.colDeductionType"]</th>
                                            <th>@Loc["payment.colAmount"]</th>
                                            <th>@Loc["payment.colCurrency"]</th>
                                            <th>@Loc["payment.colPeriod"]</th>
                                            <th>@Loc["payment.startDate"]</th>
                                            <th>@Loc["payment.endDate"]</th>
                                            <th>@Loc["payment.colDescription"]</th>
                                            @if (!SelfService)
                                            {
                                                <th class="dzd-col-actions">@Loc["payment.colActions"]</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var record in _payment.Deductions)
                                        {
                                            <tr>
                                                <td>@GetDeductionTypeName(record.DeductionType)</td>
                                                <td class="dzd-cell-amount">@record.Amount.ToString("N3")</td>
                                                <td>@GetCurrencyName(record.Currency)</td>
                                                <td>@GetAdditionalPaymentPeriodName(record.Period)</td>
                                                <td>@AppFormatter.FormatDate(record.StartDate)</td>
                                                <td>@(record.EndDate.HasValue ? AppFormatter.FormatDate(record.EndDate) : Loc["payment.ongoing"])</td>
                                                <td class="dzd-cell-desc">@(string.IsNullOrWhiteSpace(record.Notes) ? "—" : record.Notes)</td>
                                                @if (!SelfService)
                                                {
                                                    <td class="dzd-col-actions">
                                                        <div class="dzd-row-actions">
                                                            <MudIconButton Icon="@DzdIcons.Pencil" Size="Size.Small" Color="Color.Primary" OnClick="@(() => OpenEditDeductionDialogAsync(record))" />
                                                            <MudIconButton Icon="@DzdIcons.Trash" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteDeductionAsync(record))" />
                                                        </div>
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </MudPaper>
                    </text>
                    break;
                }
            }
            </div>
    }
</div>
