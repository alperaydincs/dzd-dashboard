@page "/offboarding"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = Roles.AdminOrHrPolicy)]
@using DZDDashboard.Client.Components.Pages.Offboarding.Dialogs
@using DZDDashboard.Client.Services
@using DZDDashboard.Common.Constants
@using DZDDashboard.Common.DTOs
@using DZDDashboard.Common.Utils
@inject IOffboardingClientService OffboardingService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject DZDDashboard.Client.Localization.AppLocalizer Loc

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudText Typo="Typo.h5">@Loc["offboarding.title"]</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@DzdIcons.UserMinus" OnClick="StartOffboarding">@Loc["offboarding.start"]</MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_items.Count == 0)
    {
        <MudPaper Elevation="0" Class="pa-8 d-flex justify-center">
            <MudText Typo="Typo.body1" Style="color:var(--dzd-text-secondary);">@Loc["offboarding.empty"]</MudText>
        </MudPaper>
    }
    else
    {
        <MudTable Items="_items" Hover="true" Breakpoint="Breakpoint.Sm" OnRowClick="@(args => OpenDetail(args.Item))" T="OffboardingListItemDto">
            <HeaderContent>
                <MudTh>Çalışan</MudTh>
                <MudTh>Senaryo</MudTh>
                <MudTh>Çıkış</MudTh>
                <MudTh>İlerleme</MudTh>
                <MudTh>Durum</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Çalışan">@context.EmployeeName</MudTd>
                <MudTd DataLabel="Senaryo">@TypeLabel(context.Type)</MudTd>
                <MudTd DataLabel="Çıkış">@AppFormatter.FormatDate(context.ExitDate)</MudTd>
                <MudTd DataLabel="İlerleme">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="min-width:160px;">
                        <MudProgressLinear Value="@Percent(context)" Color="Color.Primary" Style="flex:1;" Rounded="true" />
                        <MudText Typo="Typo.caption">@context.CompletedCount/@context.TotalCount</MudText>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Durum">
                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)" Variant="Variant.Text">@StatusLabel(context.Status)</MudChip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudContainer>

@code {
    private List<OffboardingListItemDto> _items = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _items = await OffboardingService.GetAllAsync() ?? [];
        _loading = false;
    }

    private async Task StartOffboarding()
    {
        var dialog = await DialogService.ShowAsync<StartOffboardingDialog>("Yeni Offboarding");
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: StartOffboardingDto dto })
        {
            try
            {
                var created = await OffboardingService.StartAsync(dto);
                if (created is null) { Snackbar.Add("Offboarding başlatılamadı.", Severity.Error); return; }
                Snackbar.Add("Offboarding başlatıldı.", Severity.Success);
                Nav.NavigateTo($"/offboarding/{created.Id}");
            }
            catch
            {
                Snackbar.Add("Offboarding başlatılamadı. Bu çalışan için zaten bir süreç olabilir.", Severity.Error);
            }
        }
    }

    private void OpenDetail(OffboardingListItemDto? item)
    {
        if (item is not null) Nav.NavigateTo($"/offboarding/{item.Id}");
    }

    private static double Percent(OffboardingListItemDto i) => i.TotalCount == 0 ? 0 : 100.0 * i.CompletedCount / i.TotalCount;

    private static string TypeLabel(string type) => type == OffboardingTypes.Termination ? "İşten Çıkarma" : "İstifa";

    private static Color StatusColor(string status) => status switch
    {
        ProcessStatuses.Completed => Color.Success,
        ProcessStatuses.Cancelled => Color.Error,
        _                         => Color.Info
    };

    private static string StatusLabel(string status) => status switch
    {
        ProcessStatuses.Completed => "Tamamlandı",
        ProcessStatuses.Cancelled => "İptal",
        _                         => "Devam ediyor"
    };
}
