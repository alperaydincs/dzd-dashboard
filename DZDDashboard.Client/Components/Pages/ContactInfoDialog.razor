@using DZDDashboard.Common.DTOs
@using DZDDashboard.Common.Utils

<MudDialog>
    <DialogContent>
        <MudForm Model="@Model">
            <MudText Typo="Typo.body2" Class="mb-4">Update your contact information below.</MudText>

            <MudTextField Label="Work Email" Value="@WorkEmail" ReadOnly="true" Variant="Variant.Outlined" Class="mb-3" HelperText="Contact admin to change work email" />

            <MudTextField @bind-Value="Model.WorkPhoneNumber" Label="Work Phone" Variant="Variant.Outlined" Class="mb-3" />

            <MudTextField @bind-Value="Model.PersonalEmail" Label="Personal Email" Variant="Variant.Outlined" Class="mb-3" InputType="InputType.Email" />

            <MudTextField @bind-Value="Model.PersonalPhoneNumber" Label="Personal Phone" Variant="Variant.Outlined" Class="mb-3" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Variant="Variant.Filled" Disabled="@(!IsFormValid)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public UpdateContactInfoDto Model { get; set; } = new();
    [Parameter] public string? WorkEmail { get; set; }

    // At least one field must be filled, and any provided personal email must be valid.
    private bool IsFormValid =>
        (!string.IsNullOrWhiteSpace(Model.WorkPhoneNumber) ||
         !string.IsNullOrWhiteSpace(Model.PersonalEmail)   ||
         !string.IsNullOrWhiteSpace(Model.PersonalPhoneNumber))
        && (string.IsNullOrWhiteSpace(Model.PersonalEmail) || AppFormatter.IsValidEmail(Model.PersonalEmail));

    void Submit() => MudDialog.Close(DialogResult.Ok(Model));
    void Cancel() => MudDialog.Cancel();
}
