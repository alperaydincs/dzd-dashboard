@using DZDDashboard.Common.DTOs
@using DZDDashboard.Common.Utils
@inject DZDDashboard.Client.Localization.AppLocalizer Loc

<MudDialog>
    <DialogContent>
        <MudForm Model="@Model">
            <MudText Typo="Typo.body2" Class="mb-4">@Loc["contactInfoDialog.updateInfo"]</MudText>

            <MudTextField Label="@Loc["startOnboardingDialog.workEmail"]" Value="@WorkEmail" ReadOnly="true" Variant="Variant.Outlined" Class="mb-3" HelperText="@Loc["contactInfoDialog.workEmailHelper"]" />

            <MudTextField @bind-Value="Model.WorkPhoneNumber" Label="@Loc["employeeProfile.workPhone"]" Variant="Variant.Outlined" Class="mb-3" />

            <MudTextField @bind-Value="Model.PersonalEmail" Label="@Loc["startOnboardingDialog.personalEmail"]" Variant="Variant.Outlined" Class="mb-3" InputType="InputType.Email" />

            <MudTextField @bind-Value="Model.PersonalPhoneNumber" Label="@Loc["employeeProfile.personalPhone"]" Variant="Variant.Outlined" Class="mb-3" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@Loc["common.cancel"]</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Variant="Variant.Filled" Disabled="@(!IsFormValid)">@Loc["common.save"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public UpdateContactInfoDto Model { get; set; } = new();
    [Parameter] public string? WorkEmail { get; set; }

    private bool IsFormValid =>
        (!string.IsNullOrWhiteSpace(Model.WorkPhoneNumber) ||
         !string.IsNullOrWhiteSpace(Model.PersonalEmail)   ||
         !string.IsNullOrWhiteSpace(Model.PersonalPhoneNumber))
        && (string.IsNullOrWhiteSpace(Model.PersonalEmail) || AppFormatter.IsValidEmail(Model.PersonalEmail));

    void Submit() => MudDialog.Close(DialogResult.Ok(Model));
    void Cancel() => MudDialog.Cancel();
}
